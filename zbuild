#!/usr/bin/env bash
# zbuild — build zebra and install the binary, killing any locked instance first.
#
# Usage:
#   ./zbuild          — build + install
#   ./zbuild test     — build + run unit tests
#   ./zbuild run <file.zbr>   — build + run a .zbr file

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUT="$SCRIPT_DIR/zig-out/bin/zebra.exe"
CACHE_DIR="$SCRIPT_DIR/.zig-cache/o"

# ── Kill any running instance so the install step can overwrite the binary ────
if command -v taskkill &>/dev/null; then
    taskkill //F //IM zebra.exe 2>/dev/null || true
fi

# ── Build ─────────────────────────────────────────────────────────────────────
case "${1:-}" in
    test)
        zig build test
        exit $?
        ;;
    run)
        shift
        # fall through: build first, then run
        ;;
    ""|build)
        zig build 2>&1 && echo "Build OK" && exit 0
        # If install failed (AccessDenied), find and copy manually.
        ;;
esac

zig build 2>&1 || true   # compile step always succeeds; install may fail

# ── Find the freshest compiled binary in the cache ────────────────────────────
NEWEST=$(find "$CACHE_DIR" -name "zebra.exe" -newer "$SCRIPT_DIR/build.zig" 2>/dev/null \
         | xargs ls -t 2>/dev/null | head -1)

if [[ -z "$NEWEST" ]]; then
    # Fallback: just newest zebra.exe anywhere in cache
    NEWEST=$(ls -t "$CACHE_DIR"/*/zebra.exe 2>/dev/null | head -1)
fi

if [[ -z "$NEWEST" ]]; then
    echo "zbuild: no compiled binary found in cache" >&2
    exit 1
fi

# Kill again in case something grabbed it during the build
if command -v taskkill &>/dev/null; then
    taskkill //F //IM zebra.exe 2>/dev/null || true
fi

mkdir -p "$(dirname "$OUT")"
cp -f "$NEWEST" "$OUT"
echo "Installed: $OUT  (from $(basename "$(dirname "$NEWEST")"))"

# ── Optional: run a file ──────────────────────────────────────────────────────
if [[ "${1:-}" == "run" && -n "${2:-}" ]]; then
    shift
    "$OUT" "$@"
fi
