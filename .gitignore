.zig-cache/
zig-out/
*.exe
*.pdb
*.lib
*.dll

# REPL session files (generated in cwd during repl)
_repl_session.zbr
_repl_session.zig

# Generated GUI project directories (scaffolded by --gui-backend=XXX)
# Pattern covers plain (_gui/), TUI (_gui_tui/), and libui-ng (_gui_libui_ng/) variants
examples/*_gui*/
test/*_gui*/

# Zig package cache directories created by zig fetch / zig build
zig-pkg/

# Windows build artifacts
*.obj

# Selfhost debug/temp artifacts
selfhost/*_err.txt
selfhost/codegen_roundtrip.zig

# tools/*.zig — generated when running tools/*.zbr via zig build run
tools/*.zig

# Generated parity-check outputs
_parity_sh/

# IDE project — ignore artifacts and generated files; track build.zig, shims, vendor
IDE/ZebraIDE_gui/.zig-cache/
IDE/ZebraIDE_gui/zig-out/
IDE/ZebraIDE_gui/imgui.ini
IDE/ZebraIDE_gui/src/main.zig
IDE/ZebraIDE_gui/src/fonts/

# Test fixture compile artifacts
test/selfhost_compat/*.zig

# Python artifacts
__pycache__/
*.pyc
*.pyo

# One-off migration scripts
fix_016*.py

# Claude Code internal
.claude/scheduled_tasks.lock
.claude


# Generated Zig from test/*.zbr fixtures — inert reference snapshots regenerated
# by smoke / compile-check (the selfhost routes these to a temp dir; the bootstrap
# still writes beside the source, hence the ignore). Nothing compiles them
# (test/main.zig imports the compiler *modules*, not per-test .zig). The
# hand-written harness + standalone .zig are kept via the exceptions below.
test/**/*.zig
!test/main.zig
!test/ZigMath.zig
!test/bench_zig.zig
!test/error_map_test.zig
!test/fuzzy_selfhost_selfhost.zig
!test/hello.zig
!test/mathlib_test.zig
!test/regex_gaps.zig

# N-API spike build artifacts (the .node + import lib + pdb)
spike/*.node
spike/*.lib
spike/*.pdb
spike/*.node.o

# N-API node-addon test artifacts (generated by tools/node_addon_test.sh).
# The .check.js assertion scripts ARE tracked; the .js require() shims are not.
test/node_addon/*.node
test/node_addon/*.d.ts
test/node_addon/*.js
!test/node_addon/*.check.js
