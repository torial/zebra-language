# Random instance form (A3, #216): independent, seedable PRNG streams via
# Random.new(seed). Each instance owns its own stream, so a deterministic
# sub-computation can seed a local generator without disturbing global state.
# Verifies determinism (same seed -> same sequence), range bounds, and that
# two equally-seeded streams stay in lock-step (isolation from each other).

def test_deterministic_same_seed()
    var a = Random.new(12345)
    var b = Random.new(12345)
    assert_eq a.nextInt(1, 1000000), b.nextInt(1, 1000000)
    assert_eq a.nextInt(1, 1000000), b.nextInt(1, 1000000)
    assert_eq a.nextInt(1, 1000000), b.nextInt(1, 1000000)

def test_int_in_range()
    var rng = Random.new(7)
    var i = 0
    while i < 50
        var n = rng.nextInt(1, 6)
        assert_true n >= 1
        assert_true n <= 6
        i = i + 1

def test_float_in_range()
    var rng = Random.new(99)
    var i = 0
    while i < 20
        var f = rng.nextFloat()
        assert_true f >= 0.0
        assert_true f < 1.0
        i = i + 1

def test_bool_is_usable()
    var rng = Random.new(5)
    var t = rng.nextBool()
    # A drawn bool is exactly one of the two values.
    assert_true (t == true) or (t == false)

def test_bytes_deterministic()
    var a = Random.new(2024)
    var b = Random.new(2024)
    # Same seed -> identical hex byte string.
    assert_eq a.bytes(8), b.bytes(8)

def main()
    print "random_instance_test: run with 'zebra test'"
