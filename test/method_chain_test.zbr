struct Builder
    var value: int

    cue init(v: int)
        value = v

    def withVal(n: int): Builder
        var r = this except
            value = n
        return r

    def doubled(): Builder
        var r = this except
            value = value * 2
        return r

    def result(): int
        return value

def makeBuilder(n: int): Builder
    return Builder(n)

# Pattern A: var-initializer position
def testVarInit(): int
    var r1 = makeBuilder(5).withVal(10)
    var r2 = makeBuilder(3).doubled().withVal(99)
    return r1.result() + r2.result()   # 10 + 99 = 109

# Pattern B: return position
def testReturn(): Builder
    return makeBuilder(7).withVal(42)

# Pattern C: assignment position
def testAssign(): int
    var r = makeBuilder(0)
    r = makeBuilder(5).withVal(20)
    return r.result()   # 20

# Pattern D: call-arg position (BUG-027 expression-position fix)
def acceptBuilder(b: Builder): int
    return b.result()

def testCallArg(): int
    return acceptBuilder(makeBuilder(5).withVal(30))   # 30

def testNestedCallArg(): int
    return acceptBuilder(makeBuilder(10).doubled().withVal(7))   # 7

def main()
    print testVarInit()        # 109
    var rb = testReturn()
    print rb.result()          # 42
    print testAssign()         # 20
    print testCallArg()        # 30
    print testNestedCallArg()  # 7
    print "ok"
