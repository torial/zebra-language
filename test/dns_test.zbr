class Main
    shared
        def testLocalhostResolve
            # localhost always resolves (to 127.0.0.1 and/or ::1)
            print "Resolving localhost:"
            for ip in Net.resolve("localhost")
                print ip

        def testMultipleHosts
            var hosts: List(str) = List()
            hosts.add("localhost")
            hosts.add("127.0.0.1")
            for hostname in hosts
                print "Resolving: ".concat(hostname)
                for ip in Net.resolve(hostname)
                    print "  -> ".concat(ip)

        def testInvalidHost
            # This should fail gracefully or return empty
            print "Attempting to resolve invalid host:"
            var results = Net.resolve("invalid.hostname.that.does.not.exist.local")
            print "Got ".concat(results.count().toString()).concat(" results")

        def main
            testLocalhostResolve()
            testMultipleHosts()
            testInvalidHost()
