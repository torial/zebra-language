class Dog
    var name: str
    var breed: str
    cue init(n: str, b: str)
        name = n
        breed = b

class Cat
    var name: str
    cue init(n: str)
        name = n

def main()
    var d = Dog("Rex", "Labrador")
    var c = Cat("Whiskers")

    # is checks — same-type always true
    if d is Dog
        print("d is Dog: true")

    if c is Cat
        print("c is Cat: true")

    # cross-type is false (different _type_id)
    if not (d is Cat)
        print("d is not Cat: correct")

    if not (c is Dog)
        print("c is not Dog: correct")
