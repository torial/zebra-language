class Point
    var x: int = 0
    var y: int = 0

    def move(dx: int, dy: int)
        x = x + dx
        y = y + dy

    def describe: String
        return "(" + x.toString() + ", " + y.toString() + ")"

class Program
    static
        def main
            # Unannotated var — type inferred from constructor call
            var p = Point()
            p.move(dx: 5, dy: 3)
            print(p.describe())

            # Explicit annotation for comparison
            var q: Point = Point()
            q.move(dy: 10, dx: 2)
            print(q.describe())
