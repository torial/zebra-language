class Main
    shared
        def main
            # ── isValidUtf8 ───────────────────────────────────────────────
            var s as str = "hello"
            print s.isValidUtf8()       # true

            # ── codePointCount ────────────────────────────────────────────
            # ASCII: codepoints == bytes
            print s.codePointCount()    # 5

            # ── chars() — Unicode codepoint iteration ─────────────────────
            # Each iteration yields a u21 codepoint
            var word as str = "abc"
            for c in word.chars()
                print c                 # 97, 98, 99  (codepoint values)

            # ── Char predicates (ASCII-aware) ─────────────────────────────
            var ca as char = c'A'
            var cz as char = c'z'
            var c0 as char = c'0'
            var sp as char = c' '

            print ca.isAlpha()          # true
            print c0.isAlpha()          # false
            print c0.isDigit()          # true
            print ca.isDigit()          # false
            print sp.isWhitespace()     # true
            print ca.isUpper()          # true
            print cz.isLower()          # true

            # ── Char transforms ───────────────────────────────────────────
            print ca.toLower()          # 97 (= 'a')
            print cz.toUpper()          # 90 (= 'Z')
