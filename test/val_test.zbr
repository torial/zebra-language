use val_lib exposing Val, Container, makeContainer

def extractFromParam(c: Container): Val
    return c.opt_val!

def main()
    # Parameter path (should already work)
    var c1 = makeContainer(42)
    var v1: Val = extractFromParam(c1)
    if v1 is Val.int_val as n
        assert n == 42

    # Local var path (BUG-122)
    var c2 = makeContainer(99)
    var v2: Val = c2.opt_val!
    if v2 is Val.int_val as n2
        assert n2 == 99

    print "val_test: OK"
