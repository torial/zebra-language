# tc_infer_test.zbr -- smoke test for tc_infer.zbr
# Verifies TcInfer.inferExpr on literals, idents, members, calls, binary ops.
#
# NOTE: TcInfer copies TcScope at construction time (Zebra class copy semantics).
# All scope setup (push/define) must be done BEFORE constructing TcInfer.

use tc_types  exposing TcType, TcTypes
use tc_scope  exposing TcScope, TcScopeKind, TcSymbol, TcSymKind
use tc_infer  exposing TcInfer, TcExpr, TcExprMember, TcExprCall, TcExprBinary, TcExprUnary, TcExprCast

class Main
    static
        def main
            # Build scope with all symbols before constructing TcInfer.
            var sc = TcScope()
            sc.push(TcScopeKind.module_)
            sc.push(TcScopeKind.method_)

            var sym_x = TcSymbol("x", TcSymKind.local, TcType.int_())
            assert sc.define("x", sym_x)

            var resp_sym = TcSymbol("resp", TcSymKind.local, TcType.http_response())
            assert sc.define("resp", resp_sym)

            var jv_sym = TcSymbol("jv", TcSymKind.local, TcType.json_value())
            assert sc.define("jv", jv_sym)

            var opt_resp_sym = TcSymbol("maybe_resp", TcSymKind.local, TcType.optional(TcType.http_response()))
            assert sc.define("maybe_resp", opt_resp_sym)

            # Create inf AFTER scope is fully populated.
            var inf = TcInfer(sc)

            # 1. Literal type inference
            assert TcTypes.eql(inf.inferExpr(TcExpr.int_lit()),    TcType.int_())
            assert TcTypes.eql(inf.inferExpr(TcExpr.float_lit()),  TcType.float_())
            assert TcTypes.eql(inf.inferExpr(TcExpr.bool_lit()),   TcType.bool_())
            assert TcTypes.eql(inf.inferExpr(TcExpr.string_lit()), TcType.string_())
            assert TcTypes.eql(inf.inferExpr(TcExpr.char_lit()),   TcType.char_())
            var nil_t = inf.inferExpr(TcExpr.nil_())
            assert TcTypes.eql(nil_t, TcType.optional(TcType.void_()))
            print "1. literal inference OK"

            # 2. Identifier lookup — defined vs undefined
            assert TcTypes.eql(inf.inferExpr(TcExpr.ident("x")), TcType.int_())
            assert TcTypes.eql(inf.inferExpr(TcExpr.ident("y")), TcType.unknown_())
            print "2. identifier lookup OK"

            # 3. Member access on opaque stdlib types (delegates to TcStdlib)
            var resp_expr = TcExpr.ident("resp")
            var mem_status = TcExprMember(resp_expr, "status")
            var t_status = inf.inferExpr(TcExpr.member(mem_status))
            assert TcTypes.eql(t_status, TcType.uint_())
            var mem_text = TcExprMember(resp_expr, "text")
            var t_text = inf.inferExpr(TcExpr.member(mem_text))
            assert TcTypes.eql(t_text, TcType.string_())
            print "3. member inference on http_response OK"

            # 4. Member access on json_value
            var jv_expr = TcExpr.ident("jv")
            var mem_get = TcExprMember(jv_expr, "get")
            var t_get = inf.inferExpr(TcExpr.member(mem_get))
            assert TcTypes.eql(t_get, TcType.json_value())
            print "4. member inference on json_value OK"

            # 5. Static call: Http.get(url) → ?http_response
            var http_ident = TcExpr.ident("Http")
            var http_mem   = TcExprMember(http_ident, "get")
            var http_args  = List(TcExpr)()
            http_args.add(TcExpr.string_lit())
            var http_call  = TcExprCall(TcExpr.member(http_mem), http_args)
            var t_http_get = inf.inferExpr(TcExpr.call(http_call))
            assert TcTypes.eql(t_http_get, TcType.optional(TcType.http_response()))
            print "5. static call Http.get OK"

            # 6. Static call: Timer.start() → timer_handle
            var tm_ident = TcExpr.ident("Timer")
            var tm_mem   = TcExprMember(tm_ident, "start")
            var tm_args  = List(TcExpr)()
            var tm_call  = TcExprCall(TcExpr.member(tm_mem), tm_args)
            var t_timer  = inf.inferExpr(TcExpr.call(tm_call))
            assert TcTypes.eql(t_timer, TcType.timer_handle())
            print "6. static call Timer.start OK"

            # 7. Binary operator inference
            var bi_arith = TcExprBinary("+", TcExpr.int_lit(), TcExpr.int_lit())
            assert TcTypes.eql(inf.inferExpr(TcExpr.binary(bi_arith)), TcType.int_())
            var bi_cmp = TcExprBinary("==", TcExpr.int_lit(), TcExpr.int_lit())
            assert TcTypes.eql(inf.inferExpr(TcExpr.binary(bi_cmp)), TcType.bool_())
            var bi_str = TcExprBinary("+", TcExpr.string_lit(), TcExpr.string_lit())
            assert TcTypes.eql(inf.inferExpr(TcExpr.binary(bi_str)), TcType.string_())
            var bi_lt = TcExprBinary("<", TcExpr.float_lit(), TcExpr.float_lit())
            assert TcTypes.eql(inf.inferExpr(TcExpr.binary(bi_lt)), TcType.bool_())
            print "7. binary operator inference OK"

            # 8. Unary operator inference
            var un_neg = TcExprUnary("-", TcExpr.int_lit())
            assert TcTypes.eql(inf.inferExpr(TcExpr.unary(un_neg)), TcType.int_())
            var un_not = TcExprUnary("not", TcExpr.bool_lit())
            assert TcTypes.eql(inf.inferExpr(TcExpr.unary(un_not)), TcType.bool_())
            print "8. unary operator inference OK"

            # 9. Explicit cast
            var cast_expr = TcExprCast(TcType.float_())
            assert TcTypes.eql(inf.inferExpr(TcExpr.cast(cast_expr)), TcType.float_())
            print "9. cast inference OK"

            # 10. Optional chain unwrapping
            var opt_chain = TcExpr.ident("maybe_resp")
            var chain_expr = TcExpr.optional_chain(opt_chain)
            assert TcTypes.eql(inf.inferExpr(chain_expr), TcType.http_response())
            print "10. optional_chain inference OK"

            print "tc_infer_test: all OK"
