
class Calc
    @profile
    def add(a: int, b: int): int
        return a + b

    @profile
    def mul(a: int, b: int): int
        return a * b

@profile
def helper(n: int): int
    return n * 2

def main()
    var c = Calc()
    var r1 = c.add(2, 3)
    assert r1 == 5
    var r2 = c.mul(4, 5)
    assert r2 == 20
    var r3 = helper(7)
    assert r3 == 14
    Profile.report()
    Profile.reset()
    print "profile_attr OK"
