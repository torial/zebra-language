class FileInfo
    var path: str
    var code: int

    cue init(p: str, c: int)
        path = p
        code = c

    def toString: str
        return "FileInfo(".concat(path).concat(")")

class Main
    static
        def tryRead(path: str) throws
            raise "file not found", FileInfo(path, 404)

        def main
            try
                Main.tryRead("data.txt")
            catch |e|
                print e.message
                print e.details.toString()

            # Simple raise (no details)
            try
                raise "simple error"
            catch |e|
                print e.message
