class FileInfo
    var path: str
    var code: int

    cue init(p: str, c: int)
        path = p
        code = c

    def toString(): str
        return "FileInfo(".concat(path).concat(")")

def tryRead(path: str) throws
    raise "file not found", FileInfo(path, 404)

def testRaiseWithDetails()
    tryRead("data.txt")
catch |e|
    print(e.message)
    print(e.details.toString())

def testSimpleRaise()
    raise "simple error"
catch |e|
    print(e.message)

def main()
    testRaiseWithDetails()
    testSimpleRaise()
