class Container
    var items: List(str)
    var flags: List(bool)
    cue init()
        items = List()
        flags = List()
    def add(s: str, flag: bool)
        items.add(s)
        flags.add(flag)
    def first(): str
        return items.at(0)
    def firstFlag(): bool
        return flags.at(0)

class Main
    static def main()
        var c = Container()
        c.add("hello", true)
        c.add("world", false)
        assert c.first()     == "hello"
        assert c.firstFlag() == true
        print "generic_infer_test: all OK"
