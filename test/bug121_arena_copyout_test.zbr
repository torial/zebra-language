class Main
    static def main()
        # Basic arena copy-out: str value survives arena deinit.
        var result: str = ""
        arena
            var tmp = "hello" + " " + "world"
            result <- tmp
        if result == "hello world"
            print "BUG-121 <- arena copy-out: OK"
        else
            print "BUG-121 <- arena copy-out: FAIL got: " + result

        # No-op form: <- outside any arena is a plain assign.
        var x: str = ""
        x <- "plain"
        if x == "plain"
            print "BUG-121 <- outside arena: OK"
        else
            print "BUG-121 <- outside arena: FAIL"
