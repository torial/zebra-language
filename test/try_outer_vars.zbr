class App
    static
        def risky(x: int): int throws
            if x < 0
                raise "negative", x
            return x * 2

        def testRiskyCalc(base: int, multiplier: int)
            var result: int = try App.risky(base)
            var total: int = result * multiplier
            print total
        catch
            print "error"

        def main
            var base: int = 10
            var multiplier: int = 3
            testRiskyCalc(base, multiplier)
            print base
