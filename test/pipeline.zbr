class Math
    shared
        def add(a: int, b: int): int
            return a + b

        def double(x: int): int
            return x + x

        def main
            # Pipeline: 3 -> add(10) -> double() = double(add(3, 10)) = 26
            var result = 3 -> Math.add(10) -> Math.double()
            print result

            # Expression-body lambda with explicit return type
            var triple = def(x: int): int = x + x + x
            var t = triple(7)
            print t
