class Box(T)
    var value: T

    cue init(v: T)
        value = v

class Main
    shared
        def main
            var b = Box(int)(42)
            print b is Box           # true  — bare class check
            print not (b is Box)     # false

            var s = Box(str)("hi")
            print s is Box           # true  — same class, different type arg
