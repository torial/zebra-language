class Math
    static
        def safeDiv(a: int, b: int): int throws
            if b == 0
                raise "division by zero"
            return a / b

class Main
    static
        def main
            # try prefix propagates errors on failure
            try
                var result = try Math.safeDiv(10, 2)
                print result
            catch |e|
                print "unexpected error: ".concat(e.message)

            # division by zero — verify error is raised with correct message
            try
                var result2 = try Math.safeDiv(10, 0)
                print result2
            catch |e|
                print "caught: ".concat(e.message)

            print "ok"
