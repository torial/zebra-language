@reflectable
class Point
    var x: int = 0
    var y: int = 0

@reflectable
class Person
    var name: str = ""
    var age: int = 0

def main()
    # Json.parse(T, src) — typed overload, same machinery as parseStrict
    var p = Json.parse(Point, "{\"x\":3,\"y\":7}")
    if p as pt
        print pt.x
        print pt.y

    var q = Json.parse(Person, "{\"name\":\"Alice\",\"age\":30}")
    if q as person
        print person.name
        print person.age

    # Json.parse(src) — untyped form still works
    var raw = Json.parse("{\"key\":\"val\"}")
    if raw as rv
        var s = rv.getString("key")
        if s as sv
            print sv

    print "done"
