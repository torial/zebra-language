class App
    static
        def findPositive(x: int): int?
            if x > 0
                return x
            return nil

        def orDefault(val: int?, fallback: int): int
            return val orelse fallback

        def main
            var a: int? = App.findPositive(5)
            var b: int? = App.findPositive(-1)

            if a == nil
                print "a is nil"
            else
                print a to!

            if b == nil
                print "b is nil"

            var c: int = App.orDefault(a, 99)
            var d: int = App.orDefault(b, 99)
            print c
            print d
