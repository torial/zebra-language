def main()
    var pool: ThreadPool = ThreadPool(4)
    var counter: Atomic(int) = Atomic(int)(0)
    var i: int = 0
    while i < 8
        pool.submit(def()
            capture
                var counter: Atomic(int) = counter
            counter.add(1)
        )
        i = i + 1
    pool.wait()
    print(counter.load())
    print("thread_pool_test OK")
