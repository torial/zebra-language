# Cross-module type test: library module exporting a user-defined type.

class Point
    var x: int
    var y: int
    cue init(px: int, py: int)
        x = px
        y = py

    def distFromOrigin(): float
        var dx = x * x
        var dy = y * y
        return Math.sqrt(dx + dy)

    def show(): str
        return "(${x}, ${y})"
