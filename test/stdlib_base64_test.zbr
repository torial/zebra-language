def main()
    # Standard Base64
    var encoded = Base64.encode("hello world")
    assert encoded == "aGVsbG8gd29ybGQ="
    var decoded = Base64.decode("aGVsbG8gd29ybGQ=")
    assert decoded != nil
    assert decoded! == "hello world"

    # URL-safe Base64
    var enc_url = Base64.encodeUrl("hello world")
    assert enc_url == "aGVsbG8gd29ybGQ"
    var dec_url = Base64.decodeUrl("aGVsbG8gd29ybGQ")
    assert dec_url != nil
    assert dec_url! == "hello world"

    # Invalid decode returns nil
    var bad = Base64.decode("!!!invalid!!!")
    assert bad == nil

    # String instance methods (ergonomic form; decodeBase64 panics on invalid input)
    var s = "hello"
    var s_enc = s.encodeBase64()
    assert s_enc == "aGVsbG8="
    var s_dec = s_enc.decodeBase64()   # non-optional: panics on invalid base64
    assert s_dec == "hello"

    print "stdlib_base64 OK"
