# Probe 2: wrap kindName in a class to get past parse error

union TokenKind
    ident
    number
    plus
    eof

class Span
    var line: int
    var col : int
    cue init(l: int, c: int)
        line = l
        col  = c

class Token
    var kind: TokenKind
    var text: str
    var span: Span
    cue init(k: TokenKind, t: str, l: int, c: int)
        kind = k
        text = t
        span = Span(l, c)

class Diag
    var message: str
    var line   : int
    var col    : int
    cue init(msg: str, l: int, c: int)
        message = msg
        line    = l
        col     = c
    def show(): str
        return message

class Helper
    static
        def kindName(k: TokenKind): str
            branch k
                on TokenKind.ident  return "ident"
                on TokenKind.number return "number"
                on TokenKind.plus   return "plus"
                on TokenKind.eof    return "eof"

class Lexer
    var tokens: List(Token)
    var pos   : int

    cue init()
        tokens = List()
        pos = 0

    def push(k: TokenKind, t: str, l: int, c: int)
        tokens.append(Token(k, t, l, c))

    def peek(): TokenKind
        if pos < tokens.len
            return tokens[pos].kind
        return TokenKind.eof()

    def advance(): Token
        var t = tokens[pos]
        pos = pos + 1
        return t

class Main
    static
        def main
            var t = Token(TokenKind.ident(), "foo", 1, 0)
            assert t.text == "foo"
            assert t.span.line == 1

            assert Helper.kindName(TokenKind.plus()) == "plus"
            assert Helper.kindName(TokenKind.eof())  == "eof"

            var d = Diag("unexpected token", 3, 7)
            assert d.show() == "unexpected token"

            print "self-hosting probe OK"
