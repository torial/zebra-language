class Main
    shared
        def main
            # else runs when no break occurred (search fails — loop completes)
            var nums = List(int)()
            nums.add(1)
            nums.add(2)
            nums.add(3)
            var found: int = -1
            for x in nums
                if x == 99
                    found = x
                    break
            else
                found = 0
            print found

            # else does NOT run when break occurs
            var found2: int = -1
            for x in nums
                if x == 2
                    found2 = x
                    break
            else
                found2 = 0
            print found2

            # else runs when list is empty
            var found3: int = -1
            var empty = List(int)()
            for x in empty
                found3 = x
            else
                found3 = 42
            print found3

            print "ok"
