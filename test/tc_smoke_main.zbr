# Smoke: verify multi-file selfhost with ^T cross-module union works.

use tc_smoke_types exposing TcType, TcTypes

def testOptionalTypes()
    var opt = TcType.optional(TcType.str_())
    assert TcTypes.describe(opt) == "?str"
    var nested = TcType.optional(TcType.optional(TcType.int_()))
    assert TcTypes.describe(nested) == "??int"
catch |e|
    print "FAIL: " + e.message

def main()
    assert TcTypes.describe(TcType.int_())    == "int"
    assert TcTypes.describe(TcType.unknown()) == "unknown"
    testOptionalTypes()
    print "multi-file selfhost smoke: OK"
