# Formerly tested `unless`/`until`; those keywords were removed pre-1.0 as
# redundant sugar. This now exercises their replacements: `if not` / `while not`.
class UnlessUntilTest
    def run
        # if not: body runs when the condition is false (was `unless x > 10`)
        var x = 5
        if not (x > 10)
            x = x + 1
        assert x == 6

        # if not: body skipped when the condition is true
        if not (x < 10)
            x = 99
        assert x == 6

        # while not: loops while the condition is false (was `until n >= 3`)
        var n = 0
        while not (n >= 3)
            n = n + 1
        assert n == 3

        print("if-not/while-not OK")

def main()
    UnlessUntilTest().run()
