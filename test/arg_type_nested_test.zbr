# Audit #3: a type-mismatched argument in a NESTED call (here inside print(...))
# is now caught with a clean Zebra diagnostic + caret, instead of falling through
# to a cryptic Zig "expected type 'i64'..." error. Expected to FAIL TC.
def add(a: int, b: int): int
    return a + b
def main()
    print(add(1, "two").toString())
