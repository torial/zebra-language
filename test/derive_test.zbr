@derive(Debug, Eq, Hash)
struct Point
    var x: int
    var y: int

@derive(Debug)
struct Greeting
    var name: str
    var count: int

@derive(Eq, Hash)
struct Key
    var id: int
    var label: str

def main()
    var p1 = Point.init(3, 4)
    var p2 = Point.init(3, 4)
    var p3 = Point.init(1, 2)

    # @derive(Debug) produces toString()
    print p1.toString()

    # @derive(Eq) makes == work on structs
    if p1 == p2
        print "p1 == p2: true"
    if p1 != p3
        print "p1 != p3: true"

    # @derive(Debug) with str field uses {s} format specifier
    var g = Greeting.init("Alice", 5)
    print g.toString()

    # @derive(Hash) — hash() callable and consistent with eql
    var k1 = Key.init(42, "hello")
    var k2 = Key.init(42, "hello")
    var k3 = Key.init(99, "world")
    var h1 = k1.hash()
    var h2 = k2.hash()
    var h3 = k3.hash()
    if h1 == h2
        print "hash consistent: ok"
    if h1 != h3
        print "hash distinct: ok"
