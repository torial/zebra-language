# Tests for `x is not ClassName` — class type-tag negated check.
# `x is not C` emits `!(x._type_tag == _ttag_C)` in Zig.

class Cat
    var name: str
    cue init(n: str)
        .name = n

class Dog
    var name: str
    cue init(n: str)
        .name = n

def main()
    var c = Cat("Whiskers")
    var d = Dog("Rex")

    # Cat instance is not Dog — true
    print(c is not Dog)

    # Cat instance is not Cat — false
    print(c is not Cat)

    # Dog instance is not Cat — true
    print(d is not Cat)

    # Dog instance is not Dog — false
    print(d is not Dog)

    # in an if condition
    if c is not Dog
        print("cat is not a dog")

    # in a function call position (expression context)
    var r: bool = d is not Cat
    print(r)

    print("is_not_class: OK")
