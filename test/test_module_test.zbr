def test_assert_eq_int()
    assert_eq 1 + 1, 2
    assert_eq 10 - 3, 7

def test_assert_ne_int()
    assert_ne 1, 2
    assert_ne 42, 0

def test_assert_eq_str()
    assert_eq "hello", "hello"

def test_assert_ne_str()
    assert_ne "hello", "world"

def test_assert_true_false()
    assert_true 5 > 3
    assert_false 1 > 2
    assert_true not false

def main()
    print("test_module_test: run with 'zebra test'")
