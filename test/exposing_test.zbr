use expose_lib exposing Color, Palette

class Main
    static def main()
        # Use the exposed union type directly (no expose_lib. prefix)
        var c = Color.green()
        branch c
            on expose_lib.Color.red
                print "red"
            on expose_lib.Color.green
                print "green"
            on expose_lib.Color.blue
                print "blue"

        # Use the exposed class type directly (no expose_lib. prefix)
        var p = Palette("warm")
        assert p.describe() == "Palette:warm"

        print "exposing_test: all OK"
