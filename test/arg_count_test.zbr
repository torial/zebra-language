# BUG-142: calling a function with too few arguments emits a (non-fatal) warning
# — "too few arguments to 'add'" — instead of silently padding the missing arg
# with `undefined`. Compiles (exit 0); the smoke harness asserts the warning.
def add(a: int, b: int): int
    return a + b
def main()
    print(add(1).toString())
