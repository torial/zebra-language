# expose_dotted.lib.zbr -- library module under a dotted (namespace) path.
# Used by expose_dotted_test.zbr to verify that:
#   use expose_dotted.lib exposing DottedLib
#   DottedLib.greet()           # static method call via exposed class name
#   DottedLib.makePoint()       # static method returning a user-defined type
# all resolve correctly even though the module path has a dot.

class DottedLib
    shared
        def greet(): str
            return "hello from dotted lib"

        def add(a: int, b: int): int
            return a + b

        def makePoint(): Point
            return Point(3, 4)

struct Point
    var x: int
    var y: int
    cue init(px: int, py: int)
        x = px
        y = py

    def sum(): int
        return x + y
