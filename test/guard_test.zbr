class Validator
    static
        def checkPositive(n: int): int throws
            # block form: guard cond else\n    body
            guard n > 0 else
                raise "expected positive number"
            return n

        def firstChar(s: str): str
            # inline form: guard cond else, return
            guard s.len > 0 else, return "?"
            return s[0..1]

class Main
    static
        def main
            # block form guard — success path
            try
                var x = try Validator.checkPositive(42)
                print x
            catch |e|
                print "unexpected error: ".concat(e.message)

            # inline form guard
            var c = Validator.firstChar("hello")
            print c

            var empty = Validator.firstChar("")
            print empty

            # guard that fires — verify error propagates with correct message
            try
                var bad = try Validator.checkPositive(-5)
                print bad
            catch |e|
                print "guard raised: ".concat(e.message)

            print "ok"
