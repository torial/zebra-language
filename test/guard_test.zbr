class Validator
    shared
        def checkPositive(n as int) as int throws
            # block form: guard cond else\n    body
            guard n > 0 else
                raise "expected positive number"
            return n

        def firstChar(s as str) as str
            # inline form: guard cond else, return
            guard s.len > 0 else, return "?"
            return s[0..1]

class Main
    shared
        def main throws
            # block form guard
            var x = Validator.checkPositive(42)?
            print x

            # inline form guard
            var c = Validator.firstChar("hello")
            print c

            var empty = Validator.firstChar("")
            print empty

            # guard that fires — propagates error
            var bad = Validator.checkPositive(-5)?
            print bad
