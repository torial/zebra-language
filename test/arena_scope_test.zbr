# Tests that `allocate Arena()` blocks compile and run correctly.
# List.append allocation issues are a separate pre-existing bug.

class Counter
    var n: int
    cue init()
        n = 0
    def inc
        n = n + 1
    def value(): int
        return n

def main()
    var x: int = 0

    # allocate Arena() block: verify it compiles, runs, and exits cleanly
    allocate Arena()
        var c = Counter()
        c.inc()
        c.inc()
        c.inc()
        x = c.value()

    # x survives (primitive on the stack)
    assert x == 3

    # nested allocate Arena() blocks
    var y: int = 0
    allocate Arena()
        var a = Counter()
        a.inc()
        allocate Arena()
            var b = Counter()
            b.inc()
            b.inc()
            y = a.value() + b.value()

    assert y == 3
    print "allocate Arena() scope OK"
