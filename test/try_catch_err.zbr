class App
    static
        def risky(x: int): int throws
            if x < 0
                raise "negative input", x
            return x * 2

        def testRiskyFail()
            var result: int = try App.risky(-3)
            print result
        catch
            print "caught an error"

        def main
            testRiskyFail()
            print "after try"
