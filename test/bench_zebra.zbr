class Bench
    static
        def fib(n: int): int
            if n < 2
                return n
            return Bench.fib(n - 1) + Bench.fib(n - 2)

        def sumLoop(n: int): int
            var acc: int = 0
            for i in 0 : n
                acc = acc + i
            return acc

class Program
    static
        def main
            var f = Bench.fib(40)
            print(f)
            var s = Bench.sumLoop(100000000)
            print(s)
