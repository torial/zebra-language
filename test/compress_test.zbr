def main()
    # gzip round-trip: compress then decompress should recover original
    const original: str = "hello world"
    const compressed: str = Compress.gzip(original)
    assert compressed.len > 0
    print "gzip produces output: OK"

    var recovered = Compress.gunzip(compressed)
    assert recovered != nil
    assert recovered! == original
    print "gzip round-trip: OK"

    # Larger input to exercise real compression
    const big: str = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    const big_gz: str = Compress.gzip(big)
    assert big_gz.len > 0
    assert big_gz.len < big.len   # highly compressible — should shrink
    var big_back = Compress.gunzip(big_gz)
    assert big_back != nil
    assert big_back! == big
    print "gzip compressible data round-trip: OK"

    # gunzip on invalid data returns nil
    var bad = Compress.gunzip("not valid gzip")
    assert bad == nil
    print "gunzip bad input: OK"

    print "All compress tests passed."
