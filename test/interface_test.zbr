interface Greetable
    def greet: str
    def greetName(name: str): str

class English implements Greetable
    def greet: str
        return "Hello"

    def greetName(name: str): str
        return "Hello, ".concat(name)

class Spanish implements Greetable
    def greet: str
        return "Hola"

    def greetName(name: str): str
        return "Hola, ".concat(name)

class Counter
    var count: int

    cue init()
        count = 0

    def increment
        count = count + 1

    def value: int
        return count

class Main
    shared
        def main
            var e = English()
            var s = Spanish()
            print e.greet()
            print s.greet()
            print e.greetName("Alice")
            print s.greetName("Bob")
            var c = Counter()
            c.increment()
            c.increment()
            c.increment()
            print c.value()
