extend String
    def shout(): str
        return this.upper().concat("!")

    def isLong(): bool
        return this.len > 5

    def greet(): str
        return "Hello, ".concat(this).concat("!")

class Main
    static
        def main
            var s: str = "hello"
            var t: str = "world"
            print s.shout()
            print s.isLong()
            print t.greet()
