# #219: size is unified on `.len`. List/HashMap expose `.len` (property);
# user classes can maintain a plain `len` field updated by their mutations
# (O(1) read, no accessor-call overhead in hot loops). `str.count(sub)` stays
# the substring-count METHOD (1-arg) — distinct from the size accessor.

class IntBag
    var _items: List(int)
    # Maintained by every mutation — read as the plain field `bag.len`.
    var len: int

    cue init()
        _items = List(int)()
        len = 0

    def add(v: int)
        _items.add(v)
        len = _items.len

    def removeAll()
        _items = List(int)()
        len = 0

def test_list_len()
    var xs = List(str)()
    xs.add("a")
    xs.add("b")
    xs.add("c")
    assert_eq xs.len, 3

def test_hashmap_len()
    var m = HashMap(str, int)()
    m.put("x", 1)
    m.put("y", 2)
    assert_eq m.len, 2

def test_str_count_substring()
    # `str.count(sub)` is the substring-count method (kept), not a size accessor.
    assert_eq "banana".count("a"), 3
    assert_eq "banana".count("na"), 2

def test_maintained_len_field()
    var bag = IntBag()
    assert_eq bag.len, 0
    bag.add(10)
    bag.add(20)
    assert_eq bag.len, 2
    bag.removeAll()
    assert_eq bag.len, 0

def main()
    print("len_size_test: run with 'zebra test'")
