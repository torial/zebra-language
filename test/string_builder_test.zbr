class Main
    shared
        def main
            # ── Basic append + build ──────────────────────────────────────
            var sb as StringBuilder = StringBuilder()
            sb.append("hello")
            sb.append(", ")
            sb.append("world")
            print sb.build()         # hello, world

            # ── len() ─────────────────────────────────────────────────────
            print sb.len()           # 12

            # ── clear() + reuse ───────────────────────────────────────────
            sb.clear()
            print sb.len()           # 0

            # ── Build a string in a loop (O(n), not O(n²)) ────────────────
            var words as List(str) = List()
            words.add("one")
            words.add("two")
            words.add("three")
            var sb2 as StringBuilder = StringBuilder()
            var first as bool = true
            for w in words
                if not first
                    sb2.append(", ")
                sb2.append(w)
                first = false
            print sb2.build()        # one, two, three

            # ── appendChar ────────────────────────────────────────────────
            var sb3 as StringBuilder = StringBuilder()
            sb3.append("abc")
            sb3.appendChar(33)       # '!' = ASCII 33
            print sb3.build()        # abc!
