class Pair(A, B)
    var first: A
    var second: B

    cue init(a: A, b: B)
        first = a
        second = b

    def swap(): Pair(B, A)
        return Pair(B, A)(second, first)

def main()
    var p = Pair(str, int)("hello", 42)
    print(p.second)     # 42

    var q = Pair(int, bool)(100, true)
    print(q.first)      # 100
    print(q.second)     # true

    var r = Pair(int, str)(1, "one")
    print(r.first)      # 1

    # swap: Pair(int, str) → Pair(str, int)
    var s = r.swap()
    print(s.second)     # 1
