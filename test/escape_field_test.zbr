# Tests that escape analysis propagates through field writes:
#   result.items = list; return result
# should mark `list`: escaped so defer deinit is suppressed.

class Container
    var items: List(str)
    var label : str

class Builder
    static
        def build(label: str): Container
            var c = Container()
            var items: List(str) = List()
            items.add("alpha")
            items.add("beta")
            c.items = items     # field write — items should escape with c
            c.label = label
            return c            # c escapes; items must escape too

def main()
    var c = Builder.build("test")
    assert c.items.count() == 2, "item count"
    print c.items.at(0)   # "alpha" — UAF here if list was freed early
    print c.label         # "test"
    print "escape_field_test: all assertions passed"
