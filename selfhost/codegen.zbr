    # ── genRandomCall ────────────────────────────────────────────────────────
    def genRandomCall(mname: str, args: List(Arg))
        if mname == "randInt"
            w.emit("_random_int(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("100")
            w.emit(")")
            return
        if mname == "randFloat"
            w.emit("_random_float()")
            return
        if mname == "randBool"
            w.emit("_random_bool()")
            return
        if mname == "bytes"
            w.emit("_random_bytes(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("16")
            w.emit(")")
            return
        if mname == "seed"
            w.emit("_random_seed(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")")
            return
        if mname == "choice"
            if args.count() > 0
                genExpr(args.at(0).value)
                w.emit(".items[_rng().uintLessThan(usize, ")
                genExpr(args.at(0).value)
                w.emit(".items.len)]")
            return
        if mname == "shuffle"
            if args.count() > 0
                w.emit("(if (")
                genExpr(args.at(0).value)
                w.emit(".items.len > 0) _rng().shuffle(@TypeOf(")
                genExpr(args.at(0).value)
                w.emit(".items[0]), ")
                genExpr(args.at(0).value)
                w.emit(".items))")
            return
        w.emit("@compileError(\"selfhost: unknown Random.")
        w.emit(mname)
        w.emit("\")")

