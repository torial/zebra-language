# codegen.zbr — Phase 7 self-hosting: CodeGen main body
#
# Port of src/CodeGen.zig to Zebra.  Consumes the AST produced by the parser
# (selfhost/ast.zbr) and emits Zig source.
#
# Phase 7a scope:
#   Writer       — output sink class
#   Generator    — struct with context-forking methods
#   genType      — TypeRef → Zig type string
#   genFieldDecl — field declaration inside class/struct body
#   genEnum / genUnion / genStruct / genClass
#
# Phase 7b scope (this update):
#   genMethod / genInit / genProperty  — full bodies replacing 7a stubs
#   genStmts / genStmt                — statement dispatch
#   genLocalVar, genAssign, genReturn, genIf, genWhile
#   genForIn, genForNum, genBranch, genPrint, genRaise
#   genTryCatch, genAssert, genDefer, genWith, genArenaScope
#   genGuard, genDestruct
#   genExpr                           — expression dispatch
#   genIdent, genBinary, genUnary, genStringLit, genStringInterp
#   genCall, genMemberCall, genMathCall, genArgList, genGenericCtorCall
#   genTypeFromExpr — type-as-expr → Zig type name

use ast exposing Decl, DeclUse, DeclEnum, DeclUnion, DeclStruct, DeclClass, DeclVar, DeclMethod, DeclInit, DeclProperty, DeclSig, EnumMember, UnionVariant, TypeRef, NamedTypeRef, GenericTypeRef, TupleTypeRef, Module, Param, Modifiers, Span, Stmt, StmtAssign, StmtReturn, StmtIf, ElseIf, StmtWhile, StmtForIn, StmtForNum, StmtBranch, BranchOn, StmtPrint, StmtRaise, StmtTryCatch, CatchClause, StmtAssert, StmtDefer, StmtWith, StmtArenaScope, StmtGuard, StmtDestruct, AssignOp, Expr, ExprIdent, ExprMember, ExprCall, ExprBinary, ExprUnary, ExprStringLit, ExprStringInterp, Arg, StringPart, StringKind, BinaryOp, UnaryOp, AllAnyKind, LambdaBody, ExprLambda, DeclNamespace, DeclInterface, DeclExtend
use cg_helpers exposing StrSet, scanMutations, analyzeEscapes, assignOpStr, binaryOpStr, nameUsedInStmts
use typechecker exposing ModuleTypes, buildModuleTypes, Type_, InferCtx, inferExpr, walkStmts, typeFromRef, isString


# ── getMemberFieldName ────────────────────────────────────────────────────────
# Given a member-access Expr (self.field), return the field name.
# Returns nil if the expr is not a member access.

def getMemberFieldName(e as Expr) as str?
    branch e
        on Expr.member as m
            return m.member
        on Expr.ident as id
            # In init context, bare field names like `out = List()` become Expr.ident
            return id.name
        on Expr.to_non_nil as tnn
            # x to! — unwrap and check inner
            return getMemberFieldName(tnn.expr)
        else
            pass
    return nil

def makeDottedKey(a as str, b as str) as str
    return a + "." + b

def extractAfterDot(s as str) as str
    # Return the part after the last '.' in a dotted name
    # e.g. "Token.Token" → "Token", "a.b.c" → "c"
    var result as str = s
    for part in s.split(".")
        result = part
    return result

def isUpperCase(s as str) as bool
    if s.len == 0
        return false
    var c = s[0]
    return c >= c'A' and c <= c'Z'

def getVariantKey(e as Expr) as str?
    branch e
        on Expr.member as m
            var obj_name = getIdentName(m.object)
            if obj_name != nil
                return makeDottedKey(obj_name to!, m.member)
        else
            pass
    return nil

def addCrossModuleBoxedVariants(bv as StrSet, module_name as str)
    # PNode from Parser module has many boxed variants
    if module_name == "Parser"
        bv.add("PNode.module_")
        bv.add("PNode.use_")
        bv.add("PNode.class_")
        bv.add("PNode.struct_")
        bv.add("PNode.enum_")
        bv.add("PNode.union_decl")
        bv.add("PNode.sig_")
        bv.add("PNode.field_")
        bv.add("PNode.method_")
        bv.add("PNode.init_")
        bv.add("PNode.stmt_return")
        bv.add("PNode.stmt_if")
        bv.add("PNode.stmt_while")
        bv.add("PNode.stmt_for_in")
        bv.add("PNode.stmt_var")
        bv.add("PNode.stmt_assign")
        bv.add("PNode.stmt_assert")
        bv.add("PNode.stmt_raise")
        bv.add("PNode.stmt_try_catch")
        bv.add("PNode.stmt_expr")
        bv.add("PNode.stmt_print")
        bv.add("PNode.expr_member")
        bv.add("PNode.expr_call")
        bv.add("PNode.expr_index")
        bv.add("PNode.expr_slice")
        bv.add("PNode.expr_binary")
        bv.add("PNode.expr_unary")
        bv.add("PNode.expr_try")
        bv.add("PNode.expr_to_bang")
        bv.add("PNode.stmt_branch")
        bv.add("PNode.expr_except")
        bv.add("PNode.expr_string_interp")
    # Decl, Stmt, Expr, TypeRef from ast module
    if module_name == "ast" or module_name == "codegen" or module_name == "astbuilder" or module_name == "cg_helpers"
        # Decl variants — all are ^T boxed
        bv.add("Decl.use_")
        bv.add("Decl.namespace_")
        bv.add("Decl.class_")
        bv.add("Decl.interface_")
        bv.add("Decl.struct_")
        bv.add("Decl.mixin_")
        bv.add("Decl.enum_")
        bv.add("Decl.method")
        bv.add("Decl.property")
        bv.add("Decl.var_")
        bv.add("Decl.init")
        bv.add("Decl.extend_")
        bv.add("Decl.union_")
        bv.add("Decl.sig_")
        # TypeRef boxed variants (nilable, stream, error_union, ref_to are ^TypeRef)
        bv.add("TypeRef.nilable")
        bv.add("TypeRef.stream")
        bv.add("TypeRef.error_union")
        bv.add("TypeRef.ref_to")
        # Stmt boxed variants
        bv.add("Stmt.if_")
        bv.add("Stmt.while_")
        bv.add("Stmt.for_in")
        bv.add("Stmt.for_num")
        bv.add("Stmt.branch_")
        bv.add("Stmt.return_")
        bv.add("Stmt.assert_")
        bv.add("Stmt.assign")
        bv.add("Stmt.var_")
        bv.add("Stmt.expr")
        bv.add("Stmt.defer_")
        bv.add("Stmt.with_")
        bv.add("Stmt.raise_")
        bv.add("Stmt.try_catch")
        bv.add("Stmt.guard_")
        bv.add("Stmt.destruct")
        bv.add("Stmt.print_")
        bv.add("Stmt.arena_scope")
        # Expr boxed variants
        bv.add("Expr.string_interp")
        bv.add("Expr.member")
        bv.add("Expr.call")
        bv.add("Expr.index")
        bv.add("Expr.slice")
        bv.add("Expr.binary")
        bv.add("Expr.unary")
        bv.add("Expr.cast")
        bv.add("Expr.to_nilable")
        bv.add("Expr.to_non_nil")
        bv.add("Expr.is_nil")
        bv.add("Expr.orelse_")
        bv.add("Expr.catch_")
        bv.add("Expr.if_expr")
        bv.add("Expr.lambda")
        bv.add("Expr.list_lit")
        bv.add("Expr.dict_lit")
        bv.add("Expr.array_lit")
        bv.add("Expr.all_any")
        bv.add("Expr.try_")
        bv.add("Expr.except_")
        # StringPart boxed variant
        bv.add("StringPart.expr_")

def addCrossModuleRefFields(rf as StrSet, orf as StrSet, module_name as str)
    # ^T struct fields from ast.zbr: StructName.fieldName
    # rf = non-optional ^T, orf = optional ^T?
    if module_name == "ast" or module_name == "codegen" or module_name == "astbuilder" or module_name == "cg_helpers"
        # Optional ^T? fields
        orf.add("DeclVar.init_expr")
        orf.add("EnumMember.value")
        orf.add("Param.default_")
        orf.add("StmtForNum.step")
        orf.add("StmtReturn.value")
        orf.add("StmtAssert.message")
        orf.add("StmtRaise.message")
        orf.add("StmtRaise.details")
        orf.add("ExprSlice.start")
        orf.add("ExprSlice.stop_")
        # Non-optional ^T fields
        rf.add("StmtIf.cond")
        rf.add("StmtWhile.cond")
        rf.add("StmtForIn.iter")
        rf.add("StmtForNum.start")
        rf.add("StmtForNum.stop_")
        rf.add("StmtBranch.expr")
        rf.add("StmtAssert.cond")
        rf.add("StmtAssign.target")
        rf.add("StmtAssign.value")
        rf.add("StmtDefer.stmt")
        rf.add("StmtWith.target")
        rf.add("StmtGuard.cond")
        rf.add("StmtDestruct.init_expr")
        rf.add("ExprMember.object")
        rf.add("ExprIndex.object")
        rf.add("ExprIndex.index")
        rf.add("ExprSlice.object")
        rf.add("ExprBinary.left")
        rf.add("ExprBinary.right")
        rf.add("ExprUnary.operand")
        rf.add("ExprCast.expr")
        rf.add("ExprTry.expr")
        rf.add("ExprToNonNil.expr")
        rf.add("ExprIsNil.expr")
        rf.add("ExprToNilable.expr")
        rf.add("ExprOrelse.expr")
        rf.add("ExprOrelse.fallback")
        rf.add("ExprCatch.expr")
        rf.add("ExprCatch.fallback")
        rf.add("ExprIf.cond")
        rf.add("ExprIf.then_expr")
        rf.add("ExprIf.else_expr")
        rf.add("ExprAllAny.iter")
        rf.add("ExprAllAny.cond")
        rf.add("ExprTypeCheck.expr")
        rf.add("DictEntry.key")
        rf.add("DictEntry.value")

def isKnownListField(name as str) as bool
    # Known List-typed fields on Parser structs and AST types
    if name == "value" or name == "else_stmts" or name == "init_expr"
        return true
    if name == "message" or name == "base" or name == "args"
        return true
    if name == "params" or name == "decls" or name == "stmts"
        return true
    if name == "variants" or name == "exposed" or name == "fields"
        return true
    if name == "members" or name == "methods" or name == "parts"
        return true
    if name == "imports" or name == "dep_modules" or name == "items_"
        return true
    return false

# Phase 16c retire #3: `isKnownStrSetField(name)` (a hardcoded allow-list
# of 28 Generator/Helpers/Resolver StrSet-typed field names) was replaced
# by `fieldIsStrSet(mt, dep_mt, name)`, which consults the ModuleTypes
# reverse index populated at class/struct-build time in
# typechecker.addClassMembers. Verified equivalent across the full
# 175-file .zbr corpus before flip.

# Phase 16c retire #1: replaced isAstStructWithPtrParams + isUnboxedCtorArg
# with a direct ModuleTypes.ctorParamAt is-ref-to check. The two heuristics
# answered "is ctor param at (class_name, idx) a ^T?" by name-list
# enumeration; ModuleTypes answers it from the actual AST. Verified
# effective-equivalent across the full 175-file .zbr corpus before flip.
# Phase 16c retire #3: Replacement for `isKnownStrSetField(name)`.
# Answers "is there a field by this name with StrSet type anywhere in
# the current-module or dep-module type tables?" Populated at class/
# struct-build time (typechecker.addClassMembers), so a reverse index
# without HashMap iteration.
def fieldIsStrSet(mt as ModuleTypes, dep_mt as ModuleTypes, field_name as str) as bool
    if mt.hasStrSetField(field_name)
        return true
    if dep_mt.hasStrSetField(field_name)
        return true
    return false

# BUG-032 infrastructure. "Is there a field by this name with HashMap(K,V)
# type anywhere in the current-module or dep-module type tables?" Mirrors
# fieldIsStrSet; populated at class-build time in typechecker.addClassMembers
# via isHashMapTypeRef on the raw TypeRef (since typeFromRef maps generics to
# Type_.unknown_ and would lose the HashMap signal).
def fieldIsHashMap(mt as ModuleTypes, dep_mt as ModuleTypes, field_name as str) as bool
    if mt.hasHashMapField(field_name)
        return true
    if dep_mt.hasHashMapField(field_name)
        return true
    return false

def ctorParamAtIsRefTo(mt as ModuleTypes, dep_mt as ModuleTypes, class_name as str, idx as int) as bool
    var t as Type_? = mt.ctorParamAt(class_name, idx)
    if t == nil
        t = dep_mt.ctorParamAt(class_name, idx)
    if t == nil
        return false
    var tv as Type_ = t to!
    branch tv
        on Type_.ref_to
            return true
        else
            return false

def shouldBoxCtorArg(e as Expr) as bool
    # Returns true if the expression likely produces a union value (Expr/Stmt/TypeRef)
    # that needs to be heap-allocated when passed to a ^T struct parameter
    branch e
        on Expr.ident as id
            # Variables ending in _expr, _stmt, _type_ are union values
            var nm = id.name
            if nm.endsWith("_expr") or nm.endsWith("_stmt")
                return true
            # Known variable names that are Expr values
            if nm == "rval" or nm == "msg" or nm == "cond" or nm == "inner_expr"
                return true
            if nm == "this_expr" or nm == "callee_expr" or nm == "base_expr"
                return true
            if nm == "left_expr" or nm == "right_expr" or nm == "operand_expr"
                return true
            if nm == "target_expr" or nm == "value_expr" or nm == "obj_expr"
                return true
            if nm == "idx_expr" or nm == "subject_expr" or nm == "iter_expr"
                return true
            if nm == "initval" or nm == "type_ref"
                return true
        on Expr.call as c
            # buildExpr(), buildStmt() return union values
            branch c.callee
                on Expr.member as cm
                    if cm.member == "buildExpr" or cm.member == "buildStmt"
                        return true
                    if cm.member == "buildTypeRef"
                        return true
                else
                    pass
        else
            pass
    return false

def variantStructName(union_name as str, variant_name as str) as str?
    # Map union variant to struct type name: Stmt.assign → StmtAssign
    # Use variant_name directly (including trailing underscores)
    if union_name == "Stmt"
        if variant_name == "assign"
            return "StmtAssign"
        if variant_name == "return_"
            return "StmtReturn"
        if variant_name == "if_"
            return "StmtIf"
        if variant_name == "while_"
            return "StmtWhile"
        if variant_name == "for_in"
            return "StmtForIn"
        if variant_name == "for_num"
            return "StmtForNum"
        if variant_name == "branch_"
            return "StmtBranch"
        if variant_name == "assert_"
            return "StmtAssert"
        if variant_name == "defer_"
            return "StmtDefer"
        if variant_name == "with_"
            return "StmtWith"
        if variant_name == "raise_"
            return "StmtRaise"
        if variant_name == "guard_"
            return "StmtGuard"
        if variant_name == "destruct"
            return "StmtDestruct"
        if variant_name == "print_"
            return "StmtPrint"
        if variant_name == "var_"
            return "DeclVar"
        if variant_name == "expr"
            return nil
        if variant_name == "arena_scope"
            return "StmtArenaScope"
        if variant_name == "try_catch"
            return "StmtTryCatch"
    if union_name == "Expr"
        if variant_name == "member"
            return "ExprMember"
        if variant_name == "call"
            return "ExprCall"
        if variant_name == "index"
            return "ExprIndex"
        if variant_name == "slice"
            return "ExprSlice"
        if variant_name == "binary"
            return "ExprBinary"
        if variant_name == "unary"
            return "ExprUnary"
        if variant_name == "cast"
            return "ExprCast"
        if variant_name == "try_"
            return "ExprTry"
        if variant_name == "orelse_"
            return "ExprOrelse"
        if variant_name == "catch_"
            return "ExprCatch"
        if variant_name == "if_" or variant_name == "if_expr"
            return "ExprIf"
        if variant_name == "all_any"
            return "ExprAllAny"
        if variant_name == "to_non_nil"
            return "ExprToNonNil"
        if variant_name == "to_nilable"
            return "ExprToNilable"
        if variant_name == "type_check"
            return "ExprTypeCheck"
        if variant_name == "is_nil"
            return "ExprIsNil"
        if variant_name == "except_"
            return "ExprExcept"
        if variant_name == "string_interp"
            return "ExprStringInterp"
    if union_name == "Decl"
        if variant_name == "var_"
            return "DeclVar"
        if variant_name == "method"
            return "DeclMethod"
        if variant_name == "init"
            return "DeclInit"
        if variant_name == "property"
            return "DeclProperty"
        if variant_name == "sig_"
            return "DeclSig"
    return nil

def isUnionLikeName(name as str) as bool
    # Known union type names from cross-module imports
    if name == "PNode" or name == "PParam"
        return true
    if name == "Decl" or name == "TypeRef" or name == "Stmt" or name == "Expr"
        return true
    if name == "StringPart" or name == "LambdaBody"
        return true
    return false

def isEnumLikeName(name as str) as bool
    # Check if name ends with common enum suffixes: Kind, Mode, Op
    if name == "TokenKind" or name == "LineKind" or name == "StringKind"
        return true
    if name == "ParamMode"
        return true
    if name == "BinaryOp" or name == "UnaryOp" or name == "AssignOp"
        return true
    return false

def getIdentName(e as Expr) as str?
    branch e
        on Expr.ident as id
            return id.name
        on Expr.to_non_nil as tnn
            return getIdentName(tnn.expr)
        else
            pass
    return nil

def isCrossModuleCtorCall(callee as Expr) as bool
    # Check if call is Module.ClassName() where module == class name
    branch callee
        on Expr.member as m
            var obj_name = getIdentName(m.object)
            if obj_name != nil
                return obj_name to! == m.member
        else
            pass
    return false

def getMemberObjectIdent(callee as Expr) as str?
    # Extract the object ident name from a member expression, e.g. Foo.bar → "Foo"
    branch callee
        on Expr.member as m
            return getIdentName(m.object)
        else
            pass
    return nil

def getMemberName(callee as Expr) as str?
    # Extract the member name from a member expression, e.g. Foo.bar → "bar"
    branch callee
        on Expr.member as m
            return m.member
        else
            pass
    return nil

# ── bodyMentionsThis ─────────────────────────────────────────────────────────
# Returns true if any statement in the list contains Expr.this_ or
# a member access on "this" (self/this field access).
# Used to detect whether `self` is used in a method body.

def exprMentionsThis(e as Expr) as bool
    branch e
        on Expr.this_
            return true
        on Expr.member as m
            return exprMentionsThis(m.object)
        on Expr.call as c
            if exprMentionsThis(c.callee)
                return true
            for a in c.args
                if exprMentionsThis(a.value)
                    return true
            return false
        on Expr.binary as b
            return exprMentionsThis(b.left) or exprMentionsThis(b.right)
        on Expr.unary as u
            return exprMentionsThis(u.operand)
        on Expr.index as ix
            return exprMentionsThis(ix.object) or exprMentionsThis(ix.index)
        on Expr.try_ as t
            return exprMentionsThis(t.expr)
        on Expr.cast as ca
            return exprMentionsThis(ca.expr)
        on Expr.to_nilable as t
            return exprMentionsThis(t.expr)
        on Expr.to_non_nil as t
            return exprMentionsThis(t.expr)
        on Expr.is_nil as t
            return exprMentionsThis(t.expr)
        on Expr.orelse_ as o
            return exprMentionsThis(o.expr) or exprMentionsThis(o.fallback)
        on Expr.catch_ as ca
            return exprMentionsThis(ca.expr) or exprMentionsThis(ca.fallback)
        on Expr.if_expr as ie
            return exprMentionsThis(ie.cond) or exprMentionsThis(ie.then_expr) or exprMentionsThis(ie.else_expr)
        on Expr.string_interp as si
            for part in si.parts
                branch part
                    on StringPart.expr_ as pe
                        if exprMentionsThis(pe)
                            return true
                    else
                        pass
            return false
        on Expr.except_ as ex
            return exprMentionsThis(ex.base)
        else
            pass
    return false

def stmtMentionsThis(s as Stmt) as bool
    branch s
        on Stmt.assign as a
            return exprMentionsThis(a.target) or exprMentionsThis(a.value)
        on Stmt.return_ as r
            if r.value != nil
                return exprMentionsThis(r.value to!)
            return false
        on Stmt.var_ as v
            if v.init_expr != nil
                return exprMentionsThis(v.init_expr to!)
            return false
        on Stmt.expr as e
            return exprMentionsThis(e)
        on Stmt.if_ as i
            for st in i.then_stmts
                if stmtMentionsThis(st)
                    return true
            return exprMentionsThis(i.cond)
        on Stmt.while_ as w
            return exprMentionsThis(w.cond) or bodyMentionsThis(w.stmts)
        on Stmt.for_in as fi
            return exprMentionsThis(fi.iter) or bodyMentionsThis(fi.stmts)
        on Stmt.print_ as p
            for a in p.args
                if exprMentionsThis(a)
                    return true
            return false
        on Stmt.branch_ as b
            if exprMentionsThis(b.expr)
                return true
            for c in b.cases
                for cv in c.values
                    if exprMentionsThis(cv)
                        return true
                if bodyMentionsThis(c.stmts)
                    return true
            if b.else_ != nil
                return bodyMentionsThis(b.else_ to!)
            return false
        on Stmt.try_catch as tc
            if bodyMentionsThis(tc.stmts)
                return true
            for cl in tc.clauses
                if bodyMentionsThis(cl.stmts)
                    return true
            return false
        on Stmt.defer_ as d
            return stmtMentionsThis(d.stmt)
        on Stmt.guard_ as g
            if exprMentionsThis(g.cond)
                return true
            return bodyMentionsThis(g.else_stmts)
        else
            pass
    return false

def bodyUsesAnyField(stmts as List(Stmt), members as List(Decl)) as bool
    for d in members
        branch d
            on Decl.var_ as fld
                if nameUsedInStmts(fld.name, stmts)
                    return true
            else
                pass
    return false

def bodyUsesAnyMethod(stmts as List(Stmt), members as List(Decl)) as bool
    for d in members
        branch d
            on Decl.method as dm
                if nameUsedInStmts(dm.name, stmts)
                    return true
            else
                pass
    return false

def bodyMentionsThis(stmts as List(Stmt)) as bool
    for s in stmts
        if stmtMentionsThis(s)
            return true
    return false

# ── Module-level entry points ─────────────────────────────────────────────────
#
# generateModule(m, file) — declarations only (no preamble, no entry thunk).
#   Used for testing and incremental development.
#
# generateEntryPoint(m) — emits `pub fn main()` thunk if any class has
#   `shared def main`.  Returns "" if no main found.
#
# generateFull(m, file, preamble_path) — complete Zig file:
#   preamble (read from file) + declarations + entry thunk.
#   Output is a valid, self-contained .zig program.
#
# Usage:
#   var module = ASTBuilder.build(pm, path)?
#   var zig_src = generateFull(module, path, "selfhost/stdlib_preamble.zig")?
#   File.write(zig_path, zig_src)

def typeRefStr(tr as TypeRef) as str
    branch tr
        on TypeRef.named as n
            return n.name
        on TypeRef.nilable as inner
            return "?" + typeRefStr(inner)
        on TypeRef.error_union as inner
            return "!" + typeRefStr(inner)
        on TypeRef.ref_to as inner
            return "^" + typeRefStr(inner)
        on TypeRef.stream as inner
            return typeRefStr(inner) + "*"
        on TypeRef.generic as g
            var s = g.name + "("
            var i = 0
            while i < g.args.count()
                if i > 0
                    s = s + ", "
                s = s + typeRefStr(g.args.at(i))
                i = i + 1
            return s + ")"
        on TypeRef.void_
            return "void"
        on TypeRef.same_
            return "same"
        on TypeRef.tuple
            return "tuple"
    return "unknown"

def generateModule(m as Module, file as str) as str
    return generateModuleWith(m, file, List(str)(), ModuleTypes())

def generateModuleWith(m as Module, file as str, extra_class_names as List(str), deps_mt as ModuleTypes) as str
    var w = Writer()
    var cn = StrSet()
    # Pre-populate class_names, union_names, enum_names for forward references.
    for decl in m.decls
        branch decl
            on Decl.class_ as c
                cn.add(c.name)
            else
                pass
    # Add cross-module class names from dependencies
    var i as int = 0
    while i < extra_class_names.len
        cn.add(extra_class_names.at(i))
        i = i + 1
    # Phase 16c: wire ModuleTypes. module_types built from this module's AST;
    # deps_mt received from caller (MultiCompiler accumulates across deps).
    var g = Generator(w, 0, "", false, false, false, false, nil, "", file, cn,
                      buildModuleTypes(m), deps_mt)
    # Pre-populate union/enum names from module declarations
    for decl in m.decls
        branch decl
            on Decl.union_ as u
                g.union_names.add(u.name)
                for v in u.variants
                    if v.payload != nil
                        branch v.payload to!
                            on TypeRef.ref_to
                                g.boxed_variants.add(makeDottedKey(u.name, v.name))
                            else
                                pass
            on Decl.enum_ as e
                g.enum_names.add(e.name)
            on Decl.use_ as imp
                addCrossModuleBoxedVariants(g.boxed_variants, imp.path)
                addCrossModuleRefFields(g.ref_fields, g.opt_ref_fields, imp.path)
                for exposed_name in imp.exposed
                    # BUG-034: prefer the dep-module's authoritative type table
                    # over name heuristics. deps_mt.hasUnion covers any exposed
                    # cross-module union declared in a dep (e.g. Type_ from
                    # typechecker.zbr); the hardcoded isUnionLikeName /
                    # isEnumLikeName lists remain as a fallback for the
                    # generate-single-file path where deps_mt is empty.
                    if deps_mt.hasUnion(exposed_name)
                        g.union_names.add(exposed_name)
                    else if isEnumLikeName(exposed_name)
                        g.enum_names.add(exposed_name)
                    else if isUnionLikeName(exposed_name)
                        g.union_names.add(exposed_name)
                    else
                        # Default: treat exposed uppercase names as struct/class types
                        # Only uppercase names — lowercase are functions, not types
                        if isUpperCase(exposed_name)
                            g.struct_names.add(exposed_name)
            on Decl.struct_ as s
                g.struct_names.add(s.name)
            else
                pass
    for decl in m.decls
        branch decl
            on Decl.use_ as u
                g.genUse(u)
            on Decl.enum_ as e
                g.genEnum(e)
            on Decl.union_ as u
                g.genUnion(u)
            on Decl.struct_ as s
                g.genStruct(s)
            on Decl.class_ as c
                g.genClass(c)
            on Decl.method as mth
                g.genMethod(mth)
            on Decl.var_ as v
                g.genFieldDecl(v)
            on Decl.sig_ as s2
                g.genSig(s2)
            on Decl.namespace_ as ns
                g.genNamespace(ns)
            on Decl.interface_ as ifc
                g.genInterface(ifc)
            on Decl.extend_ as ext
                g.genExtend(ext)
            else
                pass
    # Emit Reflect runtime lookup functions
    var reflect_classes = List(str)()
    for decl in m.decls
        branch decl
            on Decl.class_ as rc
                reflect_classes.add(rc.name)
            else
                pass
    if reflect_classes.count() > 0
        # Emit a wrapper struct so that reflect slices work with .items.len and .items[i]
        w.emit("const _ReflectStrSlice = struct { items: []const []const u8, fn count(self: @This()) i64 { return @intCast(self.items.len); } fn at(self: @This(), i: i64) []const u8 { return self.items[@intCast(i)]; } };\n")
        w.emit("fn _reflect_lookup_name(tag: u64) []const u8 {\n")
        var ri2 = 0
        while ri2 < reflect_classes.count()
            w.emit("    if (tag == _ttag_")
            w.emit(reflect_classes.at(ri2))
            w.emit(") return _reflect_")
            w.emit(reflect_classes.at(ri2))
            w.emit("_name;\n")
            ri2 = ri2 + 1
        w.emit("    return \"unknown\";\n}\n")
        w.emit("fn _reflect_lookup_fields(tag: u64) _ReflectStrSlice {\n")
        ri2 = 0
        while ri2 < reflect_classes.count()
            w.emit("    if (tag == _ttag_")
            w.emit(reflect_classes.at(ri2))
            w.emit(") return .{ .items = _reflect_")
            w.emit(reflect_classes.at(ri2))
            w.emit("_fields };\n")
            ri2 = ri2 + 1
        w.emit("    return .{ .items = &.{} };\n}\n")
        w.emit("fn _reflect_lookup_field_types(tag: u64) _ReflectStrSlice {\n")
        ri2 = 0
        while ri2 < reflect_classes.count()
            w.emit("    if (tag == _ttag_")
            w.emit(reflect_classes.at(ri2))
            w.emit(") return .{ .items = _reflect_")
            w.emit(reflect_classes.at(ri2))
            w.emit("_field_types };\n")
            ri2 = ri2 + 1
        w.emit("    return .{ .items = &.{} };\n}\n")
    return w.result()

# ── Entry point thunk ─────────────────────────────────────────────────────────
#
# Scans decls for a class with `shared def main`.  If found, emits:
#   pub fn main() void { _allocator = _arena.allocator(); defer _arena.deinit(); ClassName.main(); }
# For a throws main, wraps in a catch block for clean error display.

def generateEntryPoint(m as Module) as str
    var main_class = ""
    var main_throws = false
    for decl in m.decls
        branch decl
            on Decl.class_ as c
                for mem in c.members
                    branch mem
                        on Decl.method as mth
                            if mth.name == "main" and mth.mods.is_shared
                                main_class = c.name
                                main_throws = mth.throws_
                        else
                            pass
            else
                pass
    if main_class == ""
        return ""
    var sb as StringBuilder = StringBuilder()
    sb.append("pub fn main() void {\n")
    sb.append("    _allocator = _arena.allocator();\n")
    sb.append("    defer _arena.deinit();\n")
    if main_throws
        sb.append("    ")
        sb.append(main_class)
        sb.append(".main() catch |_err| {\n")
        sb.append("        if (_err == error.ZebraError) {\n")
        sb.append("            std.debug.print(\"Error: {s}\\n\", .{_zbr_error_msg()});\n")
        sb.append("        } else {\n")
        sb.append("            std.debug.print(\"Error: {}\\n\", .{_err});\n")
        sb.append("        }\n")
        sb.append("        std.process.exit(1);\n")
        sb.append("    };\n")
    else
        sb.append("    ")
        sb.append(main_class)
        sb.append(".main();\n")
    sb.append("}\n")
    return sb.build()

# ── Cross-module error message helper ─────────────────────────────────────────
#
# Generates a `_zbr_error_msg()` function that checks the local `_error_ctx`
# first, then falls through to each imported dep module's `_error_ctx`.
# This solves the cross-module error context isolation problem: when a dep
# raises, its `_error_ctx` is set in its own module, but the caller's is empty.

def generateErrorMsgHelper(m as Module) as str
    # Back-compat: walk m.decls for direct uses only. Misses transitive deps
    # (e.g. parser.zbr uses Lexer, but main.zbr only uses parser — Lexer's
    # _error_ctx was invisible to main.zig). Prefer generateErrorMsgHelperWith
    # with the full transitive module list from main.zbr's compile graph.
    var dep_modules as List(str) = List(str)()
    for decl in m.decls
        branch decl
            on Decl.use_ as u
                dep_modules.add(u.path)
            else
                pass
    return generateErrorMsgHelperWith(dep_modules)

def generateErrorMsgHelperWith(dep_modules as List(str)) as str
    var sb as StringBuilder = StringBuilder()
    sb.append("fn _zbr_error_msg() []const u8 {\n")
    sb.append("    if (_error_ctx.message.len > 0) return _error_ctx.message;\n")
    var di as int = 0
    while di < dep_modules.len
        var dep_name = dep_modules.at(di)
        # For cross-module _error_ctx, always use @import to access the module-level variable
        # (even when genUse unwraps same-named classes like Resolver.Resolver)
        sb.append("    if (@import(\"")
        sb.append(dep_name)
        sb.append(".zig\")._error_ctx.message.len > 0) return @import(\"")
        sb.append(dep_name)
        sb.append(".zig\")._error_ctx.message;\n")
        di = di + 1
    sb.append("    return \"\";\n")
    sb.append("}\n")
    return sb.build()

# ── Full file generator ───────────────────────────────────────────────────────
#
# Returns a complete, self-contained .zig file.
# preamble_path must be relative to the current working directory.

def generateFull(m as Module, file as str, preamble_path as str) as str throws
    return generateFullWith(m, file, preamble_path, List(str)(), ModuleTypes())

def generateFullWith(m as Module, file as str, preamble_path as str, extra_class_names as List(str), deps_mt as ModuleTypes) as str throws
    return generateFullWithDeps(m, file, preamble_path, extra_class_names, deps_mt, List(str)())

def generateFullWithDeps(m as Module, file as str, preamble_path as str, extra_class_names as List(str), deps_mt as ModuleTypes, all_dep_modules as List(str)) as str throws
    var preamble = File.read(preamble_path)
    var decls = generateModuleWith(m, file, extra_class_names, deps_mt)
    var entry = generateEntryPoint(m)
    var error_helper as str = ""
    if all_dep_modules.len > 0
        error_helper = generateErrorMsgHelperWith(all_dep_modules)
    else
        error_helper = generateErrorMsgHelper(m)
    var sb as StringBuilder = StringBuilder()
    sb.append("// Generated by zebra-selfhost.\n")
    sb.append("// Source: ")
    sb.append(file)
    sb.append("\n\n")
    sb.append(preamble)
    sb.append("\n")
    sb.append(decls)
    if error_helper != ""
        sb.append("\n")
        sb.append(error_helper)
    if entry != ""
        sb.append("\n")
        sb.append(entry)
    return sb.build()

# Generate a dependency file (no entry point thunk, preamble + imports + declarations).
def generateDep(m as Module, file as str, preamble_path as str) as str throws
    return generateDepWith(m, file, preamble_path, List(str)(), ModuleTypes())

def generateDepWith(m as Module, file as str, preamble_path as str, extra_class_names as List(str), deps_mt as ModuleTypes) as str throws
    var preamble = File.read(preamble_path)
    var decls = generateModuleWith(m, file, extra_class_names, deps_mt)
    var sb as StringBuilder = StringBuilder()
    sb.append("// Generated by zebra-selfhost.\n")
    sb.append("// Source: ")
    sb.append(file)
    sb.append("\n\n")
    sb.append(preamble)
    sb.append("\n")
    sb.append(decls)
    return sb.build()

# ── Writer ────────────────────────────────────────────────────────────────────
# Reference-type output sink.  All Generator copies share the same Writer.

class Writer
    var _buf as StringBuilder
    var _uid as int

    cue init()
        _buf = StringBuilder()
        _uid = 0

    def emit(s as str)
        _buf.append(s)

    def result() as str
        return _buf.build()

    # Monotonic counter for deterministic unique identifier suffixes in emitted
    # Zig (_rdet_N, _rshim_N, etc). Shared across all Generator copies because
    # Writer is a class — `except`-derived Generators keep the same Writer ref.
    def nextUid() as int
        _uid = _uid + 1
        return _uid

# ── Generator ─────────────────────────────────────────────────────────────────

struct Generator
    var w                     as Writer   # shared output (class = reference type)
    var indent                as int      # current indentation depth (4 spaces/level)
    var owner                 as str      # enclosing type name ("" at module scope)
    var in_method             as bool     # true inside method/init/property body
    var is_struct_owner       as bool     # true when owner is a struct (not class)
    var is_generic            as bool     # true inside a generic class body
    var current_method_throws as bool     # true when current method is `throws`
    var try_block_label       as str?     # non-nil inside a `try` block
    var catch_var             as str      # catch clause binding name ("" if none)
    var source_file           as str      # source path for comment markers
    var class_names           as StrSet  # names of classes → emit *ClassName in genType
    var union_names           as StrSet  # names of unions → emit union construction
    var enum_names            as StrSet  # names of enums → emit enum construction
    var struct_names          as StrSet  # names of structs → emit struct.init() construction
    var boxed_variants        as StrSet  # "UnionName.variant" entries where payload is ^T
    var ref_fields            as StrSet  # "StructName.fieldName" entries where field is ^T (non-optional)
    var opt_ref_fields        as StrSet  # "StructName.fieldName" entries where field is ^T? (optional)
    var unwrapped_imports     as StrSet  # module names where genUse did .ModuleName unwrap
    # Phase 7b additions
    var mut_set               as StrSet?  # variables that are mutated
    var ret_set               as StrSet?  # variables that escape via return
    var nil_narrowed          as StrSet?  # variables narrowed to non-nil in current scope
    var try_err_var           as str?     # current try-block error variable name
    var owner_members         as List(Decl)  # members of current enclosing type
    var param_names           as StrSet?  # current method parameter names
    var str_params            as StrSet   # param names with type str
    var list_locals           as StrSet   # local/param names with type List(*)
    var strset_locals         as StrSet   # local/param names with type StrSet
    var hashmap_locals        as StrSet   # local/param names with type HashMap(K,V)
    var ptr_field_bindings    as StrSet   # "bindingName.fieldName" where field is ^T (non-optional)
    var opt_ptr_field_bindings as StrSet  # "bindingName.fieldName" where field is ^T? (optional)
    var for_loop_deref        as StrSet   # "loopVar.field" needing .* in for-loop body (e.g. DictEntry)
    var for_loop_vars         as StrSet   # active for-loop variable names (suppress stale branch deref)
    var in_try_expr           as bool     # suppress auto-try when already inside Expr.try_
    var self_name             as str      # "self" for methods, "_self" for init
    var capture_fields        as StrSet   # captured var names → emit self.name in genIdent
    var closure_vars          as StrSet   # local vars holding capture-lambdas → .call() dispatch
    # Phase 16c additions — ModuleTypes for this module and merged deps.
    # Plumbed now, consumed incrementally as heuristics retire (16c..17).
    var module_types          as ModuleTypes
    var dep_types             as ModuleTypes
    # Phase 17c addition — per-method inference context. Seeded by genMethod/
    # genInit via walkStmts pre-walk before emit. nil at module scope.
    var infer_ctx             as InferCtx?

    cue init(w as Writer, indent as int, owner as str, in_method as bool,
             is_struct_owner as bool, is_generic as bool,
             current_method_throws as bool, try_block_label as str?,
             catch_var as str, source_file as str, class_names as StrSet,
             module_types as ModuleTypes, dep_types as ModuleTypes)
        this.w                     = w
        this.indent                = indent
        this.owner                 = owner
        this.in_method             = in_method
        this.is_struct_owner       = is_struct_owner
        this.is_generic            = is_generic
        this.current_method_throws = current_method_throws
        this.try_block_label       = try_block_label
        this.catch_var             = catch_var
        this.source_file           = source_file
        this.class_names           = class_names
        this.union_names           = StrSet()
        this.enum_names            = StrSet()
        this.struct_names          = StrSet()
        this.boxed_variants        = StrSet()
        this.ref_fields            = StrSet()
        this.opt_ref_fields        = StrSet()
        this.unwrapped_imports     = StrSet()
        # Phase 7b field initializations
        this.mut_set               = nil
        this.ret_set               = nil
        this.nil_narrowed          = nil
        this.try_err_var           = nil
        this.owner_members         = List(Decl)()
        this.param_names           = nil
        this.str_params            = StrSet()
        this.list_locals           = StrSet()
        this.strset_locals         = StrSet()
        this.hashmap_locals        = StrSet()
        this.ptr_field_bindings    = StrSet()
        this.opt_ptr_field_bindings = StrSet()
        this.for_loop_deref        = StrSet()
        this.for_loop_vars         = StrSet()
        this.in_try_expr           = false
        this.self_name             = "self"
        this.capture_fields        = StrSet()
        this.closure_vars          = StrSet()
        this.module_types          = module_types
        this.dep_types             = dep_types
        this.infer_ctx             = nil

    # ── Context-adjustment helpers ────────────────────────────────────────────

    def withOwner(new_owner as str) as Generator
        var g = this except
            owner = new_owner
        return g

    def asMethod as Generator
        var g = this except
            in_method = true
        return g

    def asStructOwner as Generator
        var g = this except
            is_struct_owner = true
        return g

    def indented as Generator
        var g = this except
            indent = indent + 1
        return g

    def withThrows as Generator
        var g = this except
            current_method_throws = true
        return g

    def withTryLabel(label as str, err_var as str) as Generator
        var g = this except
            try_block_label = label
            try_err_var     = err_var
        return g

    def withCatchVar(name as str) as Generator
        var g = this except
            catch_var = name
        return g

    def withCaptureFields(cf as StrSet) as Generator
        var g = this except
            capture_fields = cf
        return g

    # Phase 7b context helpers
    def withOwnerMembers(members as List(Decl)) as Generator
        var g = this except
            owner_members = members
        return g

    def withSelfName(name as str) as Generator
        var g = this except
            self_name = name
        return g

    # Phase 17c — attach an InferCtx. Written as a method on Generator so the
    # `except`-on-this path goes through the self-pointer (workaround for a
    # selfhost emit bug where `local = local except` emits an illegal
    # `local.*` deref; `this except` is fine because `this` is a pointer).
    def withInferCtx(ctx as InferCtx) as Generator
        var g = this except
            infer_ctx = ctx
        return g

    # Phase 17c — true iff t is a named union type known in this module or a dep.
    # Used to replace shouldBoxCtorArg (name-pattern heuristic) with a walker-
    # verified answer from inferExpr.
    def isUnionType(t as Type_) as bool
        branch t
            on Type_.named as tn
                if this.module_types.hasUnion(tn)
                    return true
                if this.dep_types.hasUnion(tn)
                    return true
                return false
            else
                return false

    # Phase 17d: walker-derived "is this expression a string?" — replaces the
    # isStringExpr name-pattern heuristic when infer_ctx is populated.
    def isStringWalker(e as Expr) as bool
        if this.infer_ctx == nil
            return false
        var t as Type_ = inferExpr(e, this.infer_ctx to!)
        return isString(t)

    # Phase 17d — walker-derived string detection replaces the name-pattern
    # heuristic. isStringExpr is retained only as a fallback for callers
    # reached before infer_ctx has been seeded (tests, emission paths that
    # bypass genMethod / genInit). Flipped after corpus runs showed the
    # walker is a strict superset of the heuristic over all selfhost files.
    def isStringBoth(e as Expr, site as str) as bool
        if this.infer_ctx != nil
            return this.isStringWalker(e)
        return isStringExpr(e)

    def withMethodCtx(ms as StrSet?, rs as StrSet?, throws_ as bool, members as List(Decl), pnames as StrSet?, sparams as StrSet, sname as str) as Generator
        var g = this except
            in_method             = true
            current_method_throws = throws_
            mut_set               = ms
            ret_set               = rs
            owner_members         = members
            param_names           = pnames
            str_params            = sparams
            self_name             = sname
            indent                = indent + 1
            for_loop_deref        = StrSet()
            for_loop_vars         = StrSet()
        return g

    # ── Output helpers ────────────────────────────────────────────────────────

    def emitTryBlockCatch()
        # Inside a try block: emit `catch |_e| { _try_err = _e; break :_try_blk; }`
        # instead of using `try` which propagates to the enclosing function
        w.emit(" catch |_tc_e| { ")
        w.emit(try_err_var to!)
        w.emit(" = _tc_e; break :")
        w.emit(try_block_label to!)
        w.emit("; }")

    def writeIndent
        var i = 0
        while i < indent
            w.emit("    ")
            i += 1

    def line(s as str)
        writeIndent()
        w.emit(s)
        w.emit("\n")

    # ── genType ───────────────────────────────────────────────────────────────

    def genType(tr as TypeRef)
        branch tr
            on TypeRef.named as n
                if class_names.contains_(n.name)
                    w.emit("*")
                    w.emit(n.name)
                    return
                if n.name == "StringBuilder"
                    w.emit("std.ArrayList(u8)")
                    return
                if "." in n.name
                    # Dotted cross-module type: Module.ClassName
                    # If ClassName is a class, emit *Module.ClassName
                    var class_part = extractAfterDot(n.name)
                    if class_names.contains_(class_part)
                        w.emit("*")
                    w.emit(n.name)
                    return
                w.emit(zigPrimitive(n.name))

            on TypeRef.nilable as inner
                w.emit("?")
                genType(inner)

            on TypeRef.error_union as inner
                w.emit("anyerror!")
                genType(inner)

            on TypeRef.ref_to as inner
                # BUG-041: classes are already auto-boxed to `*T` by the `.named`
                # arm, so a recursive genType on a class inner would stack a
                # second `*`, producing `**T` (or `?**T`). For classes, `^T` is a
                # no-op on representation — emit `*ClassName` / `?*ClassName`
                # directly and skip the auto-box recursion.
                var is_nilable = false
                branch inner
                    on TypeRef.nilable
                        is_nilable = true
                    else
                        pass
                var prefix as str
                if is_nilable
                    prefix = "?*"
                else
                    prefix = "*"
                var handled = false
                branch inner
                    on TypeRef.nilable as ni2
                        branch ni2
                            on TypeRef.named as n
                                if class_names.contains_(n.name)
                                    w.emit(prefix)
                                    w.emit(n.name)
                                    handled = true
                                else if "." in n.name
                                    var class_part = extractAfterDot(n.name)
                                    if class_names.contains_(class_part)
                                        w.emit(prefix)
                                        w.emit(n.name)
                                        handled = true
                            else
                                pass
                    on TypeRef.named as n
                        if class_names.contains_(n.name)
                            w.emit(prefix)
                            w.emit(n.name)
                            handled = true
                        else if "." in n.name
                            var class_part = extractAfterDot(n.name)
                            if class_names.contains_(class_part)
                                w.emit(prefix)
                                w.emit(n.name)
                                handled = true
                    else
                        pass
                if not handled
                    w.emit(prefix)
                    if is_nilable
                        branch inner
                            on TypeRef.nilable as ni3
                                genType(ni3)
                            else
                                pass
                    else
                        genType(inner)

            on TypeRef.generic as gtr
                genGenericType(gtr)

            on TypeRef.stream as inner
                w.emit("anytype /* stream: ")
                genType(inner)
                w.emit(" */")

            on TypeRef.void_
                w.emit("void")

            on TypeRef.same_
                if owner != ""
                    w.emit(owner)
                else
                    w.emit("@This()")

            on TypeRef.tuple as ttr
                w.emit("struct { ")
                var j = 0
                while j < ttr.elems.count()
                    if j > 0
                        w.emit(", ")
                    genType(ttr.elems.at(j))
                    j += 1
                w.emit(" }")

    def genGenericType(gtr as GenericTypeRef)
        if gtr.name == "Result"
            w.emit("_Result(")
            if gtr.args.count() >= 1
                genType(gtr.args.at(0))
            else
                w.emit("void")
            w.emit(", ")
            if gtr.args.count() >= 2
                genType(gtr.args.at(1))
            else
                w.emit("[]const u8")
            w.emit(")")
            return
        if gtr.name == "HashMap"
            var key_str = gtr.args.count() >= 1 and isStringTypeRef(gtr.args.at(0))
            if key_str
                w.emit("std.StringHashMap(")
                if gtr.args.count() >= 2
                    genType(gtr.args.at(1))
                else
                    w.emit("anytype")
                w.emit(")")
            else
                w.emit("std.AutoHashMap(")
                var ai = 0
                while ai < gtr.args.count()
                    if ai > 0
                        w.emit(", ")
                    genType(gtr.args.at(ai))
                    ai += 1
                w.emit(")")
            return
        if gtr.name == "List"
            w.emit("std.ArrayList(")
            if gtr.args.count() >= 1
                genType(gtr.args.at(0))
            else
                w.emit("[]const u8")
            w.emit(")")
            return
        w.emit(gtr.name)
        if gtr.args.count() > 0
            w.emit("(")
            var bi = 0
            while bi < gtr.args.count()
                if bi > 0
                    w.emit(", ")
                genType(gtr.args.at(bi))
                bi += 1
            w.emit(")")

    def zigPrimitive(name as str) as str
        if name == "int"
            return "i64"
        if name == "uint"
            return "u64"
        if name == "float"
            return "f64"
        if name == "bool"
            return "bool"
        if name == "char"
            return "u21"
        if name == "str"
            return "[]const u8"
        if name == "String"
            return "[]const u8"
        if name == "int8"
            return "i8"
        if name == "int16"
            return "i16"
        if name == "int32"
            return "i32"
        if name == "int64"
            return "i64"
        if name == "int128"
            return "i128"
        if name == "uint8"
            return "u8"
        if name == "uint16"
            return "u16"
        if name == "uint32"
            return "u32"
        if name == "uint64"
            return "u64"
        if name == "uint128"
            return "u128"
        if name == "float16"
            return "f16"
        if name == "float32"
            return "f32"
        if name == "float64"
            return "f64"
        if name == "float128"
            return "f128"
        return name

    def isStringTypeRef(tr as TypeRef) as bool
        branch tr
            on TypeRef.named as n
                return n.name == "str" or n.name == "String"
            else
                pass
        return false

    # ── genUse ────────────────────────────────────────────────────────────────
    # Emit @import for `use Module` / `use Module exposing Name1, Name2`.
    # Each dependency .zbr file is compiled to its own .zig file by the multi-file
    # pipeline. The import path uses the module name + ".zig".

    def genUse(n as DeclUse)
        # Simple module path (no dots) → @import("path.zig")
        # If the module has a sole same-named class (e.g. `use Lexer` where Lexer.zbr
        # defines class Lexer), unwrap the class: const Lexer = @import("Lexer.zig").Lexer;
        var alias as str = n.path
        var has_same_named_class = class_names.contains_(alias)
        if n.exposed.len == 0
            # `use Mod` — import module (or unwrap same-named class)
            w.emit("const ")
            w.emit(alias)
            w.emit(" = @import(\"")
            w.emit(n.path)
            w.emit(".zig\")")
            if has_same_named_class
                w.emit(".")
                w.emit(alias)
                unwrapped_imports.add(alias)
            w.emit(";\n")
        else
            # `use Mod exposing Name1, Name2` — import module, then alias each exposed name
            w.emit("const ")
            w.emit(alias)
            w.emit(" = @import(\"")
            w.emit(n.path)
            w.emit(".zig\");\n")
            var i as int = 0
            while i < n.exposed.len
                var ename as str = n.exposed.at(i)
                if ename != alias
                    w.emit("const ")
                    w.emit(ename)
                    w.emit(" = ")
                    w.emit(alias)
                    w.emit(".")
                    w.emit(ename)
                    w.emit(";\n")
                i = i + 1

    # ── genFieldDecl ──────────────────────────────────────────────────────────

    def genFieldDecl(n as DeclVar)
        writeIndent()
        w.emit(n.name)
        w.emit(": ")
        if n.type_ != nil
            var tr = n.type_ to!
            branch tr
                on TypeRef.named as nt
                    if nt.name == "StringBuilder"
                        w.emit("std.ArrayList(u8) = .{},\n")
                        return
                else
                    pass
            genType(tr)
        else
            w.emit("anytype")
        w.emit(",\n")

    # ── genEnum ───────────────────────────────────────────────────────────────

    def genEnum(n as DeclEnum)
        enum_names.add(n.name)
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = enum")
        if n.base != nil
            w.emit("(")
            genType(n.base to!)
            w.emit(")")
        w.emit(" {\n")
        var ig = indented()
        for m in n.members
            ig.writeIndent()
            ig.w.emit(m.name)
            ig.w.emit(",\n")
        writeIndent()
        w.emit("};\n\n")

    # ── genUnion ──────────────────────────────────────────────────────────────

    def genUnion(n as DeclUnion)
        union_names.add(n.name)
        # Track boxed variants (^T payloads)
        for v in n.variants
            if v.payload != nil
                branch v.payload to!
                    on TypeRef.ref_to
                        boxed_variants.add(makeDottedKey(n.name, v.name))
                    else
                        pass
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = union(enum) {\n")
        var ig = indented()
        for v in n.variants
            ig.writeIndent()
            ig.w.emit(v.name)
            if v.payload != nil
                ig.w.emit(": ")
                ig.genType(v.payload to!)
            ig.w.emit(",\n")
        writeIndent()
        w.emit("};\n\n")

    # ── genStruct ─────────────────────────────────────────────────────────────

    def genStruct(n as DeclStruct)
        struct_names.add(n.name)
        # Track ^T fields for auto-deref
        for decl in n.members
            branch decl
                on Decl.var_ as fld
                    if fld.type_ != nil
                        branch fld.type_ to!
                            on TypeRef.ref_to
                                ref_fields.add(makeDottedKey(n.name, fld.name))
                            else
                                pass
                else
                    pass
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = struct {\n")
        var ig0 = indented()
        var ig1 = ig0.withOwner(n.name)
        var ig2 = ig1.asStructOwner()
        var ig  = ig2.withOwnerMembers(n.members)
        for decl in n.members
            branch decl
                on Decl.var_ as fld
                    ig.genFieldDecl(fld)
                else
                    pass
        for decl in n.members
            branch decl
                on Decl.method as m
                    ig.genMethod(m)
                on Decl.init as ini
                    ig.genInit(ini)
                else
                    pass
        writeIndent()
        w.emit("};\n\n")

    # ── genClass ──────────────────────────────────────────────────────────────

    def genClass(n as DeclClass)
        class_names.add(n.name)
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = struct {\n")
        var ig0 = indented()
        var ig1 = ig0.withOwner(n.name)
        var ig  = ig1.withOwnerMembers(n.members)
        ig.line("_type_tag: u64 = _ttag_" + n.name + ",")
        for decl in n.members
            branch decl
                on Decl.var_ as fld
                    ig.genFieldDecl(fld)
                else
                    pass
        var has_init = false
        for decl in n.members
            branch decl
                on Decl.method as m
                    ig.genMethod(m)
                on Decl.init as ini
                    ig.genInit(ini)
                    has_init = true
                on Decl.property as prop
                    ig.genProperty(prop)
                else
                    pass
        # Synthetic default init for classes without explicit cue init
        if not has_init
            ig.writeIndent()
            ig.w.emit("pub fn init() *")
            ig.w.emit(n.name)
            ig.w.emit(" {\n")
            var dig = ig.indented()
            dig.writeIndent()
            dig.w.emit("const self = _allocator.create(")
            dig.w.emit(n.name)
            dig.w.emit(") catch @panic(\"OOM\");\n")
            dig.writeIndent()
            dig.w.emit("self._type_tag = _ttag_")
            dig.w.emit(n.name)
            dig.w.emit(";\n")
            dig.writeIndent()
            dig.w.emit("return self;\n")
            ig.writeIndent()
            ig.w.emit("}\n\n")
        writeIndent()
        w.emit("};\n")
        w.emit("const _ttag_")
        w.emit(n.name)
        w.emit(": u64 = _zbr_hash(\"")
        w.emit(n.name)
        w.emit("\");\n")
        # Tier-1 reflection metadata
        var rf_names = List(str)()
        var rf_types = List(str)()
        for decl in n.members
            branch decl
                on Decl.var_ as fld
                    if not fld.mods.is_shared
                        rf_names.add(fld.name)
                        if fld.type_ != nil
                            rf_types.add(typeRefStr(fld.type_ to!))
                        else
                            rf_types.add("unknown")
                else
                    pass
        w.emit("const _reflect_")
        w.emit(n.name)
        w.emit("_name: []const u8 = \"")
        w.emit(n.name)
        w.emit("\";\n")
        w.emit("const _reflect_")
        w.emit(n.name)
        w.emit("_fields: []const []const u8 = &.{")
        var ri = 0
        while ri < rf_names.count()
            if ri > 0
                w.emit(", ")
            w.emit("\"")
            w.emit(rf_names.at(ri))
            w.emit("\"")
            ri = ri + 1
        w.emit("};\n")
        w.emit("const _reflect_")
        w.emit(n.name)
        w.emit("_field_types: []const []const u8 = &.{")
        ri = 0
        while ri < rf_types.count()
            if ri > 0
                w.emit(", ")
            w.emit("\"")
            w.emit(rf_types.at(ri))
            w.emit("\"")
            ri = ri + 1
        w.emit("};\n\n")

    # ── genMethod ─────────────────────────────────────────────────────────────

    def genMethod(m as DeclMethod)
        writeIndent()
        w.emit("pub fn ")
        w.emit(m.name)
        w.emit("(")
        var has_self = owner != "" and not m.mods.is_shared
        if has_self
            if is_generic
                w.emit("self: *@This()")
            else
                w.emit("self: *")
                w.emit(owner)
            if m.params.count() > 0
                w.emit(", ")
        genParamList(m.params)
        w.emit(") ")
        if m.throws_
            w.emit("anyerror!")
        if m.return_type != nil
            genType(m.return_type to!)
        else
            w.emit("void")
        if m.stmts != nil
            var mstmts = m.stmts to!
            var ms = scanMutations(mstmts)
            var rs = analyzeEscapes(mstmts)
            var ps = StrSet()
            var sp = StrSet()
            for p in m.params
                ps.add(p.name)
                if p.type_ != nil
                    branch p.type_ to!
                        on TypeRef.named as nt
                            if nt.name == "str" or nt.name == "String"
                                sp.add(p.name)
                        else
                            pass
            w.emit(" {\n")
            var bg = withMethodCtx(ms, rs, m.throws_, owner_members, ps, sp, "self")
            # Phase 17c — seed a per-method InferCtx and pre-walk statements so
            # expression-level type inference has a populated scope map. Used
            # during emit (e.g., at ctor-arg boxing) to replace name-pattern
            # heuristics with walker-derived types.
            var ctx17c = InferCtx(this.module_types, owner)
            ctx17c.withDepTypes(this.dep_types)
            for pp in m.params
                if pp.type_ != nil
                    ctx17c.bind(pp.name, typeFromRef(pp.type_ to!))
                else
                    ctx17c.bind(pp.name, Type_.unknown_)
            walkStmts(mstmts, ctx17c)
            bg = bg.withInferCtx(ctx17c)
            # Track List/StrSet/HashMap params for type-aware codegen
            for p2 in m.params
                if p2.type_ != nil
                    branch p2.type_ to!
                        on TypeRef.generic as gt
                            if gt.name == "List"
                                bg.list_locals.add(p2.name)
                            if gt.name == "HashMap"
                                bg.hashmap_locals.add(p2.name)
                        on TypeRef.named as nt2
                            if nt2.name == "StrSet"
                                bg.strset_locals.add(p2.name)
                        else
                            pass
            # Suppress unused-parameter errors for self and params
            # Check explicit Expr.this_ usage AND implicit field access (bare ident matching a field)
            if has_self and not bodyMentionsThis(mstmts) and not bodyUsesAnyField(mstmts, owner_members) and not bodyUsesAnyMethod(mstmts, owner_members)
                bg.line("_ = self;")
            for p in m.params
                if not nameUsedInStmts(p.name, mstmts)
                    bg.writeIndent()
                    bg.w.emit("_ = ")
                    bg.w.emit(p.name)
                    bg.w.emit(";\n")
            bg.genStmts(mstmts)
            writeIndent()
            w.emit("}\n\n")
        else
            w.emit(" {\n")
            var ig = indented()
            ig.line("unreachable; // abstract")
            writeIndent()
            w.emit("}\n\n")

    # ── genInit ───────────────────────────────────────────────────────────────

    def genInit(ini as DeclInit)
        writeIndent()
        w.emit("pub fn init(")
        genParamList(ini.params)
        w.emit(") ")
        if not is_struct_owner
            w.emit("*")
        w.emit(owner)
        w.emit(" {\n")
        var ig = indented()
        if not is_struct_owner
            # Class init: allocate on arena
            ig.writeIndent()
            ig.w.emit("const _self = _allocator.create(")
            ig.w.emit(owner)
            ig.w.emit(") catch @panic(\"OOM\");\n")
            ig.writeIndent()
            ig.w.emit("_self._type_tag = _zbr_hash(\"")
            ig.w.emit(owner)
            ig.w.emit("\");\n")
        else
            # Struct init: local value
            ig.writeIndent()
            ig.w.emit("var _self: ")
            ig.w.emit(owner)
            ig.w.emit(" = undefined;\n")
        if ini.stmts != nil
            var istmts = ini.stmts to!
            var ms = scanMutations(istmts)
            var rs = analyzeEscapes(istmts)
            var ps = StrSet()
            for p in ini.params
                ps.add(p.name)
            var bg = ig.withMethodCtx(ms, rs, false, owner_members, ps, StrSet(), "_self")
            # Phase 17c — seed InferCtx for the init body as well (see genMethod).
            var ctx17ci = InferCtx(this.module_types, owner)
            ctx17ci.withDepTypes(this.dep_types)
            for pp in ini.params
                if pp.type_ != nil
                    ctx17ci.bind(pp.name, typeFromRef(pp.type_ to!))
                else
                    ctx17ci.bind(pp.name, Type_.unknown_)
            walkStmts(istmts, ctx17ci)
            bg = bg.withInferCtx(ctx17ci)
            bg.genStmts(istmts)
        ig.writeIndent()
        ig.w.emit("return _self;\n")
        writeIndent()
        w.emit("}\n\n")

    # ── genSig ────────────────────────────────────────────────────────────────

    def genSig(sd as DeclSig)
        writeIndent()
        w.emit("const ")
        w.emit(sd.name)
        w.emit(" = *const fn(")
        var first = true
        for p in sd.params
            if not first
                w.emit(", ")
            first = false
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")
        w.emit(") ")
        if sd.return_type != nil
            genType(sd.return_type to!)
        else
            w.emit("void")
        w.emit(";\n")

    # ── genNamespace ─────────────────────────────────────────────────────────
    # namespace Foo → pub const Foo = struct { ... };
    def genNamespace(ns as DeclNamespace)
        writeIndent()
        w.emit("pub const ")
        w.emit(ns.name)
        w.emit(" = struct {\n")
        var ig = indented()
        for d in ns.decls
            branch d
                on Decl.method as mth
                    ig.genMethod(mth)
                on Decl.var_ as v
                    ig.genFieldDecl(v)
                on Decl.class_ as c
                    ig.genClass(c)
                on Decl.struct_ as s
                    ig.genStruct(s)
                on Decl.enum_ as e
                    ig.genEnum(e)
                else
                    pass
        writeIndent()
        w.emit("};\n\n")

    # ── genInterface ─────────────────────────────────────────────────────────
    # interface Shape → comptime validation fn: checks @hasDecl on each member
    def genInterface(ifc as DeclInterface)
        writeIndent()
        w.emit("pub fn ")
        w.emit(ifc.name)
        w.emit("(comptime T: type) void {\n")
        var ig = indented()
        ig.writeIndent()
        w.emit("comptime {\n")
        var iig = ig.indented()
        for mem in ifc.members
            branch mem
                on Decl.method as mth
                    iig.writeIndent()
                    w.emit("if (!@hasDecl(T, \"")
                    w.emit(mth.name)
                    w.emit("\")) @compileError(\"type \" ++ @typeName(T) ++ \" does not implement ")
                    w.emit(ifc.name)
                    w.emit(".")
                    w.emit(mth.name)
                    w.emit("\");\n")
                on Decl.property as prop
                    iig.writeIndent()
                    w.emit("if (!@hasDecl(T, \"")
                    w.emit(prop.name)
                    w.emit("\")) @compileError(\"type \" ++ @typeName(T) ++ \" does not implement ")
                    w.emit(ifc.name)
                    w.emit(".")
                    w.emit(prop.name)
                    w.emit("\");\n")
                else
                    pass
        ig.writeIndent()
        w.emit("}\n")
        writeIndent()
        w.emit("}\n\n")

    # ── genExtend ────────────────────────────────────────────────────────────
    # extend Type → standalone functions prefixed with _ext_Type_
    def genExtend(ext as DeclExtend)
        var tname = ""
        branch ext.target
            on TypeRef.named as n
                tname = n.name
            else
                tname = "Unknown"
        writeIndent()
        w.emit("// extend ")
        w.emit(tname)
        w.emit("\n")
        for mem in ext.members
            branch mem
                on Decl.method as mth
                    genExtMethod(tname, mth)
                else
                    pass
        w.emit("\n")

    def genExtMethod(tname as str, mth as DeclMethod)
        writeIndent()
        w.emit("fn _ext_")
        w.emit(tname)
        w.emit("_")
        w.emit(mth.name)
        w.emit("(self: ")
        # Map builtin type names to Zig types
        if tname == "str"
            w.emit("[]const u8")
        else if tname == "int"
            w.emit("i64")
        else if tname == "float"
            w.emit("f64")
        else if tname == "bool"
            w.emit("bool")
        else
            w.emit(tname)
        for p in mth.params
            w.emit(", ")
            w.emit(p.name)
            w.emit(": ")
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")
        w.emit(") ")
        if mth.throws_
            w.emit("anyerror!")
        if mth.return_type != nil
            genType(mth.return_type to!)
        else
            w.emit("void")
        if mth.stmts != nil
            w.emit(" {\n")
            var ig = indented()
            ig.genStmts(mth.stmts to!)
            writeIndent()
            w.emit("}\n")
        else
            w.emit(" {}\n")

    # ── genProperty ───────────────────────────────────────────────────────────

    def genProperty(prop as DeclProperty)
        # getter
        writeIndent()
        w.emit("pub fn ")
        w.emit(prop.name)
        w.emit("(self: *")
        w.emit(owner)
        w.emit(") ")
        if prop.type_ != nil
            genType(prop.type_ to!)
        else
            w.emit("void")
        w.emit(" {\n")
        if prop.getter_ != nil
            var gbody = prop.getter_ to!
            var ms = scanMutations(gbody)
            var rs = analyzeEscapes(gbody)
            var pig = indented()
            var bg = pig.withMethodCtx(ms, rs, false, owner_members, nil, StrSet(), "self")
            bg.genStmts(gbody)
        else
            var ig = indented()
            ig.line("_ = self;")
        writeIndent()
        w.emit("}\n\n")

    # ── genParamList ──────────────────────────────────────────────────────────

    def genParamList(params as List(Param))
        var first = true
        for p in params
            if not first
                w.emit(", ")
            first = false
            w.emit(p.name)
            w.emit(": ")
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")

    # ── genStmts / genStmt ────────────────────────────────────────────────────

    def genStmts(stmts as List(Stmt))
        for s in stmts
            genStmt(s)

    def genStmt(s as Stmt)
        branch s
            on Stmt.var_ as n
                genLocalVar(n)
            on Stmt.assign as a
                genAssign(a)
            on Stmt.return_ as r
                genReturn(r)
            on Stmt.if_ as si
                genIf(si)
            on Stmt.while_ as ww
                genWhile(ww)
            on Stmt.for_in as fi
                genForIn(fi)
            on Stmt.for_num as fn_
                genForNum(fn_)
            on Stmt.branch_ as b
                genBranch(b)
            on Stmt.print_ as p
                genPrint(p)
            on Stmt.raise_ as r
                genRaise(r)
            on Stmt.try_catch as tc
                genTryCatch(tc)
            on Stmt.assert_ as a
                genAssert(a)
            on Stmt.defer_ as d
                genDefer(d)
            on Stmt.with_ as ww
                genWith(ww)
            on Stmt.arena_scope as a
                genArenaScope(a)
            on Stmt.guard_ as g
                genGuard(g)
            on Stmt.destruct as d
                genDestruct(d)
            on Stmt.expr as e
                writeIndent()
                genExpr(e)
                w.emit(";\n")
            on Stmt.pass_
                line("// pass")
            on Stmt.break_
                line("break;")
            on Stmt.continue_
                line("continue;")

    # ── genLocalVar ───────────────────────────────────────────────────────────

    def genLocalVar(n as DeclVar)
        writeIndent()
        # Determine const vs var
        var is_mut = false
        if mut_set != nil
            is_mut = mut_set to!.contains_(n.name)
        if n.is_const
            is_mut = false
        if is_mut
            w.emit("var ")
        else
            w.emit("const ")
        w.emit(n.name)
        # Track local str/List variables for type-aware codegen
        # Must happen BEFORE early-return paths (StringBuilder, generic stdlib ctor)
        if n.type_ != nil
            branch n.type_ to!
                on TypeRef.named as tn
                    if tn.name == "str" or tn.name == "String"
                        str_params.add(n.name)
                on TypeRef.generic as gtn
                    if gtn.name == "List"
                        list_locals.add(n.name)
                    if gtn.name == "HashMap"
                        hashmap_locals.add(n.name)
                else
                    pass
        # Detect StrSet from init expression (StrSet() has no type annotation)
        if n.init_expr != nil
            if isStrSetCtor(n.init_expr to!)
                strset_locals.add(n.name)
        # Detect string vars from init expression (var x = "" or var x = "literal")
        if n.init_expr != nil
            if this.isStringBoth(n.init_expr to!, "var_decl")
                str_params.add(n.name)
        # Track capture-lambda vars for .call() dispatch at call sites
        if n.init_expr != nil
            branch n.init_expr to!
                on Expr.lambda as lam
                    if lam.captures.count() > 0
                        closure_vars.add(n.name)
                else
                    pass
        # Special-case: StringBuilder() constructor
        if n.init_expr != nil
            var ie = n.init_expr to!
            if isStringBuilderCtor(ie)
                w.emit(" = std.ArrayList(u8){};\n")
                return
            if isGenericStdlibCtor(ie)
                w.emit(" = ")
                genGenericCtorExpr(ie, n.type_)
                w.emit(";\n")
                return
        # Type annotation if present
        if n.type_ != nil and n.init_expr == nil
            w.emit(": ")
            genType(n.type_ to!)
            w.emit(" = undefined;\n")
            return
        if n.type_ != nil
            w.emit(": ")
            genType(n.type_ to!)
        else if n.init_expr != nil
            # No type annotation — if init is a literal, emit explicit type
            # to avoid comptime_int/comptime_float or *const [N:0]u8 issues in Zig.
            branch n.init_expr to!
                on Expr.int_lit
                    w.emit(": i64")
                on Expr.float_lit
                    w.emit(": f64")
                on Expr.string_lit
                    w.emit(": []const u8")
                else
                    pass
        w.emit(" = ")
        if n.init_expr != nil
            genExpr(n.init_expr to!)
        else
            w.emit("undefined")
        w.emit(";\n")

    def isStringBuilderCtor(e as Expr) as bool
        branch e
            on Expr.call as c
                if c.args.count() == 0
                    branch c.callee
                        on Expr.ident as id
                            return id.name == "StringBuilder"
                        else
                            pass
            else
                pass
        return false

    def isStrSetCtor(e as Expr) as bool
        branch e
            on Expr.call as c
                if c.args.count() == 0
                    branch c.callee
                        on Expr.ident as id
                            return id.name == "StrSet"
                        else
                            pass
            else
                pass
        return false

    def isGenericStdlibCtor(e as Expr) as bool
        # List(T)() or HashMap(K,V)() or StrSet()
        # Also bare List() / HashMap() where type is inferred from the variable annotation
        branch e
            on Expr.call as outer
                if outer.args.count() == 0
                    branch outer.callee
                        on Expr.call as inner
                            branch inner.callee
                                on Expr.ident as id
                                    return id.name == "List" or id.name == "HashMap"
                                else
                                    pass
                        on Expr.ident as id
                            return id.name == "StrSet" or id.name == "List" or id.name == "HashMap"
                        else
                            pass
            else
                pass
        return false

    def genGenericCtorExpr(e as Expr, type_hint as TypeRef?)
        branch e
            on Expr.call as outer
                branch outer.callee
                    on Expr.call as inner
                        branch inner.callee
                            on Expr.ident as id
                                if id.name == "List"
                                    w.emit("std.ArrayList(")
                                    if inner.args.count() > 0
                                        genTypeFromExpr(inner.args.at(0).value)
                                    else
                                        w.emit("anytype")
                                    w.emit("){}")
                                    return
                                if id.name == "HashMap"
                                    var key_str = inner.args.count() > 0 and isStringArgExpr(inner.args.at(0).value)
                                    if key_str
                                        w.emit("std.StringHashMap(")
                                        if inner.args.count() >= 2
                                            genTypeFromExpr(inner.args.at(1).value)
                                        else
                                            w.emit("anytype")
                                    else
                                        w.emit("std.AutoHashMap(")
                                        var fi = true
                                        for ta in inner.args
                                            if not fi
                                                w.emit(", ")
                                            fi = false
                                            genTypeFromExpr(ta.value)
                                    w.emit(").init(_allocator)")
                                    return
                            else
                                pass
                    on Expr.ident as id
                        if id.name == "StrSet"
                            w.emit("StrSet.init()")
                            return
                        # Bare List() or HashMap() — use type_hint from variable declaration
                        if id.name == "List"
                            w.emit("std.ArrayList(")
                            if type_hint != nil
                                branch type_hint to!
                                    on TypeRef.generic as gtr
                                        if gtr.args.count() > 0
                                            genType(gtr.args.at(0))
                                        else
                                            w.emit("anytype")
                                    else
                                        w.emit("anytype")
                            else
                                w.emit("anytype")
                            w.emit("){}")
                            return
                        if id.name == "HashMap"
                            if type_hint != nil
                                branch type_hint to!
                                    on TypeRef.generic as gtr
                                        var key_is_str = gtr.args.count() > 0 and isStringTypeRef(gtr.args.at(0))
                                        if key_is_str
                                            w.emit("std.StringHashMap(")
                                            if gtr.args.count() >= 2
                                                genType(gtr.args.at(1))
                                            else
                                                w.emit("anytype")
                                        else
                                            w.emit("std.AutoHashMap(")
                                            var fi = true
                                            for ta in gtr.args
                                                if not fi
                                                    w.emit(", ")
                                                fi = false
                                                genType(ta)
                                    else
                                        w.emit("std.AutoHashMap(anytype, anytype")
                            else
                                w.emit("std.AutoHashMap(anytype, anytype")
                            w.emit(").init(_allocator)")
                            return
                    else
                        pass
            else
                pass
        # Fallback: normal expr
        genExpr(e)

    def isStringArgExpr(e as Expr) as bool
        branch e
            on Expr.ident as id
                return id.name == "str" or id.name == "String"
            else
                pass
        return false

    def genTypeFromExpr(e as Expr)
        branch e
            on Expr.ident as id
                w.emit(zigPrimitive(id.name))
            on Expr.call as c
                branch c.callee
                    on Expr.ident as id
                        if id.name == "List"
                            w.emit("std.ArrayList(")
                            if c.args.count() > 0
                                genTypeFromExpr(c.args.at(0).value)
                            w.emit(")")
                            return
                        if id.name == "HashMap"
                            var ks = c.args.count() > 0 and isStringArgExpr(c.args.at(0).value)
                            if ks
                                w.emit("std.StringHashMap(")
                                if c.args.count() >= 2
                                    genTypeFromExpr(c.args.at(1).value)
                                else
                                    w.emit("anytype")
                            else
                                w.emit("std.AutoHashMap(")
                                var fi = true
                                for ta in c.args
                                    if not fi
                                        w.emit(", ")
                                    fi = false
                                    genTypeFromExpr(ta.value)
                            w.emit(")")
                            return
                        w.emit(id.name)
                    else
                        genExpr(e)
            else
                genExpr(e)

    # ── genAssign ─────────────────────────────────────────────────────────────

    def genAssign(a as StmtAssign)
        writeIndent()
        if a.op == AssignOp.slashslash_eq
            genExpr(a.target)
            w.emit(" = @divTrunc(")
            genExpr(a.target)
            w.emit(", ")
            genExpr(a.value)
            w.emit(");\n")
            return
        if a.op == AssignOp.starstar_eq
            genExpr(a.target)
            w.emit(" = std.math.pow(i64, ")
            genExpr(a.target)
            w.emit(", ")
            genExpr(a.value)
            w.emit(");\n")
            return
        # Detect bare collection ctor in field assignment: self.field = List()/HashMap()/StrSet()
        if a.op == AssignOp.assign
            var field_type = getAssignFieldType(a)
            if field_type != nil
                branch a.value
                    on Expr.call as vc
                        if vc.args.count() == 0
                            branch vc.callee
                                on Expr.ident as vid
                                    if vid.name == "List" or vid.name == "HashMap" or vid.name == "StrSet"
                                        genExpr(a.target)
                                        w.emit(" = ")
                                        genCallWithTypeHint(a.value, field_type to!)
                                        w.emit(";\n")
                                        return
                                else
                                    pass
                    else
                        pass
        genExpr(a.target)
        w.emit(" ")
        w.emit(assignOpStr(a.op))
        w.emit(" ")
        genExpr(a.value)
        w.emit(";\n")

    def getAssignFieldType(a as StmtAssign) as TypeRef?
        # If target is a member expression (self.field), extract field name and look up type
        var fname = getMemberFieldName(a.target)
        if fname != nil
            return lookupFieldType(fname to!)
        return nil

    def isStringField(e as Expr) as bool
        var fname = getMemberFieldName(e)
        if fname != nil
            var ftype = lookupFieldType(fname to!)
            if ftype != nil
                branch ftype to!
                    on TypeRef.named as nt
                        return nt.name == "str" or nt.name == "String"
                    else
                        pass
        return false

    def isListField(field_name as str) as bool
        var ftype = lookupFieldType(field_name)
        if ftype != nil
            branch ftype to!
                on TypeRef.generic as gtr
                    return gtr.name == "List"
                else
                    pass
        return false

    def isOwnerMethod(name as str) as bool
        for d in owner_members
            branch d
                on Decl.method as dm
                    if dm.name == name
                        return true
                else
                    pass
        return false

    def isOwnerSharedMethod(name as str) as bool
        for d in owner_members
            branch d
                on Decl.method as dm
                    if dm.name == name
                        return dm.mods.is_shared
                else
                    pass
        return false

    def isOwnerMethodThrows(name as str) as bool
        for d in owner_members
            branch d
                on Decl.method as dm
                    if dm.name == name
                        return dm.throws_
                else
                    pass
        return false

    def lookupFieldType(field_name as str) as TypeRef?
        for d in owner_members
            branch d
                on Decl.var_ as fld
                    if fld.name == field_name
                        return fld.type_
                else
                    pass
        return nil

    def genCallWithTypeHint(e as Expr, hint as TypeRef)
        branch e
            on Expr.call as c
                if c.args.count() == 0
                    branch c.callee
                        on Expr.ident as id
                            if id.name == "List"
                                w.emit("std.ArrayList(")
                                branch hint
                                    on TypeRef.generic as gtr
                                        if gtr.args.count() > 0
                                            genType(gtr.args.at(0))
                                        else
                                            w.emit("anytype")
                                    else
                                        w.emit("anytype")
                                w.emit("){}")
                                return
                            if id.name == "HashMap"
                                branch hint
                                    on TypeRef.generic as gtr
                                        var key_is_str = gtr.args.count() > 0 and isStringTypeRef(gtr.args.at(0))
                                        if key_is_str
                                            w.emit("std.StringHashMap(")
                                            if gtr.args.count() >= 2
                                                genType(gtr.args.at(1))
                                            else
                                                w.emit("anytype")
                                        else
                                            w.emit("std.AutoHashMap(")
                                            var fi = true
                                            for ta in gtr.args
                                                if not fi
                                                    w.emit(", ")
                                                fi = false
                                                genType(ta)
                                    else
                                        w.emit("std.AutoHashMap(anytype, anytype")
                                w.emit(").init(_allocator)")
                                return
                            if id.name == "StrSet"
                                w.emit("StrSet.init()")
                                return
                        else
                            pass
            else
                pass
        genExpr(e)

    # ── genReturn ─────────────────────────────────────────────────────────────

    def genReturn(r as StmtReturn)
        writeIndent()
        if r.value != nil
            w.emit("return ")
            genExpr(r.value to!)
            w.emit(";\n")
        else
            w.emit("return;\n")

    # ── genIf ─────────────────────────────────────────────────────────────────

    def genIf(si as StmtIf)
        writeIndent()
        w.emit("if (")
        genExpr(si.cond)
        w.emit(") {\n")
        var ig = indented()
        ig.genStmts(si.then_stmts)
        writeIndent()
        w.emit("}")
        for ei in si.else_ifs
            w.emit(" else if (")
            genExpr(ei.cond)
            w.emit(") {\n")
            ig.genStmts(ei.stmts)
            writeIndent()
            w.emit("}")
        if si.else_stmts != nil
            var es = si.else_stmts to!
            w.emit(" else {\n")
            ig.genStmts(es)
            writeIndent()
            w.emit("}")
        w.emit("\n")

    # ── genWhile ──────────────────────────────────────────────────────────────

    def genWhile(ww as StmtWhile)
        writeIndent()
        w.emit("while (")
        genExpr(ww.cond)
        w.emit(") {\n")
        var ig = indented()
        ig.genStmts(ww.stmts)
        writeIndent()
        w.emit("}\n")

    # ── genForIn ──────────────────────────────────────────────────────────────
    # Conservative: 1 var → List (.items), 2 vars → HashMap iterator.

    def genForIn(fi as StmtForIn)
        var ig = indented()
        if fi.vars.count() == 2
            var kname = fi.vars.at(0)
            var vname = fi.vars.at(1)
            writeIndent()
            w.emit("{\n")
            ig.writeIndent()
            ig.w.emit("var _it_")
            ig.w.emit(kname)
            ig.w.emit(" = ")
            genExpr(fi.iter)
            ig.w.emit(".iterator();\n")
            ig.writeIndent()
            ig.w.emit("while (_it_")
            ig.w.emit(kname)
            ig.w.emit(".next()) |_ent_")
            ig.w.emit(kname)
            ig.w.emit("| {\n")
            var iig = ig.indented()
            iig.writeIndent()
            iig.w.emit("const ")
            iig.w.emit(kname)
            iig.w.emit(" = _ent_")
            iig.w.emit(kname)
            iig.w.emit(".key_ptr.*;\n")
            iig.writeIndent()
            iig.w.emit("const ")
            iig.w.emit(vname)
            iig.w.emit(" = _ent_")
            iig.w.emit(kname)
            iig.w.emit(".value_ptr.*;\n")
            iig.genStmts(fi.stmts)
            ig.writeIndent()
            ig.w.emit("}\n")
            writeIndent()
            w.emit("}\n")
        else
            var vname = fi.vars.at(0)
            if isSplitIter(fi.iter)
                # for p in str.split(sep) → while loop with splitSequence iterator
                writeIndent()
                w.emit("{\n")
                ig.writeIndent()
                ig.w.emit("var _it_")
                ig.w.emit(vname)
                ig.w.emit(" = std.mem.splitSequence(u8, ")
                genSplitObject(fi.iter)
                ig.w.emit(", ")
                genSplitSep(fi.iter)
                ig.w.emit(");\n")
                ig.writeIndent()
                ig.w.emit("while (_it_")
                ig.w.emit(vname)
                ig.w.emit(".next()) |")
                ig.w.emit(vname)
                ig.w.emit("| {\n")
                var iig = ig.indented()
                iig.genStmts(fi.stmts)
                ig.writeIndent()
                ig.w.emit("}\n")
                writeIndent()
                w.emit("}\n")
            else if isCharsIter(fi.iter)
                # for c in str.chars() → Utf8View while loop yielding u21 codepoints
                writeIndent()
                w.emit("{\n")
                ig.writeIndent()
                ig.w.emit("var _cp_it_")
                ig.w.emit(vname)
                ig.w.emit(" = std.unicode.Utf8View.initUnchecked(")
                genCharsObject(fi.iter)
                ig.w.emit(").iterator();\n")
                ig.writeIndent()
                ig.w.emit("while (_cp_it_")
                ig.w.emit(vname)
                ig.w.emit(".nextCodepoint()) |")
                ig.w.emit(vname)
                ig.w.emit("| {\n")
                var iig = ig.indented()
                iig.genStmts(fi.stmts)
                ig.writeIndent()
                ig.w.emit("}\n")
                writeIndent()
                w.emit("}\n")
            else
                writeIndent()
                w.emit("for (")
                genExpr(fi.iter)
                w.emit(".items) |")
                w.emit(vname)
                w.emit("| {\n")
                # Track for-loop variable deref fields based on element type
                var iter_member = getMemberFieldName(fi.iter)
                if iter_member != nil
                    if iter_member to! == "entries"
                        # List(DictEntry): key and value are ^Expr
                        for_loop_deref.add(makeDottedKey(vname, "key"))
                        for_loop_deref.add(makeDottedKey(vname, "value"))
                # Mark this variable as a for-loop var to suppress stale branch deref
                for_loop_vars.add(vname)
                ig.genStmts(fi.stmts)
                writeIndent()
                w.emit("}\n")

    # Detect `str.split(sep)` as a for-in iterator (needs special while-loop emission)
    def isSplitIter(e as Expr) as bool
        branch e
            on Expr.call as c
                branch c.callee
                    on Expr.member as m
                        return m.member == "split"
                    else
                        pass
            else
                pass
        return false

    # Emit just the object part of a split call: str.split(sep) → str
    def genSplitObject(e as Expr)
        branch e
            on Expr.call as c
                branch c.callee
                    on Expr.member as m
                        genExpr(m.object)
                    else
                        pass
            else
                pass

    # Emit just the separator of a split call: str.split(sep) → sep
    def genSplitSep(e as Expr)
        branch e
            on Expr.call as c
                if c.args.count() > 0
                    genExpr(c.args.at(0).value)
                else
                    w.emit("\" \"")
            else
                w.emit("\" \"")

    # Detect `str.chars()` as a for-in iterator (needs Utf8View while-loop emission)
    def isCharsIter(e as Expr) as bool
        branch e
            on Expr.call as c
                branch c.callee
                    on Expr.member as m
                        return m.member == "chars"
                    else
                        pass
            else
                pass
        return false

    # Emit just the object of a chars() call: str.chars() → str
    def genCharsObject(e as Expr)
        branch e
            on Expr.call as c
                branch c.callee
                    on Expr.member as m
                        genExpr(m.object)
                    else
                        pass
            else
                pass

    # ── genForNum ─────────────────────────────────────────────────────────────

    def genForNum(fn_ as StmtForNum)
        var ig = indented()
        writeIndent()
        w.emit("{\n")
        ig.writeIndent()
        ig.w.emit("var ")
        ig.w.emit(fn_.var_)
        ig.w.emit(": i64 = ")
        genExpr(fn_.start)
        ig.w.emit(";\n")
        ig.writeIndent()
        ig.w.emit("const _stop_")
        ig.w.emit(fn_.var_)
        ig.w.emit(": i64 = ")
        genExpr(fn_.stop_)
        ig.w.emit(";\n")
        if fn_.step != nil
            ig.writeIndent()
            ig.w.emit("const _step_")
            ig.w.emit(fn_.var_)
            ig.w.emit(": i64 = ")
            ig.genExpr(fn_.step to!)
            ig.w.emit(";\n")
        ig.writeIndent()
        ig.w.emit("while (")
        ig.w.emit(fn_.var_)
        ig.w.emit(" < _stop_")
        ig.w.emit(fn_.var_)
        ig.w.emit(") : (")
        ig.w.emit(fn_.var_)
        if fn_.step != nil
            ig.w.emit(" += _step_")
            ig.w.emit(fn_.var_)
        else
            ig.w.emit(" += 1")
        ig.w.emit(") {\n")
        var iig = ig.indented()
        iig.genStmts(fn_.stmts)
        ig.writeIndent()
        ig.w.emit("}\n")
        writeIndent()
        w.emit("}\n")

    # ── genBranch ─────────────────────────────────────────────────────────────

    def genBranch(b as StmtBranch)
        if b.cases.count() == 0
            if b.else_ != nil
                genStmts(b.else_ to!)
            return
        var first_case = b.cases.at(0)
        if first_case.values.count() == 0
            genStmts(first_case.stmts)
            return
        # Detect dispatch kind: string literal values → if/else chain
        var fv = first_case.values.at(0)
        var is_str_branch = false
        branch fv
            on Expr.string_lit
                is_str_branch = true
            else
                pass
        if is_str_branch
            genBranchString(b)
        else
            genBranchTagged(b)

    def genBranchString(b as StmtBranch)
        var first = true
        for cas in b.cases
            if first
                writeIndent()
                w.emit("if (")
            else
                w.emit(" else if (")
            first = false
            var fi = true
            var vi = 0
            while vi < cas.values.count()
                if not fi
                    w.emit(" or ")
                fi = false
                w.emit("std.mem.eql(u8, ")
                genExpr(b.expr)
                w.emit(", ")
                genExpr(cas.values.at(vi))
                w.emit(")")
                vi += 1
            w.emit(") {\n")
            var ig = indented()
            ig.genStmts(cas.stmts)
            writeIndent()
            w.emit("}")
        if b.else_ != nil
            w.emit(" else {\n")
            var ig = indented()
            ig.genStmts(b.else_ to!)
            writeIndent()
            w.emit("}")
        w.emit("\n")

    def genBranchTagged(b as StmtBranch)
        # Determine if any case has a binding (union dispatch vs enum dispatch)
        var has_binding = false
        for cas in b.cases
            if cas.binding != nil
                has_binding = true
        writeIndent()
        w.emit("switch (")
        genExpr(b.expr)
        w.emit(") {\n")
        var ig = indented()
        for cas in b.cases
            ig.writeIndent()
            var fi = true
            var vi = 0
            while vi < cas.values.count()
                if not fi
                    ig.w.emit(", ")
                fi = false
                ig.genSwitchTag(cas.values.at(vi))
                vi += 1
            ig.w.emit(" => ")
            # Check if this variant has a boxed (^T) payload that needs deref
            var needs_deref = false
            if has_binding and cas.binding != nil and cas.values.count() > 0
                var vkey = getVariantKey(cas.values.at(0))
                if vkey != nil
                    needs_deref = boxed_variants.contains_(vkey to!)
            if has_binding
                if cas.binding != nil
                    if needs_deref
                        ig.w.emit("|_ptr_")
                        ig.w.emit(cas.binding to!)
                        ig.w.emit("| ")
                    else
                        ig.w.emit("|")
                        ig.w.emit(cas.binding to!)
                        ig.w.emit("| ")
                else
                    ig.w.emit("|_| ")
            ig.w.emit("{\n")
            var iig = ig.indented()
            if needs_deref
                iig.writeIndent()
                iig.w.emit("const ")
                iig.w.emit(cas.binding to!)
                iig.w.emit(" = _ptr_")
                iig.w.emit(cas.binding to!)
                iig.w.emit(".*;\n")
            # Track ^T fields for this binding to enable auto-deref
            if cas.binding != nil and cas.values.count() > 0
                var vkey2 = getVariantKey(cas.values.at(0))
                if vkey2 != nil
                    # Parse "Union.variant" into union_name and variant_name
                    var vk = vkey2 to!
                    # Extract union and variant names from dotted key
                    var vname = extractAfterDot(vk)
                    var uname as str = ""
                    if vname.len < vk.len
                        # Extract union name: everything before the dot
                        # Use extractAfterDot trick in reverse — split and take first
                        for upart in vk.split(".")
                            uname = upart
                            break
                    if uname.len > 0 and vname.len > 0
                        var stype = variantStructName(uname, vname)
                        if stype != nil
                            var st = stype to!
                            var st_dot = st + "."
                            # Find all non-optional ref_fields for this struct
                            var rf_items = ref_fields.items()
                            var rfi as int = 0
                            while rfi < rf_items.count()
                                var rf_entry as str = rf_items.at(rfi)
                                if rf_entry.startsWith(st_dot)
                                    var fname2 = extractAfterDot(rf_entry)
                                    iig.ptr_field_bindings.add(makeDottedKey(cas.binding to!, fname2))
                                rfi += 1
                            # Find all optional ref_fields for this struct
                            var orf_items = opt_ref_fields.items()
                            var orfi as int = 0
                            while orfi < orf_items.count()
                                var orf_entry as str = orf_items.at(orfi)
                                if orf_entry.startsWith(st_dot)
                                    var fname3 = extractAfterDot(orf_entry)
                                    iig.opt_ptr_field_bindings.add(makeDottedKey(cas.binding to!, fname3))
                                orfi += 1
            iig.genStmts(cas.stmts)
            ig.writeIndent()
            ig.w.emit("},\n")
        if b.else_ != nil
            ig.writeIndent()
            ig.w.emit("else => ")
            if has_binding
                ig.w.emit("|_| ")
            ig.w.emit("{\n")
            var iig = ig.indented()
            iig.genStmts(b.else_ to!)
            ig.writeIndent()
            ig.w.emit("},\n")
        writeIndent()
        w.emit("}\n")

    def genSwitchTag(e as Expr)
        branch e
            on Expr.member as m
                w.emit(".")
                w.emit(m.member)
            on Expr.ident as id
                w.emit(".")
                w.emit(id.name)
            on Expr.binary as b
                if b.op == BinaryOp.dotdot
                    # Switch range: c'0'..c'9' → '0'...'9' (three dots, no parens)
                    genExpr(b.left)
                    w.emit("...")
                    genExpr(b.right)
                else
                    genExpr(e)
            else
                genExpr(e)

    # ── genPrint ──────────────────────────────────────────────────────────────

    def genPrint(p as StmtPrint)
        if p.args.count() == 0
            if p.newline
                line("std.debug.print(\"\\n\", .{});")
            else
                line("// print (no args)")
            return
        writeIndent()
        w.emit("std.debug.print(\"")
        var ai = 0
        while ai < p.args.count()
            if ai > 0
                w.emit(" ")
            var arg = p.args.at(ai)
            if this.isStringBoth(arg, "print_fmt") or isStringLitArg(arg)
                w.emit("{s}")
            else
                w.emit("{}")
            ai += 1
        if p.newline
            w.emit("\\n")
        w.emit("\", .{")
        var ai2 = 0
        while ai2 < p.args.count()
            if ai2 > 0
                w.emit(", ")
            genExpr(p.args.at(ai2))
            ai2 += 1
        w.emit("});\n")

    def isStringLitArg(e as Expr) as bool
        branch e
            on Expr.string_lit
                return true
            on Expr.string_interp
                return true
            else
                pass
        return false

    # ── genRaise ──────────────────────────────────────────────────────────────

    def genRaise(r as StmtRaise)
        writeIndent()
        if r.message != nil and r.details != nil
            # Two-arg form: `raise "msg", details_expr`. Mirrors the three-path
            # dispatch in src/CodeGen.zig:genRaise — primitive / string / object.
            # Non-primitive details currently raise a selfhost compile error
            # (the object-details path is not ported yet); primitive-only paths
            # cover all current target corpus files (all int details).
            var det as Expr = r.details to!
            var det_t as Type_ = Type_.unknown_
            if this.infer_ctx != nil
                det_t = inferExpr(det, this.infer_ctx to!)
            var uid as int = w.nextUid()
            var is_prim as bool = false
            branch det_t
                on Type_.int_
                    is_prim = true
                on Type_.uint_
                    is_prim = true
                on Type_.float_
                    is_prim = true
                on Type_.bool_
                    is_prim = true
                on Type_.char_
                    is_prim = true
                on Type_.int_n as _
                    is_prim = true
                on Type_.uint_n as _
                    is_prim = true
                on Type_.float_n as _
                    is_prim = true
                else
                    pass
            var is_string_det as bool = false
            branch det_t
                on Type_.string_
                    is_string_det = true
                else
                    pass
            if is_prim
                var fmt as str = "{}"
                branch det_t
                    on Type_.float_
                        fmt = "{d}"
                    on Type_.float_n as _
                        fmt = "{d}"
                    on Type_.char_
                        fmt = "{u}"
                    else
                        pass
                w.emit("{ const _rdet_")
                w.emit(uid.toString())
                w.emit(": []const u8 = std.fmt.allocPrint(_allocator, \"")
                w.emit(fmt)
                w.emit("\", .{")
                genExpr(det)
                w.emit("}) catch @panic(\"OOM\");\n")
                writeIndent()
                w.emit("  const _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(" = _allocator.create([]const u8) catch @panic(\"OOM\");\n")
                writeIndent()
                w.emit("  _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(".* = _rdet_")
                w.emit(uid.toString())
                w.emit(";\n")
                writeIndent()
                w.emit("  const _rshim_")
                w.emit(uid.toString())
                w.emit(" = struct { fn call(p: *anyopaque) []const u8 {\n")
                writeIndent()
                w.emit("      return @as(*[]const u8, @alignCast(@ptrCast(p))).*;\n")
                writeIndent()
                w.emit("  } };\n")
                writeIndent()
                w.emit("  _error_ctx = .{ .message = ")
                genExpr(r.message to!)
                w.emit(", .details = .{ .ptr = @ptrCast(_rdet_ptr_")
                w.emit(uid.toString())
                w.emit("), .toString_fn = _rshim_")
                w.emit(uid.toString())
                w.emit(".call } };\n")
                writeIndent()
                w.emit("  ")
            else if is_string_det
                w.emit("{ const _rdet_")
                w.emit(uid.toString())
                w.emit(": []const u8 = ")
                genExpr(det)
                w.emit(";\n")
                writeIndent()
                w.emit("  const _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(" = _allocator.create([]const u8) catch @panic(\"OOM\");\n")
                writeIndent()
                w.emit("  _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(".* = _rdet_")
                w.emit(uid.toString())
                w.emit(";\n")
                writeIndent()
                w.emit("  const _rshim_")
                w.emit(uid.toString())
                w.emit(" = struct { fn call(p: *anyopaque) []const u8 {\n")
                writeIndent()
                w.emit("      return @as(*[]const u8, @alignCast(@ptrCast(p))).*;\n")
                writeIndent()
                w.emit("  } };\n")
                writeIndent()
                w.emit("  _error_ctx = .{ .message = ")
                genExpr(r.message to!)
                w.emit(", .details = .{ .ptr = @ptrCast(_rdet_ptr_")
                w.emit(uid.toString())
                w.emit("), .toString_fn = _rshim_")
                w.emit(uid.toString())
                w.emit(".call } };\n")
                writeIndent()
                w.emit("  ")
            else
                # Object-details path not ported in BUG-051. Emit a Zig compile
                # error so divergence is loud, not silent.
                w.emit("@compileError(\"selfhost BUG-051: 2-arg raise with non-primitive/string details not yet supported\");\n")
                writeIndent()
            if try_block_label != nil
                w.emit(try_err_var to!)
                w.emit(" = error.ZebraError; break :")
                w.emit(try_block_label to!)
                w.emit("; ")
            else
                w.emit("return error.ZebraError; ")
            w.emit("}\n")
        else if r.message != nil
            w.emit("{ _error_ctx = .{ .message = ")
            genExpr(r.message to!)
            w.emit(" }; ")
            if try_block_label != nil
                w.emit(try_err_var to!)
                w.emit(" = error.ZebraError; break :")
                w.emit(try_block_label to!)
                w.emit("; ")
            else
                w.emit("return error.ZebraError; ")
            w.emit("}\n")
        else
            if try_block_label != nil
                w.emit(try_err_var to!)
                w.emit(" = error.ZebraError; break :")
                w.emit(try_block_label to!)
                w.emit("; ")
            else
                w.emit("return error.ZebraError; ")
            w.emit("\n")

    # ── genTryCatch ───────────────────────────────────────────────────────────
    # Simplified: labeled block with catch clause.

    def genTryCatch(tc as StmtTryCatch)
        # Use labeled-block + error-variable pattern (matches trusted backend).
        # This avoids `try` inside a non-error-returning function.
        #
        #   var _try_err: ?anyerror = null;
        #   _try_blk: {
        #       // body — raises/throws calls use `break :_try_blk`
        #       break :_try_blk;   // normal exit
        #   }
        #   if (_try_err != null) {
        #       // catch body
        #   }
        writeIndent()
        w.emit("{\n")
        var ig = indented()
        ig.writeIndent()
        ig.w.emit("var _try_err: ?anyerror = null;\n")
        ig.writeIndent()
        ig.w.emit("_try_blk: {\n")
        var iig = ig.indented()
        var try_gen = iig.withTryLabel("_try_blk", "_try_err")
        try_gen.genStmts(tc.stmts)
        iig.writeIndent()
        iig.w.emit("break :_try_blk;\n")
        ig.writeIndent()
        ig.w.emit("}\n")
        ig.writeIndent()
        ig.w.emit("if (_try_err != null) {\n")
        for cl in tc.clauses
            var catch_gen = iig
            if cl.binding != nil
                var bname as str = cl.binding to!
                if bname.startsWith("_")
                    iig.writeIndent()
                    iig.w.emit("_ = _try_err;\n")
                else
                    catch_gen = iig.withCatchVar(bname)
            catch_gen.genStmts(cl.stmts)
        ig.writeIndent()
        ig.w.emit("}\n")
        writeIndent()
        w.emit("}\n")

    # ── genAssert ─────────────────────────────────────────────────────────────

    def genAssert(a as StmtAssert)
        writeIndent()
        if a.message != nil
            w.emit("if (!(")
            genExpr(a.cond)
            w.emit(")) @panic(")
            genExpr(a.message to!)
            w.emit(");\n")
        else
            w.emit("std.debug.assert(")
            genExpr(a.cond)
            w.emit(");\n")

    # ── genDefer ──────────────────────────────────────────────────────────────

    def genDefer(d as StmtDefer)
        writeIndent()
        if d.is_err
            w.emit("errdefer {\n")
        else
            w.emit("defer {\n")
        var ig = indented()
        ig.genStmt(d.stmt)
        writeIndent()
        w.emit("}\n")

    # ── genWith ───────────────────────────────────────────────────────────────

    def genWith(ww as StmtWith)
        writeIndent()
        w.emit("{ // with\n")
        var ig = indented()
        ig.genStmts(ww.stmts)
        writeIndent()
        w.emit("}\n")

    # ── genArenaScope ─────────────────────────────────────────────────────────

    def genArenaScope(a as StmtArenaScope)
        writeIndent()
        w.emit("{\n")
        var ig = indented()
        ig.line("var _arena = std.heap.ArenaAllocator.init(_allocator);")
        ig.line("defer _arena.deinit();")
        ig.line("const _saved_alloc = _allocator;")
        ig.line("_allocator = _arena.allocator();")
        ig.genStmts(a.stmts)
        ig.line("_allocator = _saved_alloc;")
        writeIndent()
        w.emit("}\n")

    # ── genGuard ──────────────────────────────────────────────────────────────

    def genGuard(g as StmtGuard)
        writeIndent()
        w.emit("if (!(")
        genExpr(g.cond)
        w.emit(")) {\n")
        var ig = indented()
        ig.genStmts(g.else_stmts)
        writeIndent()
        w.emit("}\n")

    # ── genDestruct ───────────────────────────────────────────────────────────

    def genDestruct(d as StmtDestruct)
        writeIndent()
        w.emit("const _zbr_dt = ")
        genExpr(d.init_expr)
        w.emit(";\n")
        var i = 0
        while i < d.names.count()
            writeIndent()
            w.emit("const ")
            w.emit(d.names.at(i))
            w.emit(" = _zbr_dt.@\"")
            w.emit(i.toString())
            w.emit("\";\n")
            i += 1

    # ── genExpr ───────────────────────────────────────────────────────────────

    def genExpr(e as Expr)
        branch e
            on Expr.int_lit as il
                w.emit(il.text)
            on Expr.float_lit as fl
                w.emit(fl.text)
            on Expr.bool_lit as bl
                if bl.value
                    w.emit("true")
                else
                    w.emit("false")
            on Expr.char_lit as cl
                # Raw text is e.g. c'A' or c'\'' — strip leading c, emit rest as-is
                if cl.text.len > 1 and cl.text.startsWith("c")
                    # cl.text[1..] — use split trick: split on first char, rejoin rest
                    var parts as List(str) = List(str)()
                    var first_skipped as bool = false
                    for p in cl.text.split("c")
                        if not first_skipped
                            first_skipped = true
                        else
                            parts.add(p)
                    # Rejoin with "c" in case the inner text contains c
                    var rest as str = ""
                    var pi as int = 0
                    while pi < parts.len
                        if pi > 0
                            rest = rest + "c"
                        rest = rest + parts.at(pi)
                        pi = pi + 1
                    w.emit(rest)
                else
                    w.emit("'")
                    w.emit(cl.text)
                    w.emit("'")
            on Expr.string_lit as sl
                genStringLit(sl)
            on Expr.string_interp as si
                genStringInterp(si)
            on Expr.nil_
                w.emit("null")
            on Expr.this_
                w.emit(self_name)
            on Expr.ident as id
                genIdent(id)
            on Expr.member as m
                # Catch-variable member: e.message → _zbr_error_msg()
                if catch_var != ""
                    branch m.object
                        on Expr.ident as mid
                            if mid.name == catch_var and m.member == "message"
                                w.emit("_zbr_error_msg()")
                                return
                        else
                            pass
                # List.len → @as(i64, @intCast(.items.len))
                # String.len → .len (no .items)
                if m.member == "len" or m.member == "count"
                    var fname = getMemberFieldName(m.object)
                    var is_list_obj = false
                    if fname != nil
                        is_list_obj = isListField(fname to!) or list_locals.contains_(fname to!) or isKnownListField(fname to!)
                    if is_list_obj
                        w.emit("@as(i64, @intCast(")
                        genExpr(m.object)
                        w.emit(".items.len))")
                        return
                genExpr(m.object)
                w.emit(".")
                w.emit(m.member)
                # Auto-deref ^T fields: if binding.field is a *T, emit .*
                var obj_name = getIdentName(m.object)
                if obj_name != nil
                    var bfkey = makeDottedKey(obj_name to!, m.member)
                    # For-loop variable deref takes priority over branch-binding deref
                    if for_loop_vars.contains_(obj_name to!)
                        # Variable is a for-loop var: only deref if in for_loop_deref
                        if for_loop_deref.contains_(bfkey)
                            w.emit(".*")
                    else if ptr_field_bindings.contains_(bfkey)
                        w.emit(".*")
            on Expr.call as c
                genCall(c)
            on Expr.index as ix
                genExpr(ix.object)
                w.emit("[@as(usize, @intCast(")
                genExpr(ix.index)
                w.emit("))]")
            on Expr.slice as sl2
                genExpr(sl2.object)
                w.emit("[")
                if sl2.start != nil
                    w.emit("@as(usize, @intCast(")
                    genExpr(sl2.start to!)
                    w.emit("))")
                w.emit("..")
                if sl2.stop_ != nil
                    w.emit("@as(usize, @intCast(")
                    genExpr(sl2.stop_ to!)
                    w.emit("))")
                w.emit("]")
            on Expr.binary as b
                genBinary(b)
            on Expr.unary as u
                genUnary(u)
            on Expr.cast as ca
                w.emit("@as(")
                genType(ca.target)
                w.emit(", ")
                genExpr(ca.expr)
                w.emit(")")
            on Expr.to_nilable as tn
                # Just emit the inner expression (optional wrapping is implicit)
                genExpr(tn.expr)
            on Expr.to_non_nil as tnn
                genExpr(tnn.expr)
                w.emit(".?")
                # If inner expr is a member access to a ^T? field, deref after unwrap
                branch tnn.expr
                    on Expr.member as tnn_m
                        var tnn_obj = getIdentName(tnn_m.object)
                        if tnn_obj != nil
                            var tnn_key = makeDottedKey(tnn_obj to!, tnn_m.member)
                            if opt_ptr_field_bindings.contains_(tnn_key)
                                w.emit(".*")
                    else
                        pass
            on Expr.is_nil as isn
                w.emit("(")
                genExpr(isn.expr)
                w.emit(" == null)")
            on Expr.orelse_ as or_
                genExpr(or_.expr)
                w.emit(" orelse ")
                genExpr(or_.fallback)
            on Expr.catch_ as ca2
                genExpr(ca2.expr)
                w.emit(" catch ")
                if ca2.err_var != nil
                    w.emit("|")
                    w.emit(ca2.err_var to!)
                    w.emit("| ")
                genExpr(ca2.fallback)
            on Expr.if_expr as ie
                w.emit("if (")
                genExpr(ie.cond)
                w.emit(") ")
                genExpr(ie.then_expr)
                w.emit(" else ")
                genExpr(ie.else_expr)
            on Expr.lambda as lam
                genLambda(lam)
            on Expr.list_lit as ll
                # List literal: build dynamically
                w.emit("blk: { var _ll = std.ArrayList(")
                if ll.elem_type != nil
                    genType(ll.elem_type to!)
                else
                    w.emit("anytype")
                w.emit("{}; ")
                var li = 0
                while li < ll.elems.count()
                    w.emit("_ll.append(_allocator, ")
                    genExpr(ll.elems.at(li))
                    w.emit(") catch @panic(\"OOM\"); ")
                    li += 1
                w.emit("break :blk _ll; }")
            on Expr.dict_lit as dl
                w.emit("blk: { var _dl = std.StringHashMap(anytype).init(_allocator); ")
                for en in dl.entries
                    w.emit("_dl.put(")
                    genExpr(en.key)
                    w.emit(", ")
                    genExpr(en.value)
                    w.emit(") catch @panic(\"OOM\"); ")
                w.emit("break :blk _dl; }")
            on Expr.array_lit as al
                w.emit(".{")
                var ali = 0
                while ali < al.elems.count()
                    if ali > 0
                        w.emit(", ")
                    genExpr(al.elems.at(ali))
                    ali += 1
                w.emit("}")
            on Expr.all_any as aa
                # all/any comprehension over List: simplified
                w.emit("blk: { var _aa_res = ")
                if aa.kind == AllAnyKind.all_
                    w.emit("true")
                else
                    w.emit("false")
                w.emit("; for (")
                genExpr(aa.iter)
                w.emit(".items) |")
                w.emit(aa.var_)
                w.emit("| { if (")
                if aa.kind == AllAnyKind.all_
                    w.emit("!(")
                    genExpr(aa.cond)
                    w.emit(")")
                else
                    genExpr(aa.cond)
                w.emit(") { _aa_res = ")
                if aa.kind == AllAnyKind.all_
                    w.emit("false")
                else
                    w.emit("true")
                w.emit("; break; } } break :blk _aa_res; }")
            on Expr.zig_lit as zl
                # astbuilder already stripped the zig"..." wrapper via stripZigQuotes.
                w.emit(zl.text)
            on Expr.try_ as tr
                if try_block_label != nil
                    # Inside try block: use catch-break pattern instead of try keyword
                    in_try_expr = true
                    genExpr(tr.expr)
                    in_try_expr = false
                    emitTryBlockCatch()
                else
                    w.emit("try ")
                    in_try_expr = true
                    genExpr(tr.expr)
                    in_try_expr = false
            on Expr.tuple_lit as tu
                w.emit(".{")
                var ti = 0
                while ti < tu.elems.count()
                    if ti > 0
                        w.emit(", ")
                    genExpr(tu.elems.at(ti))
                    ti += 1
                w.emit("}")
            on Expr.type_check as tc2
                # expr is TypeName → check _type_tag
                genExpr(tc2.expr)
                w.emit("._type_tag == _ttag_")
                w.emit(tc2.type_name)
            on Expr.except_ as ex
                # struct update: blk: { var _tmp = base; _tmp.f = v; break :blk _tmp; }
                w.emit("blk: { var _except_tmp = ")
                genExpr(ex.base)
                # BUG-031: emit `.*` only when the base is `this`.  In method
                # bodies `this` lowers to `self: *Owner` (for both class and
                # struct owners — genMethod always writes `self: *T`), so a
                # deref is needed to produce a value copy.  Value-typed
                # locals (`local except {...}`) must not be deref'd.
                var base_is_this = false
                branch ex.base
                    on Expr.this_
                        base_is_this = true
                    else
                        pass
                if base_is_this and in_method
                    w.emit(".*")
                w.emit("; ")
                for ef in ex.fields
                    w.emit("_except_tmp.")
                    w.emit(ef.name)
                    w.emit(" = ")
                    genExpr(ef.value)
                    w.emit("; ")
                w.emit("break :blk _except_tmp; }")

    # ── genIdent ──────────────────────────────────────────────────────────────

    def genIdent(id as ExprIdent)
        if capture_fields.contains_(id.name)
            w.emit("self.")
            w.emit(id.name)
            return
        if in_method and isFieldName(id.name)
            w.emit(self_name)
            w.emit(".")
        w.emit(id.name)

    def isFieldName(name as str) as bool
        # Not a field if it's a parameter name (params shadow fields)
        if param_names != nil
            if param_names to!.contains_(name)
                return false
        for d in owner_members
            branch d
                on Decl.var_ as fld
                    if fld.name == name
                        return true
                else
                    pass
        return false

    # ── genBinary ─────────────────────────────────────────────────────────────

    def genBinary(b as ExprBinary)
        if b.op == BinaryOp.add
            # Check if string concatenation — use _str_concat which is always safe (no try needed)
            if this.isStringBoth(b.left, "bin_add_l") or this.isStringBoth(b.right, "bin_add_r")
                w.emit("_str_concat(")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(", _allocator)")
                return
        if b.op == BinaryOp.mod
            w.emit("@mod(")
            genExpr(b.left)
            w.emit(", ")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.int_div or b.op == BinaryOp.div
            w.emit("@divTrunc(")
            genExpr(b.left)
            w.emit(", ")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.pow
            w.emit("std.math.pow(i64, ")
            genExpr(b.left)
            w.emit(", ")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.in_
            # "needle" in haystack → std.mem.indexOf != null
            w.emit("(std.mem.indexOf(u8, ")
            genExpr(b.right)
            w.emit(", ")
            genExpr(b.left)
            w.emit(") != null)")
            return
        if b.op == BinaryOp.dotdot
            w.emit("(")
            genExpr(b.left)
            w.emit("..")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.eq or b.op == BinaryOp.ne
            # String ==/!= must use std.mem.eql in Zig (slices can't use ==).
            # Skip when either side is nil (null comparison on optionals).
            var either_nil as bool = false
            branch b.left
                on Expr.nil_
                    either_nil = true
                else
                    pass
            if not either_nil
                branch b.right
                    on Expr.nil_
                        either_nil = true
                    else
                        pass
            if not either_nil and (this.isStringBoth(b.left, "bin_eq_l") or this.isStringBoth(b.right, "bin_eq_r"))
                if b.op == BinaryOp.ne
                    w.emit("!")
                w.emit("std.mem.eql(u8, ")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(")")
                return
        w.emit("(")
        genExpr(b.left)
        w.emit(" ")
        w.emit(binaryOpStr(b.op))
        w.emit(" ")
        genExpr(b.right)
        w.emit(")")

    def isStringExpr(e as Expr) as bool
        branch e
            on Expr.string_lit
                return true
            on Expr.string_interp
                return true
            on Expr.ident as id
                # Parameter or local typed as str
                if str_params.contains_(id.name)
                    return true
                # Owner field typed as str (bare ident = implicit self.field)
                var ftype = lookupFieldType(id.name)
                if ftype != nil
                    branch ftype to!
                        on TypeRef.named as nt
                            if nt.name == "str" or nt.name == "String"
                                return true
                        else
                            pass
            on Expr.member as m
                # Common string field names
                if m.member == "text" or m.member == "name" or m.member == "message" or m.member == "path" or m.member == "stdout" or m.member == "stderr" or m.member == "src" or m.member == "member"
                    return true
                # Check field type from owner declarations
                if isStringField(e)
                    return true
            on Expr.call as c
                # .toString() calls
                branch c.callee
                    on Expr.member as cm
                        if cm.member == "toString"
                            return true
                    else
                        pass
            on Expr.to_non_nil as tnn
                # x to! where x is a string? → still a string
                return isStringExpr(tnn.expr)
            on Expr.binary as bin
                # s + "x" or s + typeRefStr(...) — concat is a string if either side is
                if bin.op == BinaryOp.add
                    if isStringExpr(bin.left) or isStringExpr(bin.right)
                        return true
            else
                pass
        return false

    # ── genUnary ──────────────────────────────────────────────────────────────

    def genUnary(u as ExprUnary)
        if u.op == UnaryOp.neg
            w.emit("(-")
            genExpr(u.operand)
            w.emit(")")
            return
        if u.op == UnaryOp.not_
            w.emit("(!")
            genExpr(u.operand)
            w.emit(")")
            return
        if u.op == UnaryOp.bit_not
            w.emit("(~")
            genExpr(u.operand)
            w.emit(")")
            return
        genExpr(u.operand)

    # ── genStringLit ──────────────────────────────────────────────────────────

    def genStringLit(sl as ExprStringLit)
        if sl.kind == StringKind.zig_
            w.emit(sl.text)
            return
        if sl.kind == StringKind.raw
            w.emit("\"")
            w.emit(sl.text)
            w.emit("\"")
            return
        # plain / nosub: emit as Zig string literal
        w.emit("\"")
        w.emit(sl.text)
        w.emit("\"")

    # ── genStringInterp ───────────────────────────────────────────────────────

    def genStringInterp(si as ExprStringInterp)
        w.emit("(try std.fmt.allocPrint(_allocator, \"")
        for part in si.parts
            branch part
                on StringPart.literal as lit
                    w.emit(lit)
                on StringPart.format as fmt
                    w.emit("{")
                    w.emit(fmt)
                    w.emit("}")
                on StringPart.expr_
                    w.emit("{}")
        w.emit("\", .{")
        var first = true
        for part in si.parts
            branch part
                on StringPart.expr_ as e
                    if not first
                        w.emit(", ")
                    first = false
                    genExpr(e)
                else
                    pass
        w.emit("}))")

    # ── genCall ───────────────────────────────────────────────────────────────

    def genCall(c as ExprCall)
        # Closure vars: capture-lambda struct instances use .call()
        branch c.callee
            on Expr.ident as cid
                if closure_vars.contains_(cid.name)
                    w.emit(cid.name)
                    w.emit(".call(")
                    genArgList(c.args)
                    w.emit(")")
                    return
            else
                pass
        # Cross-module constructor: Module.ClassName(args) → ClassName.init(args)
        # When genUse unwraps same-named class, Module IS the class, so emit .init() directly
        if isCrossModuleCtorCall(c.callee)
            var cm_obj = getMemberObjectIdent(c.callee)
            var cm_mem = getMemberName(c.callee)
            # Cross-module ctor: Module.Class(args) → Module.Class.init(args) or Class.init(args)
            if cm_obj != nil and cm_mem != nil
                # If genUse unwrapped this module (class_names), emit ClassName.init()
                # Otherwise emit ModuleName.ClassName.init()
                if unwrapped_imports.contains_(cm_obj to!)
                    w.emit(cm_mem to!)
                else
                    w.emit(cm_obj to!)
                    w.emit(".")
                    w.emit(cm_mem to!)
                w.emit(".init(")
                var fc = true
                for a in c.args
                    if not fc
                        w.emit(", ")
                    fc = false
                    genExpr(a.value)
                w.emit(")")
                return
        # Union construction: UnionName.variant(value?) → UnionName{ .variant = value }
        # Enum construction: EnumName.variant() → .variant
        var callee_obj = getMemberObjectIdent(c.callee)
        var callee_mem = getMemberName(c.callee)
        if callee_obj != nil and callee_mem != nil
            var oname = callee_obj to!
            var mname2 = callee_mem to!
            if union_names.contains_(oname) or enum_names.contains_(oname)
                if enum_names.contains_(oname)
                    # Full form for enum: EnumName{ .variant = {} }
                    # Bare .variant fails with `var` in Zig
                    w.emit(oname)
                    w.emit("{ .")
                    w.emit(mname2)
                    w.emit(" = {} }")
                else
                    var variant_key = makeDottedKey(oname, mname2)
                    # Check if this variant has a ^T (pointer) payload
                    # For same-module unions: check boxed_variants set
                    # For cross-module unions: assume all payload variants are boxed
                    # (most AST unions use ^T for their payloads)
                    var is_boxed = boxed_variants.contains_(variant_key)
                    if not is_boxed and c.args.count() > 0
                        # Cross-module or unknown: assume boxed if it has a payload arg
                        if not union_names.contains_(oname)
                            is_boxed = true
                    w.emit(oname)
                    w.emit("{ .")
                    w.emit(mname2)
                    w.emit(" = ")
                    if c.args.count() > 0
                        if is_boxed
                            # Heap-allocate the value for ^T payloads
                            # Use a labeled block to avoid evaluating the arg twice
                            w.emit("blk_box: { const _bv = ")
                            genExpr(c.args.at(0).value)
                            w.emit("; const _bp = _allocator.create(@TypeOf(_bv)) catch @panic(\"OOM\"); _bp.* = _bv; break :blk_box _bp; }")
                        else
                            genExpr(c.args.at(0).value)
                    else
                        w.emit("{}")
                    w.emit(" }")
                return
        # Member call dispatch
        branch c.callee
            on Expr.member as m
                genMemberCall(m, c.args)
                return
            else
                pass
        # Generic stdlib ctor: List(T)(), HashMap(K,V)()
        branch c.callee
            on Expr.call as inner
                branch inner.callee
                    on Expr.ident as id
                        if id.name == "List" or id.name == "HashMap"
                            genGenericCtorCall(id.name, inner.args, c.args)
                            return
                    else
                        pass
            else
                pass
        # Bare stdlib ctor: HashMap() or StrSet() without type params
        branch c.callee
            on Expr.ident as id
                if id.name == "HashMap" and c.args.count() == 0
                    # Bare HashMap() — needs type_hint from context (not available here)
                    # Fall back to a reasonable default. If used in an assignment to a
                    # typed field, the Zig backend would have the type from the field decl.
                    w.emit("std.StringHashMap(i64).init(_allocator)")
                    return
                if id.name == "StrSet" and c.args.count() == 0
                    w.emit("StrSet.init()")
                    return
                if id.name == "StringBuilder" and c.args.count() == 0
                    w.emit("std.ArrayList(u8){}")
                    return
            else
                pass
        # Class/struct constructor: ClassName(args) → ClassName.init(args)
        branch c.callee
            on Expr.ident as id
                if class_names.contains_(id.name) or struct_names.contains_(id.name)
                    w.emit(id.name)
                    w.emit(".init(")
                    var first2 = true
                    var box_labels as List(str) = List(str)()
                    box_labels.add("_bx0")
                    box_labels.add("_bx1")
                    box_labels.add("_bx2")
                    box_labels.add("_bx3")
                    box_labels.add("_bx4")
                    box_labels.add("_bx5")
                    var box_idx as int = 0
                    var arg_idx as int = 0
                    for a in c.args
                        if not first2
                            w.emit(", ")
                        first2 = false
                        # Phase 17c: box when the ctor param is ^T (per ModuleTypes)
                        # and inferExpr says the arg produces a union-typed value.
                        # This replaced `shouldBoxCtorArg`, a name-pattern
                        # heuristic (idents ending in _expr, _stmt, etc., plus a
                        # short allow-list of known variable names). Walker is
                        # strictly more conservative: on a 175-.zbr corpus it
                        # boxed 16 additional sites the heuristic missed — all
                        # of them legitimately require `&local` / boxing since
                        # the receiving ctor param is `^Expr` and Zig does not
                        # implicitly take addresses of values.
                        var is_ref_param as bool = ctorParamAtIsRefTo(this.module_types, this.dep_types, id.name, arg_idx)
                        var should_box as bool = false
                        if is_ref_param and this.infer_ctx != nil
                            var wt17c as Type_ = inferExpr(a.value, this.infer_ctx to!)
                            should_box = this.isUnionType(wt17c)
                        if is_ref_param and should_box
                            # Box: heap-allocate for ^T parameter
                            var lbl = box_labels.at(box_idx)
                            w.emit(lbl)
                            w.emit(": { const _bv = ")
                            genExpr(a.value)
                            w.emit("; const _bp = _allocator.create(@TypeOf(_bv)) catch @panic(\"OOM\"); _bp.* = _bv; break :")
                            w.emit(lbl)
                            w.emit(" _bp; }")
                            box_idx = box_idx + 1
                        else
                            genExpr(a.value)
                        arg_idx = arg_idx + 1
                    w.emit(")")
                    return
            else
                pass
        # Bare method call: method(args) → self.method(args) or Owner.method(args)
        branch c.callee
            on Expr.ident as id
                if in_method and owner != "" and isOwnerMethod(id.name)
                    var callee_throws = isOwnerMethodThrows(id.name)
                    if callee_throws and current_method_throws and try_block_label == nil and not in_try_expr
                        w.emit("try ")
                    if isOwnerSharedMethod(id.name)
                        w.emit(owner)
                        w.emit(".")
                    else
                        w.emit("self.")
                    w.emit(id.name)
                    w.emit("(")
                    var first3 = true
                    for a in c.args
                        if not first3
                            w.emit(", ")
                        first3 = false
                        genExpr(a.value)
                    w.emit(")")
                    if callee_throws and try_block_label != nil
                        emitTryBlockCatch()
                    return
            else
                pass
        # Regular call: callee(args)
        genExpr(c.callee)
        w.emit("(")
        var first = true
        for a in c.args
            if not first
                w.emit(", ")
            first = false
            genExpr(a.value)
        w.emit(")")

    def genMemberCall(m as ExprMember, args as List(Arg))
        var mname = m.member
        # StringBuilder
        if mname == "append"
            genExpr(m.object)
            w.emit(".appendSlice(_allocator, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(") catch @panic(\"OOM\")")
            return
        if mname == "build"
            # Only apply for StringBuilder instances (lowercase idents like sb, _buf)
            # Skip for class/struct static calls like ASTBuilder.build()
            var build_obj = getMemberFieldName(m.object)
            var is_sb = build_obj != nil and not isUpperCase(build_obj to!)
            if is_sb
                if current_method_throws
                    w.emit("(try ")
                    genExpr(m.object)
                    w.emit(".toOwnedSlice(_allocator))")
                else
                    w.emit("(")
                    genExpr(m.object)
                    w.emit(".toOwnedSlice(_allocator) catch \"\")")
                return
        # List (not StrSet — StrSet.add is a real method)
        if mname == "add"
            var add_obj_name = getMemberFieldName(m.object)
            var is_strset = false
            if add_obj_name != nil
                var add_nm = add_obj_name to!
                is_strset = strset_locals.contains_(add_nm) or fieldIsStrSet(this.module_types, this.dep_types, add_nm)
            if not is_strset
                genExpr(m.object)
                w.emit(".append(_allocator, ")
                if args.count() > 0
                    genExpr(args.at(0).value)
                w.emit(") catch @panic(\"OOM\")")
                return
        if mname == "count"
            var cnt_obj_name = getMemberFieldName(m.object)
            var is_strset_cnt = false
            if cnt_obj_name != nil
                var cnt_nm = cnt_obj_name to!
                is_strset_cnt = strset_locals.contains_(cnt_nm) or fieldIsStrSet(this.module_types, this.dep_types, cnt_nm)
            if is_strset_cnt
                w.emit("@as(i64, @intCast(")
                genExpr(m.object)
                w.emit(".count()))")
            else
                w.emit("@as(i64, @intCast(")
                genExpr(m.object)
                w.emit(".items.len))")
            return
        if mname == "at"
            genExpr(m.object)
            w.emit(".items[@intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")]")
            return
        if mname == "remove"
            # BUG-032: discriminate HashMap vs List receiver. HashMap.remove(key)
            # returns bool; List has no .remove, only .orderedRemove(idx).
            var rem_obj_name = getMemberFieldName(m.object)
            var is_hashmap_rem = false
            if rem_obj_name != nil
                var rem_nm = rem_obj_name to!
                is_hashmap_rem = hashmap_locals.contains_(rem_nm) or fieldIsHashMap(this.module_types, this.dep_types, rem_nm)
            if is_hashmap_rem
                w.emit("_ = ")
                genExpr(m.object)
                w.emit(".remove(")
                if args.count() > 0
                    genExpr(args.at(0).value)
                w.emit(")")
            else
                w.emit("_ = ")
                genExpr(m.object)
                w.emit(".orderedRemove(@intCast(")
                if args.count() > 0
                    genExpr(args.at(0).value)
                w.emit("))")
            return
        if mname == "clear"
            genExpr(m.object)
            w.emit(".clearRetainingCapacity()")
            return
        if mname == "sort"
            w.emit("_zebra_sort_natural(@TypeOf(")
            genExpr(m.object)
            w.emit(".items[0]), ")
            genExpr(m.object)
            w.emit(".items)")
            return
        if mname == "sortBy"
            if args.count() > 0
                w.emit("_zebra_sort_by(@TypeOf(")
                genExpr(m.object)
                w.emit(".items[0]), ")
                genExpr(args.at(0).value)
                w.emit(", ")
                genExpr(m.object)
                w.emit(".items)")
            return
        # StrSet
        if mname == "contains_"
            genExpr(m.object)
            # StrSet.contains_ stays as contains_ (user-defined method)
            # Other types: drop the underscore → .contains()
            var cont_obj_name = getMemberFieldName(m.object)
            var is_strset_obj = false
            if cont_obj_name != nil
                var cont_nm = cont_obj_name to!
                is_strset_obj = strset_locals.contains_(cont_nm) or fieldIsStrSet(this.module_types, this.dep_types, cont_nm)
            if is_strset_obj
                w.emit(".contains_(")
            else
                w.emit(".contains(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")")
            return
        # HashMap
        if mname == "set"
            genExpr(m.object)
            w.emit(".put(")
            var fi = true
            for a in args
                if not fi
                    w.emit(", ")
                fi = false
                genExpr(a.value)
            w.emit(") catch @panic(\"OOM\")")
            return
        if mname == "get"
            genExpr(m.object)
            w.emit(".get(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")")
            return
        if mname == "contains" and not this.isStringBoth(m.object, "contains_recv")
            genExpr(m.object)
            w.emit(".contains(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")")
            return
        if mname == "fetch"
            # HashMap.fetch(key) → (obj.get(key) orelse undefined)
            w.emit("(")
            genExpr(m.object)
            w.emit(".get(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(") orelse undefined)")
            return
        if mname == "put"
            # HashMap.put(key, value) — allocator stored internally
            genExpr(m.object)
            w.emit(".put(")
            var fi = true
            for a in args
                if not fi
                    w.emit(", ")
                fi = false
                genExpr(a.value)
            w.emit(") catch @panic(\"OOM\")")
            return
        if mname == "entries"
            genExpr(m.object)
            return
        if mname == "keys"
            # HashMap.keys() → collect keys into ArrayList
            w.emit("(blk_hk: { var _hk = std.ArrayList(@TypeOf(")
            genExpr(m.object)
            w.emit(".keys()[0])){}; for (")
            genExpr(m.object)
            w.emit(".keys()) |_k| _hk.append(_allocator, _k) catch unreachable; break :blk_hk _hk; })")
            return
        if mname == "values"
            # HashMap.values() → collect values into ArrayList
            w.emit("(blk_hv: { var _hv = std.ArrayList(@TypeOf(")
            genExpr(m.object)
            w.emit(".values()[0])){}; for (")
            genExpr(m.object)
            w.emit(".values()) |_v| _hv.append(_allocator, _v) catch unreachable; break :blk_hv _hv; })")
            return
        # Result methods
        if mname == "isOk" or mname == "isErr" or mname == "unwrap" or mname == "unwrapOr" or mname == "okValue" or mname == "errValue" or mname == "map" or mname == "flatMap"
            genExpr(m.object)
            w.emit(".")
            w.emit(mname)
            w.emit("(")
            var fi_r = true
            for a in args
                if not fi_r
                    w.emit(", ")
                fi_r = false
                genExpr(a.value)
            w.emit(")")
            return
        # String methods
        if mname == "concat"
            w.emit("(std.mem.concat(_allocator, u8, &.{ ")
            genExpr(m.object)
            for a in args
                w.emit(", ")
                genExpr(a.value)
            w.emit(" }) catch unreachable)")
            return
        if mname == "startsWith"
            w.emit("std.mem.startsWith(u8, ")
            genExpr(m.object)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")")
            return
        if mname == "endsWith"
            w.emit("std.mem.endsWith(u8, ")
            genExpr(m.object)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")")
            return
        if mname == "indexOf"
            w.emit("blk: { const _idx = std.mem.indexOf(u8, ")
            genExpr(m.object)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit("); break :blk if (_idx) |_i| @as(i64, @intCast(_i)) else null; }")
            return
        if mname == "split"
            # Returns a splitSequence iterator (use in for-in via isSplitIter/genForIn)
            w.emit("std.mem.splitSequence(u8, ")
            genExpr(m.object)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\" \"")
            w.emit(")")
            return
        if mname == "join"
            w.emit("(try _zbr_list_join(_allocator, ")
            genExpr(m.object)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit("))")
            return
        if mname == "codePointCount"
            w.emit("@as(i64, @intCast(std.unicode.utf8CountCodepoints(")
            genExpr(m.object)
            w.emit(") catch 0))")
            return
        if mname == "trim"
            w.emit("std.mem.trim(u8, ")
            genExpr(m.object)
            w.emit(", \" \\t\\n\\r\")")
            return
        if mname == "upper"
            w.emit("(try _zbr_str_upper(_allocator, ")
            genExpr(m.object)
            w.emit("))")
            return
        if mname == "lower"
            w.emit("(try _zbr_str_lower(_allocator, ")
            genExpr(m.object)
            w.emit("))")
            return
        if mname == "toString"
            # For u21 codepoints (from chars() loop) use "{u}" format.
            # This also works for printing integers as Unicode scalars.
            w.emit("(blk: { var _cpbuf: [4]u8 = undefined; const _cplen = std.unicode.utf8Encode(@intCast(")
            genExpr(m.object)
            w.emit("), &_cpbuf) catch 1; break :blk _allocator.dupe(u8, _cpbuf[0.._cplen]) catch @panic(\"OOM\"); })")
            return
        if mname == "toFloat"
            w.emit("@as(f64, @floatFromInt(")
            genExpr(m.object)
            w.emit("))")
            return
        if mname == "toInt"
            w.emit("@as(i64, @intFromFloat(")
            genExpr(m.object)
            w.emit("))")
            return
        # Math / File / sys namespace dispatch
        branch m.object
            on Expr.ident as id
                if id.name == "Math"
                    genMathCall(mname, args)
                    return
                if id.name == "File"
                    genFileCall(mname, args)
                    return
                if id.name == "sys"
                    genSysCall(mname, args)
                    return
                if id.name == "Arg"
                    genArgCall(mname, args)
                    return
                if id.name == "Json"
                    genJsonCall(mname, args)
                    return
                if id.name == "Http"
                    genHttpCall(mname, args)
                    return
                if id.name == "HttpResponse"
                    genHttpResponseFactory(mname, args)
                    return
                if id.name == "Regex"
                    genRegexCall(mname, args)
                    return
                if id.name == "DateTime"
                    genDateTimeCall(mname, args)
                    return
                if id.name == "Hash"
                    genHashCall(mname, args)
                    return
                if id.name == "Random"
                    genRandomCall(mname, args)
                    return
                if id.name == "Terminal"
                    genTerminalCall(mname, args)
                    return
                if id.name == "Log"
                    genLogCall(mname, args)
                    return
                if id.name == "Csv"
                    genCsvCall(mname, args)
                    return
                if id.name == "Timer"
                    genTimerCall(mname, args)
                    return
                if id.name == "Uri"
                    genUriCall(mname, args)
                    return
                if id.name == "Compress"
                    genCompressCall(mname, args)
                    return
                if id.name == "Mime"
                    genMimeCall(mname, args)
                    return
                if id.name == "Tcp"
                    genTcpCall(mname, args)
                    return
                if id.name == "Udp"
                    genUdpCall(mname, args)
                    return
                if id.name == "Net"
                    genNetCall(mname, args)
                    return
                if id.name == "Gui"
                    genGuiCall(mname, args)
                    return
                if id.name == "Shell"
                    genShellCall(mname, args)
                    return
                if id.name == "Dir"
                    genDirCall(mname, args)
                    return
                if id.name == "Path"
                    genPathCall(mname, args)
                    return
                if id.name == "Reflect"
                    genReflectCall(mname, args)
                    return
            else
                pass
        # String methods ([]const u8 has no methods in Zig — use std.mem functions)
        if mname == "contains" and args.count() > 0
            # str.contains(substr) → (std.mem.indexOf(u8, str, substr) != null)
            w.emit("(std.mem.indexOf(u8, ")
            genExpr(m.object)
            w.emit(", ")
            genExpr(args.at(0).value)
            w.emit(") != null)")
            return
        if mname == "startsWith" and args.count() > 0
            w.emit("(std.mem.startsWith(u8, ")
            genExpr(m.object)
            w.emit(", ")
            genExpr(args.at(0).value)
            w.emit("))")
            return
        if mname == "endsWith" and args.count() > 0
            w.emit("(std.mem.endsWith(u8, ")
            genExpr(m.object)
            w.emit(", ")
            genExpr(args.at(0).value)
            w.emit("))")
            return
        if mname == "split" and args.count() > 0
            # Return an ArrayList from split
            w.emit("blk_split: { var _sp = std.ArrayList([]const u8){}; var _it = std.mem.splitSequence(u8, ")
            genExpr(m.object)
            w.emit(", ")
            genExpr(args.at(0).value)
            w.emit("); while (_it.next()) |_p| { _sp.append(_allocator, _p) catch @panic(\"OOM\"); } break :blk_split _sp; }")
            return
        # replace / replaceAll
        if mname == "replace" or mname == "replaceAll"
            w.emit("(std.mem.replaceOwned(u8, _allocator, ")
            genExpr(m.object)
            for a in args
                w.emit(", ")
                genExpr(a.value)
            w.emit(") catch unreachable)")
            return
        if mname == "repeat" and args.count() > 0
            w.emit("(blk_rep: { var _rep = std.ArrayList([]const u8){}; defer _rep.deinit(_allocator); var _ri: i64 = 0; while (_ri < ")
            genExpr(args.at(0).value)
            w.emit(") : (_ri += 1) _rep.append(_allocator, ")
            genExpr(m.object)
            w.emit(") catch unreachable; break :blk_rep std.mem.concat(_allocator, u8, _rep.items) catch unreachable; })")
            return
        if mname == "trimLeft"
            w.emit("std.mem.trimLeft(u8, ")
            genExpr(m.object)
            w.emit(", &std.ascii.whitespace)")
            return
        if mname == "trimRight"
            w.emit("std.mem.trimRight(u8, ")
            genExpr(m.object)
            w.emit(", &std.ascii.whitespace)")
            return
        if mname == "padLeft"
            w.emit("_pad_left(")
            genExpr(m.object)
            w.emit(", @as(usize, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")), ")
            if args.count() > 1
                genExpr(args.at(1).value)
            else
                w.emit("' '")
            w.emit(", _allocator)")
            return
        if mname == "padRight"
            w.emit("_pad_right(")
            genExpr(m.object)
            w.emit(", @as(usize, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")), ")
            if args.count() > 1
                genExpr(args.at(1).value)
            else
                w.emit("' '")
            w.emit(", _allocator)")
            return
        if mname == "center"
            w.emit("_pad_center(")
            genExpr(m.object)
            w.emit(", @as(usize, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")), ")
            if args.count() > 1
                genExpr(args.at(1).value)
            else
                w.emit("' '")
            w.emit(", _allocator)")
            return
        if mname == "isEmpty"
            w.emit("(")
            genExpr(m.object)
            w.emit(".len == 0)")
            return
        if mname == "lines"
            w.emit("std.mem.splitScalar(u8, ")
            genExpr(m.object)
            w.emit(", '\\n')")
            return
        if mname == "reverse"
            w.emit("(blk_rev: { const _rbuf = _allocator.alloc(u8, ")
            genExpr(m.object)
            w.emit(".len) catch @panic(\"OOM\"); @memcpy(_rbuf, ")
            genExpr(m.object)
            w.emit("); std.mem.reverse(u8, _rbuf); break :blk_rev _rbuf; })")
            return
        if mname == "charAt" and args.count() > 0
            genExpr(m.object)
            w.emit("[@intCast(")
            genExpr(args.at(0).value)
            w.emit(")]")
            return
        if mname == "substring" and args.count() >= 2
            genExpr(m.object)
            w.emit("[@intCast(")
            genExpr(args.at(0).value)
            w.emit(")..@intCast(")
            genExpr(args.at(1).value)
            w.emit(")]")
            return
        if mname == "lastIndexOf" and args.count() > 0
            w.emit("(if (std.mem.lastIndexOf(u8, ")
            genExpr(m.object)
            w.emit(", ")
            genExpr(args.at(0).value)
            w.emit(")) |_li| @as(i64, @intCast(_li)) else @as(i64, -1))")
            return
        if mname == "isAlpha"
            w.emit("(blk_ia: { if (")
            genExpr(m.object)
            w.emit(".len == 0) break :blk_ia false; for (")
            genExpr(m.object)
            w.emit(") |_ac| { if (!std.ascii.isAlphabetic(_ac)) break :blk_ia false; } break :blk_ia true; })")
            return
        if mname == "isNumeric"
            w.emit("(blk_in: { if (")
            genExpr(m.object)
            w.emit(".len == 0) break :blk_in false; for (")
            genExpr(m.object)
            w.emit(") |_nc| { if (!std.ascii.isDigit(_nc)) break :blk_in false; } break :blk_in true; })")
            return
        if mname == "isValidUtf8"
            w.emit("std.unicode.utf8ValidateSlice(")
            genExpr(m.object)
            w.emit(")")
            return
        if mname == "toHex"
            w.emit("(blk_hex: { const _hx_s = ")
            genExpr(m.object)
            w.emit("; const _hx_buf = _allocator.alloc(u8, _hx_s.len * 2) catch @panic(\"OOM\"); ")
            w.emit("for (_hx_s, 0..) |_hx_b, _hx_i| { _ = std.fmt.bufPrint(_hx_buf[_hx_i * 2 .. _hx_i * 2 + 2], \"{x:0>2}\", .{_hx_b}) catch unreachable; } ")
            w.emit("break :blk_hex _hx_buf; })")
            return
        if mname == "fromHex"
            w.emit("(blk_fhx: { if (")
            genExpr(m.object)
            w.emit(".len % 2 != 0) break :blk_fhx @as(?[]const u8, null); ")
            w.emit("const _hbuf = _allocator.alloc(u8, ")
            genExpr(m.object)
            w.emit(".len / 2) catch @panic(\"OOM\"); ")
            w.emit("std.fmt.hexToBytes(_hbuf, ")
            genExpr(m.object)
            w.emit(") catch { _allocator.free(_hbuf); break :blk_fhx @as(?[]const u8, null); }; ")
            w.emit("break :blk_fhx @as(?[]const u8, _hbuf); })")
            return
        if mname == "format"
            w.emit("(std.fmt.allocPrint(_allocator, ")
            genExpr(m.object)
            for a in args
                w.emit(", .{ ")
                genExpr(a.value)
                w.emit(" }")
            w.emit(") catch unreachable)")
            return
        # Default: object.method(args)
        # Auto-try: if calling a throws method on self, emit try prefix
        var callee_throws2 = false
        branch m.object
            on Expr.this_
                if isOwnerMethodThrows(mname)
                    callee_throws2 = true
            else
                pass
        if callee_throws2 and current_method_throws and try_block_label == nil and not in_try_expr
            w.emit("try ")
        genExpr(m.object)
        w.emit(".")
        w.emit(mname)
        w.emit("(")
        var first = true
        for a in args
            if not first
                w.emit(", ")
            first = false
            genExpr(a.value)
        w.emit(")")
        if callee_throws2 and try_block_label != nil
            emitTryBlockCatch()

    def genMathCall(mname as str, args as List(Arg))
        if mname == "sqrt"
            w.emit("std.math.sqrt(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "abs"
            w.emit("@abs(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "floor"
            w.emit("@floor(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "ceil"
            w.emit("@ceil(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "max"
            w.emit("@max(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "min"
            w.emit("@min(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "pow"
            w.emit("std.math.pow(f64, ")
            genArgList(args)
            w.emit(")")
            return
        if mname == "PI"
            w.emit("std.math.pi")
            return
        if mname == "E"
            w.emit("std.math.e")
            return
        # Default: std.math.name(args)
        w.emit("std.math.")
        w.emit(mname)
        w.emit("(")
        genArgList(args)
        w.emit(")")

    def genArgList(args as List(Arg))
        var first = true
        for a in args
            if not first
                w.emit(", ")
            first = false
            genExpr(a.value)

    # ── genLambda ────────────────────────────────────────────────────────────
    # Emit anonymous struct with a call method.
    # Without capture:   struct { fn call(params) RetT { body } }.call
    def genLambda(lam as ExprLambda)
        var has_capture = lam.captures.count() > 0
        if has_capture
            w.emit("(")
        w.emit("struct {")
        # Emit capture fields
        if has_capture
            w.emit("\n")
            var fg = indented()
            for cv in lam.captures
                fg.writeIndent()
                fg.w.emit(cv.name)
                fg.w.emit(": ")
                if cv.type_ != nil
                    fg.genType(cv.type_ to!)
                else if cv.init_expr != nil
                    fg.w.emit("@TypeOf(")
                    fg.w.emit(cv.name)
                    fg.w.emit(")")
                else
                    fg.w.emit("anytype")
                fg.w.emit(",\n")
            writeIndent()
        # call method
        w.emit(" fn call(")
        var first = true
        if has_capture
            w.emit("self: @This()")
            first = false
        for p in lam.params
            if not first
                w.emit(", ")
            first = false
            w.emit(p.name)
            w.emit(": ")
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")
        w.emit(") ")
        # Return type
        if lam.return_type != nil
            genType(lam.return_type to!)
        else
            branch lam.body_
                on LambdaBody.expr_ as ex
                    w.emit("@TypeOf(")
                    genExpr(ex)
                    w.emit(")")
                on LambdaBody.stmts
                    w.emit("void")
        w.emit(" {")
        # Build capture context for body
        var cf = StrSet()
        for cv in lam.captures
            cf.add(cv.name)
        var mg = asMethod()
        var lg = mg.withCaptureFields(cf)
        branch lam.body_
            on LambdaBody.expr_ as ex
                w.emit(" return ")
                lg.genExpr(ex)
                w.emit(";")
            on LambdaBody.stmts as ss
                w.emit("\n")
                var ig = lg.indented()
                ig.genStmts(ss)
                lg.writeIndent()
        w.emit(" } }")
        # Capture initializer or .call suffix
        if has_capture
            w.emit("{ ")
            for cv in lam.captures
                w.emit(".")
                w.emit(cv.name)
                w.emit(" = ")
                if cv.init_expr != nil
                    w.emit(cv.name)
                else
                    w.emit("undefined")
                w.emit(", ")
            w.emit("})")
        else
            w.emit(".call")

    # ── genFileCall ───────────────────────────────────────────────────────────
    # Emit File.* static calls as inline Zig expressions (no allocation needed).

    def genFileCall(mname as str, args as List(Arg))
        if mname == "read"
            w.emit("(std.fs.cwd().readFileAlloc(_allocator, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", std.math.maxInt(usize)) catch @panic(\"File.read error\"))")
            return
        if mname == "write"
            w.emit("(std.fs.cwd().writeFile(.{ .sub_path = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .data = ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(" }) catch @panic(\"File.write error\"))")
            return
        if mname == "exists"
            w.emit("(blk_fex: { std.fs.cwd().access(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_fex false; break :blk_fex true; })")
            return
        if mname == "readLines"
            w.emit("(blk_frl: {\n")
            writeIndent()
            w.emit("    const _fl_content = std.fs.cwd().readFileAlloc(_allocator, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", std.math.maxInt(usize)) catch @panic(\"File.readLines error\");\n")
            writeIndent()
            w.emit("    var _fl_list = std.ArrayList([]const u8){};\n")
            writeIndent()
            w.emit("    var _fl_it = std.mem.splitScalar(u8, _fl_content, '\\n');\n")
            writeIndent()
            w.emit("    while (_fl_it.next()) |_fl_line| { _fl_list.append(_allocator, _fl_line) catch unreachable; }\n")
            writeIndent()
            w.emit("    break :blk_frl _fl_list;\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "append"
            w.emit("(blk_fa: {\n")
            writeIndent()
            w.emit("    const _fa_path = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(";\n")
            writeIndent()
            w.emit("    const _fa_file = std.fs.cwd().openFile(_fa_path, .{ .mode = .read_write })")
            w.emit(" catch std.fs.cwd().createFile(_fa_path, .{}) catch @panic(\"File.append error\");\n")
            writeIndent()
            w.emit("    defer _fa_file.close();\n")
            writeIndent()
            w.emit("    _ = _fa_file.seekFromEnd(0) catch @panic(\"File.append seek error\");\n")
            writeIndent()
            w.emit("    _fa_file.writeAll(")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"File.append write error\");\n")
            writeIndent()
            w.emit("    break :blk_fa {};\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "delete"
            w.emit("(std.fs.cwd().deleteFile(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"File.delete error\"))")
            return
        # Fallback: unknown File method
        w.emit("@compileError(\"selfhost: unknown File.")
        w.emit(mname)
        w.emit("\")")

    # ── genSysCall ────────────────────────────────────────────────────────────
    # Emit sys.* static calls.

    def genSysCall(mname as str, args as List(Arg))
        if mname == "errln"
            w.emit("std.debug.print(\"{s}\\n\", .{")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("})")
            return
        if mname == "err"
            w.emit("std.debug.print(\"{s}\", .{")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("})")
            return
        if mname == "exit"
            w.emit("std.process.exit(@intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("))")
            return
        if mname == "run"
            w.emit("_sys_run(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "args"
            w.emit("(blk_sa: {\n")
            writeIndent()
            w.emit("    const _sa_raw = std.process.argsAlloc(_allocator) catch @panic(\"sys.args OOM\");\n")
            writeIndent()
            w.emit("    var _sa_list = std.ArrayList([]const u8){};\n")
            writeIndent()
            w.emit("    for (_sa_raw) |_sa_arg| _sa_list.append(_allocator, _sa_arg) catch unreachable;\n")
            writeIndent()
            w.emit("    break :blk_sa _sa_list;\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "getenv"
            w.emit("std.posix.getenv(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        # Fallback: unknown sys method
        w.emit("@compileError(\"selfhost: unknown sys.")
        w.emit(mname)
        w.emit("\")")

    def genArgCall(mname as str, args as List(Arg))
        if mname == "parse"
            w.emit("_arg_parse()")
            return
        # Fallback: unknown Arg method
        w.emit("@compileError(\"selfhost: unknown Arg.")
        w.emit(mname)
        w.emit("\")")

    # ── genJsonCall ──────────────────────────────────────────────────────────
    def genJsonCall(mname as str, args as List(Arg))
        if mname == "parse"
            w.emit("_json_parse(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"{}\"")
            w.emit(")")
            return
        if mname == "stringify"
            w.emit("_json_stringify(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("_json_object()")
            w.emit(")")
            return
        if mname == "object"
            w.emit("_json_object()")
            return
        if mname == "array"
            w.emit("_json_array()")
            return
        w.emit("@compileError(\"selfhost: unknown Json.")
        w.emit(mname)
        w.emit("\")")

    # ── genHttpCall ──────────────────────────────────────────────────────────
    def genHttpCall(mname as str, args as List(Arg))
        if mname == "get"
            w.emit("_http_get(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "post"
            w.emit("_http_post(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "serve"
            w.emit("_http_serve(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("8080")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "json"
            w.emit("_http_json_get(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "postJson"
            w.emit("_http_json_post(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown Http.")
        w.emit(mname)
        w.emit("\")")

    # ── genHttpResponseFactory ───────────────────────────────────────────────
    def genHttpResponseFactory(mname as str, args as List(Arg))
        if mname == "ok"
            w.emit("HttpResponse{ .status = 200, .text = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(" }")
            return
        if mname == "notFound"
            w.emit("HttpResponse{ .status = 404, .text = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"Not Found\"")
            w.emit(" }")
            return
        if mname == "err"
            w.emit("HttpResponse{ .status = 500, .text = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"Internal Server Error\"")
            w.emit(" }")
            return
        if mname == "new"
            w.emit("HttpResponse{ .status = @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("200")
            w.emit("), .text = ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(" }")
            return
        w.emit("@compileError(\"selfhost: unknown HttpResponse.")
        w.emit(mname)
        w.emit("\")")

    # ── genRegexCall ─────────────────────────────────────────────────────────
    def genRegexCall(mname as str, args as List(Arg))
        if mname == "compile"
            w.emit("_regex_compile(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown Regex.")
        w.emit(mname)
        w.emit("\")")

    # ── genDateTimeCall ──────────────────────────────────────────────────────
    def genDateTimeCall(mname as str, args as List(Arg))
        if mname == "now"
            w.emit("_dt_now()")
            return
        if mname == "fromEpoch"
            w.emit("_DateTime{ .epoch_ms = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(" }")
            return
        if mname == "of"
            w.emit("_dt_from_gregorian(")
            genArgList(args)
            # Fill missing hour/minute/second with 0
            var provided = args.count()
            if provided < 4
                w.emit(", 0")
            if provided < 5
                w.emit(", 0")
            if provided < 6
                w.emit(", 0")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown DateTime.")
        w.emit(mname)
        w.emit("\")")

    # ── genHashCall ──────────────────────────────────────────────────────────
    def genHashCall(mname as str, args as List(Arg))
        if mname == "sha256"
            w.emit("_hash_sha256(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "sha512"
            w.emit("_hash_sha512(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "md5"
            w.emit("_hash_md5(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "blake3"
            w.emit("_hash_blake3(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "hmac256"
            w.emit("_hash_hmac256(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown Hash.")
        w.emit(mname)
        w.emit("\")")

    # ── genRandomCall ────────────────────────────────────────────────────────
    def genRandomCall(mname as str, args as List(Arg))
        if mname == "randInt"
            w.emit("_random_int(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("100")
            w.emit(")")
            return
        if mname == "randFloat"
            w.emit("_random_float()")
            return
        if mname == "randBool"
            w.emit("_random_bool()")
            return
        if mname == "bytes"
            w.emit("_random_bytes(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("16")
            w.emit(")")
            return
        if mname == "seed"
            w.emit("_random_seed(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")")
            return
        if mname == "choice"
            if args.count() > 0
                genExpr(args.at(0).value)
                w.emit(".items[_rng().uintLessThan(usize, ")
                genExpr(args.at(0).value)
                w.emit(".items.len)]")
            return
        if mname == "shuffle"
            if args.count() > 0
                w.emit("(if (")
                genExpr(args.at(0).value)
                w.emit(".items.len > 0) _rng().shuffle(@TypeOf(")
                genExpr(args.at(0).value)
                w.emit(".items[0]), ")
                genExpr(args.at(0).value)
                w.emit(".items))")
            return
        w.emit("@compileError(\"selfhost: unknown Random.")
        w.emit(mname)
        w.emit("\")")

    # ── genTerminalCall ──────────────────────────────────────────────────────
    def genTerminalCall(mname as str, args as List(Arg))
        if mname == "isTty"
            w.emit("_term_is_tty()")
            return
        if mname == "width"
            w.emit("_term_width()")
            return
        if mname == "height"
            w.emit("_term_height()")
            return
        if mname == "writeln" or mname == "write"
            var is_println = mname == "writeln"
            w.emit("_term_print(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            if is_println
                w.emit(", true)")
            else
                w.emit(", false)")
            return
        w.emit("@compileError(\"selfhost: unknown Terminal.")
        w.emit(mname)
        w.emit("\")")

