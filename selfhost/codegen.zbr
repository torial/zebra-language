    # ── genShellCall ─────────────────────────────────────────────────────────
    def genShellCall(mname: str, args: List(Arg))
        if mname == "run"
            w.emit("(blk_sh: {\n")
            writeIndent()
            w.emit("    const _sh_cmd = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(";\n")
            writeIndent()
            w.emit("    const _sh_argv = if (comptime builtin.os.tag == .windows)\n")
            writeIndent()
            w.emit("        @as([]const []const u8, &[_][]const u8{ \"cmd\", \"/c\", _sh_cmd })\n")
            writeIndent()
            w.emit("    else\n")
            writeIndent()
            w.emit("        @as([]const []const u8, &[_][]const u8{ \"sh\", \"-c\", _sh_cmd });\n")
            writeIndent()
            w.emit("    const _sh_res = std.process.Child.run(.{\n")
            writeIndent()
            w.emit("        .allocator = _allocator,\n")
            writeIndent()
            w.emit("        .argv = _sh_argv,\n")
            writeIndent()
            w.emit("        .max_output_bytes = 1024 * 1024,\n")
            writeIndent()
            w.emit("    }) catch @panic(\"Shell.run error\");\n")
            writeIndent()
            w.emit("    break :blk_sh std.mem.concat(_allocator, u8, &[_][]const u8{ _sh_res.stdout, _sh_res.stderr }) catch @panic(\"OOM\");\n")
            writeIndent()
            w.emit("})")
            return
        w.emit("@compileError(\"selfhost: unknown Shell.")
        w.emit(mname)
        w.emit("\")")

    # ── genDirCall ───────────────────────────────────────────────────────────
    def genDirCall(mname: str, args: List(Arg))
        if mname == "create"
            w.emit("(std.fs.cwd().makeDir(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch |_dc_err| { if (_dc_err != error.PathAlreadyExists) @panic(\"Dir.create error\"); })")
            return
        if mname == "createAll"
            w.emit("(std.fs.cwd().makePath(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"Dir.createAll error\"))")
            return
        if mname == "delete"
            w.emit("(std.fs.cwd().deleteDir(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch |_dd_err| { if (_dd_err != error.FileNotFound) @panic(\"Dir.delete error\"); })")
            return
        if mname == "deleteAll"
            w.emit("(std.fs.cwd().deleteTree(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"Dir.deleteAll error\"))")
            return
        if mname == "exists"
            w.emit("(blk_de: { var _de_d = std.fs.cwd().openDir(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_de false; _de_d.close(); break :blk_de true; })")
            return
        if mname == "list"
            w.emit("(blk_dl: {\n")
            writeIndent()
            w.emit("    var _dl_dir = std.fs.cwd().openDir(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\".\"")
            w.emit(", .{ .iterate = true }) catch @panic(\"Dir.list error\");\n")
            writeIndent()
            w.emit("    defer _dl_dir.close();\n")
            writeIndent()
            w.emit("    var _dl_list = std.ArrayList([]const u8){};\n")
            writeIndent()
            w.emit("    var _dl_iter = _dl_dir.iterate();\n")
            writeIndent()
            w.emit("    while (_dl_iter.next() catch null) |_dl_entry| {\n")
            writeIndent()
            w.emit("        _dl_list.append(_allocator, _allocator.dupe(u8, _dl_entry.name) catch @panic(\"OOM\")) catch @panic(\"OOM\");\n")
            writeIndent()
            w.emit("    }\n")
            writeIndent()
            w.emit("    break :blk_dl _dl_list;\n")
            writeIndent()
            w.emit("})")
            return
        w.emit("@compileError(\"selfhost: unknown Dir.")
        w.emit(mname)
        w.emit("\")")

    # ── genPathCall ──────────────────────────────────────────────────────────
    def genPathCall(mname: str, args: List(Arg))
        if mname == "join"
            w.emit("(std.fs.path.join(_allocator, &.{")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            if args.count() >= 2
                w.emit(", ")
                genExpr(args.at(1).value)
            if args.count() >= 3
                w.emit(", ")
                genExpr(args.at(2).value)
            w.emit("}) catch @panic(\"Path.join error\"))")
            return
        if mname == "basename"
            w.emit("(std.fs.path.basename(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("))")
            return
        if mname == "dirname"
            w.emit("(std.fs.path.dirname(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") orelse \"\")")
            return
        if mname == "ext"
            w.emit("(std.fs.path.extension(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("))")
            return
        if mname == "stem"
            w.emit("(blk_ps: {\n")
            writeIndent()
            w.emit("    const _ps_base = std.fs.path.basename(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(");\n")
            writeIndent()
            w.emit("    const _ps_ext = std.fs.path.extension(_ps_base);\n")
            writeIndent()
            w.emit("    break :blk_ps _ps_base[0 .. _ps_base.len - _ps_ext.len];\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "isAbsolute"
            w.emit("(std.fs.path.isAbsolute(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("))")
            return
        w.emit("@compileError(\"selfhost: unknown Path.")
        w.emit(mname)
        w.emit("\")")

    # ── genReflectCall ───────────────────────────────────────────────────────
    def genReflectCall(mname: str, args: List(Arg))
        if args.count() < 1
            w.emit("@compileError(\"Reflect requires 1 argument\")")
            return
        if mname == "className"
            w.emit("_reflect_lookup_name(")
            genExpr(args.at(0).value)
            w.emit("._type_tag)")
            return
        if mname == "fieldNames"
            w.emit("_reflect_lookup_fields(")
            genExpr(args.at(0).value)
            w.emit("._type_tag)")
            return
        if mname == "fieldTypes"
            w.emit("_reflect_lookup_field_types(")
            genExpr(args.at(0).value)
            w.emit("._type_tag)")
            return
        w.emit("@compileError(\"selfhost: unknown Reflect.")
        w.emit(mname)
        w.emit("\")")

    def genGenericCtorCall(name: str, type_args: List(Arg), val_args: List(Arg))
        if name == "List"
            w.emit("std.ArrayList(")
            if type_args.count() > 0
                genTypeFromExpr(type_args.at(0).value)
            else
                w.emit("anytype")
            w.emit("){}")
            return
        if name == "HashMap"
            var key_is_str = type_args.count() > 0 and isStringArgExpr(type_args.at(0).value)
            if key_is_str
                w.emit("std.StringHashMap(")
                if type_args.count() >= 2
                    genTypeFromExpr(type_args.at(1).value)
                else
                    w.emit("anytype")
            else
                w.emit("std.AutoHashMap(")
                var fi = true
                for ta in type_args
                    if not fi
                        w.emit(", ")
                    fi = false
                    genTypeFromExpr(ta.value)
            w.emit(").init(_allocator)")
            return
        # Generic user type
        w.emit(name)
        w.emit("(")
        var fi2 = true
        for ta in type_args
            if not fi2
                w.emit(", ")
            fi2 = false
            genTypeFromExpr(ta.value)
        w.emit(").init(")
        var fi3 = true
        for va in val_args
            if not fi3
                w.emit(", ")
            fi3 = false
            genExpr(va.value)
        w.emit(")")
