# typechecker_test.zbr -- Phase 16a/16b smoke tests for typechecker.zbr.
#
# Phase 16a exercises Type_ / ClassTypes / ModuleTypes construction & lookup.
# Phase 16b adds typeFromRef, buildModuleTypes, and inferExpr tests — AST is
# hand-constructed (no Parser dependency) to keep the test file self-contained.

use typechecker exposing Type_, ClassTypes, ModuleTypes, CrossModuleType, typeFromName, typeFromRef, buildModuleTypes, InferCtx, inferExpr, narrowPayloadFromOnValue
use ast exposing Module, Decl, DeclClass, DeclStruct, DeclVar, DeclMethod, DeclInit, DeclUnion, UnionVariant, Param, Modifiers, ParamMode, TypeRef, NamedTypeRef, Expr, ExprIdent, ExprIntLit, ExprFloatLit, ExprBoolLit, ExprCharLit, ExprStringLit, ExprBinary, ExprCall, ExprMember, Arg, BinaryOp, IntBase, StringKind, Span

def check(ok: bool, label: str)
    if ok
        print "PASS " + label
    else
        print "FAIL " + label

# ── Type_ construction and equality ──────────────────────────────────────────
# Equality at the variant level is by-shape (branch match); structural equality
# lands in Phase 18. For Phase 16a we verify variants construct without error
# and that `typeFromName` maps the expected primitive names.

def typeIsInt(t: Type_): bool
    branch t
        on Type_.int_
            return true
        else
            return false

def typeIsString(t: Type_): bool
    branch t
        on Type_.string_
            return true
        else
            return false

def typeIsNamed(t: Type_): bool
    branch t
        on Type_.named as _
            return true
        else
            return false

def typeIsUnknown(t: Type_): bool
    branch t
        on Type_.unknown_
            return true
        else
            return false

def testTypeFromName()
    check(typeIsInt(typeFromName("int")), "typeFromName(int)")
    check(typeIsString(typeFromName("str")), "typeFromName(str)")
    check(typeIsString(typeFromName("String")), "typeFromName(String)")
    check(typeIsNamed(typeFromName("Foo")), "typeFromName(Foo) → named")
    # Type_.unknown_ constructed directly
    check(typeIsUnknown(Type_.unknown_), "Type_.unknown_")

# ── ClassTypes lookups ───────────────────────────────────────────────────────

def testClassTypesFields()
    var ct: ClassTypes = ClassTypes("Foo")
    ct.setField("name", Type_.string_)
    ct.setField("count", Type_.int_)

    var ft: Type_? = ct.fieldType("name")
    check(ft != nil, "ClassTypes.fieldType(name) found")
    if ft != nil
        check(typeIsString(ft to!), "ClassTypes.fieldType(name) is string")

    var ft2: Type_? = ct.fieldType("count")
    if ft2 != nil
        check(typeIsInt(ft2 to!), "ClassTypes.fieldType(count) is int")

    var miss: Type_? = ct.fieldType("absent")
    check(miss == nil, "ClassTypes.fieldType(absent) is nil")

def testClassTypesMethods()
    var ct: ClassTypes = ClassTypes("Bar")
    ct.setMethodReturn("greet", Type_.string_)
    var rt: Type_? = ct.methodReturn("greet")
    check(rt != nil, "ClassTypes.methodReturn(greet) found")
    if rt != nil
        check(typeIsString(rt to!), "ClassTypes.methodReturn(greet) is string")

def testClassTypesCtorParams()
    var ct: ClassTypes = ClassTypes("Baz")
    ct.addCtorParam(Type_.int_)
    ct.addCtorParam(Type_.string_)
    check(ct.ctorParamCount() == 2, "ClassTypes.ctorParamCount() == 2")

    var p0: Type_? = ct.ctorParamAt(0)
    if p0 != nil
        check(typeIsInt(p0 to!), "ctorParamAt(0) is int")

    var p1: Type_? = ct.ctorParamAt(1)
    if p1 != nil
        check(typeIsString(p1 to!), "ctorParamAt(1) is string")

    var pn: Type_? = ct.ctorParamAt(2)
    check(pn == nil, "ctorParamAt(2) is nil (out of range)")

    var pneg: Type_? = ct.ctorParamAt(-1)
    check(pneg == nil, "ctorParamAt(-1) is nil")

# ── ModuleTypes lookups ──────────────────────────────────────────────────────

def testModuleTypesFields()
    var mt: ModuleTypes = ModuleTypes()
    var ct: ClassTypes = ClassTypes("Foo")
    ct.setField("name", Type_.string_)
    mt.addClass(ct)

    check(mt.hasClass("Foo"), "ModuleTypes.hasClass(Foo)")
    check(not mt.hasClass("Missing"), "ModuleTypes.hasClass(Missing) is false")

    var ft: Type_? = mt.fieldType("Foo", "name")
    check(ft != nil, "ModuleTypes.fieldType(Foo, name) found")
    if ft != nil
        check(typeIsString(ft to!), "ModuleTypes.fieldType(Foo, name) is string")

    var miss_cls: Type_? = mt.fieldType("Missing", "name")
    check(miss_cls == nil, "ModuleTypes.fieldType(Missing, name) is nil")

    var miss_fld: Type_? = mt.fieldType("Foo", "absent")
    check(miss_fld == nil, "ModuleTypes.fieldType(Foo, absent) is nil")

def testModuleTypesMethods()
    var mt: ModuleTypes = ModuleTypes()
    var ct: ClassTypes = ClassTypes("Bar")
    ct.setMethodReturn("go", Type_.int_)
    mt.addClass(ct)

    var rt: Type_? = mt.methodReturn("Bar", "go")
    check(rt != nil, "ModuleTypes.methodReturn(Bar, go) found")
    if rt != nil
        check(typeIsInt(rt to!), "ModuleTypes.methodReturn(Bar, go) is int")

    var miss: Type_? = mt.methodReturn("Bar", "absent")
    check(miss == nil, "ModuleTypes.methodReturn(Bar, absent) is nil")

def testModuleTypesCtorParams()
    var mt: ModuleTypes = ModuleTypes()
    var ct: ClassTypes = ClassTypes("Baz")
    ct.addCtorParam(Type_.string_)
    ct.addCtorParam(Type_.int_)
    mt.addClass(ct)

    var p0: Type_? = mt.ctorParamAt("Baz", 0)
    if p0 != nil
        check(typeIsString(p0 to!), "ModuleTypes.ctorParamAt(Baz, 0) is string")

    var p1: Type_? = mt.ctorParamAt("Baz", 1)
    if p1 != nil
        check(typeIsInt(p1 to!), "ModuleTypes.ctorParamAt(Baz, 1) is int")

    var miss: Type_? = mt.ctorParamAt("Missing", 0)
    check(miss == nil, "ModuleTypes.ctorParamAt(Missing, 0) is nil")

# ── CrossModuleType smoke ───────────────────────────────────────────────────
# Phase 16a: just construct. Symmetric equality with named ships in Phase 18.

def testCrossModuleType()
    var cm: CrossModuleType = CrossModuleType("parser", "PNode")
    check(cm.module == "parser", "CrossModuleType.module")
    check(cm.type_name == "PNode", "CrossModuleType.type_name")
    var t: Type_ = Type_.cross_module(cm)
    branch t
        on Type_.cross_module as c
            check(c.module == "parser", "Type_.cross_module.module")
            check(c.type_name == "PNode", "Type_.cross_module.type_name")
        else
            check(false, "Type_.cross_module branch")

# ── Phase 16b: typeFromRef ──────────────────────────────────────────────────
# Hand-build TypeRef variants and verify the mapping to Type_.

def mkSpan(): Span
    return Span(1, 1, 1, 1)

def isOptional(t: Type_): bool
    branch t
        on Type_.optional
            return true
        else
            return false

def isRefTo(t: Type_): bool
    branch t
        on Type_.ref_to
            return true
        else
            return false

def namedRef(n: str): TypeRef
    return TypeRef.named(NamedTypeRef(mkSpan(), n))

def testTypeFromRef()
    check(typeIsInt(typeFromRef(namedRef("int"))), "typeFromRef(named int)")
    check(typeIsString(typeFromRef(namedRef("str"))), "typeFromRef(named str)")
    check(typeIsNamed(typeFromRef(namedRef("Foo"))), "typeFromRef(named Foo)")

    # nilable wraps Type_.optional.
    check(isOptional(typeFromRef(TypeRef.nilable(namedRef("int")))), "typeFromRef(nilable) → optional")

    # void_ maps to Type_.void_.
    var t_void: Type_ = typeFromRef(TypeRef.void_)
    branch t_void
        on Type_.void_
            check(true, "typeFromRef(void_) → void_")
        else
            check(false, "typeFromRef(void_) → void_")

    # ref_to wraps Type_.ref_to.
    check(isRefTo(typeFromRef(TypeRef.ref_to(namedRef("Foo")))), "typeFromRef(ref_to) → ref_to")

    # same_ is not mapped in 16b — falls to unknown_.
    check(typeIsUnknown(typeFromRef(TypeRef.same_)), "typeFromRef(same_) → unknown_")

# ── Phase 16b: buildModuleTypes on a hand-built Module ──────────────────────
# Construct a tiny Module with one class:  class Foo { var name: str }

def emptyMods(): Modifiers
    return Modifiers(false, false, false, false, false, false, false)

def varDecl(name: str, t: TypeRef): Decl
    return Decl.var_(DeclVar(mkSpan(), emptyMods(), name, t, nil, false))

def classDecl(name: str, members: List(Decl)): Decl
    return Decl.class_(DeclClass(mkSpan(), emptyMods(), name, List(ast.TypeParam)(), List(TypeRef)(), List(TypeRef)(), members))

def testBuildModuleTypesClass()
    var members: List(Decl) = List(Decl)()
    members.add(varDecl("name", namedRef("str")))
    members.add(varDecl("count", namedRef("int")))
    var decls: List(Decl) = List(Decl)()
    decls.add(classDecl("Foo", members))
    var m: Module = Module("" + "<test>", decls)
    var mt: ModuleTypes = buildModuleTypes(m)

    check(mt.hasClass("Foo"), "buildModuleTypes: hasClass(Foo)")
    var ft: Type_? = mt.fieldType("Foo", "name")
    check(ft != nil, "buildModuleTypes: field `name` present")
    if ft != nil
        check(typeIsString(ft to!), "buildModuleTypes: field `name` is string")
    var ft2: Type_? = mt.fieldType("Foo", "count")
    if ft2 != nil
        check(typeIsInt(ft2 to!), "buildModuleTypes: field `count` is int")

def testBuildModuleTypesInit()
    # class Bar { cue init(x: int, y: str) { ... } }
    var params: List(Param) = List(Param)()
    params.add(Param(mkSpan(), ParamMode.normal, "x", namedRef("int"), nil))
    params.add(Param(mkSpan(), ParamMode.normal, "y", namedRef("str"), nil))
    var members: List(Decl) = List(Decl)()
    members.add(Decl.init(DeclInit(mkSpan(), emptyMods(), params, nil)))
    var decls: List(Decl) = List(Decl)()
    decls.add(classDecl("Bar", members))
    var m: Module = Module("" + "<test>", decls)
    var mt: ModuleTypes = buildModuleTypes(m)

    var p0: Type_? = mt.ctorParamAt("Bar", 0)
    if p0 != nil
        check(typeIsInt(p0 to!), "buildModuleTypes: ctor param 0 is int")
    var p1: Type_? = mt.ctorParamAt("Bar", 1)
    if p1 != nil
        check(typeIsString(p1 to!), "buildModuleTypes: ctor param 1 is string")

# ── Phase 16b: inferExpr ────────────────────────────────────────────────────
# Construct Expr literals directly; module_types is an empty ModuleTypes.

def mkInt(x: str): Expr
    return Expr.int_lit(ExprIntLit(mkSpan(), x, IntBase.decimal))

def mkStr(x: str): Expr
    return Expr.string_lit(ExprStringLit(mkSpan(), StringKind.plain, x))

def mkBool(v: bool): Expr
    return Expr.bool_lit(ExprBoolLit(mkSpan(), v))

def mkFloat(x: str): Expr
    return Expr.float_lit(ExprFloatLit(mkSpan(), x))

def mkChar(x: str): Expr
    return Expr.char_lit(ExprCharLit(mkSpan(), x))

def testInferLiterals()
    var mt: ModuleTypes = ModuleTypes()
    var ctx: InferCtx = InferCtx(mt, "")
    check(typeIsInt(inferExpr(mkInt("42"), ctx)), "inferExpr(int_lit) → int")
    check(typeIsString(inferExpr(mkStr("hi"), ctx)), "inferExpr(string_lit) → string")

    branch inferExpr(mkBool(true), ctx)
        on Type_.bool_
            check(true, "inferExpr(bool_lit) → bool")
        else
            check(false, "inferExpr(bool_lit) → bool")

    branch inferExpr(mkFloat("3.14"), ctx)
        on Type_.float_
            check(true, "inferExpr(float_lit) → float")
        else
            check(false, "inferExpr(float_lit) → float")

    branch inferExpr(mkChar("a"), ctx)
        on Type_.char_
            check(true, "inferExpr(char_lit) → char")
        else
            check(false, "inferExpr(char_lit) → char")

def testInferBinaryAdd()
    var mt: ModuleTypes = ModuleTypes()
    var ctx: InferCtx = InferCtx(mt, "")
    # "foo" + "bar" → string
    var e: Expr = Expr.binary(ExprBinary(mkSpan(), BinaryOp.add, mkStr("foo"), mkStr("bar")))
    check(typeIsString(inferExpr(e, ctx)), "inferExpr(str + str) → string")
    # 1 + 2 → int
    var e2: Expr = Expr.binary(ExprBinary(mkSpan(), BinaryOp.add, mkInt("1"), mkInt("2")))
    check(typeIsInt(inferExpr(e2, ctx)), "inferExpr(int + int) → int")
    # "x" + 1 → string (string-concat wins)
    var e3: Expr = Expr.binary(ExprBinary(mkSpan(), BinaryOp.add, mkStr("x"), mkInt("1")))
    check(typeIsString(inferExpr(e3, ctx)), "inferExpr(str + int) → string")

def testInferBinaryCompare()
    var mt: ModuleTypes = ModuleTypes()
    var ctx: InferCtx = InferCtx(mt, "")
    var e: Expr = Expr.binary(ExprBinary(mkSpan(), BinaryOp.eq, mkInt("1"), mkInt("2")))
    branch inferExpr(e, ctx)
        on Type_.bool_
            check(true, "inferExpr(int == int) → bool")
        else
            check(false, "inferExpr(int == int) → bool")

def testInferThisField()
    # module_types for `class Foo { var name: str }` + ctx.current_class = "Foo"
    var mt: ModuleTypes = ModuleTypes()
    var ct: ClassTypes = ClassTypes("Foo")
    ct.setField("name", Type_.string_)
    mt.addClass(ct)
    var ctx: InferCtx = InferCtx(mt, "Foo")
    # this.name
    var this_expr: Expr = Expr.this_(mkSpan())
    var mem: Expr = Expr.member(ExprMember(mkSpan(), this_expr, "name"))
    check(typeIsString(inferExpr(mem, ctx)), "inferExpr(this.name) → string")
    # this.missing → unknown_
    var mem2: Expr = Expr.member(ExprMember(mkSpan(), this_expr, "missing"))
    check(typeIsUnknown(inferExpr(mem2, ctx)), "inferExpr(this.missing) → unknown_")

def testInferCtorCall()
    # Foo() with ModuleTypes containing Foo → Type_.named("Foo")
    var mt: ModuleTypes = ModuleTypes()
    mt.addClass(ClassTypes("Foo"))
    var ctx: InferCtx = InferCtx(mt, "")
    var callee: Expr = Expr.ident(ExprIdent(mkSpan(), "Foo"))
    var call: Expr = Expr.call(ExprCall(mkSpan(), callee, List(Arg)()))
    check(typeIsNamed(inferExpr(call, ctx)), "inferExpr(Foo()) → named")
    # int(x) primitive cast → int
    var callee_int: Expr = Expr.ident(ExprIdent(mkSpan(), "int"))
    var call_int: Expr = Expr.call(ExprCall(mkSpan(), callee_int, List(Arg)()))
    check(typeIsInt(inferExpr(call_int, ctx)), "inferExpr(int(x)) → int")

def testInferIdentScope()
    var mt: ModuleTypes = ModuleTypes()
    var ctx: InferCtx = InferCtx(mt, "")
    ctx.bind("x", Type_.int_)
    var e: Expr = Expr.ident(ExprIdent(mkSpan(), "x"))
    check(typeIsInt(inferExpr(e, ctx)), "inferExpr(bound ident x) → int")
    var e2: Expr = Expr.ident(ExprIdent(mkSpan(), "unbound"))
    check(typeIsUnknown(inferExpr(e2, ctx)), "inferExpr(unbound ident) → unknown_")

def testInferMethodCall()
    # Bar.go() where Bar has method go returning int.
    var mt: ModuleTypes = ModuleTypes()
    var ct: ClassTypes = ClassTypes("Bar")
    ct.setMethodReturn("go", Type_.int_)
    mt.addClass(ct)
    var ctx: InferCtx = InferCtx(mt, "")
    ctx.bind("b", Type_.named("Bar"))
    var recv: Expr = Expr.ident(ExprIdent(mkSpan(), "b"))
    var mem: Expr = Expr.member(ExprMember(mkSpan(), recv, "go"))
    var call: Expr = Expr.call(ExprCall(mkSpan(), mem, List(Arg)()))
    check(typeIsInt(inferExpr(call, ctx)), "inferExpr(b.go()) → int")

# ── Phase 17a: union variant payload indexing ───────────────────────────────
# Build Module with `union Shape { circle: int, square: str, dot }` and
# verify populateModuleTypes populates variant_payloads.

def unionDecl(name: str, variants: List(UnionVariant)): Decl
    return Decl.union_(DeclUnion(mkSpan(), emptyMods(), name, variants))

def testUnionVariantIndex()
    var variants: List(UnionVariant) = List(UnionVariant)()
    variants.add(UnionVariant(mkSpan(), "circle", namedRef("int")))
    variants.add(UnionVariant(mkSpan(), "square", namedRef("str")))
    variants.add(UnionVariant(mkSpan(), "dot", nil))
    var decls: List(Decl) = List(Decl)()
    decls.add(unionDecl("Shape", variants))
    var m: Module = Module("" + "<test>", decls)
    var mt: ModuleTypes = buildModuleTypes(m)

    check(mt.hasUnion("Shape"), "buildModuleTypes: hasUnion(Shape)")
    check(not mt.hasUnion("Missing"), "buildModuleTypes: hasUnion(Missing) is false")

    var p_circle: Type_? = mt.variantPayload("Shape", "circle")
    check(p_circle != nil, "variantPayload(Shape.circle) present")
    if p_circle != nil
        check(typeIsInt(p_circle to!), "variantPayload(Shape.circle) is int")

    var p_square: Type_? = mt.variantPayload("Shape", "square")
    if p_square != nil
        check(typeIsString(p_square to!), "variantPayload(Shape.square) is string")

    var p_dot: Type_? = mt.variantPayload("Shape", "dot")
    check(p_dot != nil, "variantPayload(Shape.dot) present (payload-less)")
    if p_dot != nil
        check(typeIsUnknown(p_dot to!), "variantPayload(Shape.dot) is unknown_ (payload-less)")

    var p_missing: Type_? = mt.variantPayload("Shape", "missing")
    check(p_missing == nil, "variantPayload(Shape.missing) is nil")

# ── Phase 17b: narrowPayloadFromOnValue ─────────────────────────────────────
# Build `union Shape { circle: int, dot }` and verify the narrowing
# helper returns the payload for `Shape.circle`, nil for `Shape.dot`
# (payload-less), and nil for shapes not matching the expected form.

def testNarrowPayloadFromOnValue()
    # Build Shape with circle(int) and dot (no payload).
    var variants: List(UnionVariant) = List(UnionVariant)()
    variants.add(UnionVariant(mkSpan(), "circle", namedRef("int")))
    variants.add(UnionVariant(mkSpan(), "dot", nil))
    var decls: List(Decl) = List(Decl)()
    decls.add(unionDecl("Shape", variants))
    var m: Module = Module("" + "<test>", decls)
    var mt: ModuleTypes = buildModuleTypes(m)

    # Construct `Shape.circle`: Expr.member(ident("Shape"), "circle").
    var shape_ident: Expr = Expr.ident(ExprIdent(mkSpan(), "Shape"))
    var circle_val: Expr = Expr.member(ExprMember(mkSpan(), shape_ident, "circle"))
    var nt: Type_? = narrowPayloadFromOnValue(mt, circle_val)
    check(nt != nil, "narrowPayloadFromOnValue(Shape.circle) is not nil")
    if nt != nil
        check(typeIsInt(nt to!), "narrowPayloadFromOnValue(Shape.circle) is int")

    # `Shape.dot` — payload-less → nil (not bound).
    var shape_ident2: Expr = Expr.ident(ExprIdent(mkSpan(), "Shape"))
    var dot_val: Expr = Expr.member(ExprMember(mkSpan(), shape_ident2, "dot"))
    var nt_dot: Type_? = narrowPayloadFromOnValue(mt, dot_val)
    check(nt_dot == nil, "narrowPayloadFromOnValue(Shape.dot) is nil (payload-less)")

    # `Shape.missing` — variant doesn't exist → nil.
    var shape_ident3: Expr = Expr.ident(ExprIdent(mkSpan(), "Shape"))
    var miss_val: Expr = Expr.member(ExprMember(mkSpan(), shape_ident3, "missing"))
    check(narrowPayloadFromOnValue(mt, miss_val) == nil, "narrowPayloadFromOnValue(Shape.missing) is nil")

    # Non-member expression → nil (e.g., a bare ident).
    var bare: Expr = Expr.ident(ExprIdent(mkSpan(), "Shape"))
    check(narrowPayloadFromOnValue(mt, bare) == nil, "narrowPayloadFromOnValue(bare ident) is nil")

# ── Module-level function inference ─────────────────────────────────────────
# Verifies that top-level `def` functions are registered under the "" sentinel
# in ModuleTypes and that inferExpr resolves bare calls to them correctly.

def moduleFuncDecl(name: str, ret: TypeRef): Decl
    return Decl.method(DeclMethod(mkSpan(), emptyMods(), name, List(Param)(), ret, nil, false, false))

def testInferModuleFuncCall()
    # Module: struct Point { var x: int }  +  def makePoint(): Point
    var point_members: List(Decl) = List(Decl)()
    point_members.add(varDecl("x", namedRef("int")))
    var decls: List(Decl) = List(Decl)()
    decls.add(classDecl("Point", point_members))
    decls.add(moduleFuncDecl("makePoint", namedRef("Point")))
    var m: Module = Module("" + "<test>", decls)
    var mt: ModuleTypes = buildModuleTypes(m)

    # Sentinel "" entry is populated.
    var mr: Type_? = mt.methodReturn("", "makePoint")
    check(mr != nil, "buildModuleTypes: module func makePoint registered under sentinel")

    # inferExpr on `makePoint()` with no current class → named(Point)
    var ctx: InferCtx = InferCtx(mt, "")
    var callee: Expr = Expr.ident(ExprIdent(mkSpan(), "makePoint"))
    var call: Expr = Expr.call(ExprCall(mkSpan(), callee, List(Arg)()))
    check(typeIsNamed(inferExpr(call, ctx)), "inferExpr(makePoint()) → named")

    # Same lookup from inside a class body (sibling path, current_class = Point)
    var ctx2: InferCtx = InferCtx(mt, "Point")
    check(typeIsNamed(inferExpr(call, ctx2)), "inferExpr(makePoint()) from inside Point → named")

def testInferDepModuleFuncCall()
    # Simulate a dep module that exports `def helper(): str` at top level.
    # This exercises the dep_types.methodReturn("", ...) path — the risk noted
    # after the sentinel design was committed.
    var dep_decls: List(Decl) = List(Decl)()
    dep_decls.add(moduleFuncDecl("helper", namedRef("str")))
    var dep_m: Module = Module("" + "<dep>", dep_decls)
    var dep_mt: ModuleTypes = buildModuleTypes(dep_m)

    # Verify sentinel is populated in the dep module's own ModuleTypes.
    var dep_mr: Type_? = dep_mt.methodReturn("", "helper")
    check(dep_mr != nil, "dep buildModuleTypes: helper registered under sentinel")

    # Importing module has class Caller with no methods.
    var caller_decls: List(Decl) = List(Decl)()
    caller_decls.add(classDecl("Caller", List(Decl)()))
    var caller_m: Module = Module("" + "<caller>", caller_decls)
    var caller_mt: ModuleTypes = buildModuleTypes(caller_m)

    # Wire dep_types into InferCtx — same path as codegen.zbr ctx17c.withDepTypes.
    var ctx: InferCtx = InferCtx(caller_mt, "Caller")
    ctx.withDepTypes(dep_mt)

    # Bare call to `helper()` inside Caller — should resolve via dep sentinel.
    var callee: Expr = Expr.ident(ExprIdent(mkSpan(), "helper"))
    var call: Expr = Expr.call(ExprCall(mkSpan(), callee, List(Arg)()))
    check(typeIsString(inferExpr(call, ctx)), "inferExpr(helper()) via dep_types sentinel → string")

    # Without dep_types wired, the same call should return unknown_.
    var ctx_nodep: InferCtx = InferCtx(caller_mt, "Caller")
    check(typeIsUnknown(inferExpr(call, ctx_nodep)), "inferExpr(helper()) without dep_types → unknown_")

# ── Main ────────────────────────────────────────────────────────────────────

class Main
    static def main()
        testTypeFromName()
        testClassTypesFields()
        testClassTypesMethods()
        testClassTypesCtorParams()
        testModuleTypesFields()
        testModuleTypesMethods()
        testModuleTypesCtorParams()
        testCrossModuleType()
        testTypeFromRef()
        testBuildModuleTypesClass()
        testBuildModuleTypesInit()
        testInferLiterals()
        testInferBinaryAdd()
        testInferBinaryCompare()
        testInferThisField()
        testInferCtorCall()
        testInferIdentScope()
        testInferMethodCall()
        testUnionVariantIndex()
        testNarrowPayloadFromOnValue()
        testInferModuleFuncCall()
        testInferDepModuleFuncCall()
        print "typechecker_test: done"
