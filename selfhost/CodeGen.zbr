    # ── Build instance call: b.exe/lib/test_/run/dependency/target ────────────
    def genBuildInstanceCall(obj: Expr, mname: str, args: List(Arg))
        if mname == "exe" or mname == "lib" or mname == "test_"
            w.emit("_build_add(")
            genExpr(obj)
            w.emit(", _Build_Kind.")
            w.emit(mname)
            w.emit(", ")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "target"
            w.emit("_build_target_by_name(")
            genExpr(obj)
            w.emit(", ")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "run"
            w.emit("_build_run(")
            genExpr(obj)
            w.emit(")")
            return
        if mname == "dependency"
            w.emit("_build_dep_stub(")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown Build instance method ")
        w.emit(mname)
        w.emit("\")")

    # ── BuildTarget instance call: t.linkLib/platform/option ─────────────────
    def genBuildTargetInstanceCall(obj: Expr, mname: str, args: List(Arg))
        if mname == "linkLib"
            w.emit("_build_target_link_lib(")
            genExpr(obj)
            w.emit(", ")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "platform"
            w.emit("_build_target_platform(")
            genExpr(obj)
            w.emit(", ")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "option"
            w.emit("_build_target_option(")
            genExpr(obj)
            w.emit(", ")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        # BuildTarget methods chain — any unknown method returns self
        genExpr(obj)

    # ── genJsonCall ──────────────────────────────────────────────────────────
    def genJsonCall(mname: str, args: List(Arg))
        if mname == "parse"
            # Json.parse(T, src) overload — first arg is a class ident → strict parser.
            if args.count() >= 2
                var first_arg = args.at(0).value
                if first_arg is Expr.ident as id_ref
                    var class_name2: str = id_ref.name
                    var found2: bool = false
                    var refl2: bool = false
                    for d2 in module_decls
                        if d2 is Decl.class_ as cls2
                            if cls2.name == class_name2
                                found2 = true
                                if cls2.mods.is_reflectable
                                    refl2 = true
                    if found2
                        if not refl2
                            w.emit("@compileError(\"Json.parse(")
                            w.emit(class_name2)
                            w.emit(", …) requires '@reflectable class ")
                            w.emit(class_name2)
                            w.emit("'\")")
                            return
                        w.emit("_json_parse_strict_")
                        w.emit(class_name2)
                        w.emit("(")
                        genExpr(args.at(1).value)
                        w.emit(")")
                        return
            w.emit("_json_parse(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"{}\"")
            w.emit(")")
            return
        if mname == "parseStrict"
            # Json.parseStrict(T, src) — T must be a @reflectable class.
            if args.count() < 2
                w.emit("@compileError(\"Json.parseStrict requires (T, src)\")")
                return
            var first = args.at(0).value
            var class_name: str = ""
            if first is Expr.ident as id_ref
                class_name = id_ref.name
            else
                w.emit("@compileError(\"Json.parseStrict requires (T, src) where T is a class name\")")
                return
            var found: bool = false
            var reflectable: bool = false
            for d in module_decls
                if d is Decl.class_ as cls
                    if cls.name == class_name
                        found = true
                        if cls.mods.is_reflectable
                            reflectable = true
            if not found
                w.emit("@compileError(\"Json.parseStrict: '")
                w.emit(class_name)
                w.emit("' is not a class declared in this module\")")
                return
            if not reflectable
                w.emit("@compileError(\"Json.parseStrict requires '@reflectable class ")
                w.emit(class_name)
                w.emit("' — add the annotation to ")
                w.emit(class_name)
                w.emit("'s declaration.\")")
                return
            w.emit("_json_parse_strict_")
            w.emit(class_name)
            w.emit("(")
            genExpr(args.at(1).value)
            w.emit(")")
            return
        if mname == "stringify"
            w.emit("_json_stringify(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("_json_object()")
            w.emit(")")
            return
        if mname == "object"
            w.emit("_json_object()")
            return
        if mname == "array"
            w.emit("_json_array()")
            return
        w.emit("@compileError(\"selfhost: unknown Json.")
        w.emit(mname)
        w.emit("\")")

