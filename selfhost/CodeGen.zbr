            else
                w.emit("\"\"")
            w.emit("})")
            return
        if mname == "exit"
            w.emit("std.process.exit(@intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("))")
            return
        if mname == "run"
            w.emit("_sys_run(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "exec_inherit"
            w.emit("_sys_exec_inherit(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "spawn"
