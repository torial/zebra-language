    # ── genDateTimeCall ──────────────────────────────────────────────────────
    def genDateTimeCall(mname: str, args: List(Arg))
        if mname == "now"
            w.emit("_dt_now()")
            return
        if mname == "fromEpoch"
            w.emit("_DateTime{ .epoch_ms = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(" }")
            return
        if mname == "of"
            w.emit("_dt_from_gregorian(")
            genArgList(args)
            # Fill missing hour/minute/second with 0
            var provided = args.count()
            if provided < 4
                w.emit(", 0")
            if provided < 5
                w.emit(", 0")
            if provided < 6
                w.emit(", 0")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown DateTime.")
        w.emit(mname)
        w.emit("\")")

