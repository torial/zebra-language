            w.emit("_random_int(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("100")
            w.emit(")")
            return
        if mname == "randFloat"
            w.emit("_random_float()")
            return
        if mname == "randBool"
            w.emit("_random_bool()")
            return
        if mname == "bytes"
            w.emit("_random_bytes(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("16")
            w.emit(")")
            return
        if mname == "seed"
            w.emit("_random_seed(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")")
            return
        if mname == "choice"
            if args.count() > 0
                genExpr(args.at(0).value)
                w.emit(".items[_rng().uintLessThan(usize, ")
                genExpr(args.at(0).value)
                w.emit(".items.len)]")
            return
        if mname == "gaussian"
            w.emit("_random_gaussian(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0.0")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("1.0")
            w.emit(")")
            return
        if mname == "shuffle"
            if args.count() > 0
                w.emit("(if (")
                genExpr(args.at(0).value)
                w.emit(".items.len > 0) _rng().shuffle(@TypeOf(")
                genExpr(args.at(0).value)
                w.emit(".items[0]), ")
                genExpr(args.at(0).value)
                w.emit(".items))")
            return
        if mname == "weighted"
            w.emit("_random_weighted(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown Random.")
        w.emit(mname)
        w.emit("\")")

    # ── genTerminalCall ──────────────────────────────────────────────────────
    def genTerminalCall(mname: str, args: List(Arg))
        if mname == "isTty"
            w.emit("_term_is_tty()")
            return
        if mname == "width"
            w.emit("_term_width()")
            return
        if mname == "height"
            w.emit("_term_height()")
            return
        if mname == "writeln" or mname == "write"
            var is_println = mname == "writeln"
            w.emit("_term_print(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            if is_println
                w.emit(", true)")
            else
                w.emit(", false)")
            return
        w.emit("@compileError(\"selfhost: unknown Terminal.")
        w.emit(mname)
        w.emit("\")")

