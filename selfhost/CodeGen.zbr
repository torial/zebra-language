            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "args"
            w.emit("(blk_sa: {\n")
            writeIndent()
            w.emit("    const _sa_raw = std.process.argsAlloc(_allocator) catch @panic(\"sys.args OOM\");\n")
            writeIndent()
            w.emit("    var _sa_list = std.ArrayList([]const u8).empty;\n")
            writeIndent()
            w.emit("    for (_sa_raw) |_sa_arg| _sa_list.append(_allocator, _sa_arg) catch unreachable;\n")
            writeIndent()
            w.emit("    break :blk_sa _sa_list;\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "getenv"
            w.emit("_sys_getenv(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "readLine"
            w.emit("_sys_readline()")
            return
        if mname == "go"
            w.emit("_sys_go(")
            if args.count() > 0
                genExpr(args.at(0).value)
            w.emit(")")
            return
        if mname == "sleep"
            w.emit("std.Thread.sleep(@as(u64, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")) * std.time.ns_per_ms)")
            return
        if mname == "cwd"
            w.emit("(std.process.currentPathAlloc(_io, _allocator) catch @panic(\"sys.cwd error\"))")
            return
        if mname == "setenv"
            w.emit("_sys_setenv(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(")")
            return
        if mname == "selfExe"
            w.emit("_sys_self_exe()")
            return
        # Fallback: unknown sys method
        w.emit("@compileError(\"selfhost: unknown sys.")
        w.emit(mname)
        w.emit("\")")

