# CodeGen.zbr — Phase 7 self-hosting: CodeGen main body
#
# Port of src/CodeGen.zig to Zebra.  Consumes the AST produced by the parser
# (selfhost/Ast.zbr) and emits Zig source.
#
# Phase 7a scope:
#   Writer       — output sink class
#   Generator    — struct with context-forking methods
#   genType      — TypeRef → Zig type string
#   genFieldDecl — field declaration inside class/struct body
#   genEnum / genUnion / genStruct / genClass
#
# Phase 7b scope (this update):
#   genMethod / genInit / genProperty  — full bodies replacing 7a stubs
#   genStmts / genStmt                — statement dispatch
#   genLocalVar, genAssign, genReturn, genIf, genWhile
#   genForIn, genForNum, genBranch, genPrint, genRaise
#   genTryCatch, genAssert, genDefer, genWith
#   genGuard, genDestruct
#   genExpr                           — expression dispatch
#   genIdent, genBinary, genUnary, genStringLit, genStringInterp
#   genCall, genMemberCall, genMathCall, genArgList, genGenericCtorCall
#   genTypeFromExpr — type-as-expr → Zig type name

use Ast exposing Decl, DeclUse, DeclEnum, DeclUnion, DeclStruct, DeclClass, DeclVar, DeclMethod, DeclInit, DeclSig, DeclTypeAlias, EnumMember, UnionVariant, TypeRef, NamedTypeRef, GenericTypeRef, TupleTypeRef, AliasAppliedTypeRef, Module, Param, Modifiers, Span, Stmt, StmtAssign, StmtReturn, StmtIf, ElseIf, StmtWhile, StmtForIn, StmtForNum, StmtBranch, BranchOn, StructPat, StructFieldPat, StmtPrint, StmtRaise, StmtTryCatch, CatchClause, StmtAssert, StmtAssertCmp, StmtAssertUnary, StmtDefer, StmtWith, StmtIn, StmtAllocate, StmtCopyOut, StmtGuard, StmtDestruct, StmtContract, ContractKind, AssignOp, Expr, ExprIdent, ExprMember, ExprCall, ExprBinary, ExprUnary, ExprStringLit, ExprStringInterp, Arg, StringPart, StringKind, BinaryOp, UnaryOp, LambdaBody, ExprLambda, DeclNamespace, DeclInterface, DeclExtend
use CgHelpers exposing StrSet, scanMutations, analyzeEscapes, assignOpStr, binaryOpStr, nameUsedInStmts, mightUseName, bodyHasRaise, paramNeedsAddrOf, isContainerTypeRef, methodMutatesSelf, ClosureThunk, ThunkList
use TypeChecker exposing ModuleTypes, buildModuleTypes, Type_, HashMapType_, InferCtx, TcResult, inferExpr, walkStmts, typeFromRef, isString


# ── getMemberFieldName ────────────────────────────────────────────────────────
# Given a member-access Expr (self.field), return the field name.
# Returns nil if the expr is not a member access.

def getMemberFieldName(e: Expr): str?
    branch e
        on Expr.member as m
            return m.member
        on Expr.ident as id
            # In init context, bare field names like `out = List()` become Expr.ident
            return id.name
        on Expr.to_non_nil as tnn
            # x to! — unwrap and check inner
            return getMemberFieldName(tnn.expr)
        else
            pass
    return nil

def makeDottedKey(a: str, b: str): str
    return a + "." + b


def extractAfterDot(s: str): str
    # Return the part after the last '.' in a dotted name
    # e.g. "Token.Token" → "Token", "a.b.c" → "c"
    var out: str = s
    for part in s.split(".")
        out = part
    return out

def isUpperCase(s: str): bool
    if s.len == 0
        return false
    var c = s[0]
    return c >= c'A' and c <= c'Z'

def isAlignChar(c: char): bool
    return c == c'<' or c == c'>' or c == c'^'

def zigFmtSpec(spec: str, ex_type: Type_): str
    if spec.len == 0
        return ""
    var i: int = 0
    var fill_s: str = ""
    var align_s: str = ""
    var width_s: str = ""
    var prec_s: str = ""
    var type_s: str = ""
    # Fill + align
    var i_next: int = i + 1
    if i_next < spec.len and not isAlignChar(spec[i]) and isAlignChar(spec[i_next])
        fill_s = spec[i..i_next]
        align_s = spec[i_next..i+2]
        i = i + 2
    else if i < spec.len and isAlignChar(spec[i])
        align_s = spec[i..i+1]
        i = i + 1
    # Skip sign (+ - space)
    if i < spec.len and (spec[i] == c'+' or spec[i] == c'-' or spec[i] == c' ')
        i = i + 1
    # Skip alternate form #
    if i < spec.len and spec[i] == c'#'
        i = i + 1
    # Zero-pad
    if i < spec.len and spec[i] == c'0' and align_s == ""
        fill_s = "0"
        align_s = ">"
        i = i + 1
    # Width digits
    var w_start: int = i
    while i < spec.len and spec[i] >= c'0' and spec[i] <= c'9'
        i = i + 1
    width_s = spec[w_start..i]
    # Grouping option
    if i < spec.len and (spec[i] == c'_' or spec[i] == c',')
        i = i + 1
    # Precision (.digits)
    if i < spec.len and spec[i] == c'.'
        var p_start: int = i
        i = i + 1
        while i < spec.len and spec[i] >= c'0' and spec[i] <= c'9'
            i = i + 1
        prec_s = spec[p_start..i]
    # Type char
    if i < spec.len
        type_s = spec[i..i+1]
    # Map Python type char to Zig type prefix
    var out: str = ""
    if type_s == "s"
        out = "s"
    else if type_s == "c"
        out = "c"
    else if type_s == "u"
        out = "u"
    else if type_s == "d" or type_s == "i" or type_s == "n"
        out = "d"
    else if type_s == "f" or type_s == "g" or type_s == "G" or type_s == "%"
        out = "d"
    else if type_s == "e" or type_s == "E"
        out = "e"
    else if type_s == "x"
        out = "x"
    else if type_s == "X"
        out = "X"
    else if type_s == "o"
        out = "o"
    else if type_s == "b"
        out = "b"
    else if type_s != ""
        out = "d"
    else
        # Infer from TC type when no type char given
        if isString(ex_type)
            out = "s"
        else
            branch ex_type
                on Type_.float_
                    out = "d"
                on Type_.float_n as _
                    out = "d"
                on Type_.char_
                    out = "u"
                on Type_.int_n as _
                    out = "d"
                on Type_.int_
                    out = "d"
                else
                    pass
    var has_opts: bool = fill_s != "" or align_s != "" or width_s != "" or prec_s != ""
    if has_opts
        out = out + ":" + fill_s + align_s + width_s + prec_s
    return out

def bitCastType(spec: str, ex_type: Type_): str
    if spec.len == 0
        return ""
    if not (spec.endsWith("x") or spec.endsWith("X") or spec.endsWith("o") or spec.endsWith("b"))
        return ""
    branch ex_type
        on Type_.int_
            return "u64"
        on Type_.int_n as n
            if n == 8
                return "u8"
            if n == 16
                return "u16"
            if n == 32
                return "u32"
            if n == 64
                return "u64"
            if n == 128
                return "u128"
            return ""
        else
            return ""

def getVariantKey(e: Expr): str?
    if e is Expr.member as m
        var obj_name = getIdentName(m.object)
        if obj_name as obj_n
            return makeDottedKey(obj_n, m.member)
    return nil

def isKnownListField(name: str): bool
    # Known List-typed fields on Parser structs and AST types
    if name == "value" or name == "else_stmts" or name == "init_expr"
        return true
    if name == "message" or name == "base" or name == "args"
        return true
    if name == "params" or name == "decls" or name == "stmts"
        return true
    if name == "default_expr"
        return true
    if name == "step" or name == "start" or name == "stop_"
        return true
    if name == "variants" or name == "exposed" or name == "fields"
        return true
    if name == "members" or name == "methods" or name == "parts"
        return true
    if name == "imports" or name == "dep_modules" or name == "items_"
        return true
    return false

# Phase 16c retire #3: `isKnownStrSetField(name)` (a hardcoded allow-list
# of 28 Generator/Helpers/Resolver StrSet-typed field names) was replaced
# by `fieldIsStrSet(mt, dep_mt, name)`, which consults the ModuleTypes
# reverse index populated at class/struct-build time in
# typechecker.addClassMembers. Verified equivalent across the full
# 175-file .zbr corpus before flip.

# Phase 16c retire #1: replaced isAstStructWithPtrParams + isUnboxedCtorArg
# with a direct ModuleTypes.ctorParamAt is-ref-to check. The two heuristics
# answered "is ctor param at (class_name, idx) a ^T?" by name-list
# enumeration; ModuleTypes answers it from the actual AST. Verified
# effective-equivalent across the full 175-file .zbr corpus before flip.
# Phase 16c retire #3: Replacement for `isKnownStrSetField(name)`.
# Answers "is there a field by this name with StrSet type anywhere in
# the current-module or dep-module type tables?" Populated at class/
# struct-build time (typechecker.addClassMembers), so a reverse index
# without HashMap iteration.
def fieldIsStrSet(mt: ModuleTypes, dep_mt: ModuleTypes, field_name: str): bool
    if mt.hasStrSetField(field_name)
        return true
    if dep_mt.hasStrSetField(field_name)
        return true
    return false

# BUG-032 infrastructure. "Is there a field by this name with HashMap(K,V)
# type anywhere in the current-module or dep-module type tables?" Mirrors
# fieldIsStrSet; populated at class-build time in typechecker.addClassMembers
# via isHashMapTypeRef on the raw TypeRef (since typeFromRef maps generics to
# Type_.unknown_ and would lose the HashMap signal).
def fieldIsHashMap(mt: ModuleTypes, dep_mt: ModuleTypes, field_name: str): bool
    if mt.hasHashMapField(field_name)
        return true
    if dep_mt.hasHashMapField(field_name)
        return true
    return false

# BUG-119: "Is there a field by this name with List(T) type anywhere in the
# current-module or dep-module type tables?" Parallel to fieldIsHashMap;
# populated at class-build time in typechecker.addClassMembers via isListTypeRef.
def fieldIsList(mt: ModuleTypes, dep_mt: ModuleTypes, field_name: str): bool
    if mt.hasListField(field_name)
        return true
    if dep_mt.hasListField(field_name)
        return true
    return false

def ctorParamAtIsRefTo(mt: ModuleTypes, dep_mt: ModuleTypes, class_name: str, idx: int): bool
    var t: Type_? = mt.ctorParamAt(class_name, idx)
    if t == nil
        t = dep_mt.ctorParamAt(class_name, idx)
    if t == nil
        return false
    var tv: Type_ = t to!
    branch tv
        on Type_.ref_to
            return true
        else
            return false

def shouldBoxCtorArg(e: Expr): bool
    # Returns true if the expression likely produces a union value (Expr/Stmt/TypeRef)
    # that needs to be heap-allocated when passed to a ^T struct parameter
    branch e
        on Expr.ident as id
            # Variables ending in _expr, _stmt, _type_ are union values
            var nm = id.name
            if nm.endsWith("_expr") or nm.endsWith("_stmt")
                return true
            # Known variable names that are Expr values
            if nm == "rval" or nm == "msg" or nm == "cond" or nm == "inner_expr"
                return true
            if nm == "this_expr" or nm == "callee_expr" or nm == "base_expr"
                return true
            if nm == "left_expr" or nm == "right_expr" or nm == "operand_expr"
                return true
            if nm == "target_expr" or nm == "value_expr" or nm == "obj_expr"
                return true
            if nm == "idx_expr" or nm == "subject_expr" or nm == "iter_expr"
                return true
            if nm == "initval" or nm == "type_ref"
                return true
        on Expr.call as c
            # buildExpr(), buildStmt() return union values
            if c.callee is Expr.member as cm
                if cm.member == "buildExpr" or cm.member == "buildStmt"
                    return true
                if cm.member == "buildTypeRef"
                    return true
        else
            pass
    return false

def populateBoxedVariants(bv: StrSet, mt: ModuleTypes)
    for key in mt.boxed_variant_keys
        bv.add(key)

def populateRefFields(rf: StrSet, orf: StrSet, mt: ModuleTypes)
    for key in mt.ref_field_keys
        rf.add(key)
    for key in mt.opt_ref_field_keys
        orf.add(key)

def structNameFromType(t: Type_): str?
    # Unwrap ref_to/optional boxing layers, then return the bare struct name.
    branch t
        on Type_.ref_to as inner
            return structNameFromType(inner)
        on Type_.optional as inner
            return structNameFromType(inner)
        on Type_.named as sn
            return sn
        on Type_.cross_module as cm
            return cm.type_name
        else
            return nil

# Map an inferred Type_ to the Zig type-string used inside `std.ArrayList(...)`
# when lowering `[a, b, c]` list literals.  Only the cases that can appear as
# list elements are listed; anything else falls back to `[]const u8` which
# triggers an obvious Zig type-mismatch (better than `anytype` silently
# bleeding into the generated code).
def zigTypeForListElem(t: Type_): str
    branch t
        on Type_.int_
            return "i64"
        on Type_.uint_
            return "u64"
        on Type_.int_n as n
            if n == 8
                return "i8"
            if n == 16
                return "i16"
            if n == 32
                return "i32"
            if n == 64
                return "i64"
            if n == 128
                return "i128"
            return "i64"
        on Type_.uint_n as n
            if n == 8
                return "u8"
            if n == 16
                return "u16"
            if n == 32
                return "u32"
            if n == 64
                return "u64"
            if n == 128
                return "u128"
            return "u64"
        on Type_.float_
            return "f64"
        on Type_.float_n as n
            if n == 16
                return "f16"
            if n == 32
                return "f32"
            if n == 64
                return "f64"
            if n == 128
                return "f128"
            return "f64"
        on Type_.bool_
            return "bool"
        on Type_.char_
            return "u21"
        on Type_.string_
            return "[]const u8"
        on Type_.str_slice
            return "[]const u8"
        else
            return "[]const u8"

def isUnionLikeName(name: str): bool
    # Known union type names from cross-module imports
    if name == "PNode" or name == "PParam"
        return true
    if name == "Decl" or name == "TypeRef" or name == "Stmt" or name == "Expr"
        return true
    if name == "StringPart" or name == "LambdaBody"
        return true
    return false

def isEnumLikeName(name: str): bool
    # Check if name ends with common enum suffixes: Kind, Mode, Op
    if name == "TokenKind" or name == "LineKind" or name == "StringKind"
        return true
    if name == "ParamMode"
        return true
    if name == "BinaryOp" or name == "UnaryOp" or name == "AssignOp"
        return true
    return false

def declMembersHaveInit(members: List(Decl)): bool
    # Returns true if the member list contains a cue init declaration.
    # Uses di.params.count() to reference `di` so Zig does not emit unused-const.
    for mem in members
        if mem is Decl.init as di
            return di.params.count() >= 0
    return false

def getIdentName(e: Expr): str?
    branch e
        on Expr.ident as id
            return id.name
        on Expr.to_non_nil as tnn
            return getIdentName(tnn.expr)
        else
            pass
    return nil

def isCrossModuleCtorCall(callee: Expr): bool
    # Check if call is Module.ClassName() where module == class name
    if callee is Expr.member as m
        var obj_name = getIdentName(m.object)
        if obj_name as obj_n
            return obj_n == m.member
    return false

def getMemberObjectIdent(callee: Expr): str?
    # Extract the object ident name from a member expression, e.g. Foo.bar → "Foo"
    if callee is Expr.member as m
        return getIdentName(m.object)
    return nil

def getMemberName(callee: Expr): str?
    # Extract the member name from a member expression, e.g. Foo.bar → "bar"
    if callee is Expr.member as m
        return m.member
    return nil

def getXmUnionParts(callee: Expr): List(str)?
    # Detect Mod.Union.variant callee shape: member(member(ident(Mod), Union), variant)
    # Returns [mod_name, union_name, variant_name] or nil.
    # Uses a standalone function to avoid nested-branch TC gap (Zig backend doesn't
    # auto-deref ^Expr fields in nested branch subjects).
    if callee is Expr.member as outer_m
        var inner_union = getMemberName(outer_m.object)
        var inner_mod = getMemberObjectIdent(outer_m.object)
        if inner_union as iu
            if inner_mod as im
                var parts = List(str)()
                parts.add(im)
                parts.add(iu)
                parts.add(outer_m.member)
                return parts
    return nil

# ── bodyMentionsThis ─────────────────────────────────────────────────────────
# Returns true if any statement in the list contains Expr.this_ or
# a member access on "this" (self/this field access).
# Used to detect whether `self` is used in a method body.

def exprMentionsThis(e: Expr): bool
    branch e
        on Expr.this_
            return true
        on Expr.member as m
            return exprMentionsThis(m.object)
        on Expr.call as c
            if exprMentionsThis(c.callee)
                return true
            for a in c.args
                if exprMentionsThis(a.value)
                    return true
            return false
        on Expr.binary as b
            return exprMentionsThis(b.left) or exprMentionsThis(b.right)
        on Expr.unary as u
            return exprMentionsThis(u.operand)
        on Expr.index as ix
            return exprMentionsThis(ix.object) or exprMentionsThis(ix.index)
        on Expr.try_ as t
            return exprMentionsThis(t.expr)
        on Expr.cast as ca
            return exprMentionsThis(ca.expr)
        on Expr.to_nilable as t
            return exprMentionsThis(t.expr)
        on Expr.to_non_nil as t
            return exprMentionsThis(t.expr)
        on Expr.is_nil as t
            return exprMentionsThis(t.expr)
        on Expr.orelse_ as o
            return exprMentionsThis(o.expr) or exprMentionsThis(o.fallback)
        on Expr.catch_ as ca
            return exprMentionsThis(ca.expr) or exprMentionsThis(ca.fallback)
        on Expr.if_expr as ie
            return exprMentionsThis(ie.cond) or exprMentionsThis(ie.then_expr) or exprMentionsThis(ie.else_expr)
        on Expr.string_interp as si
            for part in si.parts
                if part is StringPart.expr_ as pe
                    if exprMentionsThis(pe)
                        return true
            return false
        on Expr.except_ as ex
            return exprMentionsThis(ex.base)
        on Expr.chained_cmp as cc
            for op in cc.operands
                if exprMentionsThis(op)
                    return true
            return false
        else
            pass
    return false

def stmtMentionsThis(s: Stmt): bool
    branch s
        on Stmt.assign as a
            return exprMentionsThis(a.target) or exprMentionsThis(a.value)
        on Stmt.return_ as r
            if r.value != nil
                return exprMentionsThis(r.value to!)
            return false
        on Stmt.var_ as v
            if v.init_expr != nil
                return exprMentionsThis(v.init_expr to!)
            return false
        on Stmt.expr as e
            return exprMentionsThis(e)
        on Stmt.if_ as i
            for st in i.then_stmts
                if stmtMentionsThis(st)
                    return true
            return exprMentionsThis(i.cond)
        on Stmt.while_ as w
            return exprMentionsThis(w.cond) or bodyMentionsThis(w.stmts)
        on Stmt.for_in as fi
            return exprMentionsThis(fi.iter) or bodyMentionsThis(fi.stmts)
        on Stmt.print_ as p
            for a in p.args
                if exprMentionsThis(a)
                    return true
            return false
        on Stmt.branch_ as b
            if exprMentionsThis(b.expr)
                return true
            for c in b.cases
                for cv in c.values
                    if exprMentionsThis(cv)
                        return true
                if bodyMentionsThis(c.stmts)
                    return true
            if b.else_ as be
                return bodyMentionsThis(be)
            return false
        on Stmt.try_catch as tc
            if bodyMentionsThis(tc.stmts)
                return true
            for cl in tc.clauses
                if bodyMentionsThis(cl.stmts)
                    return true
            return false
        on Stmt.defer_ as d
            return stmtMentionsThis(d.stmt)
        on Stmt.guard_ as g
            if exprMentionsThis(g.cond)
                return true
            return bodyMentionsThis(g.else_stmts)
        else
            pass
    return false

def bodyUsesAnyField(stmts: List(Stmt), members: List(Decl)): bool
    for d in members
        if d is Decl.var_ as fld
            if nameUsedInStmts(fld.name, stmts)
                return true
    return false

def bodyUsesAnyMethod(stmts: List(Stmt), members: List(Decl)): bool
    for d in members
        if d is Decl.method as dm
            if nameUsedInStmts(dm.name, stmts)
                return true
    return false

def bodyMentionsThis(stmts: List(Stmt)): bool
    for s in stmts
        if stmtMentionsThis(s)
            return true
    return false

# ── Module-level entry points ─────────────────────────────────────────────────
#
# generateModule(m, file) — declarations only (no preamble, no entry thunk).
#   Used for testing and incremental development.
#
# generateEntryPoint(m) — emits `pub fn main()` thunk if any class has
#   `static def main`.  Returns "" if no main found.
#
# generateFull(m, file, preamble_path) — complete Zig file:
#   preamble (read from file) + declarations + entry thunk.
#   Output is a valid, self-contained .zig program.
#
# Usage:
#   var module = ASTBuilder.build(pm, path)?
#   var zig_src = generateFull(module, path, "selfhost/stdlib_preamble.zig")?
#   File.write(zig_path, zig_src)

def typeRefStr(tr: TypeRef): str
    branch tr
        on TypeRef.named as n
            return n.name
        on TypeRef.nilable as inner
            return "?" + typeRefStr(inner)
        on TypeRef.error_union as inner
            return "!" + typeRefStr(inner)
        on TypeRef.ref_to as inner
            return "^" + typeRefStr(inner)
        on TypeRef.stream as inner
            return typeRefStr(inner) + "*"
        on TypeRef.generic as g
            var s = g.name + "("
            var i = 0
            while i < g.args.count()
                if i > 0
                    s = s + ", "
                s = s + typeRefStr(g.args.at(i))
                i = i + 1
            return s + ")"
        on TypeRef.void_
            return "void"
        on TypeRef.same_
            return "same"
        on TypeRef.tuple
            return "tuple"
        on TypeRef.alias_applied as aa
            return aa.name + "(...)"
    return "unknown"

def generateModule(m: Module, file: str): str
    return generateModuleWith(m, file, List(str)(), ModuleTypes(), false, nil, false)

def generateModuleWith(m: Module, file: str, extra_class_names: List(str), deps_mt: ModuleTypes, strip_contracts: bool, tc_result: TcResult?, library_mode: bool): str
    var w = Writer()
    var cn = StrSet()
    # Pre-populate class_names, union_names, enum_names for forward references.
    for decl in m.decls
        if decl is Decl.class_ as c
            cn.add(c.name)
    # Add cross-module class names from dependencies
    var i: int = 0
    while i < extra_class_names.len
        cn.add(extra_class_names.at(i))
        i = i + 1
    # Phase 16c: wire ModuleTypes. module_types built from this module's AST;
    # deps_mt received from caller (MultiCompiler accumulates across deps).
    var g = Generator(w, 0, "", false, false, false, false, nil, "", file, cn,
                      buildModuleTypes(m), deps_mt, m.decls)
    if strip_contracts
        g = g.withStripContracts()
    if tc_result as tcr
        g = g.withTcResult(tcr)
    g.library_mode = library_mode
    # Pre-populate union/enum names and throws_methods from module declarations
    for decl in m.decls
        branch decl
            on Decl.class_ as c
                for mem in c.members
                    branch mem
                        on Decl.method as dm
                            if dm.throws_
                                g.throws_methods.add(makeDottedKey(c.name, dm.name))
                            if dm.name == "toString"
                                g.toString_types.add(c.name)
                        on Decl.namespace_ as ns2
                            for nmem in ns2.decls
                                if nmem is Decl.method as ndm
                                    if ndm.throws_
                                        g.throws_methods.add(makeDottedKey(c.name, ndm.name))
                        else
                            pass
            on Decl.union_ as u
                g.union_names.add(u.name)
                for v in u.variants
                    if v.payload != nil
                        branch v.payload to!
                            on TypeRef.ref_to
                                g.boxed_variants.add(makeDottedKey(u.name, v.name))
                            else
                                pass
            on Decl.enum_ as e
                g.enum_names.add(e.name)
            on Decl.use_ as imp
                populateBoxedVariants(g.boxed_variants, deps_mt)
                populateRefFields(g.ref_fields, g.opt_ref_fields, deps_mt)
                for exposed_name in imp.exposed
                    # BUG-034: prefer the dep-module's authoritative type table
                    # over name heuristics. deps_mt.hasUnion covers any exposed
                    # cross-module union declared in a dep (e.g. Type_ from
                    # TypeChecker.zbr); the hardcoded isUnionLikeName /
                    # isEnumLikeName lists remain: a fallback for the
                    # generate-single-file path where deps_mt is empty.
                    if deps_mt.hasUnion(exposed_name)
                        g.union_names.add(exposed_name)
                    else if isEnumLikeName(exposed_name)
                        g.enum_names.add(exposed_name)
                    else if isUnionLikeName(exposed_name)
                        g.union_names.add(exposed_name)
                    else
                        # Default: treat exposed uppercase names: struct/class types
                        # Only uppercase names — lowercase are functions, not types
                        if isUpperCase(exposed_name)
                            g.struct_names.add(exposed_name)
                            g.struct_with_init.add(exposed_name)  # cross-module structs all have cue init
            on Decl.struct_ as s
                g.struct_names.add(s.name)
                if declMembersHaveInit(s.members)
                    g.struct_with_init.add(s.name)
                for mem in s.members
                    if mem is Decl.method as dm
                        if dm.throws_
                            g.throws_methods.add(makeDottedKey(s.name, dm.name))
                        if dm.name == "toString"
                            g.toString_types.add(s.name)
            else
                pass
    for decl in m.decls
        branch decl
            on Decl.use_ as u
                g.genUse(u)
            on Decl.enum_ as e
                g.genEnum(e)
            on Decl.union_ as u
                g.genUnion(u)
            on Decl.struct_ as s
                g.genStruct(s)
            on Decl.class_ as c
                g.genClass(c)
            on Decl.method as mth
                g.genMethod(mth)
            on Decl.var_ as v
                g.genFieldDecl(v)
            on Decl.sig_ as s2
                g.genSig(s2)
            on Decl.namespace_ as ns
                g.genNamespace(ns)
            on Decl.interface_ as ifc
                g.genInterface(ifc)
            on Decl.extend_ as ext
                g.genExtend(ext)
            else
                pass
    # ── Gap 1: emit module-level closure-thunk infrastructure for every
    # call site that passed a capture-block lambda to a sig-typed param.
    g.flushPendingThunks()
    # Emit Reflect runtime lookup functions
    var reflect_classes = List(str)()
    for decl in m.decls
        if decl is Decl.class_ as rc
            if rc.type_params.count() == 0
                reflect_classes.add(rc.name)
    if reflect_classes.count() > 0
        # Emit a wrapper struct so that reflect slices work with .items.len and .items[i]
        w.emit("const _ReflectStrSlice = struct { items: []const []const u8, fn count(self: @This()) i64 { return @intCast(self.items.len); } fn at(self: @This(), i: i64) []const u8 { return self.items[@intCast(i)]; } };\n")
        w.emit("fn _reflect_lookup_name(tag: u64) []const u8 {\n")
        var ri2 = 0
        while ri2 < reflect_classes.count()
            w.emit("    if (tag == _ttag_")
            w.emit(reflect_classes.at(ri2))
            w.emit(") return _reflect_")
            w.emit(reflect_classes.at(ri2))
            w.emit("_name;\n")
            ri2 = ri2 + 1
        w.emit("    return \"unknown\";\n}\n")
        w.emit("fn _reflect_lookup_fields(tag: u64) _ReflectStrSlice {\n")
        ri2 = 0
        while ri2 < reflect_classes.count()
            w.emit("    if (tag == _ttag_")
            w.emit(reflect_classes.at(ri2))
            w.emit(") return .{ .items = _reflect_")
            w.emit(reflect_classes.at(ri2))
            w.emit("_fields };\n")
            ri2 = ri2 + 1
        w.emit("    return .{ .items = &.{} };\n}\n")
        w.emit("fn _reflect_lookup_field_types(tag: u64) _ReflectStrSlice {\n")
        ri2 = 0
        while ri2 < reflect_classes.count()
            w.emit("    if (tag == _ttag_")
            w.emit(reflect_classes.at(ri2))
            w.emit(") return .{ .items = _reflect_")
            w.emit(reflect_classes.at(ri2))
            w.emit("_field_types };\n")
            ri2 = ri2 + 1
        w.emit("    return .{ .items = &.{} };\n}\n")
    return w.output()

# ── Entry point thunk ─────────────────────────────────────────────────────────
#
# Scans decls for a class with `static def main`.  If found, emits:
#   pub fn main() void { _allocator = _arena.allocator(); defer _arena.deinit(); ClassName.main(); }
# For a throws main, wraps in a catch block for clean error display.

def generateEntryPoint(m: Module, library_mode: bool): str
    var main_class = ""
    var main_throws = false
    for decl in m.decls
        branch decl
            on Decl.class_ as c
                for mem in c.members
                    if mem is Decl.method as mth
                        if mth.name == "main" and mth.mods.is_static
                            main_class = c.name
                            main_throws = mth.throws_
            on Decl.namespace_ as ns
                for nested in ns.decls
                    if nested is Decl.class_ as nc
                        for nmem in nc.members
                            if nmem is Decl.method as nmth
                                if nmth.name == "main" and nmth.mods.is_static
                                    var qn: str = ns.name
                                    qn = qn + "."
                                    qn = qn + nc.name
                                    main_class = qn
                                    main_throws = nmth.throws_
            else
                pass
    if main_class == ""
        return ""
    var sb: StringBuilder = StringBuilder()
    sb.append("pub fn main(_zinit: std.process.Init) void {\n")
    sb.append("    _io = _zinit.io;\n")
    sb.append("    _args = _zinit.minimal.args;\n")
    sb.append("    _allocator = _arena.allocator();\n")
    if not library_mode
        sb.append("    defer _arena.deinit();\n")
    if main_throws
        sb.append("    ")
        sb.append(main_class)
        sb.append(".main() catch |_err| {\n")
        sb.append("        if (_err == error.ZebraError) {\n")
        sb.append("            std.debug.print(\"Error: {s}\\n\", .{_zbr_error_msg()});\n")
        sb.append("        } else {\n")
        sb.append("            std.debug.print(\"Error: {}\\n\", .{_err});\n")
        sb.append("        }\n")
        sb.append("        std.process.exit(1);\n")
        sb.append("    };\n")
    else
        sb.append("    ")
        sb.append(main_class)
        sb.append(".main();\n")
    sb.append("}\n")
    return sb.build()

def generateTestEntryPoint(m: Module, file_stem: str, tag_filter: str?): str
    # Collect test entries: (call expression, display label).
    # Auto-tags: file_stem (all tests) + class name (class-contained static tests).
    var test_calls: List(str) = List(str)()
    var test_labels: List(str) = List(str)()

    # Top-level def test_*() functions.
    for decl in m.decls
        if decl is Decl.method as mth
            if not mth.mods.is_static and mth.name.startsWith("test_") and mth.params.len == 0
                var included: bool = true
                if tag_filter as filter
                    var matched: bool = file_stem == filter
                    if not matched
                        for tag in mth.tags
                            if tag == filter
                                matched = true
                    included = matched
                if included
                    test_calls.add(mth.name)
                    test_labels.add(mth.name)

    # Class/struct-contained static def test_*() methods.
    for decl in m.decls
        var class_name: str = ""
        var members: List(Decl) = List(Decl)()
        if decl is Decl.class_ as cls
            class_name = cls.name
            members = cls.members
        else if decl is Decl.struct_ as st
            class_name = st.name
            members = st.members
        if class_name != ""
            for mdecl in members
                if mdecl is Decl.method as mth
                    if mth.mods.is_static and mth.name.startsWith("test_") and mth.params.len == 0
                        var included: bool = true
                        if tag_filter as filter
                            var matched: bool = file_stem == filter or class_name == filter
                            if not matched
                                for tag in mth.tags
                                    if tag == filter
                                        matched = true
                            included = matched
                        if included
                            var entry: str = "${class_name}.${mth.name}"
                            test_calls.add(entry)
                            test_labels.add(entry)

    var sb: StringBuilder = StringBuilder()
    sb.append("pub fn main(_zinit: std.process.Init) void {\n")
    sb.append("    _io = _zinit.io;\n")
    sb.append("    _args = _zinit.minimal.args;\n")
    sb.append("    _allocator = _arena.allocator();\n")
    sb.append("    defer _arena.deinit();\n")
    sb.append("    var _test_pass: usize = 0;\n")
    sb.append("    var _test_fail: usize = 0;\n")
    var ti: int = 0
    while ti < test_calls.len
        var call: str = test_calls.at(ti)
        var label: str = test_labels.at(ti)
        sb.append("    if (")
        sb.append(call)
        sb.append("()) |_| {\n")
        sb.append("        _test_pass += 1;\n")
        sb.append("        std.debug.print(\"PASS: ")
        sb.append(label)
        sb.append("\\n\", .{});\n")
        sb.append("    } else |_terr| {\n")
        sb.append("        _test_fail += 1;\n")
        sb.append("        if (_terr == error.ZebraError) {\n")
        sb.append("            std.debug.print(\"FAIL: ")
        sb.append(label)
        sb.append(": {s}\\n\", .{_zbr_error_msg()});\n")
        sb.append("        } else {\n")
        sb.append("            std.debug.print(\"FAIL: ")
        sb.append(label)
        sb.append(": {}\\n\", .{_terr});\n")
        sb.append("        }\n")
        sb.append("    }\n")
        ti = ti + 1
    sb.append("    std.debug.print(\"\\n{d} passed, {d} failed\\n\", .{_test_pass, _test_fail});\n")
    sb.append("    if (_test_fail > 0) std.process.exit(1);\n")
    sb.append("}\n")
    return sb.build()

# ── Cross-module error message helper ─────────────────────────────────────────
#
# Generates a `_zbr_error_msg()` function that checks the local `_error_ctx`
# first, then falls through to each imported dep module's `_error_ctx`.
# This solves the cross-module error context isolation problem: when a dep
# raises, its `_error_ctx` is set in its own module, but the caller's is empty.

def generateErrorMsgHelper(m: Module): str
    # Back-compat: walk m.decls for direct uses only. Misses transitive deps
    # (e.g. Parser.zbr uses Lexer, but main.zbr only uses parser — Lexer's
    # _error_ctx was invisible to main.zig). Prefer generateErrorMsgHelperWith
    # with the full transitive module list from main.zbr's compile graph.
    var dep_modules: List(str) = List(str)()
    for decl in m.decls
        if decl is Decl.use_ as u
            dep_modules.add(u.path)
    return generateErrorMsgHelperWith(dep_modules)

def generateErrorMsgHelperWith(dep_modules: List(str)): str
    var sb: StringBuilder = StringBuilder()
    sb.append("fn _zbr_error_msg() []const u8 {\n")
    sb.append("    if (_error_ctx.message.len > 0) return _error_ctx.message;\n")
    var di: int = 0
    while di < dep_modules.len
        var dep_name = dep_modules.at(di)
        # For cross-module _error_ctx, always use @import to access the module-level variable
        # (even when genUse unwraps same-named classes like Resolver.Resolver)
        sb.append("    if (@import(\"")
        sb.append(dep_name)
        sb.append(".zig\")._error_ctx.message.len > 0) return @import(\"")
        sb.append(dep_name)
        sb.append(".zig\")._error_ctx.message;\n")
        di = di + 1
    sb.append("    return \"\";\n")
    sb.append("}\n")
    return sb.build()

# ── Full file generator ───────────────────────────────────────────────────────
#
# Returns a complete, self-contained .zig file.
# preamble_path must be relative to the current working directory.

# Normalize path separators to forward slash so emitted `// Source:` / `// zbr:`
# markers are byte-identical regardless of the host path separator. On Windows
# the shell may pass backslash (or mixed) paths to the compiler, sometimes
# non-deterministically (MSYS arg mangling), which would otherwise make the
# generated .zig differ run-to-run. Mirrors writePathFwd in src/CodeGen.zig.
def fwdSlashes(p: str): str
    return p.replace("\\", "/")

def generateFull(m: Module, file: str, preamble_path: str, strip_contracts: bool, library_mode: bool): str throws
    return generateFullWith(m, file, preamble_path, List(str)(), ModuleTypes(), strip_contracts, library_mode)

def generateFullWith(m: Module, file: str, preamble_path: str, extra_class_names: List(str), deps_mt: ModuleTypes, strip_contracts: bool, library_mode: bool): str throws
    return generateFullWithDeps(m, file, preamble_path, extra_class_names, deps_mt, List(str)(), strip_contracts, nil, library_mode)

def generateFullWithDeps(m: Module, file: str, preamble_path: str, extra_class_names: List(str), deps_mt: ModuleTypes, all_dep_modules: List(str), strip_contracts: bool, tc_result: TcResult?, library_mode: bool): str throws
    require
        preamble_path.len > 0
    var preamble = File.read(preamble_path)
    var decls = generateModuleWith(m, file, extra_class_names, deps_mt, strip_contracts, tc_result, library_mode)
    var entry = generateEntryPoint(m, library_mode)
    var error_helper: str = ""
    if all_dep_modules.len > 0
        error_helper = generateErrorMsgHelperWith(all_dep_modules)
    else
        error_helper = generateErrorMsgHelper(m)
    var sb: StringBuilder = StringBuilder()
    sb.append("// Generated by zebra-selfhost.\n")
    sb.append("// Source: ")
    sb.append(fwdSlashes(file))
    sb.append("\n\n")
    sb.append(preamble)
    sb.append("\n")
    sb.append(decls)
    if error_helper != ""
        sb.append("\n")
        sb.append(error_helper)
    if entry != ""
        sb.append("\n")
        sb.append(entry)
    return sb.build()

def generateFullWithDepsTest(m: Module, file: str, preamble_path: str, extra_class_names: List(str), deps_mt: ModuleTypes, all_dep_modules: List(str), strip_contracts: bool, tc_result: TcResult?, tag_filter: str?): str throws
    require
        preamble_path.len > 0
    var preamble = File.read(preamble_path)
    # Derive file stem for auto-tagging: "path/to/foo_test.zbr" -> "foo_test".
    var file_stem: str = file
    for seg in file.split("/")
        file_stem = seg
    if file_stem.endsWith(".zbr")
        for ext in file_stem.split(".zbr")
            file_stem = ext
            break
    # Filter out top-level `def main()` — the test runner provides its own pub fn main().
    var filtered_decls: List(Decl) = List(Decl)()
    for d in m.decls
        var skip: bool = false
        if d is Decl.method as mth
            var mth_name: str = mth.name
            if not mth.mods.is_static and mth_name == "main" and mth.params.len == 0
                skip = true
        if not skip
            filtered_decls.add(d)
    var m_no_main: Module = Module(m.file, filtered_decls)
    var decls = generateModuleWith(m_no_main, file, extra_class_names, deps_mt, strip_contracts, tc_result, false)
    var entry = generateTestEntryPoint(m, file_stem, tag_filter)
    var error_helper: str = ""
    if all_dep_modules.len > 0
        error_helper = generateErrorMsgHelperWith(all_dep_modules)
    else
        error_helper = generateErrorMsgHelper(m)
    var sb: StringBuilder = StringBuilder()
    sb.append("// Generated by zebra-selfhost.\n")
    sb.append("// Source: ")
    sb.append(fwdSlashes(file))
    sb.append("\n\n")
    sb.append(preamble)
    sb.append("\n")
    sb.append(decls)
    if error_helper != ""
        sb.append("\n")
        sb.append(error_helper)
    if entry != ""
        sb.append("\n")
        sb.append(entry)
    return sb.build()

# Generate a dependency file (no entry point thunk, preamble + imports + declarations).
def generateDep(m: Module, file: str, preamble_path: str, strip_contracts: bool): str throws
    return generateDepWith(m, file, preamble_path, List(str)(), ModuleTypes(), strip_contracts)

def generateDepWith(m: Module, file: str, preamble_path: str, extra_class_names: List(str), deps_mt: ModuleTypes, strip_contracts: bool): str throws
    require
        preamble_path.len > 0
    var preamble = File.read(preamble_path)
    var decls = generateModuleWith(m, file, extra_class_names, deps_mt, strip_contracts, nil, false)
    var sb: StringBuilder = StringBuilder()
    sb.append("// Generated by zebra-selfhost.\n")
    sb.append("// Source: ")
    sb.append(fwdSlashes(file))
    sb.append("\n\n")
    sb.append(preamble)
    sb.append("\n")
    sb.append(decls)
    return sb.build()

# ── Source-map helpers ────────────────────────────────────────────────────────
# Return the source line number for an Expr or Stmt (0 = no span available).
# Used by genStmt to emit `// zbr:file:line` markers for error remapping.

def exprLine(e: Expr): int
    branch e
        on Expr.int_lit as x
            return x.span.line
        on Expr.float_lit as x
            return x.span.line
        on Expr.bool_lit as x
            return x.span.line
        on Expr.char_lit as x
            return x.span.line
        on Expr.string_lit as x
            return x.span.line
        on Expr.zig_lit as x
            return x.span.line
        on Expr.ident as x
            return x.span.line
        on Expr.nil_ as sp
            return sp.line
        on Expr.this_ as sp
            return sp.line
        on Expr.result_ as sp
            return sp.line
        on Expr.string_interp as x
            return x.span.line
        on Expr.member as x
            return x.span.line
        on Expr.call as x
            return x.span.line
        on Expr.index as x
            return x.span.line
        on Expr.slice as x
            return x.span.line
        on Expr.binary as x
            return x.span.line
        on Expr.unary as x
            return x.span.line
        on Expr.cast as x
            return x.span.line
        on Expr.to_nilable as x
            return x.span.line
        on Expr.to_non_nil as x
            return x.span.line
        on Expr.is_nil as x
            return x.span.line
        on Expr.orelse_ as x
            return x.span.line
        on Expr.catch_ as x
            return x.span.line
        on Expr.if_expr as x
            return x.span.line
        on Expr.lambda as x
            return x.span.line
        on Expr.list_lit as x
            return x.span.line
        on Expr.dict_lit as x
            return x.span.line
        on Expr.array_lit as x
            return x.span.line
        on Expr.try_ as x
            return x.span.line
        on Expr.tuple_lit as x
            return x.span.line
        on Expr.type_check as x
            return x.span.line
        on Expr.except_ as x
            return x.span.line
        on Expr.old_ as x
            return x.span.line
        on Expr.chained_cmp as x
            return x.span.line
        on Expr.opt_chain as x
            return x.span.line

def stmtLine(s: Stmt): int
    branch s
        on Stmt.var_ as n
            return n.span.line
        on Stmt.assign as a
            return a.span.line
        on Stmt.return_ as r
            return r.span.line
        on Stmt.if_ as si
            return si.span.line
        on Stmt.while_ as ww
            return ww.span.line
        on Stmt.for_in as fi
            return fi.span.line
        on Stmt.for_num as fn_
            return fn_.span.line
        on Stmt.branch_ as b
            return b.span.line
        on Stmt.print_ as p
            return p.span.line
        on Stmt.raise_ as r
            return r.span.line
        on Stmt.try_catch as tc
            return tc.span.line
        on Stmt.assert_ as a
            return a.span.line
        on Stmt.assert_eq_ as a
            return a.span.line
        on Stmt.assert_ne_ as a
            return a.span.line
        on Stmt.assert_true_ as a
            return a.span.line
        on Stmt.assert_false_ as a
            return a.span.line
        on Stmt.defer_ as d
            return d.span.line
        on Stmt.with_ as ww
            return ww.span.line
        on Stmt.in_scope as si_l
            return si_l.span.line
        on Stmt.allocate_ as al
            return al.span.line
        on Stmt.copy_out as co
            return co.span.line
        on Stmt.guard_ as g
            return g.span.line
        on Stmt.destruct as d
            return d.span.line
        on Stmt.expr as e
            return exprLine(e)
        else
            return 0

struct CallChain
    var recv: Expr
    var method: String
    var args: List(Arg)

    cue init(recv: Expr, method: String, args: List(Arg))
        .recv = recv
        .method = method
        .args = args

struct EnsureCtx
    var armed: bool
    var uses_result: bool

    cue init(armed: bool, uses_result: bool)
        .armed = armed
        .uses_result = uses_result

def tryChain(e: Expr): CallChain?
    if e is Expr.call as c
        if c.callee is Expr.member as m
            if m.object is Expr.call
                return CallChain(m.object, m.member, c.args)
    return nil

# ── Writer ────────────────────────────────────────────────────────────────────
# Reference-type output sink.  All Generator copies share the same Writer.

class Writer
    var _buf: StringBuilder
    var _uid: int

    cue init()
        _buf = StringBuilder()
        _uid = 0

    def emit(s: str)
        _buf.append(s)

    def output(): str
        return _buf.build()

    # Monotonic counter for deterministic unique identifier suffixes in emitted
    # Zig (_rdet_N, _rshim_N, etc). Shared across all Generator copies because
    # Writer is a class — `except`-derived Generators keep the same Writer ref.
    def nextUid(): int
        _uid = _uid + 1
        return _uid

# ── Generator ─────────────────────────────────────────────────────────────────

struct Generator
    var w                    : Writer   # shared output (class = reference type)
    var indent               : int      # current indentation depth (4 spaces/level)
    var owner                : str      # enclosing type name ("" at module scope)
    var in_method            : bool     # true inside method/init/property body
    var is_struct_owner      : bool     # true when owner is a struct (not class)
    var is_generic           : bool     # true inside a generic class body
    var current_method_throws: bool     # true when current method is `throws`
    var try_block_label      : str?     # non-nil inside a `try` block
    var catch_var            : str      # catch clause binding name ("" if none)
    var source_file          : str      # source path for comment markers
    var library_mode         : bool     # --library-mode: omit `defer _arena.deinit()` from the main entry
    var class_names          : StrSet  # names of classes → emit *ClassName in genType
    var union_names          : StrSet  # names of unions → emit union construction
    var enum_names           : StrSet  # names of enums → emit enum construction
    var struct_names         : StrSet  # names of structs visible in this module
    var struct_with_init     : StrSet  # subset of struct_names that have cue init → emit .init()
    var toString_types       : StrSet  # names of types that have a toString() method
    var boxed_variants       : StrSet  # "UnionName.variant" entries where payload is ^T
    var ref_fields           : StrSet  # "StructName.fieldName" entries where field is ^T (non-optional)
    var opt_ref_fields       : StrSet  # "StructName.fieldName" entries where field is ^T? (optional)
    var unwrapped_imports    : StrSet  # module names where genUse did .ModuleName unwrap
    # Phase 7b additions
    var mut_set              : StrSet?  # locals mutated in current block; nil → all emitted as const; set by genStmts
    var ret_set              : StrSet?  # variables that escape via return
    var nil_narrowed         : StrSet?  # variables narrowed to non-nil in current scope
    var try_err_var          : str?     # current try-block error variable name
    var owner_members        : List(Decl)  # members of current enclosing type
    var owner_invariants     : List(Expr)  # invariant exprs of current class/struct
    var param_names          : StrSet?  # current method parameter names
    var str_params           : StrSet   # param names with type str
    var list_tuple_locals    : StrSet   # list_locals whose element type is a tuple (T1,T2,...)
    var list_tuple_str_pos   : StrSet   # "varname:N" where tuple position N is a string type
    var strset_locals        : StrSet   # local/param names with type StrSet
    var chan_locals          : StrSet   # local/param names with type Chan(T)
    var atomic_locals       : StrSet   # local/param names with type Atomic(T)
    var thread_pool_locals  : StrSet   # local/param names with type ThreadPool(n)
    var ptr_field_bindings   : StrSet   # "bindingName.fieldName" where field is ^T (non-optional)
    var opt_ptr_field_bindings: StrSet  # "bindingName.fieldName" where field is ^T? (optional)
    var for_loop_deref       : StrSet   # "loopVar.field" needing .* in for-loop body (e.g. DictEntry)
    var for_loop_vars        : StrSet   # active for-loop variable names (suppress stale branch deref)
    var for_else_label       : str?     # while-based for-else label; nil → plain break; set per-loop
    var in_try_expr          : bool     # suppress auto-try when already inside Expr.try_
    var self_name            : str      # "self" for methods, "_self" for init
    var capture_fields       : StrSet   # captured var names → emit self.name in genIdent
    var closure_vars         : StrSet   # local vars holding capture-lambdas → .call() dispatch
    # Phase 16c additions — ModuleTypes for this module and merged deps.
    # Plumbed now, consumed incrementally: heuristics retire (16c..17).
    var module_types         : ModuleTypes
    var dep_types            : ModuleTypes
    # Phase 17c addition — per-method inference context. Seeded by genMethod/
    # genInit via walkStmts pre-walk before emit. nil at module scope.
    var infer_ctx            : InferCtx?
    var arena_counter        : int      # counter for unique arena scope var names
    var allocate_depth          : int      # nesting depth of scoped allocate blocks (0 = not inside any)
    var throws_methods       : StrSet   # "ClassName.methodName" entries for throws methods
    var module_decls         : List(Decl)   # module-level decls for named/default param lookup
    var in_ensure_emit       : bool     # true while generating the ensure defer block
    var strip_contracts      : bool     # true when --turbo: suppress require/ensure/invariant emit
    var ensure_armed_active  : bool     # true while emitting a fn body whose ensure emits _ensure_armed
    var ensure_uses_result   : bool     # true while emitting a fn body whose ensure references `result`
    # BUG-097: param names emitted as *ArrayList in the current method (BUG-091).
    # genArgListNamed uses this for three-case logic: ptr→ptr (pass), ptr→value (.*), value→ptr (&).
    var caller_ptr_params    : StrSet
    # Phase 1 TcResult plumbing — populated from TC artifact; consumed in Phase 3.
    var tc_result            : TcResult?
    # Return type of the current method; nil outside a method or for void methods.
    # Set by genMethod so genReturn can emit a type-hinted zero-arg generic ctor.
    var method_return_type   : TypeRef?
    # Variable names bound to DynLib handles (result of DynLib.open).
    # Used to dispatch .close() and .lookup() to DynLib-specific codegen.
    var dynlib_vars          : StrSet
    var derive_eq_structs    : StrSet   # struct names with @derive(Eq) — route == to .eql()
    var datetime_vars        : StrSet   # local var names holding _DateTime instances
    # Gap 1 (sig-takes-closure): per-module list of thunk specs collected by
    # genCall; emitted at module end by flushPendingThunks.  See cg_helpers
    # ClosureThunk doc + bootstrap src/CodeGen.zig.
    var pending_thunks       : ThunkList
    # Gap 1: maps local-var name → its capture-lambda init (parallel to
    # closure_vars).  Populated when `var x = def(...) capture {...} ...` is
    # emitted; queried by emitCallWithClosureThunks for ident-case detection.
    var closure_lambdas      : HashMap(str, ExprLambda)

    invariant
        indent >= 0

    cue init(w: Writer, indent: int, owner: str, in_method: bool,
             is_struct_owner: bool, is_generic: bool,
             current_method_throws: bool, try_block_label: str?,
             catch_var: str, source_file: str, class_names: StrSet,
             module_types: ModuleTypes, dep_types: ModuleTypes,
             module_decls: List(Decl))
        .w                     = w
        .indent                = indent
        .owner                 = owner
        .in_method             = in_method
        .is_struct_owner       = is_struct_owner
        .is_generic            = is_generic
        .current_method_throws = current_method_throws
        .try_block_label       = try_block_label
        .catch_var             = catch_var
        .source_file           = source_file
        .library_mode          = false
        .class_names           = class_names
        .union_names           = StrSet()
        .enum_names            = StrSet()
        .struct_names          = StrSet()
        .struct_with_init      = StrSet()
        .toString_types        = StrSet()
        .boxed_variants        = StrSet()
        .ref_fields            = StrSet()
        .opt_ref_fields        = StrSet()
        .unwrapped_imports     = StrSet()
        # Phase 7b field initializations
        .mut_set               = nil
        .ret_set               = nil
        .nil_narrowed          = nil
        .try_err_var           = nil
        .owner_members         = List(Decl)()
        .owner_invariants      = List(Expr)()
        .param_names           = nil
        .str_params            = StrSet()
        .list_tuple_locals     = StrSet()
        .list_tuple_str_pos    = StrSet()
        .strset_locals         = StrSet()
        .chan_locals           = StrSet()
        .atomic_locals        = StrSet()
        .thread_pool_locals   = StrSet()
        .ptr_field_bindings    = StrSet()
        .opt_ptr_field_bindings = StrSet()
        .for_loop_deref        = StrSet()
        .for_loop_vars         = StrSet()
        .for_else_label        = nil
        .in_try_expr           = false
        .self_name             = "self"
        .capture_fields        = StrSet()
        .closure_vars          = StrSet()
        .module_types          = module_types
        .dep_types             = dep_types
        .infer_ctx             = nil
        .arena_counter         = 0
        .allocate_depth           = 0
        .throws_methods        = StrSet()
        .module_decls          = module_decls
        .in_ensure_emit        = false
        .strip_contracts       = false
        .ensure_armed_active   = false
        .ensure_uses_result    = false
        .caller_ptr_params     = StrSet()
        .tc_result             = nil
        .method_return_type    = nil
        .dynlib_vars           = StrSet()
        .derive_eq_structs     = StrSet()
        .datetime_vars         = StrSet()
        .pending_thunks        = ThunkList()
        .closure_lambdas       = HashMap(str, ExprLambda)()

    # ── Context-adjustment helpers ────────────────────────────────────────────

    def withOwner(new_owner: str): Generator
        var g = this except
            owner = new_owner
        return g

    def withStripContracts(): Generator
        var g = this except
            strip_contracts = true
        return g

    def withTcResult(tcr: TcResult): Generator
        var g = this except
            tc_result = tcr
        return g

    def withMethodReturnType(tr: TypeRef): Generator
        var g = this except
            method_return_type = tr
        return g

    def asMethod(): Generator
        var g = this except
            in_method = true
        return g

    def asStructOwner(): Generator
        var g = this except
            is_struct_owner = true
        return g

    def indented(): Generator
        var g = this except
            indent = indent + 1
        return g

    # BUG-097: true iff e is a bare identifier in caller_ptr_params
    # (i.e., already emitted as *ArrayList in the current method signature).
    def argIdentInCpp(e: Expr): bool
        if e is Expr.ident as ei
            return caller_ptr_params.contains_(ei.name)
        return false

    def withEnsureCtx(armed: bool, uses_result: bool): Generator
        var g = this except
            ensure_armed_active = armed
            ensure_uses_result  = uses_result
        return g

    # Clear the ensure context — used inside lambda bodies.
    def withInLambda(): Generator
        var g = this except
            ensure_armed_active = false
            ensure_uses_result  = false
        return g

    def withThrows(): Generator
        var g = this except
            current_method_throws = true
        return g

    def withTryLabel(label: str, err_var: str): Generator
        var g = this except
            try_block_label = label
            try_err_var     = err_var
        return g

    def withCatchVar(name: str): Generator
        var g = this except
            catch_var = name
        return g

    def withCaptureFields(cf: StrSet): Generator
        var g = this except
            capture_fields = cf
        return g

    # Phase 7b context helpers
    def withOwnerMembers(members: List(Decl)): Generator
        var g = this except
            owner_members = members
        return g

    def withOwnerInvariants(invs: List(Expr)): Generator
        var g = this except
            owner_invariants = invs
        return g

    def withGeneric(n: DeclClass): Generator
        var g = this except
            is_generic       = true
            owner_members    = n.members
            owner_invariants = n.invariants
        return g

    def withSelfName(name: str): Generator
        var g = this except
            self_name = name
        return g

    # Phase 17c — attach an InferCtx. Written: a method on Generator so the
    # `except`-on-this path goes through the self-pointer (workaround for a
    # selfhost emit bug where `local = local except` emits an illegal
    # `local.*` deref; `this except` is fine because `this` is a pointer).
    def withInferCtx(ctx: InferCtx): Generator
        var g = this except
            infer_ctx = ctx
        return g

    # Phase 17c — true iff t is a named union type known in this module or a dep.
    # Used to replace shouldBoxCtorArg (name-pattern heuristic) with a walker-
    # verified answer from inferExpr.
    def isUnionType(t: Type_): bool
        branch t
            on Type_.named as tn
                if .module_types.hasUnion(tn)
                    return true
                if .dep_types.hasUnion(tn)
                    return true
                return false
            else
                return false

    # Phase 17d: walker-derived "is this expression a string?" — replaces the
    # isStringExpr name-pattern heuristic when infer_ctx is populated.
    def isStringWalker(e: Expr): bool
        if .infer_ctx == nil
            return false
        var t: Type_ = inferExpr(e, .infer_ctx to!)
        return isString(t)

    # Phase 17d — walker-derived string detection replaces the name-pattern
    # heuristic. isStringExpr is retained only: a fallback for callers
    # reached before infer_ctx has been seeded (tests, emission paths that
    # bypass genMethod / genInit). Flipped after corpus runs showed the
    # walker is a strict superset of the heuristic over all selfhost files.
    def isStringBoth(e: Expr, site: str): bool
        if .infer_ctx != nil
            if .isStringWalker(e)
                return true
        return isStringExpr(e)

    def isPrimType(e: Expr): bool
        if .infer_ctx == nil
            return false
        var t: Type_ = inferExpr(e, .infer_ctx to!)
        branch t
            on Type_.int_   return true
            on Type_.uint_  return true
            on Type_.float_ return true
            on Type_.bool_  return true
            on Type_.char_  return true
            on Type_.void_  return true
            on Type_.int_n as _
                return true
            on Type_.uint_n as _
                return true
            on Type_.float_n as _
                return true
            else
                return false

    def withMethodCtx(ms: StrSet?, rs: StrSet?, throws_: bool, members: List(Decl), pnames: StrSet?, sparams: StrSet, sname: str): Generator
        var g = this except
            in_method              = true
            current_method_throws  = throws_
            mut_set                = ms
            ret_set                = rs
            owner_members          = members
            param_names            = pnames
            str_params             = sparams
            self_name              = sname
            indent                 = indent + 1
            for_loop_deref         = StrSet()
            for_loop_vars          = StrSet()
            ptr_field_bindings     = StrSet()
            opt_ptr_field_bindings = StrSet()
            list_tuple_locals      = StrSet()
            list_tuple_str_pos     = StrSet()
            strset_locals          = StrSet()
            chan_locals            = StrSet()
            atomic_locals         = StrSet()
            thread_pool_locals    = StrSet()
            dynlib_vars            = StrSet()
            caller_ptr_params = StrSet()
        return g

    # ── Output helpers ────────────────────────────────────────────────────────

    def emitTryBlockCatch()
        # Inside a try block: emit `catch |_e| { _try_err = _e; break :_try_blk; }`
        # instead of using `try` which propagates to the enclosing function
        w.emit(" catch |_tc_e| { ")
        w.emit(try_err_var to!)
        w.emit(" = _tc_e; break :")
        w.emit(try_block_label to!)
        w.emit("; }")

    def writeIndent
        var i = 0
        while i < indent
            w.emit("    ")
            i += 1

    def line(s: str)
        writeIndent()
        w.emit(s)
        w.emit("\n")

    # ── genType ───────────────────────────────────────────────────────────────

    def findTypeAlias(name: str): DeclTypeAlias?
        for decl in module_decls
            if decl is Decl.type_alias_ as ta
                if ta.name == name
                    return ta
        return nil

    def genType(tr: TypeRef)
        branch tr
            on TypeRef.named as n
                # Transparent alias: emit base type instead.
                var maybe_alias = findTypeAlias(n.name)
                if maybe_alias != nil
                    genType(maybe_alias to!.base)
                    return
                if isSimdTypeName(n.name)
                    var sparts: List(str) = n.name.split("x")
                    w.emit("@Vector(")
                    w.emit(sparts.at(1))
                    w.emit(", ")
                    w.emit(simdElemZig(sparts.at(0)))
                    w.emit(")")
                    return
                if class_names.contains_(n.name)
                    w.emit("*")
                    w.emit(n.name)
                    return
                if n.name == "StringBuilder"
                    w.emit("std.ArrayList(u8)")
                    return
                if n.name == "SysProcess"
                    w.emit("*_SysProcess")
                    return
                if n.name == "DynLib"
                    w.emit("*_DynLib")
                    return
                if n.name == "ThreadPool"
                    w.emit("*_ThreadPool")
                    return
                if n.name == "WsConn"
                    w.emit("*_WsConn")
                    return
                if n.name == "Build"
                    w.emit("*_Build")
                    return
                if n.name == "BuildTarget"
                    w.emit("*_BuildTarget")
                    return
                if n.name == "Allocator"
                    w.emit("std.mem.Allocator")
                    return
                if "." in n.name
                    # Dotted cross-module type: Module.ClassName
                    # If ClassName is a class, emit *Module.ClassName
                    var class_part = extractAfterDot(n.name)
                    if class_names.contains_(class_part)
                        w.emit("*")
                    w.emit(n.name)
                    return
                w.emit(zigPrimitive(n.name))

            on TypeRef.nilable as inner
                w.emit("?")
                genType(inner)

            on TypeRef.error_union as inner
                w.emit("anyerror!")
                genType(inner)

            on TypeRef.ref_to as inner
                # BUG-041: classes are already auto-boxed to `*T` by the `.named`
                # arm, so a recursive genType on a class inner would stack a
                # second `*`, producing `**T` (or `?**T`). For classes, `^T` is a
                # no-op on representation — emit `*ClassName` / `?*ClassName`
                # directly and skip the auto-box recursion.
                var is_nilable = false
                branch inner
                    on TypeRef.nilable
                        is_nilable = true
                    else
                        pass
                var prefix: str
                if is_nilable
                    prefix = "?*"
                else
                    prefix = "*"
                var handled = false
                branch inner
                    on TypeRef.nilable as ni2
                        if ni2 is TypeRef.named as n
                            if class_names.contains_(n.name)
                                w.emit(prefix)
                                w.emit(n.name)
                                handled = true
                            else if "." in n.name
                                var class_part = extractAfterDot(n.name)
                                if class_names.contains_(class_part)
                                    w.emit(prefix)
                                    w.emit(n.name)
                                    handled = true
                    on TypeRef.named as n
                        if class_names.contains_(n.name)
                            w.emit(prefix)
                            w.emit(n.name)
                            handled = true
                        else if "." in n.name
                            var class_part = extractAfterDot(n.name)
                            if class_names.contains_(class_part)
                                w.emit(prefix)
                                w.emit(n.name)
                                handled = true
                    else
                        pass
                if not handled
                    w.emit(prefix)
                    if is_nilable
                        if inner is TypeRef.nilable as ni3
                            genType(ni3)
                    else
                        genType(inner)

            on TypeRef.generic as gtr
                genGenericType(gtr)

            on TypeRef.stream as inner
                w.emit("anytype /* stream: ")
                genType(inner)
                w.emit(" */")

            on TypeRef.void_
                w.emit("void")

            on TypeRef.same_
                if owner != ""
                    w.emit(owner)
                else
                    w.emit("@This()")

            on TypeRef.tuple as ttr
                w.emit("struct { ")
                var j = 0
                while j < ttr.elems.count()
                    if j > 0
                        w.emit(", ")
                    genType(ttr.elems.at(j))
                    j += 1
                w.emit(" }")

            on TypeRef.alias_applied as aa
                # Transparent alias: emit base type of the alias declaration.
                # ThreadPool(n) is a value-parameterized stdlib type → always *_ThreadPool.
                if aa.name == "ThreadPool"
                    w.emit("*_ThreadPool")
                else
                    var maybe_alias = findTypeAlias(aa.name)
                    if maybe_alias != nil
                        genType(maybe_alias to!.base)
                    else
                        w.emit("i64")

    def genGenericType(gtr: GenericTypeRef)
        # Sized numeric types: int(N) → iN, uint(N) → uN, float(N) → fN
        if gtr.name == "int" or gtr.name == "uint" or gtr.name == "float"
            if gtr.args.count() >= 1
                if gtr.args.at(0) is TypeRef.named as an
                    if gtr.name == "uint"
                        w.emit("u")
                    else if gtr.name == "float"
                        w.emit("f")
                    else
                        w.emit("i")
                    w.emit(an.name)
                    return
        if gtr.name == "HashMap"
            var key_str = gtr.args.count() >= 1 and isStringTypeRef(gtr.args.at(0))
            if key_str
                w.emit("std.StringHashMap(")
                if gtr.args.count() >= 2
                    genType(gtr.args.at(1))
                else
                    w.emit("anytype")
                w.emit(")")
            else
                w.emit("std.AutoHashMap(")
                var ai = 0
                while ai < gtr.args.count()
                    if ai > 0
                        w.emit(", ")
                    genType(gtr.args.at(ai))
                    ai += 1
                w.emit(")")
            return
        if gtr.name == "List"
            w.emit("std.ArrayList(")
            if gtr.args.count() >= 1
                genType(gtr.args.at(0))
            else
                w.emit("[]const u8")
            w.emit(")")
            return
        if gtr.name == "Chan"
            w.emit("*_Chan(")
            if gtr.args.count() >= 1
                genType(gtr.args.at(0))
            else
                w.emit("anytype")
            w.emit(")")
            return
        if gtr.name == "Atomic"
            w.emit("*_Atomic(")
            if gtr.args.count() >= 1
                genType(gtr.args.at(0))
            else
                w.emit("anytype")
            w.emit(")")
            return
        if gtr.name == "ThreadPool"
            w.emit("*_ThreadPool")
            return
        w.emit(gtr.name)
        if gtr.args.count() > 0
            w.emit("(")
            var bi = 0
            while bi < gtr.args.count()
                if bi > 0
                    w.emit(", ")
                genType(gtr.args.at(bi))
                bi += 1
            w.emit(")")

    def zigPrimitive(name: str): str
        if name == "int"
            return "i64"
        if name == "uint"
            return "u64"
        if name == "float"
            return "f64"
        if name == "bool"
            return "bool"
        if name == "char"
            return "u21"
        if name == "str"
            return "[]const u8"
        if name == "String"
            return "[]const u8"
        if name == "int8"
            return "i8"
        if name == "int16"
            return "i16"
        if name == "int32"
            return "i32"
        if name == "int64"
            return "i64"
        if name == "int128"
            return "i128"
        if name == "uint8"
            return "u8"
        if name == "uint16"
            return "u16"
        if name == "uint32"
            return "u32"
        if name == "uint64"
            return "u64"
        if name == "uint128"
            return "u128"
        if name == "byte"
            return "u8"
        if name == "float16"
            return "f16"
        if name == "float32"
            return "f32"
        if name == "float64"
            return "f64"
        if name == "float128"
            return "f128"
        if name == "Allocator"
            return "std.mem.Allocator"
        return name

    def isStringTypeRef(tr: TypeRef): bool
        if tr is TypeRef.named as n
            return n.name == "str" or n.name == "String"
        return false

    # ── genUse ────────────────────────────────────────────────────────────────
    # Emit @import for `use Module` / `use Module exposing Name1, Name2`.
    # Each dependency .zbr file is compiled to its own .zig file by the multi-file
    # pipeline. The import path uses the module name + ".zig".

    def genUse(n: DeclUse)
        # Simple module path (no dots) → @import("path.zig")
        # If the module has a sole same-named class (e.g. `use Lexer` where Lexer.zbr
        # defines class Lexer), unwrap the class: const Lexer = @import("Lexer.zig").Lexer;
        var alias: str = n.path
        var has_same_named_class = class_names.contains_(alias)
        if n.exposed.len == 0
            # `use Mod` — import module (or unwrap same-named class)
            w.emit("const ")
            w.emit(alias)
            w.emit(" = @import(\"")
            w.emit(n.path)
            w.emit(".zig\")")
            if has_same_named_class
                w.emit(".")
                w.emit(alias)
                unwrapped_imports.add(alias)
            w.emit(";\n")
        else
            # `use Mod exposing Name1, Name2` — import module, then alias each exposed name
            w.emit("const ")
            w.emit(alias)
            w.emit(" = @import(\"")
            w.emit(n.path)
            w.emit(".zig\");\n")
            var i: int = 0
            while i < n.exposed.len
                var ename: str = n.exposed.at(i)
                if ename != alias
                    w.emit("const ")
                    w.emit(ename)
                    w.emit(" = ")
                    w.emit(alias)
                    w.emit(".")
                    w.emit(ename)
                    w.emit(";\n")
                i = i + 1

    # ── genFieldDecl ──────────────────────────────────────────────────────────

    def genFieldDecl(n: DeclVar)
        writeIndent()
        # Shared (static) fields become `pub var name: type = default;` inside the struct.
        # Module-scope vars/consts (owner == "") become file-scope `pub var`/`pub const`.
        # BUG-137: a module-scope var gets the reserved `_zbr_mv_` prefix (matched
        # by genIdent) so its file-scope Zig name can't be shadowed by — or collide
        # with — a function-local/param of the same source name (Zig forbids a
        # local shadowing a file-scope decl). Static class fields are namespaced as
        # `Owner.field`, so they are NOT prefixed.
        if n.mods.is_static or owner == ""
            if n.is_const and not n.mods.is_static
                w.emit("pub const ")
            else
                w.emit("pub var ")
            if owner == "" and not n.mods.is_static
                w.emit("_zbr_mv_")
            w.emit(n.name)
            # Untyped static `var` of a literal would be comptime_int/float (Zig:
            # "must be const or comptime"); annotate it the same way genLocalVar
            # does for untyped mutable locals.  A typed static uses its annotation;
            # a non-literal init is left for Zig to infer (never `: anytype`, which
            # is invalid).
            if n.type_ != nil
                w.emit(": ")
                genType(n.type_ to!)
            else
                if n.init_expr != nil
                    branch n.init_expr to!
                        on Expr.int_lit
                            w.emit(": i64")
                        on Expr.float_lit
                            w.emit(": f64")
                        on Expr.string_lit
                            w.emit(": []const u8")
                        on Expr.unary as un
                            if un.op == UnaryOp.neg
                                branch un.operand
                                    on Expr.int_lit
                                        w.emit(": i64")
                                    on Expr.float_lit
                                        w.emit(": f64")
                                    else
                                        pass
                        else
                            pass
            w.emit(" = ")
            if n.init_expr != nil
                genExpr(n.init_expr to!)
            else
                w.emit("undefined")
            w.emit(";\n")
            return
        w.emit(n.name)
        w.emit(": ")
        if n.type_ != nil
            var tr = n.type_ to!
            if tr is TypeRef.named as nt
                if nt.name == "StringBuilder"
                    w.emit("std.ArrayList(u8) = .empty,\n")
                    return
            genType(tr)
        else
            w.emit("anytype")
        if n.init_expr != nil
            w.emit(" = ")
            genExpr(n.init_expr to!)
        w.emit(",\n")

    # ── genEnum ───────────────────────────────────────────────────────────────

    def genEnum(n: DeclEnum)
        enum_names.add(n.name)
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = enum")
        if n.base != nil
            w.emit("(")
            genType(n.base to!)
            w.emit(")")
        w.emit(" {\n")
        var ig = indented()
        for m in n.members
            ig.writeIndent()
            ig.w.emit(m.name)
            ig.w.emit(",\n")
        writeIndent()
        w.emit("};\n\n")

    # ── genUnion ──────────────────────────────────────────────────────────────

    def genUnion(n: DeclUnion)
        union_names.add(n.name)
        # Track boxed variants (^T payloads)
        for v in n.variants
            if v.payload != nil
                branch v.payload to!
                    on TypeRef.ref_to
                        boxed_variants.add(makeDottedKey(n.name, v.name))
                    else
                        pass
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = union(enum) {\n")
        var ig = indented()
        for v in n.variants
            ig.writeIndent()
            ig.w.emit(v.name)
            if v.payload != nil
                ig.w.emit(": ")
                ig.genType(v.payload to!)
            ig.w.emit(",\n")
        writeIndent()
        w.emit("};\n\n")

    # ── genStruct ─────────────────────────────────────────────────────────────

    def genStruct(n: DeclStruct)
        struct_names.add(n.name)
        if n.mods.is_derive_eq
            derive_eq_structs.add(n.name)
        if n.mods.is_derive_debug
            toString_types.add(n.name)
        # Track ^T fields for auto-deref
        for decl in n.members
            if decl is Decl.var_ as fld
                if fld.type_ != nil
                    branch fld.type_ to!
                        on TypeRef.ref_to
                            ref_fields.add(makeDottedKey(n.name, fld.name))
                        else
                            pass
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = struct {\n")
        var ig0 = indented()
        var ig1 = ig0.withOwner(n.name)
        var ig2 = ig1.asStructOwner()
        var ig3 = ig2.withOwnerMembers(n.members)
        var ig  = ig3.withOwnerInvariants(n.invariants)
        for decl in n.members
            if decl is Decl.var_ as fld
                ig.genFieldDecl(fld)
        for decl in n.members
            branch decl
                on Decl.method as m
                    ig.genMethod(m)
                on Decl.init as ini
                    struct_with_init.add(n.name)
                    ig.genInit(ini)
                else
                    pass
        # Synthetic pub fn init(fields...) StructName for plain structs (no cue init).
        # Normalises all structs so callers can use StructName.init(...) uniformly.
        if not struct_with_init.contains_(n.name)
            var sig_ig = ig.indented()
            ig.writeIndent()
            w.emit("pub fn init(")
            var si_first = true
            for si_decl in n.members
                if si_decl is Decl.var_ as si_fld
                    if si_fld.mods.is_static
                        continue
                    if not si_first
                        w.emit(", ")
                    si_first = false
                    w.emit(si_fld.name)
                    w.emit(": ")
                    if si_fld.type_ != nil
                        ig.genType(si_fld.type_ to!)
                    else
                        w.emit("anytype")
            w.emit(") ")
            w.emit(n.name)
            w.emit(" {\n")
            sig_ig.writeIndent()
            if si_first
                w.emit("return .{};\n")
            else
                w.emit("return .{")
                var si_first2 = true
                for si_decl2 in n.members
                    if si_decl2 is Decl.var_ as si_fld2
                        if si_fld2.mods.is_static
                            continue
                        if not si_first2
                            w.emit(",")
                        si_first2 = false
                        w.emit(" .")
                        w.emit(si_fld2.name)
                        w.emit(" = ")
                        w.emit(si_fld2.name)
                w.emit(" };\n")
            ig.writeIndent()
            w.emit("}\n\n")
        if n.invariants.count() > 0 and not strip_contracts
            ig.genInvariantCheckFn()
        if n.ifaces.count() > 0
            w.emit("\n")
            ig.writeIndent()
            w.emit("comptime {\n")
            var cig2 = ig.indented()
            for tr in n.ifaces
                cig2.writeIndent()
                w.emit(typeRefStr(tr))
                w.emit(".check(@This());\n")
            ig.writeIndent()
            w.emit("}\n")
        if n.mods.is_derive_debug
            ig.genDeriveToString(n)
        if n.mods.is_derive_eq
            ig.genDeriveEql(n)
        if n.mods.is_derive_hash
            ig.genDeriveHash(n)
        writeIndent()
        w.emit("};\n\n")

    def isStrFieldType(tr: TypeRef?): bool
        if tr == nil
            return false
        var t = tr to!
        if t is TypeRef.named as n
            return n.name == "str" or n.name == "String"
        return false

    def isFloatFieldType(tr: TypeRef?): bool
        if tr == nil
            return false
        var t = tr to!
        if t is TypeRef.named as n
            return n.name == "float" or n.name == "num"
        return false

    def genDeriveToString(n: DeclStruct)
        writeIndent()
        w.emit("pub fn toString(self: *const ")
        w.emit(n.name)
        w.emit(") []const u8 {\n")
        var ig_ts = indented()
        # Build format string in a StringBuilder
        var fmt_str: str = n.name + "("
        var field_count = 0
        for decl in n.members
            if decl is Decl.var_ as fld
                if fld.mods.is_static
                    continue
                if field_count > 0
                    fmt_str = fmt_str + ", "
                fmt_str = fmt_str + fld.name + "="
                if .isStrFieldType(fld.type_)
                    fmt_str = fmt_str + "{s}"
                else if .isFloatFieldType(fld.type_)
                    fmt_str = fmt_str + "{d}"
                else
                    fmt_str = fmt_str + "{}"
                field_count = field_count + 1
        fmt_str = fmt_str + ")"
        ig_ts.writeIndent()
        w.emit("return std.fmt.allocPrint(_allocator, \"")
        w.emit(fmt_str)
        w.emit("\", .{")
        var first_arg = true
        for decl in n.members
            if decl is Decl.var_ as fld
                if fld.mods.is_static
                    continue
                if not first_arg
                    w.emit(", ")
                first_arg = false
                w.emit("self.")
                w.emit(fld.name)
        w.emit("}) catch unreachable;\n")
        writeIndent()
        w.emit("}\n")

    def genDeriveEql(n: DeclStruct)
        writeIndent()
        w.emit("pub fn eql(self: *const ")
        w.emit(n.name)
        w.emit(", other: *const ")
        w.emit(n.name)
        w.emit(") bool {\n")
        var ig_eq = indented()
        var field_count = 0
        for decl in n.members
            if decl is Decl.var_ as fld
                if not fld.mods.is_static
                    field_count = field_count + 1
        ig_eq.writeIndent()
        if field_count == 0
            w.emit("return true;\n")
        else
            w.emit("return ")
            var first_fld = true
            for decl in n.members
                if decl is Decl.var_ as fld
                    if fld.mods.is_static
                        continue
                    if not first_fld
                        w.emit(" and ")
                    first_fld = false
                    if .isStrFieldType(fld.type_)
                        w.emit("std.mem.eql(u8, self.")
                        w.emit(fld.name)
                        w.emit(", other.")
                        w.emit(fld.name)
                        w.emit(")")
                    else
                        w.emit("(self.")
                        w.emit(fld.name)
                        w.emit(" == other.")
                        w.emit(fld.name)
                        w.emit(")")
            w.emit(";\n")
        writeIndent()
        w.emit("}\n")

    def genDeriveHash(n: DeclStruct)
        writeIndent()
        w.emit("pub fn hash(self: *const ")
        w.emit(n.name)
        w.emit(") u64 {\n")
        var ig_h = indented()
        ig_h.writeIndent()
        w.emit("var hasher = std.hash.Wyhash.init(0);\n")
        for decl in n.members
            if decl is Decl.var_ as fld
                if fld.mods.is_static
                    continue
                ig_h.writeIndent()
                w.emit("std.hash.autoHashStrat(&hasher, self.")
                w.emit(fld.name)
                w.emit(", .Deep);\n")
        ig_h.writeIndent()
        w.emit("return hasher.final();\n")
        writeIndent()
        w.emit("}\n")

    # ── genGenericClass ───────────────────────────────────────────────────────

    def genGenericClass(n: DeclClass)
        class_names.add(n.name)
        writeIndent()
        w.emit("pub fn ")
        w.emit(n.name)
        w.emit("(")
        var i = 0
        while i < n.type_params.count()
            if i > 0
                w.emit(", ")
            w.emit("comptime ")
            w.emit(n.type_params.at(i).name)
            w.emit(": type")
            i = i + 1
        w.emit(") type {\n")
        var fg = indented()
        fg.writeIndent()
        fg.w.emit("return struct {\n")
        var ig0 = fg.indented()
        var ig1 = ig0.withOwner(n.name)
        var ig  = ig1.withGeneric(n)
        ig.line("_type_tag: u64 = _ttag_${n.name},")
        for decl in n.members
            if decl is Decl.var_ as fld
                ig.genFieldDecl(fld)
        var has_init = false
        for decl in n.members
            branch decl
                on Decl.method as m
                    ig.genMethod(m)
                on Decl.init as ini
                    ig.genInit(ini)
                    has_init = true
                else
                    pass
        if not has_init
            ig.writeIndent()
            ig.w.emit("pub fn init() @This() {\n")
            var dig = ig.indented()
            dig.writeIndent()
            dig.w.emit("var self: @This() = undefined;\n")
            dig.writeIndent()
            dig.w.emit("self._type_tag = _ttag_")
            dig.w.emit(n.name)
            dig.w.emit(";\n")
            dig.writeIndent()
            dig.w.emit("return self;\n")
            ig.writeIndent()
            ig.w.emit("}\n\n")
        if n.invariants.count() > 0 and not strip_contracts
            ig.genInvariantCheckFn()
        if n.ifaces.count() > 0
            w.emit("\n")
            ig.writeIndent()
            w.emit("comptime {\n")
            var cig3 = ig.indented()
            for tr in n.ifaces
                cig3.writeIndent()
                w.emit(typeRefStr(tr))
                w.emit(".check(@This());\n")
            ig.writeIndent()
            w.emit("}\n")
        fg.writeIndent()
        fg.w.emit("};\n")
        writeIndent()
        w.emit("}\n\n")
        w.emit("const _ttag_")
        w.emit(n.name)
        w.emit(": u64 = _zbr_hash(\"")
        w.emit(n.name)
        w.emit("\");\n\n")

    # ── DynLib instance method codegen ────────────────────────────────────────

    def genDynLibMethod(obj: Expr, method: str, args: List(Arg)): bool
        if method == "close"
            w.emit("_dynlib_close(")
            genExpr(obj)
            w.emit(")")
            return true
        if method == "lookup"
            if args.count() < 2
                return false
            var iface_name: str = ""
            if args.at(0).value is Expr.ident as aid
                iface_name = aid.name
            else
                return false
            var uid = w.nextUid()
            w.emit("blk_${uid.toString()}: { const _fn = ")
            genExpr(obj)
            w.emit(".lib.lookup(*const fn () *${iface_name}, ")
            genExpr(args.at(1).value)
            w.emit(") orelse break :blk_${uid.toString()} null; break :blk_${uid.toString()} _fn(); }")
            return true
        return false

    # ── Interface vtable helpers ───────────────────────────────────────────────

    def findInterfaceDecl(name: str): DeclInterface?
        for decl in module_decls
            if decl is Decl.interface_ as ifc
                if ifc.name == name
                    return ifc
        return nil

    def genIfaceVtable(class_name: str, ifc: DeclInterface)
        var iname = ifc.name
        for m in ifc.members
            if m is Decl.method as meth
                w.emit("fn _shim_${class_name}_${iname}_${meth.name}(ptr: *anyopaque")
                for p in meth.params
                    w.emit(", " + p.name + ": ")
                    if p.type_ != nil
                        genType(p.type_ to!)
                    else
                        w.emit("anytype")
                w.emit(") ")
                if meth.throws_
                    w.emit("anyerror!")
                if meth.return_type != nil
                    genType(meth.return_type to!)
                else
                    w.emit("void")
                if meth.throws_
                    w.emit(" { return try " + class_name + "." + meth.name + "(@alignCast(@ptrCast(ptr))")
                else
                    w.emit(" { return " + class_name + "." + meth.name + "(@alignCast(@ptrCast(ptr))")
                for p in meth.params
                    w.emit(", " + p.name)
                w.emit("); }\n")
        w.emit("const _vtable_${class_name}_${iname} = ${iname}.VTable{")
        for m in ifc.members
            if m is Decl.method as meth
                w.emit(" .${meth.name} = &_shim_${class_name}_${iname}_${meth.name},")
        w.emit(" };\n")

    # ── genClass ──────────────────────────────────────────────────────────────

    def genClass(n: DeclClass)
        if n.type_params.count() > 0
            genGenericClass(n)
            return
        class_names.add(n.name)
        writeIndent()
        w.emit("pub const ")
        w.emit(n.name)
        w.emit(" = struct {\n")
        var ig0 = indented()
        var ig1 = ig0.withOwner(n.name)
        var ig2 = ig1.withOwnerMembers(n.members)
        var ig  = ig2.withOwnerInvariants(n.invariants)
        ig.line("_type_tag: u64 = _ttag_${n.name},")
        for decl in n.members
            if decl is Decl.var_ as fld
                ig.genFieldDecl(fld)
        var has_init = false
        for decl in n.members
            branch decl
                on Decl.method as m
                    ig.genMethod(m)
                on Decl.init as ini
                    ig.genInit(ini)
                    has_init = true
                else
                    pass
        # BUG-089: generate methods from added mixins.
        for mixin_ref in n.mixins
            if mixin_ref is TypeRef.named as nr
                for mdecl in module_decls
                    if mdecl is Decl.mixin_ as mx
                        if mx.name == nr.name
                            for mmem in mx.members
                                if mmem is Decl.method as mm
                                    ig.genMethod(mm)
        # Synthetic default init for classes without explicit cue init
        if not has_init
            ig.writeIndent()
            ig.w.emit("pub fn init() *")
            ig.w.emit(n.name)
            ig.w.emit(" {\n")
            var dig = ig.indented()
            dig.writeIndent()
            dig.w.emit("const self = _allocator.create(")
            dig.w.emit(n.name)
            dig.w.emit(") catch @panic(\"OOM\");\n")
            dig.writeIndent()
            dig.w.emit("self.* = .{};\n")
            dig.writeIndent()
            dig.w.emit("self._type_tag = _ttag_")
            dig.w.emit(n.name)
            dig.w.emit(";\n")
            for fdecl in n.members
                if fdecl is Decl.var_ as fld
                    if not fld.mods.is_static
                        if fld.init_expr != nil
                            dig.writeIndent()
                            dig.w.emit("self.")
                            dig.w.emit(fld.name)
                            dig.w.emit(" = ")
                            dig.genExpr(fld.init_expr to!)
                            dig.w.emit(";\n")
            # Initialize @once cache fields to null (not present in AST; emitted by genMethod).
            for odecl in n.members
                if odecl is Decl.method as omth
                    if omth.mods.is_once
                        dig.writeIndent()
                        dig.w.emit("self._once_")
                        dig.w.emit(omth.name)
                        dig.w.emit("_val = null;\n")
            dig.writeIndent()
            dig.w.emit("return self;\n")
            ig.writeIndent()
            ig.w.emit("}\n\n")
        if n.invariants.count() > 0 and not strip_contracts
            ig.genInvariantCheckFn()
        if n.ifaces.count() > 0
            w.emit("\n")
            ig.writeIndent()
            w.emit("comptime {\n")
            var cig2 = ig.indented()
            for tr in n.ifaces
                cig2.writeIndent()
                w.emit(typeRefStr(tr))
                w.emit(".check(@This());\n")
            ig.writeIndent()
            w.emit("}\n")
        writeIndent()
        w.emit("};\n")
        # Emit shim functions + vtable const for each implemented interface.
        for tr in n.ifaces
            if tr is TypeRef.named as nt
                var ifc = findInterfaceDecl(nt.name)
                if ifc as ifc_decl
                    genIfaceVtable(n.name, ifc_decl)
        w.emit("const _ttag_")
        w.emit(n.name)
        w.emit(": u64 = _zbr_hash(\"")
        w.emit(n.name)
        w.emit("\");\n")
        # Tier-1 reflection metadata
        var rf_names = List(str)()
        var rf_types = List(str)()
        for decl in n.members
            if decl is Decl.var_ as fld
                if not fld.mods.is_static
                    rf_names.add(fld.name)
                    if fld.type_ != nil
                        rf_types.add(typeRefStr(fld.type_ to!))
                    else
                        rf_types.add("unknown")
        w.emit("const _reflect_")
        w.emit(n.name)
        w.emit("_name: []const u8 = \"")
        w.emit(n.name)
        w.emit("\";\n")
        w.emit("const _reflect_")
        w.emit(n.name)
        w.emit("_fields: []const []const u8 = &.{")
        var ri = 0
        while ri < rf_names.count()
            if ri > 0
                w.emit(", ")
            w.emit("\"")
            w.emit(rf_names.at(ri))
            w.emit("\"")
            ri = ri + 1
        w.emit("};\n")
        w.emit("const _reflect_")
        w.emit(n.name)
        w.emit("_field_types: []const []const u8 = &.{")
        ri = 0
        while ri < rf_types.count()
            if ri > 0
                w.emit(", ")
            w.emit("\"")
            w.emit(rf_types.at(ri))
            w.emit("\"")
            ri = ri + 1
        w.emit("};\n\n")
        # Tier-3 reflection: emit per-class strict JSON parser when @reflectable.
        if n.mods.is_reflectable
            genJsonParseStrictFn(n)
        # @export("sym") class Foo is IFoo → module-static singleton factory.
        if n.export_sym as sym
            if n.ifaces.count() > 0
                var iface_tr: TypeRef = n.ifaces.at(0)
                if iface_tr is TypeRef.named as nr
                    var iface_name: str = nr.name
                    w.emit("var _zbr_export_")
                    w.emit(sym)
                    w.emit("_iface: ?")
                    w.emit(iface_name)
                    w.emit(" = null;\n")
                    w.emit("pub export fn ")
                    w.emit(sym)
                    w.emit("() *")
                    w.emit(iface_name)
                    w.emit(" {\n")
                    w.emit("    if (_zbr_export_")
                    w.emit(sym)
                    w.emit("_iface == null) {\n")
                    w.emit("        _zbr_export_")
                    w.emit(sym)
                    w.emit("_iface = .{ .ptr = ")
                    w.emit(n.name)
                    w.emit(".init(), .vtable = &_vtable_")
                    w.emit(n.name)
                    w.emit("_")
                    w.emit(iface_name)
                    w.emit(" };\n")
                    w.emit("    }\n")
                    w.emit("    return &_zbr_export_")
                    w.emit(sym)
                    w.emit("_iface.?;\n")
                    w.emit("}\n\n")

    # Map a primitive TypeRef to a kind tag for the strict JSON parser.
    # Returns "" for unsupported types.
    def primitiveKindName(tr: TypeRef): str
        if tr is TypeRef.named as nt
            if nt.name == "int"
                return "int"
            if nt.name == "float"
                return "float"
            if nt.name == "bool"
                return "bool"
            if nt.name == "str" or nt.name == "String"
                return "str"
        return ""

    # Emit `fn _json_parse_strict_<T>(src) ?*T` for a @reflectable class T.
    def genJsonParseStrictFn(n: DeclClass)
        var f_names = List(str)()
        var f_kinds = List(str)()
        for d in n.members
            if d is Decl.var_ as fld
                if fld.mods.is_static
                    continue
                if fld.type_ == nil
                    continue
                var tr = fld.type_ to!
                var kind: str = primitiveKindName(tr)
                if kind == ""
                    w.emit("comptime { @compileError(\"Json.parseStrict on ")
                    w.emit(n.name)
                    w.emit(": field '")
                    w.emit(fld.name)
                    w.emit("' has unsupported type '")
                    w.emit(typeRefStr(tr))
                    w.emit("' (only int/float/bool/str supported in 0.9)\"); }\n")
                    return
                f_names.add(fld.name)
                f_kinds.add(kind)
        w.emit("fn _json_parse_strict_")
        w.emit(n.name)
        w.emit("(_src: []const u8) ?*")
        w.emit(n.name)
        w.emit(" {\n")
        w.emit("    const _v = _json_parse(_src) orelse return null;\n")
        w.emit("    if (!_json_is_object(_v)) return null;\n")
        if f_names.count() > 0
            w.emit("    var _it = _v.object.iterator();\n")
            w.emit("    while (_it.next()) |_e| {\n")
            w.emit("        const _k = _e.key_ptr.*;\n")
            w.emit("        const _known = ")
            var i = 0
            while i < f_names.count()
                if i > 0
                    w.emit(" or ")
                w.emit("std.mem.eql(u8, _k, \"")
                w.emit(f_names.at(i))
                w.emit("\")")
                i = i + 1
            w.emit(";\n")
            w.emit("        if (!_known) return null;\n")
            w.emit("    }\n")
        else
            w.emit("    if (_v.object.count() != 0) return null;\n")
        var j = 0
        while j < f_names.count()
            var nm = f_names.at(j)
            var kd = f_kinds.at(j)
            w.emit("    { const _x = _v.object.get(\"")
            w.emit(nm)
            w.emit("\") orelse return null;\n      switch (_x) { ")
            if kd == "int"
                w.emit(".integer => {}, else => return null")
            else if kd == "float"
                w.emit(".float, .integer => {}, else => return null")
            else if kd == "bool"
                w.emit(".bool => {}, else => return null")
            else
                w.emit(".string => {}, else => return null")
            w.emit(" } }\n")
            j = j + 1
        w.emit("    const _r = _allocator.create(")
        w.emit(n.name)
        w.emit(") catch return null;\n")
        w.emit("    _r.* = .{};\n")
        w.emit("    _r._type_tag = _ttag_")
        w.emit(n.name)
        w.emit(";\n")
        j = 0
        while j < f_names.count()
            var nm = f_names.at(j)
            var kd = f_kinds.at(j)
            w.emit("    _r.")
            w.emit(nm)
            w.emit(" = ")
            if kd == "int"
                w.emit("_json_get_int(")
            else if kd == "float"
                w.emit("_json_get_float(")
            else if kd == "bool"
                w.emit("_json_get_bool(")
            else
                w.emit("_json_get_str(")
            w.emit("_v, \"")
            w.emit(nm)
            w.emit("\");\n")
            j = j + 1
        w.emit("    return _r;\n")
        w.emit("}\n\n")

    # ── genMethod ─────────────────────────────────────────────────────────────

    def genMethod(m: DeclMethod)
        var has_self = owner != "" and not m.mods.is_static
        # @once: emit cache field + public wrapper, then emit private impl function.
        var fn_name: str = m.name
        if m.mods.is_once
            # Cache field
            writeIndent()
            w.emit("_once_")
            w.emit(m.name)
            w.emit("_val: ?")
            if m.return_type != nil
                genType(m.return_type to!)
            w.emit(" = null,\n")
            # Public wrapper
            writeIndent()
            w.emit("pub fn ")
            w.emit(m.name)
            w.emit("(self: *")
            if is_generic
                w.emit("@This()")
            else
                w.emit(owner)
            w.emit(") ")
            if m.return_type != nil
                genType(m.return_type to!)
            w.emit(" {\n")
            var wg = indented()
            wg.writeIndent()
            wg.w.emit("if (self._once_")
            wg.w.emit(m.name)
            wg.w.emit("_val) |_zbr_v| return _zbr_v;\n")
            wg.writeIndent()
            wg.w.emit("const _zbr_r = self._zbr_once_")
            wg.w.emit(m.name)
            wg.w.emit("_impl();\n")
            wg.writeIndent()
            wg.w.emit("self._once_")
            wg.w.emit(m.name)
            wg.w.emit("_val = _zbr_r;\n")
            wg.writeIndent()
            wg.w.emit("return _zbr_r;\n")
            writeIndent()
            w.emit("}\n\n")
            fn_name = "_zbr_once_${m.name}_impl"
        writeIndent()
        if m.mods.is_once
            w.emit("fn ")
        else if m.mods.is_export
            w.emit("pub export fn ")
        else
            w.emit("pub fn ")
        w.emit(fn_name)
        w.emit("(")
        # Generic function type params: def identity(T)(x: T): T → pub fn identity(comptime T: type, x: T) T
        var gfn_tp_count: int = m.type_params.count()
        if gfn_tp_count > 0
            var gfn_tpi: int = 0
            while gfn_tpi < gfn_tp_count
                if gfn_tpi > 0
                    w.emit(", ")
                w.emit("comptime ")
                w.emit(m.type_params.at(gfn_tpi))
                w.emit(": type")
                gfn_tpi += 1
            if has_self or m.params.count() > 0
                w.emit(", ")
        if has_self
            # @pure: emit `self: *const Owner` so the method can be called
            # on by-value/const receivers.  Opt-in; default = `*Owner`.
            if is_generic
                if m.mods.is_pure
                    w.emit("self: *const @This()")
                else
                    w.emit("self: *@This()")
            else
                if m.mods.is_pure
                    w.emit("self: *const ")
                else
                    w.emit("self: *")
                w.emit(owner)
            if m.params.count() > 0
                w.emit(", ")
        genParamList(m.params, m.stmts)
        # Root entry point (Zig 0.16): top-level def main() receives init: std.process.Init
        if owner == "" and m.name == "main"
            if m.params.count() > 0 or has_self
                w.emit(", ")
            w.emit("_zinit: std.process.Init")
        w.emit(") ")
        var mstmts_pre: List(Stmt)? = m.stmts
        var auto_throws = m.throws_ or (mstmts_pre != nil and bodyHasRaise(mstmts_pre to!))
        if auto_throws
            w.emit("anyerror!")
        if m.return_type != nil
            genType(m.return_type to!)
        else
            w.emit("void")
        if m.stmts as mstmts
            var rs = analyzeEscapes(mstmts)
            var ps = StrSet()
            var sp = StrSet()
            for p in m.params
                ps.add(p.name)
                if p.type_ != nil
                    var ptype = p.type_ to!
                    if ptype is TypeRef.named as nt
                        if nt.name == "str" or nt.name == "String"
                            sp.add(p.name)
            w.emit(" {\n")
            # Root entry point (Zig 0.16): inject _io/_args/_allocator init + dep propagation
            if owner == "" and m.name == "main"
                var ei = indented()
                ei.writeIndent()
                ei.w.emit("_io = _zinit.io;\n")
                ei.writeIndent()
                ei.w.emit("_args = _zinit.minimal.args;\n")
                ei.writeIndent()
                ei.w.emit("_allocator = _arena.allocator();\n")
                if not .library_mode
                    ei.writeIndent()
                    ei.w.emit("defer _arena.deinit();\n")
                for ei_decl in module_decls
                    if ei_decl is Decl.use_ as ei_u
                        var ei_path: str = ei_u.path.replace(".", "/")
                        ei.writeIndent()
                        ei.w.emit("@import(\"" + ei_path + ".zig\")._initAllocator(_allocator);\n")
                        ei.writeIndent()
                        ei.w.emit("@import(\"" + ei_path + ".zig\")._initIo(_io);\n")
            # @profile: record entry time and defer _profile_end() on any exit path.
            if m.mods.is_profile
                var prof_ig = indented()
                prof_ig.writeIndent()
                if owner != ""
                    prof_ig.w.emit("_profile_start(\"")
                    prof_ig.w.emit(owner)
                    prof_ig.w.emit(".")
                    prof_ig.w.emit(m.name)
                    prof_ig.w.emit("\");\n")
                else
                    prof_ig.w.emit("_profile_start(\"")
                    prof_ig.w.emit(m.name)
                    prof_ig.w.emit("\");\n")
                prof_ig.writeIndent()
                prof_ig.w.emit("defer _profile_end();\n")
            # Invariant exit check — public instance methods only.
            # Private helpers may temporarily break invariants; shared methods have no `self`.
            if has_self and not m.mods.is_static and not m.mods.is_private and owner_invariants.count() > 0 and not strip_contracts
                var inv_ig = indented()
                inv_ig.writeIndent()
                inv_ig.w.emit("defer self._check_invariant();\n")
            var bg = withMethodCtx(nil, rs, auto_throws, owner_members, ps, sp, "self")
            # Phase 17c — seed a per-method InferCtx and pre-walk statements so
            # expression-level type inference has a populated scope map. Used
            # during emit (e.g., at ctor-arg boxing) to replace name-pattern
            # heuristics with walker-derived types.
            var ctx17c = InferCtx(.module_types, owner)
            ctx17c.withDepTypes(.dep_types)
            if m.return_type != nil
                ctx17c.withReturnType(typeFromRef(m.return_type to!))
            for pp in m.params
                if pp.type_ != nil
                    ctx17c.bind(pp.name, typeFromRef(pp.type_ to!))
                else
                    ctx17c.bind(pp.name, Type_.unknown_)
            walkStmts(mstmts, ctx17c)
            bg = bg.withInferCtx(ctx17c)
            if m.return_type != nil
                bg = bg.withMethodReturnType(m.return_type to!)
            # BUG-097: record which params are emitted as *ArrayList so arg-emit
            # sites can apply three-case logic (ptr→ptr, ptr→value, value→ptr).
            for pptr in m.params
                if paramNeedsAddrOf(pptr, m.stmts)
                    bg.caller_ptr_params.add(pptr.name)
            # Track List-tuple and StrSet params for type-aware codegen
            for p2 in m.params
                if p2.type_ != nil
                    var p2t = p2.type_ to!
                    branch p2t
                        on TypeRef.generic as gt
                            if gt.name == "List"
                                if gt.args.count() > 0
                                    if gt.args.at(0) is TypeRef.tuple as pttr
                                        bg.list_tuple_locals.add(p2.name)
                                        var ptpos = 0
                                        for ptelem in pttr.elems
                                            if ptelem is TypeRef.named as pten
                                                if pten.name == "str" or pten.name == "String"
                                                    bg.list_tuple_str_pos.add("${p2.name}:${ptpos.toString()}")
                                            ptpos = ptpos + 1
                        on TypeRef.named as nt2
                            if nt2.name == "StrSet"
                                bg.strset_locals.add(p2.name)
                            # Seed opt_ptr_field_bindings for ^T? fields of named-type params
                            var nt2_dot = nt2.name + "."
                            var orf3 = opt_ref_fields.items()
                            var orf3i = 0
                            while orf3i < orf3.count()
                                var orf3e: str = orf3.at(orf3i)
                                if orf3e.startsWith(nt2_dot)
                                    bg.opt_ptr_field_bindings.add(makeDottedKey(p2.name, extractAfterDot(orf3e)))
                                orf3i += 1
                            # Seed ptr_field_bindings for non-optional ^T fields of named-type params
                            var rf3 = ref_fields.items()
                            var rf3i = 0
                            while rf3i < rf3.count()
                                var rf3e: str = rf3.at(rf3i)
                                if rf3e.startsWith(nt2_dot)
                                    bg.ptr_field_bindings.add(makeDottedKey(p2.name, extractAfterDot(rf3e)))
                                rf3i += 1
                        else
                            pass
            # Suppress unused-parameter errors for self and params
            # Check explicit Expr.this_ usage AND implicit field access (bare ident matching a field)
            if has_self and not bodyMentionsThis(mstmts) and not bodyUsesAnyField(mstmts, owner_members) and not bodyUsesAnyMethod(mstmts, owner_members) and (owner_invariants.count() == 0 or strip_contracts)
                bg.line("_ = self;")
            for p in m.params
                if not nameUsedInStmts(p.name, mstmts)
                    bg.writeIndent()
                    bg.w.emit("_ = ")
                    bg.w.emit(p.name)
                    bg.w.emit(";\n")
            bg.genRequireChecks(m.require_, m.name)
            var ec = bg.genEnsureBlock(m.ensure_, m.name, m.return_type)
            bg.withEnsureCtx(ec.armed, ec.uses_result).genStmts(mstmts)
            # Arm the ensure check for fall-off-the-end paths (void functions
            # with no explicit return).  Idempotent when explicit returns already armed.
            if ec.armed
                bg.writeIndent()
                bg.w.emit("_ensure_armed = true;\n")
            writeIndent()
            w.emit("}\n\n")
        else
            w.emit(" {\n")
            var ig = indented()
            ig.line("unreachable; // abstract")
            writeIndent()
            w.emit("}\n\n")

    # ── genInit ───────────────────────────────────────────────────────────────

    def genInit(ini: DeclInit)
        writeIndent()
        w.emit("pub fn init(")
        genParamList(ini.params, ini.stmts)
        w.emit(") ")
        if not is_struct_owner
            w.emit("*")
        if is_generic
            w.emit("@This()")
        else
            w.emit(owner)
        w.emit(" {\n")
        var ig = indented()
        if not is_struct_owner
            # Class init: allocate on arena
            ig.writeIndent()
            ig.w.emit("const _self = _allocator.create(")
            if is_generic
                ig.w.emit("@This()")
            else
                ig.w.emit(owner)
            ig.w.emit(") catch @panic(\"OOM\");\n")
            ig.writeIndent()
            ig.w.emit("_self._type_tag = _zbr_hash(\"")
            ig.w.emit(owner)
            ig.w.emit("\");\n")
            # Initialize @once cache fields to null (synthetic; not in owner_members).
            for odecl in owner_members
                if odecl is Decl.method as omth
                    if omth.mods.is_once
                        ig.writeIndent()
                        ig.w.emit("_self._once_")
                        ig.w.emit(omth.name)
                        ig.w.emit("_val = null;\n")
        else
            # Struct init: local value
            ig.writeIndent()
            ig.w.emit("var _self: ")
            ig.w.emit(owner)
            ig.w.emit(" = undefined;\n")
        if ini.stmts as istmts
            var rs = analyzeEscapes(istmts)
            var ps = StrSet()
            for p in ini.params
                ps.add(p.name)
            var bg = ig.withMethodCtx(nil, rs, false, owner_members, ps, StrSet(), "_self")
            # Phase 17c — seed InferCtx for the init body: well (see genMethod).
            var ctx17ci = InferCtx(.module_types, owner)
            ctx17ci.withDepTypes(.dep_types)
            for pp in ini.params
                if pp.type_ != nil
                    ctx17ci.bind(pp.name, typeFromRef(pp.type_ to!))
                else
                    ctx17ci.bind(pp.name, Type_.unknown_)
            walkStmts(istmts, ctx17ci)
            bg = bg.withInferCtx(ctx17ci)
            bg.genRequireChecks(ini.require_, "init")
            # init has no user-visible `return EXPR` — pass nil return_type so any
            # `result` reference is statically rejected.
            var ec_i1 = bg.genEnsureBlock(ini.ensure_, "init", nil)
            # BUG-095: pre-fill class fields that have declared defaults
            # before running the user's `cue init` body.  Without this,
            # any field the user does not explicitly assign retains Zig's
            # `undefined` poison (0xAAAA…).  Mirrors the same pass already
            # done for the synthetic-init path.  The user's body may
            # overwrite these defaults, which is fine.
            for fdecl in owner_members
                if fdecl is Decl.var_ as fld
                    if not fld.mods.is_static and fld.init_expr != nil
                        bg.writeIndent()
                        bg.w.emit("_self.")
                        bg.w.emit(fld.name)
                        bg.w.emit(" = ")
                        bg.genExpr(fld.init_expr to!)
                        bg.w.emit(";\n")
            bg.genStmts(istmts)
            if ec_i1.armed
                ig.writeIndent()
                ig.w.emit("_ensure_armed = true;\n")
        else
            ig.genRequireChecks(ini.require_, "init")
            var ec_i2 = ig.genEnsureBlock(ini.ensure_, "init", nil)
            # BUG-095: same pre-fill for body-less `cue init` declarations.
            for fdecl in owner_members
                if fdecl is Decl.var_ as fld
                    if not fld.mods.is_static and fld.init_expr != nil
                        ig.writeIndent()
                        ig.w.emit("_self.")
                        ig.w.emit(fld.name)
                        ig.w.emit(" = ")
                        ig.genExpr(fld.init_expr to!)
                        ig.w.emit(";\n")
            if ec_i2.armed
                ig.writeIndent()
                ig.w.emit("_ensure_armed = true;\n")
        if owner_invariants.count() > 0 and not strip_contracts
            ig.writeIndent()
            ig.w.emit("_self._check_invariant();\n")
        ig.writeIndent()
        ig.w.emit("return _self;\n")
        writeIndent()
        w.emit("}\n\n")

    # ── genSig ────────────────────────────────────────────────────────────────

    def genSig(sd: DeclSig)
        writeIndent()
        w.emit("pub const ")
        w.emit(sd.name)
        w.emit(" = *const fn(")
        var first = true
        for p in sd.params
            if not first
                w.emit(", ")
            first = false
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")
        w.emit(") ")
        if sd.return_type != nil
            genType(sd.return_type to!)
        else
            w.emit("void")
        w.emit(";\n")

    # ── genNamespace ─────────────────────────────────────────────────────────
    # namespace Foo → pub const Foo = struct { ... };
    def genNamespace(ns: DeclNamespace)
        # Split dotted names ("Outer.Inner") into nested struct layers.
        # Emit indent manually (spaces) to avoid needing const-unsafe generators.
        var parts: List(str) = ns.name.split(".")
        var depth: int = 0
        while depth < parts.count()
            var part: str = parts.at(depth)
            var oi: int = 0
            while oi < indent + depth
                w.emit("    ")
                oi += 1
            w.emit("pub const ")
            w.emit(part)
            w.emit(" = struct {\n")
            depth += 1
        # Get a generator at the body indent level via chained indented() calls.
        # The assignment `ig = ig.indented()` marks ig as mutated → var ig in Zig.
        var ig = indented()
        var body_depth: int = 1
        while body_depth < depth
            ig = ig.indented()
            body_depth += 1
        for d in ns.decls
            branch d
                on Decl.method as mth
                    ig.genMethod(mth)
                on Decl.var_ as v
                    ig.genFieldDecl(v)
                on Decl.class_ as c
                    ig.genClass(c)
                on Decl.struct_ as s
                    ig.genStruct(s)
                on Decl.enum_ as e
                    ig.genEnum(e)
                on Decl.namespace_ as inner_ns
                    ig.genNamespace(inner_ns)
                else
                    pass
        # Close in reverse order (innermost first), emitting spaces manually.
        var close_depth: int = parts.count() - 1
        while close_depth >= 0
            var ci: int = 0
            while ci < indent + close_depth
                w.emit("    ")
                ci += 1
            w.emit("};\n")
            close_depth -= 1
        w.emit("\n")

    # ── genInterface ─────────────────────────────────────────────────────────
    # interface IFoo → fat-pointer vtable struct:
    #   pub const IFoo = struct {
    #       ptr: *anyopaque, vtable: *const VTable,
    #       pub const VTable = struct { method: *const fn(...) ret };
    #       pub fn method(self: @This(), ...) ret { return self.vtable.method(...); }
    #       pub fn check(comptime T: type) void { comptime { if (!@hasDecl...) } }
    #   };
    def genInterface(ifc: DeclInterface)
        var ig = indented()
        var vtig = ig.indented()
        var mig = ig.indented()

        # ── struct header ────────────────────────────────────────────────
        writeIndent()
        w.emit("pub const ")
        w.emit(ifc.name)
        w.emit(" = struct {\n")

        # ── fat-pointer fields ───────────────────────────────────────────
        ig.writeIndent()
        w.emit("ptr:    *anyopaque,\n")
        ig.writeIndent()
        w.emit("vtable: *const VTable,\n\n")

        # ── VTable inner struct ──────────────────────────────────────────
        ig.writeIndent()
        w.emit("pub const VTable = struct {\n")
        for mem in ifc.members
            if mem is Decl.method as mth
                vtig.writeIndent()
                w.emit(mth.name)
                w.emit(": *const fn (ptr: *anyopaque")
                for p in mth.params
                    w.emit(", ")
                    w.emit(p.name)
                    w.emit(": ")
                    if p.type_ != nil
                        genType(p.type_ to!)
                    else
                        w.emit("anytype")
                w.emit(") ")
                if mth.throws_
                    w.emit("anyerror!")
                if mth.return_type != nil
                    genType(mth.return_type to!)
                else
                    w.emit("void")
                w.emit(",\n")
        ig.writeIndent()
        w.emit("};\n")

        # ── forwarding methods ───────────────────────────────────────────
        for mem in ifc.members
            if mem is Decl.method as mth
                w.emit("\n")
                ig.writeIndent()
                w.emit("pub fn ")
                w.emit(mth.name)
                w.emit("(self: @This()")
                for p in mth.params
                    w.emit(", ")
                    w.emit(p.name)
                    w.emit(": ")
                    if p.type_ != nil
                        genType(p.type_ to!)
                    else
                        w.emit("anytype")
                w.emit(") ")
                if mth.throws_
                    w.emit("anyerror!")
                if mth.return_type != nil
                    genType(mth.return_type to!)
                else
                    w.emit("void")
                w.emit(" {\n")
                mig.writeIndent()
                if mth.throws_
                    w.emit("return try self.vtable.")
                else
                    w.emit("return self.vtable.")
                w.emit(mth.name)
                w.emit("(self.ptr")
                for p in mth.params
                    w.emit(", ")
                    w.emit(p.name)
                w.emit(");\n")
                ig.writeIndent()
                w.emit("}\n")

        # ── check() — comptime conformance verifier ──────────────────────
        w.emit("\n")
        ig.writeIndent()
        w.emit("pub fn check(comptime T: type) void {\n")
        var cig = ig.indented()
        cig.writeIndent()
        w.emit("comptime {\n")
        var ccig = cig.indented()
        for mem in ifc.members
            if mem is Decl.method as mth
                ccig.writeIndent()
                w.emit("if (!@hasDecl(T, \"")
                w.emit(mth.name)
                w.emit("\")) @compileError(\"type \" ++ @typeName(T) ++ \" does not implement ")
                w.emit(ifc.name)
                w.emit(".")
                w.emit(mth.name)
                w.emit("\");\n")
        cig.writeIndent()
        w.emit("}\n")
        ig.writeIndent()
        w.emit("}\n")

        # ── struct footer ────────────────────────────────────────────────
        writeIndent()
        w.emit("};\n\n")

    # ── genExtend ────────────────────────────────────────────────────────────
    # extend Type → standalone functions prefixed with _ext_Type_
    def genExtend(ext: DeclExtend)
        var tname = ""
        branch ext.target
            on TypeRef.named as n
                tname = n.name
            else
                tname = "Unknown"
        writeIndent()
        w.emit("// extend ")
        w.emit(tname)
        w.emit("\n")
        for mem in ext.members
            if mem is Decl.method as mth
                genExtMethod(tname, mth)
        w.emit("\n")

    def genExtMethod(tname: str, mth: DeclMethod)
        writeIndent()
        w.emit("fn _ext_")
        w.emit(tname)
        w.emit("_")
        w.emit(mth.name)
        w.emit("(self: ")
        # Map builtin type names to Zig types
        if tname == "str" or tname == "String"
            w.emit("[]const u8")
        else if tname == "int"
            w.emit("i64")
        else if tname == "float"
            w.emit("f64")
        else if tname == "bool"
            w.emit("bool")
        else
            w.emit(tname)
        for p in mth.params
            w.emit(", ")
            w.emit(p.name)
            w.emit(": ")
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")
        w.emit(") ")
        if mth.throws_
            w.emit("anyerror!")
        if mth.return_type != nil
            genType(mth.return_type to!)
        else
            w.emit("void")
        if mth.stmts as mstmts
            w.emit(" {\n")
            var ig = indented()
            ig.genStmts(mstmts)
            writeIndent()
            w.emit("}\n")
        else
            w.emit(" {}\n")

    # ── genParamList ──────────────────────────────────────────────────────────

    def genParamList(params: List(Param), body: List(Stmt)?)
        var first = true
        for p in params
            if not first
                w.emit(", ")
            first = false
            w.emit(p.name)
            w.emit(": ")
            # BUG-091: List(T)/HashMap(K,V) param mutated by body → emit *T
            # so .append/.put can take *Self and the caller sees changes.
            if paramNeedsAddrOf(p, body)
                w.emit("*")
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")

    # ── BUG-091: addAddrOfMutations ──────────────────────────────────────────
    # Walk stmts for any call whose ident-arg corresponds to a mutating-container
    # param of the callee.  Add those ident names to `out` so the caller-side
    # var/const decision treats them as mutated.  Without this, `&items` becomes
    # `*const ArrayList` and Zig rejects the call.
    #
    # ORDERING REQUIREMENT: addAddrOfMutationsInExpr's instance-method arm
    # (`f.helper(out)` where `f` is a local) calls `inferExpr(m.object, infer_ctx)`
    # to resolve `f` -> "Filler.helper", then looks the params/body up.  This means
    # `infer_ctx` MUST be seeded BEFORE genStmts runs -- which is currently
    # guaranteed by genMethod and genInit calling `walkStmts(...)` then
    # `withInferCtx(...)` on `bg` before invoking `bg.genStmts(...)`.  If a future
    # refactor reorders genMethod (genStmts before walkStmts), instance-dispatch
    # mutations will silently fall through to const, producing `&items` against
    # `*const ArrayList` at the call site.  The static (`Class.method`) and self
    # (`.method`) shapes do NOT depend on infer_ctx, so they continue to work.

    def addAddrOfMutationsInStmts(stmts: List(Stmt), out: StrSet)
        for s in stmts
            branch s
                on Stmt.if_ as si
                    addAddrOfMutationsInStmts(si.then_stmts, out)
                    for ei in si.else_ifs
                        addAddrOfMutationsInStmts(ei.stmts, out)
                    if si.else_stmts as se
                        addAddrOfMutationsInStmts(se, out)
                on Stmt.while_ as ww
                    addAddrOfMutationsInStmts(ww.stmts, out)
                on Stmt.for_in as fi
                    addAddrOfMutationsInStmts(fi.stmts, out)
                    if fi.else_ as fe
                        addAddrOfMutationsInStmts(fe, out)
                on Stmt.for_num as fnum
                    addAddrOfMutationsInStmts(fnum.stmts, out)
                on Stmt.branch_ as br
                    for cc in br.cases
                        addAddrOfMutationsInStmts(cc.stmts, out)
                    if br.else_ as bre
                        addAddrOfMutationsInStmts(bre, out)
                on Stmt.try_catch as tc
                    addAddrOfMutationsInStmts(tc.stmts, out)
                    for cl in tc.clauses
                        addAddrOfMutationsInStmts(cl.stmts, out)
                on Stmt.allocate_ as al2
                    addAddrOfMutationsInStmts(al2.stmts, out)
                on Stmt.copy_out as co2
                    addAddrOfMutationsInExpr(co2.target, out)
                    addAddrOfMutationsInExpr(co2.value, out)
                on Stmt.with_ as ww2
                    addAddrOfMutationsInStmts(ww2.stmts, out)
                on Stmt.in_scope as si3
                    addAddrOfMutationsInStmts(si3.stmts, out)
                on Stmt.guard_ as g2
                    addAddrOfMutationsInStmts(g2.else_stmts, out)
                on Stmt.var_ as n
                    if n.init_expr != nil
                        addAddrOfMutationsInExpr(n.init_expr to!, out)
                on Stmt.return_ as r
                    if r.value != nil
                        addAddrOfMutationsInExpr(r.value to!, out)
                on Stmt.expr as e
                    addAddrOfMutationsInExpr(e, out)
                on Stmt.assign as a3
                    addAddrOfMutationsInExpr(a3.target, out)
                    addAddrOfMutationsInExpr(a3.value, out)
                on Stmt.print_ as pp
                    var ppi = 0
                    while ppi < pp.args.count()
                        addAddrOfMutationsInExpr(pp.args.at(ppi), out)
                        ppi += 1
                on Stmt.assert_ as asr
                    addAddrOfMutationsInExpr(asr.cond, out)
                on Stmt.assert_eq_ as asr
                    addAddrOfMutationsInExpr(asr.lhs, out)
                    addAddrOfMutationsInExpr(asr.rhs, out)
                on Stmt.assert_ne_ as asr
                    addAddrOfMutationsInExpr(asr.lhs, out)
                    addAddrOfMutationsInExpr(asr.rhs, out)
                on Stmt.assert_true_ as asr
                    addAddrOfMutationsInExpr(asr.expr, out)
                on Stmt.assert_false_ as asr
                    addAddrOfMutationsInExpr(asr.expr, out)
                else
                    pass

    def addAddrOfMutationsInExpr(e: Expr, out: StrSet)
        if e is Expr.call as c
            addAddrOfMutationsInExpr(c.callee, out)
            for a in c.args
                addAddrOfMutationsInExpr(a.value, out)
            # Resolve the callee to find its params + body.
            var key: str = ""
            if c.callee is Expr.ident as id
                key = id.name
            else if c.callee is Expr.member as mem
                branch mem.object
                    on Expr.this_
                        if owner != ""
                            key = "${owner}.${mem.member}"
                    on Expr.ident as obj_id
                        if class_names.contains_(obj_id.name)
                            key = "${obj_id.name}.${mem.member}"
                        else if .infer_ctx != nil
                            var rt_a: Type_ = inferExpr(mem.object, .infer_ctx to!)
                            if rt_a is Type_.named as cn_a
                                key = "${cn_a}.${mem.member}"
                    else
                        pass
            if key != ""
                var ps = lookupFnParams(key)
                if ps != nil
                    var body = lookupFnBody(key)
                    if body != nil
                        var psl: List(Param) = ps to!
                        var pi = 0
                        var args_count = c.args.count()
                        var pli = 0
                        while pli < psl.count()
                            if pi >= args_count
                                break
                            var p = psl.at(pli)
                            var av = c.args.at(pi).value
                            if av is Expr.ident as aid
                                if paramNeedsAddrOf(p, body)
                                    out.add(aid.name)
                            pi += 1
                            pli += 1
            return
        branch e
            on Expr.binary as bx
                addAddrOfMutationsInExpr(bx.left, out)
                addAddrOfMutationsInExpr(bx.right, out)
            on Expr.unary as ux
                addAddrOfMutationsInExpr(ux.operand, out)
            on Expr.member as mx
                addAddrOfMutationsInExpr(mx.object, out)
            on Expr.index as ix
                addAddrOfMutationsInExpr(ix.object, out)
                addAddrOfMutationsInExpr(ix.index, out)
            on Expr.if_expr as ie
                addAddrOfMutationsInExpr(ie.cond, out)
                addAddrOfMutationsInExpr(ie.then_expr, out)
                addAddrOfMutationsInExpr(ie.else_expr, out)
            on Expr.orelse_ as oe
                addAddrOfMutationsInExpr(oe.expr, out)
                addAddrOfMutationsInExpr(oe.fallback, out)
            on Expr.catch_ as ce
                addAddrOfMutationsInExpr(ce.expr, out)
                addAddrOfMutationsInExpr(ce.fallback, out)
            on Expr.try_ as te
                addAddrOfMutationsInExpr(te.expr, out)
            on Expr.opt_chain as oc
                addAddrOfMutationsInExpr(oc.base, out)
                if oc.has_args
                    for a in oc.args
                        addAddrOfMutationsInExpr(a.value, out)
            on Expr.type_check as tc2
                addAddrOfMutationsInExpr(tc2.expr, out)
            on Expr.chained_cmp as cc
                for op in cc.operands
                    addAddrOfMutationsInExpr(op, out)
            else
                pass

    # ── genStmts / genStmt ────────────────────────────────────────────────────

    def genStmts(stmts: List(Stmt))
        # Per-block mutation scope: save caller's mut_set, install block-scoped one,
        # restore on exit. This prevents sibling branch arms from polluting each
        # other's const/var decisions via the method-wide mut_set.
        var saved_ms = mut_set
        var ms: StrSet = scanMutations(stmts)
        # BUG-091: idents passed as `&` to mutating-container params must be
        # declared `var`, otherwise `&items` is `*const ArrayList`.
        addAddrOfMutationsInStmts(stmts, ms)
        mut_set = ms
        # Auto-discard a local that is never read anywhere in the block and never
        # mutated.  Zig hard-errors on unused locals; translated code routinely
        # emits dead `var X = …` stubs (and unused lambda vars).  A `_ = X;` no-op
        # satisfies Zig.  Conservative (mutated OR used => no discard); a stray
        # discard would only be a harmless redundant read.  Mirrors src/CodeGen.zig.
        for s in stmts
            genStmt(s)
            if s is Stmt.var_ as n
                # Skip explicitly-typed locals: a refinement type emits an inline
                # contract check that uses the local (invisible to mightUseName).
                if n.name != "_"
                    if n.type_ == nil
                        if not ms.contains_(n.name)
                            if not mightUseName(n.name, stmts)
                                writeIndent()
                                w.emit("_ = ")
                                w.emit(n.name)
                                w.emit(";\n")
        mut_set = saved_ms

    def genStmt(s: Stmt)
        if source_file != ""
            var ln = stmtLine(s)
            if ln > 0
                w.emit("// zbr:")
                w.emit(fwdSlashes(source_file))
                w.emit(":")
                w.emit(ln.toString())
                w.emit("\n")
        branch s
            on Stmt.var_ as n
                genLocalVar(n)
            on Stmt.assign as a
                genAssign(a)
            on Stmt.return_ as r
                genReturn(r)
            on Stmt.if_ as si
                genIf(si)
            on Stmt.while_ as ww
                genWhile(ww)
            on Stmt.for_in as fi
                genForIn(fi)
            on Stmt.for_num as fn_
                genForNum(fn_)
            on Stmt.branch_ as b
                genBranch(b)
            on Stmt.print_ as p
                genPrint(p)
            on Stmt.raise_ as r
                genRaise(r)
            on Stmt.try_catch as tc
                genTryCatch(tc)
            on Stmt.assert_ as a
                genAssert(a)
            on Stmt.assert_eq_ as a
                genAssertCmp(a, true)
            on Stmt.assert_ne_ as a
                genAssertCmp(a, false)
            on Stmt.assert_true_ as a
                genAssertUnary(a, true)
            on Stmt.assert_false_ as a
                genAssertUnary(a, false)
            on Stmt.defer_ as d
                genDefer(d)
            on Stmt.with_ as ww
                genWith(ww)
            on Stmt.in_scope as si
                genInScope(si)
            on Stmt.allocate_ as al
                genAllocate(al)
            on Stmt.copy_out as co
                genCopyOut(co)
            on Stmt.guard_ as g
                genGuard(g)
            on Stmt.destruct as d
                genDestruct(d)
            on Stmt.expr as e
                # BUG-027 fix (statement-position): hoist f().method(args)
                # → var _mc_N = f(); _mc_N.method(args);
                # hoistCallOnTemp takes object by value so ^Expr auto-derefs at call site.
                var hoisted = false
                if e is Expr.call as ec
                    if ec.callee is Expr.member as mem
                        hoisted = hoistCallOnTemp(mem.object, mem.member, ec.args)
                if not hoisted
                    writeIndent()
                    # BUG-006: zig"stmt;" already ends with ";"; skip the extra one.
                    if e is Expr.zig_lit as zl
                        w.emit(zl.text)
                        if not zl.text.endsWith(";")
                            w.emit(";")
                        w.emit("\n")
                    else
                        # Zig rejects discarding a non-void expr as a statement.
                        # Try inferExpr first; fall back to structural checks for
                        # types that typeFromRef maps to unknown_ (Atomic, etc.).
                        var needs_discard = false
                        if .infer_ctx != nil
                            var stmt_t: Type_ = inferExpr(e, .infer_ctx to!)
                            if not stmt_t is Type_.void_ and not stmt_t is Type_.unknown_ and not stmt_t is Type_.unresolved and not stmt_t is Type_.context_dependent
                                needs_discard = true
                        # Atomic non-void methods: add/sub/swap return the prior
                        # value, load returns the current value, cas returns a
                        # bool.  store → void (no discard).  inferExpr can't see
                        # through Atomic(T) → unknown_, so check directly.  Set
                        # must match the bootstrap TC's non-void Atomic methods
                        # (src/TypeChecker.zig atomicElemType) so emission agrees.
                        if not needs_discard
                            if e is Expr.call as ec_at
                                if ec_at.callee is Expr.member as mem_at
                                    if mem_at.object is Expr.ident as recv_at
                                        if atomic_locals.contains_(recv_at.name)
                                            if mem_at.member == "add" or mem_at.member == "sub" or mem_at.member == "swap" or mem_at.member == "load" or mem_at.member == "cas"
                                                needs_discard = true
                        if needs_discard
                            w.emit("_ = ")
                        genExpr(e)
                        w.emit(";\n")
            on Stmt.pass_
                line("// pass")
            on Stmt.break_
                if for_else_label != nil
                    line("break :${for_else_label to!} false;")
                else
                    line("break;")
            on Stmt.continue_
                line("continue;")
            on Stmt.contract
                pass  # partitioned out in buildMethod; no-op if residual

    # ── genLocalVar ───────────────────────────────────────────────────────────

    def genLocalVar(n: DeclVar)
        # Seed infer_ctx with this variable's type so subsequent statements
        # in the same method body can resolve it via inferExpr(Expr.ident(n.name)).
        # This covers generic class instances (Box(int)(42) → Type_.named("Box"))
        # and other locally-declared class vars with no explicit annotation.
        var lv_struct_name: str = ""
        if .infer_ctx as ic_lv
            var var_t: Type_ = Type_.unknown_
            if n.type_ != nil
                var_t = typeFromRef(n.type_ to!)
            else
                if n.init_expr != nil
                    var_t = inferExpr(n.init_expr to!, ic_lv)
            if not (var_t is Type_.unknown_) and not (var_t is Type_.unresolved)
                ic_lv.bind(n.name, var_t)
            else
                # BUG-137: still record the local NAME (as unknown) so the
                # genIdent shadow guard (isLocalOrParamName) and the module-var
                # inferExpr fallback know this name is a local, not a module var.
                ic_lv.bind(n.name, Type_.unknown_)
            if var_t is Type_.named as lv_vtn
                lv_struct_name = lv_vtn
            if var_t is Type_.cross_module as lv_cm
                lv_struct_name = lv_cm.type_name
        if lv_struct_name == ""
            if n.type_ != nil
                var nvt2 = n.type_ to!
                if nvt2 is TypeRef.named as lv_tn
                    lv_struct_name = lv_tn.name
        # BUG-122: seed opt_ptr_field_bindings / ptr_field_bindings for ^T? / ^T fields
        # of named-type local vars — mirrors parameter seeding at genMethod ~line 2861.
        if lv_struct_name != ""
            var lv_dot = lv_struct_name + "."
            var orf_lv = opt_ref_fields.items()
            var orf_lvi = 0
            while orf_lvi < orf_lv.count()
                var orf_lve: str = orf_lv.at(orf_lvi)
                if orf_lve.startsWith(lv_dot)
                    opt_ptr_field_bindings.add(makeDottedKey(n.name, extractAfterDot(orf_lve)))
                orf_lvi += 1
            var rf_lv = ref_fields.items()
            var rf_lvi = 0
            while rf_lvi < rf_lv.count()
                var rf_lve: str = rf_lv.at(rf_lvi)
                if rf_lve.startsWith(lv_dot)
                    ptr_field_bindings.add(makeDottedKey(n.name, extractAfterDot(rf_lve)))
                rf_lvi += 1
        # BUG-079: auto-hoist method chains on call temporaries.
        # If init_expr is `someCall().method(args)`, materialize someCall() first.
        var mc_recv = ""
        var mc_field = ""
        var mc_throws: bool = false
        if n.init_expr != nil
            var ch = tryChain(n.init_expr to!)
            if ch != nil
                var chain = ch to!
                mc_recv = hoistCallChain(chain.recv)
                mc_field = chain.method
                if .infer_ctx != nil
                    var recv_t: Type_ = inferExpr(chain.recv, .infer_ctx to!)
                    if recv_t is Type_.named as cn
                        if isClassMethodThrows(cn, chain.method)
                            mc_throws = true
        # Mutable fn-ref vars: Zig requires `*const fn(P) R` type.
        # Detect `var pred = isAlpha` where isAlpha is a top-level def,
        # and emit `var pred: @TypeOf(&isAlpha) = &isAlpha;` instead.
        var is_mut = false
        if mut_set != nil
            is_mut = mut_set to!.contains_(n.name)
        if n.is_const
            is_mut = false
        if is_mut and n.init_expr != nil and not n.is_const
            if n.init_expr to! is Expr.ident as fid
                if isTopLevelMethod(fid.name)
                    writeIndent()
                    w.emit("var " + n.name + ": @TypeOf(&" + fid.name + ") = &" + fid.name + ";\n")
                    return
        # Interface coercion: `var x: IFace = ClassCtor()` or `var x: ^IFace = ClassCtor()`
        if n.init_expr != nil
            if n.type_ != nil
                var iinit = n.init_expr to!
                if iinit is Expr.call as ic
                    if ic.callee is Expr.ident as iid
                        var iclass_name = iid.name
                        var itr = n.type_ to!
                        if itr is TypeRef.named as itn
                            var ifc = findInterfaceDecl(itn.name)
                            if ifc != nil
                                var ikw: str = "const"
                                if is_mut
                                    ikw = "var"
                                writeIndent()
                                w.emit(ikw + " " + n.name + ": " + itn.name + " = .{ .ptr = " + iclass_name + ".init(), .vtable = &_vtable_" + iclass_name + "_" + itn.name + " };\n")
                                return
                        if itr is TypeRef.ref_to as irto
                            if irto is TypeRef.named as irtn
                                var ifc2 = findInterfaceDecl(irtn.name)
                                if ifc2 != nil
                                    var iuid = w.nextUid()
                                    var ikw2: str = "const"
                                    if is_mut
                                        ikw2 = "var"
                                    writeIndent()
                                    w.emit("const _iface_" + iuid.toString() + " = _allocator.create(" + irtn.name + ") catch @panic(\"OOM\");\n")
                                    writeIndent()
                                    w.emit("_iface_" + iuid.toString() + ".* = .{ .ptr = " + iclass_name + ".init(), .vtable = &_vtable_" + iclass_name + "_" + irtn.name + " };\n")
                                    writeIndent()
                                    w.emit(ikw2 + " " + n.name + ": *" + irtn.name + " = _iface_" + iuid.toString() + ";\n")
                                    return
        writeIndent()
        # const vs var already computed above
        if is_mut
            w.emit("var ")
        else
            w.emit("const ")
        w.emit(n.name)
        # Track local str/List-tuple/StrSet variables for type-aware codegen
        # Must happen BEFORE early-return paths (StringBuilder, generic stdlib ctor)
        if n.type_ != nil
            branch n.type_ to!
                on TypeRef.named as tn
                    if tn.name == "str" or tn.name == "String"
                        str_params.add(n.name)
                    if tn.name == "StrSet"
                        strset_locals.add(n.name)
                    if tn.name == "ThreadPool"
                        thread_pool_locals.add(n.name)
                on TypeRef.generic as gtn
                    if gtn.name == "List"
                        if gtn.args.count() > 0
                            if gtn.args.at(0) is TypeRef.tuple as ttr
                                list_tuple_locals.add(n.name)
                                var tpos = 0
                                for telem in ttr.elems
                                    if telem is TypeRef.named as ten
                                        if ten.name == "str" or ten.name == "String"
                                            list_tuple_str_pos.add("${n.name}:${tpos.toString()}")
                                    tpos = tpos + 1
                    if gtn.name == "Chan"
                        chan_locals.add(n.name)
                    if gtn.name == "Atomic"
                        atomic_locals.add(n.name)
                    if gtn.name == "ThreadPool"
                        thread_pool_locals.add(n.name)
                else
                    pass
        # Track DynLib handle variables for instance method dispatch.
        if n.init_expr != nil
            var dynlib_ie = n.init_expr to!
            if dynlib_ie is Expr.call as dynlib_c
                if dynlib_c.callee is Expr.member as dynlib_m
                    if dynlib_m.object is Expr.ident as dynlib_id
                        if dynlib_id.name == "DynLib" and dynlib_m.member == "open"
                            dynlib_vars.add(n.name)
        # Track DateTime variables so field access (.year/.month etc.) emits _dt_to_gregorian(v.epoch_ms).field
        if n.init_expr != nil
            if isDateTimeExpr(n.init_expr to!)
                .datetime_vars.add(n.name)
        # Detect StrSet from init expression (StrSet() has no type annotation)
        if n.init_expr != nil
            if isStrSetCtor(n.init_expr to!)
                strset_locals.add(n.name)
        # Detect string vars from init expression (var x = "" or var x = "literal")
        if n.init_expr != nil
            if .isStringBoth(n.init_expr to!, "var_decl")
                str_params.add(n.name)
        # Track capture-lambda vars for .call() dispatch at call sites
        # AND for Gap 1 closure-to-sig thunking.
        if n.init_expr != nil
            if n.init_expr to! is Expr.lambda as lam
                if lam.captures.count() > 0
                    closure_vars.add(n.name)
                    closure_lambdas.set(n.name, lam)
        # Special-case: StringBuilder() constructor
        if n.init_expr != nil
            var ie = n.init_expr to!
            if isStringBuilderCtor(ie)
                w.emit(" = std.ArrayList(u8).empty;\n")
                return
            if isGenericStdlibCtor(ie)
                w.emit(" = ")
                genGenericCtorExpr(ie, n.type_)
                w.emit(";\n")
                return
            # `var x: List(T) = [a, b, c]` (or `[]`) — the LHS annotation
            # provides the element type, which the literal's expression-
            # position emit can't see.  We emit the var with its declared
            # type, then a chain of `.append(...)` calls.
            if n.type_ != nil
                if (n.type_ to!) is TypeRef.generic as gtll
                    if gtll.name == "List"
                        if ie is Expr.list_lit as ll_init
                            w.emit(": ")
                            genType(n.type_ to!)
                            w.emit(" = ")
                            genType(n.type_ to!)
                            w.emit(".empty;\n")
                            var lli = 0
                            while lli < ll_init.elems.count()
                                writeIndent()
                                w.emit(n.name + ".append(_allocator, ")
                                genExpr(ll_init.elems.at(lli))
                                w.emit(") catch @panic(\"OOM\");\n")
                                lli += 1
                            return
            # BUG-092: var lines: List(str) = s.split(sep) / s.lines() —
            # auto-collect SplitIterator into an ArrayList.  Use a labeled
            # block so const/var both work (the outer var holds the result;
            # the block's local _ll_N is mutated then break-returned).
            if n.type_ != nil
                if ie is Expr.call as ec092
                    if (n.type_ to!) is TypeRef.generic as gt092
                        if gt092.name == "List"
                            if ec092.callee is Expr.member as mem092
                                if mem092.member == "split" or mem092.member == "lines"
                                    var uid092 = w.nextUid()
                                    var lbl092: str = "blk092_${uid092.toString()}"
                                    var lname092: str = "_ll_${uid092.toString()}"
                                    var sname092: str = "_split_iter_${uid092.toString()}"
                                    var ename092: str = "_se_${uid092.toString()}"
                                    w.emit(": ")
                                    genType(n.type_ to!)
                                    w.emit(" = ")
                                    w.emit(lbl092)
                                    w.emit(": { var ")
                                    w.emit(lname092)
                                    w.emit(": ")
                                    genType(n.type_ to!)
                                    w.emit(" = ")
                                    genType(n.type_ to!)
                                    w.emit(".empty; var ")
                                    w.emit(sname092)
                                    w.emit(" = ")
                                    genExpr(ie)
                                    w.emit("; while (")
                                    w.emit(sname092)
                                    w.emit(".next()) |")
                                    w.emit(ename092)
                                    w.emit("| { ")
                                    w.emit(lname092)
                                    w.emit(".append(_allocator, ")
                                    w.emit(ename092)
                                    w.emit(") catch @panic(\"OOM\"); } break :")
                                    w.emit(lbl092)
                                    w.emit(" ")
                                    w.emit(lname092)
                                    w.emit("; };\n")
                                    return
        # Type annotation if present
        if n.type_ != nil and n.init_expr == nil
            w.emit(": ")
            genType(n.type_ to!)
            w.emit(" = undefined;\n")
            return
        # When init is a zig literal and declared type is a class, skip the type annotation.
        # zig"Greeter{}" returns a value; emitting `: *Greeter` would cause a type mismatch.
        var skip_type_ann = false
        if n.type_ != nil and n.init_expr != nil
            branch n.init_expr to!
                on Expr.zig_lit
                    if n.type_ to! is TypeRef.named as tn
                        if class_names.contains_(tn.name)
                            skip_type_ann = true
                else
                    pass
        if n.type_ != nil and not skip_type_ann
            w.emit(": ")
            genType(n.type_ to!)
        else if n.init_expr != nil
            # No type annotation — if init is a literal, emit explicit type
            # to avoid comptime_int/comptime_float or *const [N:0]u8 issues in Zig.
            branch n.init_expr to!
                on Expr.int_lit
                    w.emit(": i64")
                on Expr.float_lit
                    w.emit(": f64")
                on Expr.string_lit
                    w.emit(": []const u8")
                on Expr.unary as un
                    # BUG-127: `var x = -6.0` wraps the literal in a neg-unary,
                    # so the literal-shape checks above miss it.  A `var`
                    # bound to a bare `(-6.0)` stays comptime_float and Zig
                    # rejects it.  Recurse into the operand for neg of a
                    # numeric literal and emit the same annotation.  Use
                    # `branch` (not `is`) on the ^Expr operand so the deref
                    # round-trips identically under bootstrap and selfhost.
                    if un.op == UnaryOp.neg
                        branch un.operand
                            on Expr.int_lit
                                w.emit(": i64")
                            on Expr.float_lit
                                w.emit(": f64")
                            else
                                pass
                else
                    pass
        w.emit(" = ")
        if mc_recv.len > 0
            if mc_throws and current_method_throws and try_block_label == nil and not in_try_expr
                w.emit("try ")
            w.emit("${mc_recv}.${mc_field}(")
            if n.init_expr != nil
                var ch2 = tryChain(n.init_expr to!)
                if ch2 != nil
                    var chain2 = ch2 to!
                    genArgList(chain2.args)
            w.emit(")")
        else if n.init_expr != nil
            genExpr(n.init_expr to!)
            # Inside a try block: if init is a direct throws call, redirect the error.
            if try_block_label != nil and not in_try_expr
                var init_is_throws = false
                if n.init_expr to! is Expr.call as ic
                    if ic.callee is Expr.ident as iid
                        if isTopLevelMethodThrows(iid.name)
                            init_is_throws = true
                if init_is_throws
                    emitTryBlockCatch()
        else
            w.emit("undefined")
        w.emit(";\n")
        # Type alias constraint check: { const value = varname; if (!(cond)) panic; }
        if not strip_contracts
            if n.type_ != nil
                var alias_lookup_name: str = ""
                var alias_value_args: List(Expr) = List(Expr)()
                branch n.type_ to!
                    on TypeRef.named as alias_tn
                        alias_lookup_name = alias_tn.name
                    on TypeRef.alias_applied as aa
                        alias_lookup_name = aa.name
                        alias_value_args = aa.args
                    else
                        pass
                if alias_lookup_name != ""
                    var alias_decl = findTypeAlias(alias_lookup_name)
                    if alias_decl != nil
                        genTypeAliasConstraint(alias_decl to!, alias_lookup_name, n.name, alias_value_args)

    # Emits the constraint-check block for a type alias local variable.
    # value_args: the literal args from TypeRef.alias_applied (empty for non-parametric aliases).
    def genTypeAliasConstraint(alias_decl: DeclTypeAlias, alias_name: str, var_name: str, value_args: List(Expr))
        if alias_decl.constraint == nil
            return
        var ig = indented()
        # Seed str_params so `value.len` emits `.len` not `.items.len`
        # when the alias base is str (isKnownListField fires on "value").
        var base_t = typeFromRef(alias_decl.base)
        if base_t is Type_.string_
            ig.str_params.add("value")
        if ig.infer_ctx != nil
            ig.infer_ctx to!.bind("value", base_t)
        writeIndent()
        w.emit("{\n")
        # Emit const bindings for value params (e.g. `const lo: i64 = 0;`)
        var pi = 0
        while pi < alias_decl.params.count() and pi < value_args.count()
            ig.writeIndent()
            var p = alias_decl.params.at(pi)
            w.emit("const " + p.name + ": ")
            if p.type_ != nil
                ig.genType(p.type_ to!)
            else
                w.emit("i64")
            w.emit(" = ")
            ig.genExpr(value_args.at(pi))
            w.emit(";\n")
            pi += 1
        ig.writeIndent()
        w.emit("const value = " + var_name + ";\n")
        ig.writeIndent()
        w.emit("if (!(")
        ig.genExpr(alias_decl.constraint to!)
        w.emit(")) std.debug.panic(\"type constraint '" + alias_name + "' failed\\n\", .{});\n")
        writeIndent()
        w.emit("}\n")

    # Returns true if `name` is a top-level `def` in the current module.
    # Used to detect bare function-name expressions (fn_ref) in local var inits
    # and assignments — Zig requires `&funcName` / `@TypeOf(&funcName)` for those.
    def isTopLevelMethod(name: str): bool
        for decl in module_decls
            if decl is Decl.method as m
                if m.name == name
                    return true
        return false

    def isTopLevelMethodThrows(name: str): bool
        for decl in module_decls
            if decl is Decl.method as m
                if m.name == name
                    return m.throws_
        return false

    def isStringBuilderCtor(e: Expr): bool
        if e is Expr.call as c
            if c.args.count() == 0
                if c.callee is Expr.ident as id
                    return id.name == "StringBuilder"
        return false

    def isStrSetCtor(e: Expr): bool
        if e is Expr.call as c
            if c.args.count() == 0
                if c.callee is Expr.ident as id
                    return id.name == "StrSet"
        return false

    # Returns true if the expression produces a _DateTime value.
    # Used to route field access (.year/.month/.day/.hour/.minute/.second/.weekday)
    # through _dt_to_gregorian / _dt_weekday instead of direct struct access.
    def isDateTimeExpr(e: Expr): bool
        if e is Expr.ident as id
            return .datetime_vars.contains_(id.name)
        if e is Expr.call as c
            if c.callee is Expr.member as m
                # DateTime.fromEpoch / DateTime.of / DateTime.now
                if m.object is Expr.ident as cid
                    if cid.name == "DateTime"
                        return true
                # obj.inZone / obj.addDays / obj.addHours / obj.addMinutes /
                # obj.addSeconds / obj.addMonths / obj.addYears → all return _DateTime
                if m.member == "inZone" or m.member == "addDays" or m.member == "addHours"
                    return true
                if m.member == "addMinutes" or m.member == "addSeconds"
                    return true
                if m.member == "addMonths" or m.member == "addYears"
                    return true
        return false

    # Returns the type-arg names for `HashMap(K,V)()` init expressions (no type annotation).
    # Returns nil if the expression is not a HashMap constructor call.
    def getHashMapCtorArgs(e: Expr): List(str)?
        if e is Expr.call as outer
            if outer.args.count() == 0
                if outer.callee is Expr.call as inner
                    if inner.callee is Expr.ident as id
                        if id.name == "HashMap"
                            var out = List(str)()
                            for a in inner.args
                                if a.value is Expr.ident as ai
                                    out.add(ai.name)
                            return out
        return nil

    def isGenericStdlibCtor(e: Expr): bool
        # List(T)() or HashMap(K,V)() or StrSet()
        # Also bare List() / HashMap() where type is inferred from the variable annotation
        if e is Expr.call as outer
            if outer.args.count() == 0
                branch outer.callee
                    on Expr.call as inner
                        if inner.callee is Expr.ident as id
                            return id.name == "List" or id.name == "HashMap"
                    on Expr.ident as id
                        return id.name == "StrSet" or id.name == "List" or id.name == "HashMap"
                    else
                        pass
        return false

    def genGenericCtorExpr(e: Expr, type_hint: TypeRef?)
        if e is Expr.call as outer
            branch outer.callee
                on Expr.call as inner
                    if inner.callee is Expr.ident as id
                        if id.name == "List"
                            w.emit("std.ArrayList(")
                            if inner.args.count() > 0
                                genTypeFromExpr(inner.args.at(0).value)
                            else
                                w.emit("anytype")
                            w.emit(").empty")
                            return
                        if id.name == "HashMap"
                            var key_str = inner.args.count() > 0 and isStringArgExpr(inner.args.at(0).value)
                            if key_str
                                w.emit("std.StringHashMap(")
                                if inner.args.count() >= 2
                                    genTypeFromExpr(inner.args.at(1).value)
                                else
                                    w.emit("anytype")
                            else
                                w.emit("std.AutoHashMap(")
                                var fi = true
                                for ta in inner.args
                                    if not fi
                                        w.emit(", ")
                                    fi = false
                                    genTypeFromExpr(ta.value)
                            w.emit(").init(_allocator)")
                            return
                on Expr.ident as id
                    if id.name == "StrSet"
                        w.emit("StrSet.init()")
                        return
                    # Bare List() or HashMap() — use type_hint from variable declaration
                    if id.name == "List"
                        w.emit("std.ArrayList(")
                        if type_hint != nil
                            branch type_hint to!
                                on TypeRef.generic as gtr
                                    if gtr.args.count() > 0
                                        genType(gtr.args.at(0))
                                    else
                                        w.emit("anytype")
                                else
                                    w.emit("anytype")
                        else
                            w.emit("anytype")
                        w.emit(").empty")
                        return
                    if id.name == "HashMap"
                        if type_hint != nil
                            branch type_hint to!
                                on TypeRef.generic as gtr
                                    var key_is_str = gtr.args.count() > 0 and isStringTypeRef(gtr.args.at(0))
                                    if key_is_str
                                        w.emit("std.StringHashMap(")
                                        if gtr.args.count() >= 2
                                            genType(gtr.args.at(1))
                                        else
                                            w.emit("anytype")
                                    else
                                        w.emit("std.AutoHashMap(")
                                        var fi = true
                                        for ta in gtr.args
                                            if not fi
                                                w.emit(", ")
                                            fi = false
                                            genType(ta)
                                else
                                    w.emit("std.AutoHashMap(anytype, anytype")
                        else
                            w.emit("std.AutoHashMap(anytype, anytype")
                        w.emit(").init(_allocator)")
                        return
                else
                    pass
        # Fallback: normal expr
        genExpr(e)

    def isStringArgExpr(e: Expr): bool
        if e is Expr.ident as id
            return id.name == "str" or id.name == "String"
        return false

    def genTypeFromExpr(e: Expr)
        branch e
            on Expr.ident as id
                if class_names.contains_(id.name)
                    w.emit("*${id.name}")
                    return
                w.emit(zigPrimitive(id.name))
            on Expr.tuple_lit as tl
                # Tuple type annotation in expression position: `(int, str)` → `struct { i64, []const u8 }`
                w.emit("struct { ")
                var fi = true
                for elem in tl.elems
                    if not fi
                        w.emit(", ")
                    fi = false
                    genTypeFromExpr(elem)
                w.emit(" }")
            on Expr.call as c
                branch c.callee
                    on Expr.ident as id
                        if id.name == "List"
                            w.emit("std.ArrayList(")
                            if c.args.count() > 0
                                genTypeFromExpr(c.args.at(0).value)
                            w.emit(")")
                            return
                        if id.name == "HashMap"
                            var ks = c.args.count() > 0 and isStringArgExpr(c.args.at(0).value)
                            if ks
                                w.emit("std.StringHashMap(")
                                if c.args.count() >= 2
                                    genTypeFromExpr(c.args.at(1).value)
                                else
                                    w.emit("anytype")
                            else
                                w.emit("std.AutoHashMap(")
                                var fi = true
                                for ta in c.args
                                    if not fi
                                        w.emit(", ")
                                    fi = false
                                    genTypeFromExpr(ta.value)
                            w.emit(")")
                            return
                        w.emit(id.name)
                    else
                        genExpr(e)
            else
                genExpr(e)

    # ── genAssign ─────────────────────────────────────────────────────────────

    def genAssign(a: StmtAssign)
        # BUG-079: auto-hoist method chain on struct temporary in assignment RHS
        if a.op == AssignOp.assign
            var ch = tryChain(a.value)
            if ch != nil
                var chain = ch to!
                var mc_recv = hoistCallChain(chain.recv)
                writeIndent()
                genExpr(a.target)
                w.emit(" = ${mc_recv}.${chain.method}(")
                genArgList(chain.args)
                w.emit(");\n")
                return
        writeIndent()
        if a.op == AssignOp.slashslash_eq
            genExpr(a.target)
            w.emit(" = @divTrunc(")
            genExpr(a.target)
            w.emit(", ")
            genExpr(a.value)
            w.emit(");\n")
            return
        if a.op == AssignOp.starstar_eq
            genExpr(a.target)
            w.emit(" = std.math.pow(i64, ")
            genExpr(a.target)
            w.emit(", ")
            genExpr(a.value)
            w.emit(");\n")
            return
        # Detect HashMap[key] = value → .put(key, value)
        if a.op == AssignOp.assign
            if genHashMapAssign(a.target, a.value)
                return
        # Detect bare collection ctor in field assignment: self.field = List()/HashMap()/StrSet()
        if a.op == AssignOp.assign
            var field_type = getAssignFieldType(a)
            if field_type != nil
                if a.value is Expr.call as vc
                    if vc.args.count() == 0
                        if vc.callee is Expr.ident as vid
                            if vid.name == "List" or vid.name == "HashMap" or vid.name == "StrSet"
                                genExpr(a.target)
                                w.emit(" = ")
                                genCallWithTypeHint(a.value, field_type to!)
                                w.emit(";\n")
                                return
        genExpr(a.target)
        w.emit(" ")
        w.emit(assignOpStr(a.op))
        w.emit(" ")
        # fn-ref reassignment: `pred = isDigit` → `pred = &isDigit`
        # Mutable fn-ref vars have type `*const fn(P) R`; bare function
        # names are function values, so we need `&` to take a pointer.
        if a.op == AssignOp.assign
            if a.value is Expr.ident as vid
                if isTopLevelMethod(vid.name)
                    w.emit("&")
                    w.emit(vid.name)
                    w.emit(";\n")
                    return
        if a.op == AssignOp.assign and isStringField(a.target)
            w.emit("_intern(")
            genExpr(a.value)
            w.emit(")")
        else
            genExpr(a.value)
        w.emit(";\n")

    def genHashMapAssign(target: Expr, value: Expr): bool
        # Branch directly on target (Expr parameter) so ix.object/ix.index get correct .* deref
        if target is Expr.index as ix
            var nm = getMemberFieldName(ix.object)
            if nm != nil
                if fieldAwareIsHashMap(nm to!)
                    genExpr(ix.object)
                    w.emit(".put(")
                    genExpr(ix.index)
                    w.emit(", ")
                    genExpr(value)
                    w.emit(") catch @panic(\"OOM\");\n")
                    return true
        return false

    def getAssignFieldType(a: StmtAssign): TypeRef?
        # If target is a member expression (self.field), extract field name and look up type
        var fname = getMemberFieldName(a.target)
        if fname != nil
            return lookupFieldType(fname to!)
        return nil

    def isStringField(e: Expr): bool
        var fname = getMemberFieldName(e)
        if fname != nil
            var ftype = lookupFieldType(fname to!)
            if ftype != nil
                if ftype to! is TypeRef.named as nt
                    return nt.name == "str" or nt.name == "String"
        return false

    def isListField(field_name: str): bool
        var ftype = lookupFieldType(field_name)
        if ftype != nil
            if ftype to! is TypeRef.generic as gtr
                return gtr.name == "List"
        return false

    # BUG-140: class-scoped "is this field of the CURRENT class a HashMap?"
    # (parallel to isListField). Used by fieldAwareIsHashMap to avoid the
    # name-based false-positive across classes with same-named fields.
    def isHashMapField(field_name: str): bool
        var ftype = lookupFieldType(field_name)
        if ftype != nil
            if ftype to! is TypeRef.generic as gtr
                return gtr.name == "HashMap"
        return false

    # BUG-140: class-qualified HashMap dispatch (the sibling of the BUG-138 List
    # fix). A local var shadows any same-named field, so its type wins. Then, if
    # `name` is a field of the CURRENT class, its declared type is authoritative
    # — do NOT fall through to the global name-based fieldIsHashMap, which
    # false-positives on a same-named HashMap field of another class.
    def fieldAwareIsHashMap(name: str): bool
        if .infer_ctx != nil
            if (.infer_ctx to!).hasLocal(name)
                return localIsHashMap(name)
        if isFieldName(name)
            return isHashMapField(name)
        return localIsHashMap(name) or fieldIsHashMap(.module_types, .dep_types, name)

    # BUG-141: class-qualified List dispatch for index-read (`obj[i]` → `.items[i]`
    # for a List receiver). Same precedence as fieldAwareIsHashMap: a local var
    # shadows any same-named field; then a field of the CURRENT class is
    # authoritative; else fall back to the module-type tables.
    def fieldAwareIsList(name: str): bool
        if .infer_ctx != nil
            if (.infer_ctx to!).hasLocal(name)
                return localIsList(name)
        if isFieldName(name)
            return isListField(name)
        return localIsList(name) or fieldIsList(.module_types, .dep_types, name)

    def localIsHashMap(name: str): bool
        if .infer_ctx != nil
            var lhm_c = .infer_ctx to!
            if lhm_c.hasLocal(name)
                return lhm_c.localType(name) is Type_.hashmap_
        return false

    def localIsList(name: str): bool
        if .infer_ctx != nil
            var ll_c = .infer_ctx to!
            if ll_c.hasLocal(name)
                return ll_c.localType(name) is Type_.list_
        return false

    def localIsListStr(name: str): bool
        if .infer_ctx != nil
            var lls_c = .infer_ctx to!
            if lls_c.hasLocal(name)
                var lls_t: Type_ = lls_c.localType(name)
                if lls_t is Type_.list_ as lls_elem
                    return lls_elem is Type_.string_
        return false

    def localIsHashMapStrKey(name: str): bool
        if .infer_ctx != nil
            var lhsk_c = .infer_ctx to!
            if lhsk_c.hasLocal(name)
                var lhsk_t: Type_ = lhsk_c.localType(name)
                if lhsk_t is Type_.hashmap_ as lhsk_hm
                    return lhsk_hm.key_t is Type_.string_
        return false

    def localIsHashMapStrVal(name: str): bool
        if .infer_ctx != nil
            var lhsv_c = .infer_ctx to!
            if lhsv_c.hasLocal(name)
                var lhsv_t: Type_ = lhsv_c.localType(name)
                if lhsv_t is Type_.hashmap_ as lhsv_hm
                    return lhsv_hm.val_t is Type_.string_
        return false

    def localIsListRef(name: str): bool
        if .infer_ctx != nil
            var llr_c = .infer_ctx to!
            if llr_c.hasLocal(name)
                var llr_t: Type_ = llr_c.localType(name)
                if llr_t is Type_.list_ as llr_elem
                    branch llr_elem
                        on Type_.ref_to
                            return true
                        else
                            return false
        return false

    def localListRefType(name: str): str
        if .infer_ctx != nil
            var llrt_c = .infer_ctx to!
            if llrt_c.hasLocal(name)
                var llrt_t: Type_ = llrt_c.localType(name)
                if llrt_t is Type_.list_ as llrt_elem
                    if llrt_elem is Type_.ref_to as llrt_inner
                        if llrt_inner is Type_.named as llrt_tname
                            return llrt_tname
        return ""

    def isOwnerMethod(name: str): bool
        for d in owner_members
            if d is Decl.method as dm
                if dm.name == name
                    return true
        return false

    def isOwnerSharedMethod(name: str): bool
        for d in owner_members
            if d is Decl.method as dm
                if dm.name == name
                    return dm.mods.is_static
        return false

    def isOwnerMethodThrows(name: str): bool
        for d in owner_members
            if d is Decl.method as dm
                if dm.name == name
                    return dm.throws_
        return false

    # Look up if a same-module class method throws (pre-populated at module init).
    def isClassMethodThrows(class_name: str, method_name: str): bool
        return throws_methods.contains_(makeDottedKey(class_name, method_name))

    def lookupFieldType(field_name: str): TypeRef?
        for d in owner_members
            if d is Decl.var_ as fld
                if fld.name == field_name
                    return fld.type_
        return nil

    # Look up a struct field's TypeRef by struct name and field name using module_decls.
    # Used in struct literals (Pattern 1a) where owner_members is the enclosing struct, not the target.
    def lookupStructFieldType(struct_name: str, field_name: str): TypeRef?
        for decl in module_decls
            if decl is Decl.struct_ as s
                if s.name == struct_name
                    for mem in s.members
                        if mem is Decl.var_ as fld
                            if fld.name == field_name
                                return fld.type_
        return nil

    def genCallWithTypeHint(e: Expr, hint: TypeRef)
        if e is Expr.call as c
            if c.args.count() == 0
                if c.callee is Expr.ident as id
                    if id.name == "List"
                        w.emit("std.ArrayList(")
                        branch hint
                            on TypeRef.generic as gtr
                                if gtr.args.count() > 0
                                    genType(gtr.args.at(0))
                                else
                                    w.emit("anytype")
                            else
                                w.emit("anytype")
                        w.emit(").empty")
                        return
                    if id.name == "HashMap"
                        branch hint
                            on TypeRef.generic as gtr
                                var key_is_str = gtr.args.count() > 0 and isStringTypeRef(gtr.args.at(0))
                                if key_is_str
                                    w.emit("std.StringHashMap(")
                                    if gtr.args.count() >= 2
                                        genType(gtr.args.at(1))
                                    else
                                        w.emit("anytype")
                                else
                                    w.emit("std.AutoHashMap(")
                                    var fi = true
                                    for ta in gtr.args
                                        if not fi
                                            w.emit(", ")
                                        fi = false
                                        genType(ta)
                            else
                                w.emit("std.AutoHashMap(anytype, anytype")
                        w.emit(").init(_allocator)")
                        return
                    if id.name == "StrSet"
                        w.emit("StrSet.init()")
                        return
        genExpr(e)

    # ── genReturn ─────────────────────────────────────────────────────────────

    def genReturn(r: StmtReturn)
        # Contract `result` capture: when the current function has an ensure
        # referencing `result`, capture the value and arm the flag before returning.
        if ensure_armed_active and ensure_uses_result and r.value != nil
            writeIndent()
            w.emit("{ _result = ")
            if method_return_type != nil
                genCallWithTypeHint(r.value to!, method_return_type to!)
            else
                genExpr(r.value to!)
            w.emit("; _ensure_armed = true; return _result; }\n")
            return
        # Plain ensure-armed path (no result capture): arm before existing return logic.
        if ensure_armed_active
            writeIndent()
            w.emit("_ensure_armed = true;\n")
        # BUG-079: auto-hoist method chain on struct temporary in return position.
        # Only applies to named class types — string/list/hashmap stdlib chains must
        # go through genMemberCall (which dispatches to std.mem.replaceOwned etc.).
        if r.value != nil
            var ch = tryChain(r.value to!)
            if ch != nil
                var chain = ch to!
                var should_hoist = true
                if .infer_ctx != nil
                    var recv_t: Type_ = inferExpr(chain.recv, .infer_ctx to!)
                    if not (recv_t is Type_.named)
                        should_hoist = false
                if should_hoist
                    var mc_recv = hoistCallChain(chain.recv)
                    writeIndent()
                    w.emit("return ${mc_recv}.${chain.method}(")
                    genArgList(chain.args)
                    w.emit(");\n")
                    return
        # Interface pointer coercion: `return ClassCtor()` when ret type is `^IFace`
        if r.value != nil
            if method_return_type != nil
                var ret = method_return_type to!
                if ret is TypeRef.ref_to as rtr
                    if rtr is TypeRef.named as rtn
                        var rfc = findInterfaceDecl(rtn.name)
                        if rfc != nil
                            var rv = r.value to!
                            if rv is Expr.call as rvc
                                if rvc.callee is Expr.ident as rvid
                                    var ruid = w.nextUid()
                                    writeIndent()
                                    w.emit("const _iface_" + ruid.toString() + " = _allocator.create(" + rtn.name + ") catch @panic(\"OOM\");\n")
                                    writeIndent()
                                    w.emit("_iface_" + ruid.toString() + ".* = .{ .ptr = " + rvid.name + ".init(), .vtable = &_vtable_" + rvid.name + "_" + rtn.name + " };\n")
                                    writeIndent()
                                    w.emit("return _iface_" + ruid.toString() + ";\n")
                                    return
        writeIndent()
        if r.value != nil
            w.emit("return ")
            if method_return_type != nil
                genCallWithTypeHint(r.value to!, method_return_type to!)
            else
                genExpr(r.value to!)
            w.emit(";\n")
        else
            w.emit("return;\n")

    # BUG-027 fix: takes object by value so a ^Expr caller auto-derefs at call site.
    # Emits `var _mc_N = obj_call; _mc_N.method(args);` and returns true.
    # Returns false if obj is not a call expression (no hoisting needed).
    def hoistCallOnTemp(obj: Expr, method_name: String, call_args: List(Arg)): bool
        branch obj
            on Expr.call
                var uid = w.nextUid()
                var mc = "_mc_${uid.toString()}"
                writeIndent()
                w.emit("var ${mc} = ")
                genExpr(obj)
                w.emit(";\n")
                writeIndent()
                var stmt_is_throws: bool = false
                if .infer_ctx != nil
                    var recv_t: Type_ = inferExpr(obj, .infer_ctx to!)
                    if recv_t is Type_.named as recv_cn
                        if isClassMethodThrows(recv_cn, method_name)
                            stmt_is_throws = true
                if stmt_is_throws and current_method_throws and try_block_label == nil and not in_try_expr
                    w.emit("try ")
                w.emit("${mc}.${method_name}(")
                genArgList(call_args)
                w.emit(");\n")
                return true
            else
                return false

    # BUG-079: Recursively hoist a call chain to temporaries, returning the last temp name.
    # For a plain call (not a method-on-call), emits `var _mc_N = <expr>;` and returns "_mc_N".
    # For MethodCall(object=Call, ...), hoists the inner chain first, then hoists this level.
    # Takes expr by value so ^Expr callers auto-deref at the call site.
    def hoistCallChain(expr: Expr): String
        var ch = tryChain(expr)
        if ch != nil
            var chain = ch to!
            var inner = hoistCallChain(chain.recv)
            var uid = w.nextUid()
            var mc = "_mc_${uid.toString()}"
            writeIndent()
            w.emit("var ${mc} = ${inner}.${chain.method}(")
            genArgList(chain.args)
            w.emit(");\n")
            return mc
        # Base case: emit a temp for the plain expression
        var uid = w.nextUid()
        var mc = "_mc_${uid.toString()}"
        writeIndent()
        w.emit("var ${mc} = ")
        genExpr(expr)
        w.emit(";\n")
        return mc

    # ── genIf ─────────────────────────────────────────────────────────────────

    def genIsCaptureThen(cond_expr: Expr, cap: String, stmts: List(Stmt))
        # Helper called from genIf when is_capture is set.
        # Takes Expr by value so callers with ^Expr get auto-deref at the call site.
        # BUG-137: the capture binding shadows any same-named module var.
        .noteShadowLocal(cap)
        branch cond_expr
            on Expr.type_check as tc
                if tc.variant_name != nil
                    # Union-variant check: `if x is Union.Variant as cap`
                    var variant = tc.variant_name to!
                    var union_nm = tc.type_name
                    w.emit("if (")
                    genExpr(tc.expr)
                    w.emit(" == .")
                    w.emit(variant)
                    w.emit(") {\n")
                    var ig = indented()
                    ig.writeIndent()
                    var variant_key = union_nm + "." + variant
                    if boxed_variants.contains_(variant_key)
                        ig.w.emit("const " + cap + "_ptr = ")
                        ig.genExpr(tc.expr)
                        ig.w.emit("." + variant + ";\n")
                        ig.writeIndent()
                        ig.w.emit("const " + cap + " = " + cap + "_ptr.*;\n")
                    else
                        ig.w.emit("const " + cap + " = ")
                        ig.genExpr(tc.expr)
                        ig.w.emit("." + variant + ";\n")
                    # Track ^T fields for this binding to enable auto-deref (mirrors genBranch)
                    if union_nm.len > 0 and variant.len > 0
                        var vp_ = .module_types.variantPayload(union_nm, variant)
                        if vp_ == nil
                            vp_ = .dep_types.variantPayload(union_nm, variant)
                        if vp_ != nil
                            # Seed str_params so str methods work on the binding
                            if isString(vp_ to!)
                                ig.str_params.add(cap)
                            var sname = structNameFromType(vp_ to!)
                            if sname != nil
                                var st_dot = sname to! + "."
                                var rf_items = ref_fields.items()
                                var rfi: int = 0
                                while rfi < rf_items.count()
                                    var rf_entry: str = rf_items.at(rfi)
                                    if rf_entry.startsWith(st_dot)
                                        var fname2 = extractAfterDot(rf_entry)
                                        ig.ptr_field_bindings.add(makeDottedKey(cap, fname2))
                                    rfi += 1
                                var orf_items = opt_ref_fields.items()
                                var orfi: int = 0
                                while orfi < orf_items.count()
                                    var orf_entry: str = orf_items.at(orfi)
                                    if orf_entry.startsWith(st_dot)
                                        var fname3 = extractAfterDot(orf_entry)
                                        ig.opt_ptr_field_bindings.add(makeDottedKey(cap, fname3))
                                    orfi += 1
                    ig.genStmts(stmts)
                    var ckey = makeDottedKey(cap, "")
                    ig.ptr_field_bindings.removeStartingWith(ckey)
                    ig.opt_ptr_field_bindings.removeStartingWith(ckey)
                else
                    # Option A: `if x is T as n` -- optional unwrap
                    w.emit("if (")
                    genExpr(tc.expr)
                    w.emit(") |")
                    w.emit(cap)
                    w.emit("| {\n")
                    var ig = indented()
                    ig.genStmts(stmts)
            else
                # Option B: `if x as n` -- optional unwrap
                w.emit("if (")
                genExpr(cond_expr)
                w.emit(") |")
                w.emit(cap)
                w.emit("| {\n")
                var ig2 = indented()
                ig2.genStmts(stmts)

    def genIf(si: StmtIf)
        writeIndent()
        var ig = indented()
        if si.is_capture != nil
            # `if x is Union.Variant as r` or `if x as r` — capture form
            # si.cond is ^Expr; auto-deref passes Expr value to genIsCaptureThen
            genIsCaptureThen(si.cond, si.is_capture to!, si.then_stmts)
            writeIndent()
            w.emit("}")
        else
            w.emit("if (")
            genExpr(si.cond)
            w.emit(") {\n")
            ig.genStmts(si.then_stmts)
            writeIndent()
            w.emit("}")
        for ei in si.else_ifs
            if ei.is_capture != nil
                w.emit(" else ")
                genIsCaptureThen(ei.cond, ei.is_capture to!, ei.stmts)
                writeIndent()
                w.emit("}")
            else
                w.emit(" else if (")
                genExpr(ei.cond)
                w.emit(") {\n")
                ig.genStmts(ei.stmts)
                writeIndent()
                w.emit("}")
        if si.else_stmts != nil
            var es = si.else_stmts to!
            w.emit(" else {\n")
            ig.genStmts(es)
            writeIndent()
            w.emit("}")
        w.emit("\n")

    # ── genWhile ──────────────────────────────────────────────────────────────

    def genWhile(ww: StmtWhile)
        writeIndent()
        w.emit("while (")
        genExpr(ww.cond)
        w.emit(") {\n")
        var ig = indented()
        ig.genStmts(ww.stmts)
        writeIndent()
        w.emit("}\n")

    # ── genForIn ──────────────────────────────────────────────────────────────
    # Conservative: 1 var → List (.items), 2 vars → HashMap iterator.

    def genForIn(fi: StmtForIn)
        var ig = indented()
        # Nested loops must not inherit the enclosing for-else label — their breaks are plain.
        ig.for_else_label = nil
        # BUG-137: a loop variable shadows any same-named module var inside the
        # body — register it so genIdent emits it bare, not `_zbr_mv_`-prefixed.
        for fv in fi.vars
            .noteShadowLocal(fv)
        # for a, b in list_of_pairs — tuple List destructuring takes priority over HashMap dispatch.
        if fi.vars.count() >= 2
            var is_tuple_list = false
            if fi.iter is Expr.ident as iter_id
                if list_tuple_locals.contains_(iter_id.name)
                    is_tuple_list = true
            if is_tuple_list
                genForInTupleList(fi)
                return
        if fi.vars.count() == 2
            # HashMap two-var iterator: `for k, v in map`
            var kname = fi.vars.at(0)
            var vname = fi.vars.at(1)
            writeIndent()
            w.emit("{\n")
            ig.writeIndent()
            ig.w.emit("var _it_" + kname + " = ")
            genExpr(fi.iter)
            ig.w.emit(".iterator();\n")
            # for-else: wrap while in labeled block so break suppresses else.
            var label: str? = nil
            var wg = ig
            var bg = ig.indented()
            if fi.else_ != nil
                var uid = w.nextUid()
                label = "_fels_" + uid.toString()
                ig.writeIndent()
                ig.w.emit("const " + label to! + " = " + label to! + ": {\n")
                wg = ig.indented()
                bg = wg.indented()
                bg.for_else_label = label to!
            wg.writeIndent()
            wg.w.emit("while (_it_" + kname + ".next()) |_ent_" + kname + "| {\n")
            bg.writeIndent()
            bg.w.emit("const " + kname + " = _ent_" + kname + ".key_ptr.*;\n")
            if not nameUsedInStmts(kname, fi.stmts)
                bg.writeIndent()
                bg.w.emit("_ = " + kname + ";\n")
            # Mark key as string when iterating HashMap(str, V) — needed for print format.
            if fi.iter is Expr.ident as hm_iter_id
                if bg.localIsHashMapStrKey(hm_iter_id.name)
                    bg.str_params.add(kname)
            bg.writeIndent()
            bg.w.emit("const " + vname + " = _ent_" + kname + ".value_ptr.*;\n")
            if not nameUsedInStmts(vname, fi.stmts)
                bg.writeIndent()
                bg.w.emit("_ = " + vname + ";\n")
            # Mark value as string when iterating HashMap(K, str).
            if fi.iter is Expr.ident as hm_iter_id2
                if bg.localIsHashMapStrVal(hm_iter_id2.name)
                    bg.str_params.add(vname)
            bg.emitForGuard(fi)
            bg.genStmts(fi.stmts)
            wg.writeIndent()
            wg.w.emit("}\n")
            if label != nil
                wg.writeIndent()
                wg.w.emit("break :" + label to! + " true;\n")
                ig.writeIndent()
                ig.w.emit("};\n")
                ig.writeIndent()
                ig.w.emit("if (" + label to! + ") {\n")
                wg.genStmts(fi.else_ to!)
                ig.writeIndent()
                ig.w.emit("}\n")
            writeIndent()
            w.emit("}\n")
        else
            var vname = fi.vars.at(0)
            if isToRangeIter(fi.iter)
                # for i in start.to(end) → numeric range loop
                # Lower to: { var i: i64 = <start>; const _stop_i: i64 = <end>;
                #             while (i < _stop_i) : (i += 1) { body } }
                # NOTE: emitToRangeReceiver handles the `^Expr` deref —
                # the codegen auto-derefs only when the field access is
                # the immediate argument of a function expecting Expr.
                var range_call = fi.iter.call
                var range_end:  Expr = range_call.args.at(0).value
                writeIndent()
                w.emit("{\n")
                ig.writeIndent()
                ig.w.emit("var " + vname + ": i64 = ")
                emitToRangeReceiver(fi.iter)
                ig.w.emit(";\n")
                ig.writeIndent()
                ig.w.emit("const _stop_" + vname + ": i64 = ")
                genExpr(range_end)
                ig.w.emit(";\n")
                var label_to: str? = nil
                var wg_to = ig
                var bg_to = ig.indented()
                if fi.else_ != nil
                    var uid_to = w.nextUid()
                    label_to = "_fels_" + uid_to.toString()
                    ig.writeIndent()
                    ig.w.emit("const " + label_to to! + " = " + label_to to! + ": {\n")
                    wg_to = ig.indented()
                    bg_to = wg_to.indented()
                    bg_to.for_else_label = label_to to!
                wg_to.writeIndent()
                wg_to.w.emit("while (" + vname + " < _stop_" + vname + ") : (" + vname + " += 1) {\n")
                bg_to.emitForGuard(fi)
                bg_to.genStmts(fi.stmts)
                wg_to.writeIndent()
                wg_to.w.emit("}\n")
                if label_to != nil
                    wg_to.writeIndent()
                    wg_to.w.emit("break :" + label_to to! + " true;\n")
                    ig.writeIndent()
                    ig.w.emit("};\n")
                    ig.writeIndent()
                    ig.w.emit("if (" + label_to to! + ") {\n")
                    wg_to.genStmts(fi.else_ to!)
                    ig.writeIndent()
                    ig.w.emit("}\n")
                writeIndent()
                w.emit("}\n")
                return
            if isSplitIter(fi.iter)
                # for p in str.split(sep) → while loop with splitSequence iterator
                # for line in str.lines() → splitScalar with '\n'
                var use_scalar = isLinesIter(fi.iter)
                var split_fn = "std.mem.splitSequence(u8, "
                if use_scalar
                    split_fn = "std.mem.splitScalar(u8, "
                writeIndent()
                w.emit("{\n")
                ig.writeIndent()
                ig.w.emit("var _it_" + vname + " = " + split_fn)
                genSplitObject(fi.iter)
                ig.w.emit(", ")
                genSplitSep(fi.iter)
                ig.w.emit(");\n")
                var label: str? = nil
                var wg = ig
                var bg = ig.indented()
                if fi.else_ != nil
                    var uid = w.nextUid()
                    label = "_fels_" + uid.toString()
                    ig.writeIndent()
                    ig.w.emit("const " + label to! + " = " + label to! + ": {\n")
                    wg = ig.indented()
                    bg = wg.indented()
                    bg.for_else_label = label to!
                wg.writeIndent()
                wg.w.emit("while (_it_" + vname + ".next()) |" + vname + "| {\n")
                # split() elements are []const u8 — mark loop var as string for printFmtSpec
                str_params.add(vname)
                bg.emitForGuard(fi)
                bg.genStmts(fi.stmts)
                wg.writeIndent()
                wg.w.emit("}\n")
                if label != nil
                    wg.writeIndent()
                    wg.w.emit("break :" + label to! + " true;\n")
                    ig.writeIndent()
                    ig.w.emit("};\n")
                    ig.writeIndent()
                    ig.w.emit("if (" + label to! + ") {\n")
                    wg.genStmts(fi.else_ to!)
                    ig.writeIndent()
                    ig.w.emit("}\n")
                writeIndent()
                w.emit("}\n")
            else if isCharsIter(fi.iter)
                # for c in str.chars() → Utf8View while loop yielding u21 codepoints
                writeIndent()
                w.emit("{\n")
                ig.writeIndent()
                ig.w.emit("var _cp_it_" + vname + " = std.unicode.Utf8View.initUnchecked(")
                genCharsObject(fi.iter)
                ig.w.emit(").iterator();\n")
                var label: str? = nil
                var wg = ig
                var bg = ig.indented()
                if fi.else_ != nil
                    var uid = w.nextUid()
                    label = "_fels_" + uid.toString()
                    ig.writeIndent()
                    ig.w.emit("const " + label to! + " = " + label to! + ": {\n")
                    wg = ig.indented()
                    bg = wg.indented()
                    bg.for_else_label = label to!
                wg.writeIndent()
                wg.w.emit("while (_cp_it_" + vname + ".nextCodepoint()) |" + vname + "| {\n")
                bg.emitForGuard(fi)
                bg.genStmts(fi.stmts)
                wg.writeIndent()
                wg.w.emit("}\n")
                if label != nil
                    wg.writeIndent()
                    wg.w.emit("break :" + label to! + " true;\n")
                    ig.writeIndent()
                    ig.w.emit("};\n")
                    ig.writeIndent()
                    ig.w.emit("if (" + label to! + ") {\n")
                    wg.genStmts(fi.else_ to!)
                    ig.writeIndent()
                    ig.w.emit("}\n")
                writeIndent()
                w.emit("}\n")
            else if isBytesIter(fi.iter)
                # str.bytes() → native Zig for loop; for-else uses native `} else {`
                writeIndent()
                w.emit("for (")
                emitBytesIterObject(fi.iter)
                w.emit(") |" + vname + "| {\n")
                for_loop_vars.add(vname)
                ig.emitForGuard(fi)
                ig.genStmts(fi.stmts)
                if fi.else_ != nil
                    writeIndent()
                    w.emit("} else {\n")
                    ig.genStmts(fi.else_ to!)
                writeIndent()
                w.emit("}\n")
            else if isItemsMemberAccess(fi.iter)
                # `.items` accessor: already a slice; native Zig for, no extra .items.
                writeIndent()
                w.emit("for (")
                genExpr(fi.iter)
                w.emit(") |" + vname + "| {\n")
                for_loop_vars.add(vname)
                ig.emitForGuard(fi)
                ig.genStmts(fi.stmts)
                if fi.else_ != nil
                    writeIndent()
                    w.emit("} else {\n")
                    ig.genStmts(fi.else_ to!)
                writeIndent()
                w.emit("}\n")
            else if isStrListIter(fi.iter)
                # findAll/groups/Net.resolve return List(str) (A1, 1.0 freeze): iterate
                # .items like any List; elements are []const u8 → mark loop var a string.
                writeIndent()
                w.emit("for (")
                genExpr(fi.iter)
                w.emit(".items) |" + vname + "| {\n")
                for_loop_vars.add(vname)
                str_params.add(vname)
                ig.emitForGuard(fi)
                ig.genStmts(fi.stmts)
                if fi.else_ != nil
                    writeIndent()
                    w.emit("} else {\n")
                    ig.genStmts(fi.else_ to!)
                writeIndent()
                w.emit("}\n")
            else if isSqliteQueryIter(fi.iter)
                genForInSqliteQuery(fi)
            else
                writeIndent()
                w.emit("for (")
                genExpr(fi.iter)
                w.emit(".items) |" + vname + "| {\n")
                # Track for-loop variable deref fields based on element type
                var iter_member = getMemberFieldName(fi.iter)
                if iter_member != nil
                    if iter_member to! == "entries"
                        # List(DictEntry): key and value are ^Expr
                        for_loop_deref.add(makeDottedKey(vname, "key"))
                        for_loop_deref.add(makeDottedKey(vname, "value"))
                # If iterating a List(str), mark the loop variable: a string
                if fi.iter is Expr.ident as iter_id
                    if localIsListStr(iter_id.name)
                        str_params.add(vname)
                # Mark this variable: a for-loop var to suppress stale branch deref
                for_loop_vars.add(vname)
                # Seed opt-ptr field bindings for the loop var's optional ref
                # (^T?) fields, derived from the iterable's element struct type.
                # Without this, `loopvar.optRefField to!` (e.g. a capture's
                # `cap.init_expr to!`, ^Expr?) emits `.?` without the `.*`
                # deref in the selfhost — diverging from the bootstrap, which
                # auto-derefs.  Mirrors the branch-binding seeding (see the
                # `on Expr.is_capture`/branch path).  Round-trip fix.
                if .infer_ctx as ic_for
                    var iter_t: Type_ = inferExpr(fi.iter, ic_for)
                    if iter_t is Type_.list_ as for_elem_t
                        var for_sname = structNameFromType(for_elem_t)
                        if for_sname != nil
                            var for_st_dot = for_sname to! + "."
                            var for_orf = opt_ref_fields.items()
                            var for_oi: int = 0
                            while for_oi < for_orf.count()
                                var for_orf_e: str = for_orf.at(for_oi)
                                if for_orf_e.startsWith(for_st_dot)
                                    ig.opt_ptr_field_bindings.add(makeDottedKey(vname, extractAfterDot(for_orf_e)))
                                for_oi += 1
                ig.emitForGuard(fi)
                ig.genStmts(fi.stmts)
                if fi.else_ != nil
                    # for-else: Zig native for...else runs when no break occurred
                    writeIndent()
                    w.emit("} else {\n")
                    ig.genStmts(fi.else_ to!)
                writeIndent()
                w.emit("}\n")

    # Emit `for a, b in list_of_pairs` — tuple List destructuring.
    # Generates: for (iter.items) |_zbr_tup| { const a = _zbr_tup.@"0"; ... }
    def genForInTupleList(fi: StmtForIn)
        var ig = indented()
        ig.for_else_label = nil
        # Propagate string position info into the body generator's str_params.
        var iter_name: str = ""
        if fi.iter is Expr.ident as iter_id
            iter_name = iter_id.name
        writeIndent()
        w.emit("for (")
        genExpr(fi.iter)
        w.emit(".items) |_zbr_tup| {\n")
        var i = 0
        for vname in fi.vars
            ig.writeIndent()
            ig.w.emit("const " + vname + " = _zbr_tup.@\"" + i.toString() + "\";\n")
            if not nameUsedInStmts(vname, fi.stmts)
                ig.writeIndent()
                ig.w.emit("_ = " + vname + ";\n")
            # Mark string loop vars so print/interp uses {s} format specifier.
            if iter_name != "" and list_tuple_str_pos.contains_(iter_name + ":" + i.toString())
                ig.str_params.add(vname)
            i = i + 1
        ig.emitForGuard(fi)
        ig.genStmts(fi.stmts)
        if fi.else_ != nil
            writeIndent()
            w.emit("} else {\n")
            ig.genStmts(fi.else_ to!)
        writeIndent()
        w.emit("}\n")

    # for row in db.query(sql): capture ArrayList before iterating to avoid
    # use-after-free on temporaries. Mirrors genForInCsvRows in src/CodeGen.zig.
    def genForInSqliteQuery(fi: StmtForIn)
        var vname: str = fi.vars.at(0)
        var it_var: str = "_it_" + vname
        writeIndent()
        w.emit("{\n")
        var sqi = indented()
        sqi.for_else_label = nil
        sqi.writeIndent()
        sqi.w.emit("const " + it_var + " = ")
        sqi.genExpr(fi.iter)
        sqi.w.emit(";\n")
        sqi.writeIndent()
        sqi.w.emit("for (" + it_var + ".items) |" + vname + "| {\n")
        var sqb = sqi.indented()
        sqb.for_else_label = nil
        # Seed infer_ctx so row.asInt/asStr/asFloat resolve via sqlite_row dispatch
        if sqb.infer_ctx != nil
            sqb.infer_ctx to!.bind(vname, Type_.sqlite_row)
        sqb.emitForGuard(fi)
        sqb.genStmts(fi.stmts)
        sqi.writeIndent()
        sqi.w.emit("}\n")
        writeIndent()
        w.emit("}\n")

    # Emit `if (!(cond)) continue;` guard at the top of a for-in loop body.
    # `self` is the body-level generator (ig or bg) so indentation is correct.
    def emitForGuard(fi: StmtForIn)
        if fi.filter == nil
            return
        writeIndent()
        w.emit("if (!(")
        genExpr(fi.filter to!)
        w.emit(")) continue;\n")

    # Detect `str.bytes()`: a for-in iterator — emit `for (s) |b|` not `for (s.bytes().items) |b|`
    def isBytesIter(e: Expr): bool
        if e is Expr.call as c
            if c.callee is Expr.member as m
                return m.member == "bytes"
        return false

    # Detect `n.to(end)` — a numeric range iterator, parsed as a method call.
    # In a for-in context this lowers to a `for var in start:end` style numeric
    # loop (Zig: `while (var < stop) : (var += 1)`).
    def isToRangeIter(e: Expr): bool
        if e is Expr.call as c
            if c.args.count() == 1
                if c.callee is Expr.member as m
                    return m.member == "to"
        return false

    # Emit the receiver of a `n.to(end)` expression — i.e. just `n`.
    # Uses `branch` + `is X as m` binding so codegen auto-derefs the
    # `^Expr` field correctly (same trick as emitBytesIterObject).
    def emitToRangeReceiver(e: Expr)
        if e is Expr.call as c
            if c.callee is Expr.member as m
                genExpr(m.object)
                return
        genExpr(e)

    # Emit the string object from `s.bytes()` — used by genForIn bytes iterator handling.
    # `s.bytes()` call: callee is Expr.member{object: ^s, member:"bytes"}, emit just the object.
    def emitBytesIterObject(e: Expr)
        branch e
            on Expr.call as c
                branch c.callee
                    on Expr.member as m
                        genExpr(m.object)
                    else
                        genExpr(c.callee)
            else
                genExpr(e)

    # Detect `str.split(sep)`: a for-in iterator (needs special while-loop emission)
    def isSplitIter(e: Expr): bool
        if e is Expr.call as c
            if c.callee is Expr.member as m
                return m.member == "split" or m.member == "lines"
        return false

    # True if the iterable is str.lines() — needs splitScalar('\n') not splitSequence.
    def isLinesIter(e: Expr): bool
        if e is Expr.call as c
            if c.callee is Expr.member as m
                return m.member == "lines"
        return false

    # True if the iterable is already a `.items` member access (e.g. `nums.items`).
    # The underlying type is already a slice; adding `.items` again would be wrong.
    def isItemsMemberAccess(e: Expr): bool
        if e is Expr.member as m
            return m.member == "items"
        return false

    # True if the iterable is a Regex findAll/groups call (receiver is a Regex).
    def isRegexSliceIter(e: Expr): bool
        if e is Expr.call as c
            if c.callee is Expr.member as m
                if m.member == "findAll" or m.member == "groups"
                    if .infer_ctx != nil
                        var recv_t: Type_ = inferExpr(m.object, .infer_ctx to!)
                        branch recv_t
                            on Type_.regex
                                return true
                            else
                                pass
        return false

    # True if the iterable is a stdlib call returning List(str) that needs `.items`
    # iteration with string elements: re.findAll/re.groups or Net.resolve (A1).
    def isStrListIter(e: Expr): bool
        if isRegexSliceIter(e)
            return true
        if e is Expr.call as c
            if c.callee is Expr.member as m
                if m.member == "resolve"
                    if m.object is Expr.ident as oid
                        if oid.name == "Net"
                            return true
        return false

    # Emit just the object part of a split call: str.split(sep) → str
    def genSplitObject(e: Expr)
        if e is Expr.call as c
            if c.callee is Expr.member as m
                genExpr(m.object)
    # Emit just the separator of a split call: str.split(sep) → sep; lines() → '\n'
    def genSplitSep(e: Expr)
        branch e
            on Expr.call as c
                if c.callee is Expr.member as m
                    if m.member == "lines"
                        w.emit("'\\n'")
                        return
                if c.args.count() > 0
                    genExpr(c.args.at(0).value)
                else
                    w.emit("\" \"")
            else
                w.emit("\" \"")

    # Detect `str.chars()`: a for-in iterator (needs Utf8View while-loop emission)
    def isCharsIter(e: Expr): bool
        if e is Expr.call as c
            if c.callee is Expr.member as m
                return m.member == "chars"
        return false

    # True if the iterable is db.query(...) where db has type sqlite_db.
    # These calls return an ArrayList(_SqliteRow); we capture before iterating.
    def isSqliteQueryIter(e: Expr): bool
        if e is Expr.call as c
            if c.callee is Expr.member as m
                if m.member == "query"
                    if .infer_ctx != nil
                        var recv_t: Type_ = inferExpr(m.object, .infer_ctx to!)
                        if recv_t is Type_.sqlite_db
                            return true
        # Indirect: var rows = db.query(...) — rows typed as sqlite_row_list.
        if e is Expr.ident as id
            if .infer_ctx != nil
                var it: Type_ = .infer_ctx to!.localType(id.name)
                if it is Type_.sqlite_row_list
                    return true
        return false

    # Emit just the object of a chars() call: str.chars() → str
    def genCharsObject(e: Expr)
        if e is Expr.call as c
            if c.callee is Expr.member as m
                genExpr(m.object)
    # ── genForNum ─────────────────────────────────────────────────────────────

    def genForNum(fn_: StmtForNum)
        var ig = indented()
        # Nested loops must not inherit the enclosing for-else label.
        ig.for_else_label = nil
        # BUG-137: numeric loop variable shadows any same-named module var.
        .noteShadowLocal(fn_.var_)
        writeIndent()
        w.emit("{\n")
        ig.writeIndent()
        ig.w.emit("var " + fn_.var_ + ": i64 = ")
        genExpr(fn_.start)
        ig.w.emit(";\n")
        ig.writeIndent()
        ig.w.emit("const _stop_" + fn_.var_ + ": i64 = ")
        genExpr(fn_.stop_)
        ig.w.emit(";\n")
        if fn_.step != nil
            ig.writeIndent()
            ig.w.emit("const _step_" + fn_.var_ + ": i64 = ")
            ig.genExpr(fn_.step to!)
            ig.w.emit(";\n")
        var step_clause = " += 1"
        if fn_.step != nil
            step_clause = " += _step_" + fn_.var_
        var label: str? = nil
        var wg = ig
        var bg = ig.indented()
        if fn_.else_ != nil
            var uid = w.nextUid()
            label = "_fels_" + uid.toString()
            ig.writeIndent()
            ig.w.emit("const " + label to! + " = " + label to! + ": {\n")
            wg = ig.indented()
            bg = wg.indented()
            bg.for_else_label = label to!
        wg.writeIndent()
        wg.w.emit("while (" + fn_.var_ + " < _stop_" + fn_.var_ + ") : (" + fn_.var_ + step_clause + ") {\n")
        bg.genStmts(fn_.stmts)
        wg.writeIndent()
        wg.w.emit("}\n")
        if label != nil
            wg.writeIndent()
            wg.w.emit("break :" + label to! + " true;\n")
            ig.writeIndent()
            ig.w.emit("};\n")
            ig.writeIndent()
            ig.w.emit("if (" + label to! + ") {\n")
            wg.genStmts(fn_.else_ to!)
            ig.writeIndent()
            ig.w.emit("}\n")
        writeIndent()
        w.emit("}\n")

    # ── genBranch ─────────────────────────────────────────────────────────────

    def genBranch(b: StmtBranch)
        if b.cases.count() == 0
            if b.else_ != nil
                genStmts(b.else_ to!)
            return
        # Detect struct field pattern dispatch: any case has struct_pat set.
        var is_struct_pat = false
        for cas in b.cases
            if cas.struct_pat != nil
                is_struct_pat = true
        if is_struct_pat
            genBranchStruct(b)
            return
        var first_case = b.cases.at(0)
        if first_case.values.count() == 0
            genStmts(first_case.stmts)
            return
        # Detect if any case has a guard expression
        var has_guard = false
        for cas in b.cases
            if cas.guard_expr.count() > 0
                has_guard = true
        # Detect dispatch kind: string literal values → if/else chain
        var fv = first_case.values.at(0)
        var is_str_branch = false
        branch fv
            on Expr.string_lit
                is_str_branch = true
            else
                pass
        if is_str_branch
            genBranchString(b)
        else if has_guard
            genBranchGuarded(b)
        else
            genBranchTagged(b)

    def genBranchStruct(b: StmtBranch)
        var uid = w.nextUid()
        var tmp = "_bsp_" + uid.toString()
        writeIndent()
        w.emit("{\n")
        var ig = indented()
        ig.writeIndent()
        ig.w.emit("const ")
        ig.w.emit(tmp)
        ig.w.emit(" = ")
        ig.genExpr(b.expr)
        ig.w.emit(";\n")
        var first = true
        for cas in b.cases
            ig.writeIndent()
            if not first
                ig.w.emit("} else ")
            first = false
            if cas.struct_pat != nil
                var sp = cas.struct_pat to!
                ig.w.emit("if (")
                var fi = 0
                for f in sp.fields
                    if fi > 0
                        ig.w.emit(" and ")
                    var fv = f.value
                    var is_str_field = false
                    branch fv
                        on Expr.string_lit
                            is_str_field = true
                        else
                            pass
                    if is_str_field
                        ig.w.emit("std.mem.eql(u8, ")
                        ig.w.emit(tmp)
                        ig.w.emit(".")
                        ig.w.emit(f.name)
                        ig.w.emit(", ")
                        ig.genExpr(fv)
                        ig.w.emit(")")
                    else
                        ig.w.emit(tmp)
                        ig.w.emit(".")
                        ig.w.emit(f.name)
                        ig.w.emit(" == ")
                        ig.genExpr(fv)
                    fi = fi + 1
                if cas.guard_expr.count() > 0
                    if fi > 0
                        ig.w.emit(" and ")
                    ig.genExpr(cas.guard_expr.at(0))
            else
                ig.w.emit("if (true)")
            ig.w.emit(") {\n")
            if cas.binding != nil
                var iig = ig.indented()
                iig.writeIndent()
                iig.w.emit("const ")
                iig.w.emit(cas.binding to!)
                iig.w.emit(" = ")
                iig.w.emit(tmp)
                iig.w.emit(";\n")
                iig.genStmts(cas.stmts)
            else
                ig.indented().genStmts(cas.stmts)
        if b.else_ != nil
            ig.writeIndent()
            ig.w.emit("} else {\n")
            ig.indented().genStmts(b.else_ to!)
        if b.cases.count() > 0
            ig.writeIndent()
            ig.w.emit("}\n")
        writeIndent()
        w.emit("}\n")

    def genBranchString(b: StmtBranch)
        var first = true
        for cas in b.cases
            if first
                writeIndent()
                w.emit("if (")
            else
                w.emit(" else if (")
            first = false
            var fi = true
            var vi = 0
            while vi < cas.values.count()
                if not fi
                    w.emit(" or ")
                fi = false
                w.emit("std.mem.eql(u8, ")
                genExpr(b.expr)
                w.emit(", ")
                genExpr(cas.values.at(vi))
                w.emit(")")
                vi += 1
            w.emit(") {\n")
            var ig = indented()
            ig.genStmts(cas.stmts)
            writeIndent()
            w.emit("}")
        if b.else_ != nil
            w.emit(" else {\n")
            var ig = indented()
            ig.genStmts(b.else_ to!)
            writeIndent()
            w.emit("}")
        w.emit("\n")

    def genBranchGuarded(b: StmtBranch)
        # Lower guarded branch to sequential ifs (Zig switch prongs cannot have guards).
        # const _bv_N = <subject>;  var _bd_N = false;
        # if (!_bd_N and <match>) { [const <binding> = _bv_N.<tag>;]
        #   [if (<guard>) {] _bd_N = true; <body> [}] }
        # if (!_bd_N) unreachable; // or else block
        var is_union = false
        for cas in b.cases
            if cas.binding != nil
                is_union = true
        var uid = w.nextUid()
        var bv = "_bv_" + uid.toString()
        var bd = "_bd_" + uid.toString()
        writeIndent()
        w.emit("const ")
        w.emit(bv)
        w.emit(" = ")
        genExpr(b.expr)
        w.emit(";\n")
        writeIndent()
        w.emit("var ")
        w.emit(bd)
        w.emit(" = false;\n")
        for cas in b.cases
            writeIndent()
            w.emit("if (!")
            w.emit(bd)
            if is_union
                if cas.values.count() > 0
                    var v0 = cas.values.at(0)
                    var tag_name: str = ""
                    if v0 is Expr.member as m
                        tag_name = m.member
                    if tag_name.len > 0
                        w.emit(" and ")
                        w.emit(bv)
                        w.emit(" == .")
                        w.emit(tag_name)
                w.emit(") {\n")
                var ig = indented()
                if cas.binding != nil
                    ig.writeIndent()
                    ig.w.emit("const ")
                    ig.w.emit(cas.binding to!)
                    ig.w.emit(" = ")
                    ig.w.emit(bv)
                    ig.w.emit(".")
                    if cas.values.count() > 0
                        var v0b = cas.values.at(0)
                        if v0b is Expr.member as mb
                            ig.w.emit(mb.member)
                    ig.w.emit(";\n")
                    # Suppress unused-const warning: emit `_ = binding;` when no guard.
                    # When a guard is present, the guard expression already uses the binding.
                    if cas.guard_expr.count() == 0
                        ig.writeIndent()
                        ig.w.emit("_ = ")
                        ig.w.emit(cas.binding to!)
                        ig.w.emit(";\n")
                if cas.guard_expr.count() > 0
                    ig.writeIndent()
                    ig.w.emit("if (")
                    ig.genExpr(cas.guard_expr.at(0))
                    ig.w.emit(") {\n")
                    var iig = ig.indented()
                    iig.writeIndent()
                    iig.w.emit(bd)
                    iig.w.emit(" = true;\n")
                    iig.genStmts(cas.stmts)
                    ig.writeIndent()
                    ig.w.emit("}\n")
                else
                    ig.writeIndent()
                    ig.w.emit(bd)
                    ig.w.emit(" = true;\n")
                    ig.genStmts(cas.stmts)
            else
                # Non-union: match by value equality
                if cas.values.count() > 0
                    w.emit(" and (")
                    var fv2 = true
                    for v in cas.values
                        if not fv2
                            w.emit(" or ")
                        fv2 = false
                        w.emit(bv)
                        w.emit(" == ")
                        branch v
                            on Expr.member as m2
                                w.emit(".")
                                w.emit(m2.member)
                            else
                                genExpr(v)
                    w.emit(")")
                w.emit(") {\n")
                var ig = indented()
                if cas.guard_expr.count() > 0
                    ig.writeIndent()
                    ig.w.emit("if (")
                    ig.genExpr(cas.guard_expr.at(0))
                    ig.w.emit(") {\n")
                    var iig = ig.indented()
                    iig.writeIndent()
                    iig.w.emit(bd)
                    iig.w.emit(" = true;\n")
                    iig.genStmts(cas.stmts)
                    ig.writeIndent()
                    ig.w.emit("}\n")
                else
                    ig.writeIndent()
                    ig.w.emit(bd)
                    ig.w.emit(" = true;\n")
                    ig.genStmts(cas.stmts)
            writeIndent()
            w.emit("}\n")
        if b.else_ != nil
            writeIndent()
            w.emit("if (!")
            w.emit(bd)
            w.emit(") {\n")
            var ig = indented()
            ig.genStmts(b.else_ to!)
            writeIndent()
            w.emit("}\n")
        else
            writeIndent()
            w.emit("if (!")
            w.emit(bd)
            w.emit(") unreachable;\n")
            var all_return = true
            for cas in b.cases
                if cas.stmts.count() == 0
                    all_return = false
                else
                    var last = cas.stmts.at(cas.stmts.count() - 1)
                    branch last
                        on Stmt.return_
                            pass
                        else
                            all_return = false
            if all_return
                writeIndent()
                w.emit("unreachable;\n")

    def genBranchTagged(b: StmtBranch)
        # Determine if any case has a binding (union dispatch vs enum dispatch)
        var has_binding = false
        for cas in b.cases
            if cas.binding != nil
                has_binding = true
        writeIndent()
        w.emit("switch (")
        genExpr(b.expr)
        w.emit(") {\n")
        var ig = indented()
        for cas in b.cases
            # BUG-137: a branch-case binding (`on V as r`) shadows any same-named
            # module var inside the arm.
            if cas.binding != nil
                if cas.binding to! != "_"
                    .noteShadowLocal(cas.binding to!)
            ig.writeIndent()
            var fi = true
            var vi = 0
            while vi < cas.values.count()
                if not fi
                    ig.w.emit(", ")
                fi = false
                ig.genSwitchTag(cas.values.at(vi))
                vi += 1
            ig.w.emit(" => ")
            # Check if this variant has a boxed (^T) payload that needs deref
            var needs_deref = false
            if has_binding and cas.binding != nil and cas.values.count() > 0
                var vkey = getVariantKey(cas.values.at(0))
                if vkey != nil
                    needs_deref = boxed_variants.contains_(vkey to!)
            if has_binding
                if cas.binding != nil
                    var bnd = cas.binding to!
                    if needs_deref and bnd != "_"
                        ig.w.emit("|_ptr_")
                        ig.w.emit(bnd)
                        ig.w.emit("| ")
                    else if bnd != "_"
                        ig.w.emit("|")
                        ig.w.emit(bnd)
                        ig.w.emit("| ")
                    # else bnd == "_": Zig 0.16 rejects |_|; omit capture entirely
                # else nil binding: no capture
            ig.w.emit("{\n")
            var iig = ig.indented()
            if needs_deref and (cas.binding == nil or cas.binding to! != "_")
                iig.writeIndent()
                iig.w.emit("const ")
                iig.w.emit(cas.binding to!)
                iig.w.emit(" = _ptr_")
                iig.w.emit(cas.binding to!)
                iig.w.emit(".*;\n")
            # Track ^T fields for this binding to enable auto-deref
            if cas.binding != nil and cas.values.count() > 0
                var vkey2 = getVariantKey(cas.values.at(0))
                if vkey2 != nil
                    # Parse "Union.variant" into union_name and variant_name
                    var vk = vkey2 to!
                    # Extract union and variant names from dotted key
                    var vname = extractAfterDot(vk)
                    var uname: str = ""
                    if vname.len < vk.len
                        # Extract union name: everything before the dot
                        # Use extractAfterDot trick in reverse — split and take first
                        for upart in vk.split(".")
                            uname = upart
                            break
                    if uname.len > 0 and vname.len > 0
                        var vp_ = .module_types.variantPayload(uname, vname)
                        if vp_ == nil
                            vp_ = .dep_types.variantPayload(uname, vname)
                        if vp_ != nil
                            # Seed str_params so str methods work on the binding
                            if isString(vp_ to!)
                                iig.str_params.add(cas.binding to!)
                            var sname = structNameFromType(vp_ to!)
                            if sname != nil
                                var st_dot = sname to! + "."
                                # Find all non-optional ref_fields for this struct
                                var rf_items = ref_fields.items()
                                var rfi: int = 0
                                while rfi < rf_items.count()
                                    var rf_entry: str = rf_items.at(rfi)
                                    if rf_entry.startsWith(st_dot)
                                        var fname2 = extractAfterDot(rf_entry)
                                        iig.ptr_field_bindings.add(makeDottedKey(cas.binding to!, fname2))
                                    rfi += 1
                                # Find all optional ref_fields for this struct
                                var orf_items = opt_ref_fields.items()
                                var orfi: int = 0
                                while orfi < orf_items.count()
                                    var orf_entry: str = orf_items.at(orfi)
                                    if orf_entry.startsWith(st_dot)
                                        var fname3 = extractAfterDot(orf_entry)
                                        iig.opt_ptr_field_bindings.add(makeDottedKey(cas.binding to!, fname3))
                                    orfi += 1
            iig.genStmts(cas.stmts)
            if cas.binding != nil
                var bkey = makeDottedKey(cas.binding to!, "")
                iig.ptr_field_bindings.removeStartingWith(bkey)
                iig.opt_ptr_field_bindings.removeStartingWith(bkey)
            ig.writeIndent()
            ig.w.emit("},\n")
        if b.else_ != nil
            ig.writeIndent()
            ig.w.emit("else => ")
            # Zig 0.16: |_| capture discard not allowed; omit entirely
            ig.w.emit("{\n")
            var iig = ig.indented()
            iig.genStmts(b.else_ to!)
            ig.writeIndent()
            ig.w.emit("},\n")
        writeIndent()
        w.emit("}\n")

    def genSwitchTag(e: Expr)
        branch e
            on Expr.member as m
                w.emit(".")
                w.emit(m.member)
            on Expr.ident as id
                w.emit(".")
                w.emit(id.name)
            on Expr.binary as b
                if b.op == BinaryOp.dotdot
                    # Switch range: c'0'..c'9' → '0'...'9' (three dots, no parens)
                    genExpr(b.left)
                    w.emit("...")
                    genExpr(b.right)
                else
                    genExpr(e)
            else
                genExpr(e)

    # ── genPrint ──────────────────────────────────────────────────────────────

    def genPrint(p: StmtPrint)
        if p.args.count() == 0
            if p.newline
                line("std.debug.print(\"\\n\", .{});")
            else
                line("// print (no args)")
            return
        writeIndent()
        w.emit("std.debug.print(\"")
        var ai = 0
        while ai < p.args.count()
            if ai > 0
                w.emit(" ")
            var arg = p.args.at(ai)
            w.emit(.printFmtSpec(arg))
            ai += 1
        if p.newline
            w.emit("\\n")
        w.emit("\", .{")
        var ai2 = 0
        while ai2 < p.args.count()
            if ai2 > 0
                w.emit(", ")
            var parg = p.args.at(ai2)
            var needs_unwrap = false
            if .infer_ctx != nil
                var pt: Type_ = inferExpr(parg, .infer_ctx to!)
                if pt is Type_.optional as poi
                    if poi is Type_.string_ or poi is Type_.str_slice
                        needs_unwrap = true
                    else if poi is Type_.int_ or poi is Type_.uint_ or poi is Type_.bool_ or poi is Type_.float_ or poi is Type_.char_
                        needs_unwrap = true
            genExpr(parg)
            if needs_unwrap
                w.emit(".?")
            ai2 += 1
        w.emit("});\n")

    def isStringLitArg(e: Expr): bool
        branch e
            on Expr.string_lit
                return true
            on Expr.string_interp
                return true
            else
                pass
        return false

    # Returns the Zig format specifier for a print argument, matching
    # src/CodeGen.zig::printFmt. Uses inferExpr when available; falls back to
    # the heuristic. Zig 0.15 requires {s} for slices and {any} for optionals.
    def printFmtSpec(e: Expr): str
        if isStringLitArg(e)
            return "{s}"
        if .infer_ctx != nil
            var t: Type_ = inferExpr(e, .infer_ctx to!)
            # Unwrap one optional layer: inside nil-check bodies the value is
            # guaranteed non-nil; genPrint will emit `.?` on the Zig value.
            if t is Type_.optional as opt_inner
                t = opt_inner
            branch t
                on Type_.string_
                    return "{s}"
                on Type_.str_slice
                    return "{s}"
                on Type_.int_
                    return "{}"
                on Type_.uint_
                    return "{}"
                on Type_.bool_
                    return "{}"
                on Type_.float_
                    return "{d}"
                on Type_.char_
                    return "{u}"
                on Type_.int_n as _
                    return "{}"
                on Type_.uint_n as _
                    return "{}"
                on Type_.float_n as _
                    return "{d}"
                on Type_.unknown_
                    pass  # fall through to heuristic when type is undetermined
                on Type_.context_dependent
                    pass  # fall through to heuristic
                on Type_.unresolved
                    pass  # fall through to heuristic
                else
                    return "{any}"
        # Type undetermined: check structural heuristic; default to {any} (safe for any type).
        if isStringExpr(e)
            return "{s}"
        return "{any}"

    # ── genRaise ──────────────────────────────────────────────────────────────

    # Best-effort type name for raise details expression (mirrors detailsTypeName in src/CodeGen.zig).
    def detailsTypeName(det: Expr): str
        branch det
            on Expr.ident as id
                return id.name
            on Expr.call as c
                if c.callee is Expr.ident as ci
                    return ci.name
            else
                pass
        return "anyopaque"

    def genRaise(r: StmtRaise)
        writeIndent()
        if r.message != nil and r.details != nil
            # Two-arg form: `raise "msg", details_expr`. Mirrors the three-path
            # dispatch in src/CodeGen.zig:genRaise — primitive / string / object.
            # Non-primitive details currently raise a selfhost compile error
            # (the object-details path is not ported yet); primitive-only paths
            # cover all current target corpus files (all int details).
            var det: Expr = r.details to!
            var det_t: Type_ = Type_.unknown_
            if .infer_ctx != nil
                det_t = inferExpr(det, .infer_ctx to!)
            var uid: int = w.nextUid()
            var is_prim: bool = false
            branch det_t
                on Type_.int_
                    is_prim = true
                on Type_.uint_
                    is_prim = true
                on Type_.float_
                    is_prim = true
                on Type_.bool_
                    is_prim = true
                on Type_.char_
                    is_prim = true
                on Type_.int_n as _
                    is_prim = true
                on Type_.uint_n as _
                    is_prim = true
                on Type_.float_n as _
                    is_prim = true
                else
                    pass
            var is_string_det: bool = false
            branch det_t
                on Type_.string_
                    is_string_det = true
                else
                    pass
            if is_prim
                var fmt: str = "{}"
                branch det_t
                    on Type_.float_
                        fmt = "{d}"
                    on Type_.float_n as _
                        fmt = "{d}"
                    on Type_.char_
                        fmt = "{u}"
                    else
                        pass
                w.emit("{ const _rdet_")
                w.emit(uid.toString())
                w.emit(": []const u8 = std.fmt.allocPrint(_allocator, \"")
                w.emit(fmt)
                w.emit("\", .{")
                genExpr(det)
                w.emit("}) catch @panic(\"OOM\");\n")
                writeIndent()
                w.emit("  const _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(" = _allocator.create([]const u8) catch @panic(\"OOM\");\n")
                writeIndent()
                w.emit("  _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(".* = _rdet_")
                w.emit(uid.toString())
                w.emit(";\n")
                writeIndent()
                w.emit("  const _rshim_")
                w.emit(uid.toString())
                w.emit(" = struct { fn call(p: *anyopaque) []const u8 {\n")
                writeIndent()
                w.emit("      return @as(*[]const u8, @alignCast(@ptrCast(p))).*;\n")
                writeIndent()
                w.emit("  } };\n")
                writeIndent()
                w.emit("  _error_ctx = .{ .message = ")
                genExpr(r.message to!)
                w.emit(", .details = .{ .ptr = @ptrCast(_rdet_ptr_")
                w.emit(uid.toString())
                w.emit("), .toString_fn = _rshim_")
                w.emit(uid.toString())
                w.emit(".call } };\n")
                writeIndent()
                w.emit("  ")
            else if is_string_det
                w.emit("{ const _rdet_")
                w.emit(uid.toString())
                w.emit(": []const u8 = ")
                genExpr(det)
                w.emit(";\n")
                writeIndent()
                w.emit("  const _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(" = _allocator.create([]const u8) catch @panic(\"OOM\");\n")
                writeIndent()
                w.emit("  _rdet_ptr_")
                w.emit(uid.toString())
                w.emit(".* = _rdet_")
                w.emit(uid.toString())
                w.emit(";\n")
                writeIndent()
                w.emit("  const _rshim_")
                w.emit(uid.toString())
                w.emit(" = struct { fn call(p: *anyopaque) []const u8 {\n")
                writeIndent()
                w.emit("      return @as(*[]const u8, @alignCast(@ptrCast(p))).*;\n")
                writeIndent()
                w.emit("  } };\n")
                writeIndent()
                w.emit("  _error_ctx = .{ .message = ")
                genExpr(r.message to!)
                w.emit(", .details = .{ .ptr = @ptrCast(_rdet_ptr_")
                w.emit(uid.toString())
                w.emit("), .toString_fn = _rshim_")
                w.emit(uid.toString())
                w.emit(".call } };\n")
                writeIndent()
                w.emit("  ")
            else
                # Object-details path: class types are already heap-allocated (*T),
                # so just capture the pointer directly without extra create+deref.
                var type_name = detailsTypeName(det)
                var is_class_det = class_names.contains_(type_name)
                if is_class_det
                    # Class: det evaluates to *T already; just capture the pointer.
                    w.emit("{ const _rdet_")
                    w.emit(uid.toString())
                    w.emit(" = ")
                    genExpr(det)
                    w.emit(";\n")
                else
                    # Struct/value: heap-alloc and assign.
                    w.emit("{ const _rdet_")
                    w.emit(uid.toString())
                    w.emit(" = _allocator.create(")
                    w.emit(type_name)
                    w.emit(") catch @panic(\"OOM\");\n")
                    writeIndent()
                    w.emit("  _rdet_")
                    w.emit(uid.toString())
                    w.emit(".* = ")
                    genExpr(det)
                    w.emit(";\n")
                writeIndent()
                w.emit("  const _rshim_")
                w.emit(uid.toString())
                w.emit(" = struct { fn call(p: *anyopaque) []const u8 {\n")
                writeIndent()
                w.emit("      return @as(*")
                w.emit(type_name)
                w.emit(", @alignCast(@ptrCast(p))).toString();\n")
                writeIndent()
                w.emit("  } };\n")
                writeIndent()
                w.emit("  _error_ctx = .{ .message = ")
                genExpr(r.message to!)
                w.emit(", .details = .{ .ptr = @ptrCast(_rdet_")
                w.emit(uid.toString())
                w.emit("), .toString_fn = _rshim_")
                w.emit(uid.toString())
                w.emit(".call } };\n")
                writeIndent()
                w.emit("  ")
            if try_block_label != nil
                w.emit(try_err_var to!)
                w.emit(" = error.ZebraError; break :")
                w.emit(try_block_label to!)
                w.emit("; ")
            else
                w.emit("return error.ZebraError; ")
            w.emit("}\n")
        else if r.message != nil
            w.emit("{ _error_ctx = .{ .message = ")
            genExpr(r.message to!)
            w.emit(" }; ")
            if try_block_label != nil
                w.emit(try_err_var to!)
                w.emit(" = error.ZebraError; break :")
                w.emit(try_block_label to!)
                w.emit("; ")
            else
                w.emit("return error.ZebraError; ")
            w.emit("}\n")
        else
            if try_block_label != nil
                w.emit(try_err_var to!)
                w.emit(" = error.ZebraError; break :")
                w.emit(try_block_label to!)
                w.emit("; ")
            else
                w.emit("return error.ZebraError; ")
            w.emit("\n")

    # ── genTryCatch ───────────────────────────────────────────────────────────
    # Labeled block + error-variable pattern:
    #
    #   var _try_err: ?anyerror = null;
    #   _ = &_try_err;            ← suppresses Zig "never mutated" when body is trivial
    #   _try_blk: {
    #       // body
    #       break :_try_blk;
    #   }
    #   if (_try_err != null) { // catch body }

    def genTryCatch(tc: StmtTryCatch)
        # Detect if the last stmt is a return_ — if so the success path always
        # exits the function directly, so we skip the trailing break and emit
        # `unreachable` after the catch block (BUG-088 fix).
        var last_is_return = false
        if tc.stmts.count() > 0
            branch tc.stmts.at(tc.stmts.count() - 1)
                on Stmt.return_ as _
                    last_is_return = true
                else
                    pass
        writeIndent()
        w.emit("{\n")
        var ig = indented()
        ig.writeIndent()
        ig.w.emit("var _try_err: ?anyerror = null;\n")
        ig.writeIndent()
        ig.w.emit("_ = &_try_err;\n")
        ig.writeIndent()
        ig.w.emit("_try_blk: {\n")
        var iig = ig.indented()
        var try_gen = iig.withTryLabel("_try_blk", "_try_err")
        try_gen.genStmts(tc.stmts)
        if not last_is_return
            iig.writeIndent()
            iig.w.emit("break :_try_blk;\n")
        ig.writeIndent()
        ig.w.emit("}\n")
        ig.writeIndent()
        ig.w.emit("if (_try_err != null) {\n")
        for cl in tc.clauses
            # `_try_err` is already used in the `if` condition above; no explicit
            # discard needed. Named bindings (not starting with `_`) wire through
            # withCatchVar so the catch body can reference the error object.
            var catch_gen = iig
            if cl.binding != nil
                var bname: str = cl.binding to!
                if not bname.startsWith("_")
                    catch_gen = iig.withCatchVar(bname)
            catch_gen.genStmts(cl.stmts)
        ig.writeIndent()
        ig.w.emit("}\n")
        if last_is_return
            ig.writeIndent()
            ig.w.emit("unreachable;\n")
        writeIndent()
        w.emit("}\n")

    # ── genAssert ─────────────────────────────────────────────────────────────

    def genInvariantCheckFn()
        writeIndent()
        w.emit("fn _check_invariant(self: *")
        if is_generic
            w.emit("@This()")
        else
            w.emit(owner)
        w.emit(") void {\n")
        var ig0 = indented()
        var mg = ig0.asMethod()
        for inv_expr in owner_invariants
            mg.writeIndent()
            mg.w.emit("if (!(")
            mg.genExpr(inv_expr)
            mg.w.emit(")) std.debug.panic(\"invariant failed in '")
            mg.w.emit(owner)
            mg.w.emit("'\\n\", .{});\n")
        writeIndent()
        w.emit("}\n\n")

    def genRequireChecks(req_list: List(Expr), context: str)
        if strip_contracts
            return
        for req_expr in req_list
            writeIndent()
            w.emit("if (!(")
            genExpr(req_expr)
            w.emit(")) std.debug.panic(\"require failed in '")
            w.emit(context)
            w.emit("'\\n\", .{});\n")

    # Emit `const _old_{uid} = <operand>;` for every old() node found (depth-first).
    # Each old_ node carries a stable uid assigned by the astbuilder — no ordering
    # dependency between this traversal and the genExpr emit pass.
    # True if any sub-expression is `result` (the contract return-value reference).
    def containsResultRef(e: Expr): bool
        branch e
            on Expr.result_
                return true
            on Expr.binary as b
                return containsResultRef(b.left) or containsResultRef(b.right)
            on Expr.unary as u
                return containsResultRef(u.operand)
            on Expr.call as c
                if containsResultRef(c.callee)
                    return true
                for a in c.args
                    if containsResultRef(a.value)
                        return true
                return false
            on Expr.member as m
                return containsResultRef(m.object)
            on Expr.index as i
                return containsResultRef(i.object) or containsResultRef(i.index)
            on Expr.cast as cx
                return containsResultRef(cx.expr)
            on Expr.to_nilable as tn
                return containsResultRef(tn.expr)
            on Expr.to_non_nil as tnn
                return containsResultRef(tnn.expr)
            on Expr.is_nil as inl
                return containsResultRef(inl.expr)
            on Expr.orelse_ as o
                return containsResultRef(o.expr) or containsResultRef(o.fallback)
            on Expr.catch_ as c
                return containsResultRef(c.expr) or containsResultRef(c.fallback)
            on Expr.if_expr as ie
                return containsResultRef(ie.cond) or containsResultRef(ie.then_expr) or containsResultRef(ie.else_expr)
            on Expr.old_ as o
                return containsResultRef(o.operand)
            on Expr.try_ as t
                return containsResultRef(t.expr)
            on Expr.type_check as tc
                return containsResultRef(tc.expr)
            on Expr.list_lit as ll
                for el in ll.elems
                    if containsResultRef(el)
                        return true
                return false
            on Expr.array_lit as al
                for el in al.elems
                    if containsResultRef(el)
                        return true
                return false
            on Expr.tuple_lit as tl
                for el in tl.elems
                    if containsResultRef(el)
                        return true
                return false
            on Expr.dict_lit as dl
                for en in dl.entries
                    if containsResultRef(en.key) or containsResultRef(en.value)
                        return true
                return false
            on Expr.string_interp as si
                for p in si.parts
                    if p is StringPart.expr_ as ep
                        if containsResultRef(ep)
                            return true
                return false
            on Expr.chained_cmp as cc
                for op in cc.operands
                    if containsResultRef(op)
                        return true
                return false
            else
                return false

    def collectAndEmitOldSnapshots(e: Expr)
        branch e
            on Expr.old_ as o
                writeIndent()
                w.emit("const _old_")
                w.emit(o.uid.toString())
                w.emit(" = ")
                genExpr(o.operand)
                w.emit(";\n")
            on Expr.unary as u
                collectAndEmitOldSnapshots(u.operand)
            on Expr.binary as b
                collectAndEmitOldSnapshots(b.left)
                collectAndEmitOldSnapshots(b.right)
            on Expr.call as c
                collectAndEmitOldSnapshots(c.callee)
                for arg in c.args
                    collectAndEmitOldSnapshots(arg.value)
            on Expr.member as mem
                collectAndEmitOldSnapshots(mem.object)
            on Expr.index as ix
                collectAndEmitOldSnapshots(ix.object)
                collectAndEmitOldSnapshots(ix.index)
            on Expr.cast as ca
                collectAndEmitOldSnapshots(ca.expr)
            on Expr.to_nilable as tn
                collectAndEmitOldSnapshots(tn.expr)
            on Expr.to_non_nil as tnn
                collectAndEmitOldSnapshots(tnn.expr)
            on Expr.is_nil as isn
                collectAndEmitOldSnapshots(isn.expr)
            on Expr.orelse_ as or_
                collectAndEmitOldSnapshots(or_.expr)
                collectAndEmitOldSnapshots(or_.fallback)
            on Expr.catch_ as ca2
                collectAndEmitOldSnapshots(ca2.expr)
                collectAndEmitOldSnapshots(ca2.fallback)
            on Expr.if_expr as ie
                collectAndEmitOldSnapshots(ie.cond)
                collectAndEmitOldSnapshots(ie.then_expr)
                collectAndEmitOldSnapshots(ie.else_expr)
            on Expr.try_ as tr
                collectAndEmitOldSnapshots(tr.expr)
            on Expr.array_lit as al
                for elem in al.elems
                    collectAndEmitOldSnapshots(elem)
            on Expr.list_lit as ll
                for elem in ll.elems
                    collectAndEmitOldSnapshots(elem)
            on Expr.tuple_lit as tl
                for elem in tl.elems
                    collectAndEmitOldSnapshots(elem)
            on Expr.dict_lit as dl
                for entry in dl.entries
                    collectAndEmitOldSnapshots(entry.key)
                    collectAndEmitOldSnapshots(entry.value)
            on Expr.string_interp as si
                for part in si.parts
                    if part is StringPart.expr_ as ex
                        collectAndEmitOldSnapshots(ex)
            on Expr.type_check as tc
                collectAndEmitOldSnapshots(tc.expr)
            on Expr.slice as sl
                collectAndEmitOldSnapshots(sl.object)
                if sl.start != nil
                    collectAndEmitOldSnapshots(sl.start to!)
                if sl.stop_ != nil
                    collectAndEmitOldSnapshots(sl.stop_ to!)
            on Expr.except_ as ex
                collectAndEmitOldSnapshots(ex.base)
                for f in ex.fields
                    collectAndEmitOldSnapshots(f.value)
            on Expr.chained_cmp as cc
                for op in cc.operands
                    collectAndEmitOldSnapshots(op)
            else
                pass

    # Emit old snapshots, an `_ensure_armed` flag, and a defer block for each
    # ensure expression.  When any ensure references `result`, also emit
    # `var _result: T = undefined;` (T = return_type).  The defer check is
    # gated on `_ensure_armed` so it fires only on the success path (BUG-087).
    # Returns context the caller threads into the body (so genReturn can arm
    # the flag and capture _result).
    def genEnsureBlock(ensure_list: List(Expr), context: str, return_type: TypeRef?): EnsureCtx
        if strip_contracts or ensure_list.count() == 0
            return EnsureCtx(false, false)
        var uses_result = false
        for ens in ensure_list
            if containsResultRef(ens)
                uses_result = true
        if uses_result and return_type == nil
            print "selfhost codegen: ensure in '${context}' references 'result' but function has no return type"
            uses_result = false
        # Single pass: emit const _old_N snapshots for every old() in each ensure expr
        for ens in ensure_list
            collectAndEmitOldSnapshots(ens)
        # Capture variable for `result` references.
        if uses_result
            writeIndent()
            w.emit("var _result: ")
            genType(return_type to!)
            w.emit(" = undefined;\n")
        # Success-armed flag.
        writeIndent()
        w.emit("var _ensure_armed: bool = false;\n")
        # Emit defer block; in_ensure_emit causes genExpr to emit _old_N references
        writeIndent()
        w.emit("defer {\n")
        var ig = indented()
        ig.in_ensure_emit = true
        for ens_expr in ensure_list
            ig.writeIndent()
            ig.w.emit("if (_ensure_armed and !(")
            ig.genExpr(ens_expr)
            ig.w.emit(")) std.debug.panic(\"ensure failed in '")
            ig.w.emit(context)
            ig.w.emit("'\\n\", .{});\n")
        writeIndent()
        w.emit("}\n")
        return EnsureCtx(true, uses_result)

    def genAssert(a: StmtAssert)
        writeIndent()
        if a.message != nil
            w.emit("if (!(")
            genExpr(a.cond)
            w.emit(")) @panic(")
            genExpr(a.message to!)
            w.emit(");\n")
        else
            w.emit("std.debug.assert(")
            genExpr(a.cond)
            w.emit(");\n")

    def genAssertCmp(a: StmtAssertCmp, is_eq: bool)
        writeIndent()
        w.emit("try _zebra_assert_cmp(")
        genExpr(a.lhs)
        w.emit(", ")
        genExpr(a.rhs)
        if is_eq
            w.emit(", true);\n")
        else
            w.emit(", false);\n")

    def genAssertUnary(a: StmtAssertUnary, expect_true: bool)
        writeIndent()
        w.emit("try _zebra_assert_bool(")
        genExpr(a.expr)
        if expect_true
            w.emit(", true);\n")
        else
            w.emit(", false);\n")

    # ── genDefer ──────────────────────────────────────────────────────────────

    def genDefer(d: StmtDefer)
        writeIndent()
        if d.is_err
            w.emit("errdefer {\n")
        else
            w.emit("defer {\n")
        var ig = indented()
        ig.genStmt(d.stmt)
        writeIndent()
        w.emit("}\n")

    # ── genWith ───────────────────────────────────────────────────────────────

    def genWith(ww: StmtWith)
        writeIndent()
        w.emit("{ // with\n")
        var ig = indented()
        ig.genStmts(ww.stmts)
        writeIndent()
        w.emit("}\n")

    # ── genInScope ────────────────────────────────────────────────────────────
    # `in EXPR eol Block` → { const _in_N = EXPR; _in_N.begin(); defer _in_N.end(); body }

    def genInScope(si: StmtIn)
        var uid = w.nextUid()
        writeIndent()
        w.emit("{\n")
        var ig = indented()
        ig.writeIndent()
        w.emit("const _in_${uid} = ")
        genExpr(si.expr)
        w.emit(";\n")
        ig.writeIndent()
        w.emit("_in_${uid}.begin();")
        w.emit("\n")
        ig.writeIndent()
        w.emit("defer _in_${uid}.end();")
        w.emit("\n")
        ig.genStmts(si.stmts)
        writeIndent()
        w.emit("}\n")

    # ── allocKind ─────────────────────────────────────────────────────────────
    # Returns a tag string for the source expr: "arena", "debug", "fixed_buffer",
    # "stack_fallback", or "user".  Used to select getter and defer cleanup.

    def allocKind(e: Expr): str
        if e is Expr.call as c
            if c.callee is Expr.ident as id
                if id.name == "Arena"
                    return "arena"
                if id.name == "Debug"
                    return "debug"
                if id.name == "FixedBuffer"
                    return "fixed_buffer"
                if id.name == "StackFallback"
                    return "stack_fallback"
        return "user"

    # ── genAllocatorSourceInit ────────────────────────────────────────────────

    def genAllocatorSourceInit(e: Expr)
        if e is Expr.call as c
            if c.callee is Expr.ident as id
                if id.name == "Arena"
                    w.emit("std.heap.ArenaAllocator.init(_allocator)")
                    return
                if id.name == "Debug"
                    w.emit("std.heap.DebugAllocator(.{}){}")
                    return
                # FixedBuffer is handled inline in genAllocate (backing buffer needs depth).
                if id.name == "StackFallback"
                    w.emit("std.heap.stackFallback(")
                    if c.args.count() > 0
                        genExpr(c.args.at(0).value)
                    else
                        w.emit("256")
                    w.emit(", _allocator)")
                    return
                if id.name == "Page"
                    w.emit("std.heap.page_allocator")
                    return
                if id.name == "Smp"
                    w.emit("std.heap.smp_allocator")
                    return
                if id.name == "C"
                    w.emit("std.heap.c_allocator")
                    return
        genExpr(e)

    # ── genAllocate ───────────────────────────────────────────────────────────

    def genAllocate(al: StmtAllocate)
        var n = arena_counter
        arena_counter = arena_counter + 1
        var saved_name = "_saved_alloc_".concat(n.toString())
        writeIndent()
        w.emit("{ // allocate\n")
        var ig = indented()
        if al.is_scoped
            var kind = allocKind(al.source)
            var src_name = "_alloc_src_".concat(n.toString())
            if kind == "fixed_buffer"
                # FixedBuffer(N): emit backing buffer line, then init line.
                # ig.genExpr() writes inline to the shared writer — no temp Writer needed.
                var backing_name = "_fba_backing_".concat(n.toString())
                ig.writeIndent()
                ig.w.emit("var ")
                ig.w.emit(backing_name)
                ig.w.emit(": [")
                if al.source is Expr.call as fbc
                    if fbc.args.count() > 0
                        ig.genExpr(fbc.args.at(0).value)
                    else
                        ig.w.emit("4096")
                else
                    ig.w.emit("4096")
                ig.w.emit("]u8 = undefined;\n")
                ig.line("var ".concat(src_name).concat(" = std.heap.FixedBufferAllocator.init(&").concat(backing_name).concat(");"))
            else
                ig.writeIndent()
                ig.w.emit("var ")
                ig.w.emit(src_name)
                ig.w.emit(" = ")
                ig.genAllocatorSourceInit(al.source)
                ig.w.emit(";\n")
            ig.line("const ".concat(saved_name).concat(" = _allocator;"))
            var getter = ".allocator()"
            if kind == "stack_fallback"
                getter = ".get()"
            ig.line("_allocator = ".concat(src_name).concat(getter).concat(";"))
            if kind == "fixed_buffer" or kind == "stack_fallback"
                ig.line("defer _allocator = ".concat(saved_name).concat(";"))
            else if kind == "debug"
                ig.line("defer { _allocator = ".concat(saved_name).concat("; std.debug.assert(").concat(src_name).concat(".deinit() == .ok); }"))
            else
                ig.line("defer { _allocator = ".concat(saved_name).concat("; ").concat(src_name).concat(".deinit(); }"))
        else
            ig.writeIndent()
            ig.w.emit("const ")
            ig.w.emit(saved_name)
            ig.w.emit(" = _allocator;\n")
            ig.writeIndent()
            ig.w.emit("_allocator = ")
            ig.genAllocatorSourceInit(al.source)
            ig.w.emit(";\n")
            ig.line("defer _allocator = ".concat(saved_name).concat(";"))
        if al.is_scoped
            ig.allocate_depth = allocate_depth + 1
        ig.genStmts(al.stmts)
        writeIndent()
        w.emit("}\n")

    # ── genCopyOut ────────────────────────────────────────────────────────────

    def genCopyOut(co: StmtCopyOut)
        # Chan send: ch <- val  (target is a Chan local)
        var co_lhs_nm = getMemberFieldName(co.target)
        if co_lhs_nm != nil
            if chan_locals.contains_(co_lhs_nm to!)
                writeIndent()
                genExpr(co.target)
                w.emit(".send(")
                genExpr(co.value)
                w.emit(");\n")
                return
        # Chan recv: target <- ch  (value is a Chan local)
        var co_rhs_nm = getMemberFieldName(co.value)
        if co_rhs_nm != nil
            if chan_locals.contains_(co_rhs_nm to!)
                writeIndent()
                genExpr(co.target)
                w.emit(" = ")
                genExpr(co.value)
                w.emit(".recv();\n")
                return
        var is_str  = .isStringBoth(co.value, "copy_out")
        var is_prim = .isPrimType(co.value)
        if allocate_depth > 0 and is_str
            var uid = w.nextUid()
            var uid_str = uid.toString()
            writeIndent()
            w.emit("const _co_")
            w.emit(uid_str)
            w.emit(": []const u8 = ")
            genExpr(co.value)
            w.emit(";\n")
            writeIndent()
            genExpr(co.target)
            w.emit(" = _saved_alloc_")
            var saved_idx = arena_counter - 1
            w.emit(saved_idx.toString())
            w.emit(".dupe(u8, _co_")
            w.emit(uid_str)
            w.emit(") catch _co_")
            w.emit(uid_str)
            w.emit(";\n")
        else if allocate_depth > 0 and not is_prim
            var uid = w.nextUid()
            var uid_str = uid.toString()
            writeIndent()
            w.emit("const _co_")
            w.emit(uid_str)
            w.emit(" = ")
            genExpr(co.value)
            w.emit(";\n")
            writeIndent()
            genExpr(co.target)
            w.emit(" = _zbr_deep_copy(@TypeOf(_co_")
            w.emit(uid_str)
            w.emit("), _saved_alloc_")
            var saved_idx2 = arena_counter - 1
            w.emit(saved_idx2.toString())
            w.emit(", _co_")
            w.emit(uid_str)
            w.emit(", 0) catch @panic(\"OOM copy-out\");\n")
        else
            writeIndent()
            genExpr(co.target)
            w.emit(" = ")
            genExpr(co.value)
            w.emit(";\n")

    # ── genGuard ──────────────────────────────────────────────────────────────

    def genGuard(g: StmtGuard)
        writeIndent()
        w.emit("if (!(")
        genExpr(g.cond)
        w.emit(")) {\n")
        var ig = indented()
        ig.genStmts(g.else_stmts)
        writeIndent()
        w.emit("}\n")

    # ── genDestruct ───────────────────────────────────────────────────────────

    def genDestruct(d: StmtDestruct)
        var uid: int = w.nextUid()
        var tmp: str = "_zbr_dt_" + uid.toString()
        writeIndent()
        w.emit("const ")
        w.emit(tmp)
        w.emit(" = ")
        genExpr(d.init_expr)
        w.emit(";\n")
        var i = 0
        while i < d.names.count()
            writeIndent()
            w.emit("const ")
            w.emit(d.names.at(i))
            w.emit(" = ")
            w.emit(tmp)
            if d.is_struct
                # Struct destructure: `const x = _tmp.fieldname;`
                w.emit(".")
                w.emit(d.names.at(i))
            else
                # Tuple destructure: `const x = _tmp.@"0";`
                w.emit(".@\"")
                w.emit(i.toString())
                w.emit("\"")
            w.emit(";\n")
            i += 1

    def genFloatLit(text: str)
        # Strip _f32/_f64/f32/f64 suffix; emit @as(fNN, value). Zig has no suffixed float literals.
        # Use replace("suffix","") to extract the bare value — avoids str.len (uint) arithmetic.
        if text.endsWith("_f32")
            w.emit("@as(f32, " + text.replace("_f32", "") + ")")
        else if text.endsWith("_f64")
            w.emit("@as(f64, " + text.replace("_f64", "") + ")")
        else if text.endsWith("f32")
            w.emit("@as(f32, " + text.replace("f32", "") + ")")
        else if text.endsWith("f64")
            w.emit("@as(f64, " + text.replace("f64", "") + ")")
        else
            w.emit(text)

    # ── genExpr ───────────────────────────────────────────────────────────────

    def genExpr(e: Expr)
        branch e
            on Expr.int_lit as il
                w.emit(il.text)
            on Expr.float_lit as fl
                genFloatLit(fl.text)
            on Expr.bool_lit as bl
                if bl.value
                    w.emit("true")
                else
                    w.emit("false")
            on Expr.char_lit as cl
                # Raw text is e.g. c'A' or c'\'' — strip leading c, emit rest as-is
                if cl.text.len > 1 and cl.text.startsWith("c")
                    # cl.text[1..] — use split trick: split on first char, rejoin rest
                    var parts: List(str) = List(str)()
                    var first_skipped: bool = false
                    for p in cl.text.split("c")
                        if not first_skipped
                            first_skipped = true
                        else
                            parts.add(p)
                    # Rejoin with "c" in case the inner text contains c
                    var rest: str = ""
                    var pi: int = 0
                    while pi < parts.len
                        if pi > 0
                            rest = rest + "c"
                        rest = rest + parts.at(pi)
                        pi = pi + 1
                    w.emit(rest)
                else
                    w.emit("'")
                    w.emit(cl.text)
                    w.emit("'")
            on Expr.string_lit as sl
                genStringLit(sl)
            on Expr.string_interp as si
                genStringInterp(si)
            on Expr.nil_
                w.emit("null")
            on Expr.this_
                w.emit(self_name)
            on Expr.result_
                # `result` in ensure clause — emit the captured return-value local.
                w.emit("_result")
            on Expr.ident as id
                genIdent(id)
            on Expr.member as m
                # Catch-variable member: e.message → _zbr_error_msg(), e.details → _error_ctx.details
                if catch_var != ""
                    if m.object is Expr.ident as mid
                        if mid.name == catch_var
                            if m.member == "message"
                                w.emit("_zbr_error_msg()")
                                return
                            if m.member == "details"
                                w.emit("_error_ctx.details")
                                return
                # List.len → @as(i64, @intCast(.items.len))
                # HashMap.len/count → @as(i64, @intCast(.count()))
                # String.len → .len (no .items)
                if m.member == "len" or m.member == "count"
                    var fname = getMemberFieldName(m.object)
                    var is_list_obj = false
                    var is_hm_obj = false
                    if fname != nil
                        var fn2 = fname to!
                        # str_params takes priority — string variables are never lists
                        if not str_params.contains_(fn2)
                            if isFieldName(fn2)
                                # BUG-138: a field of the CURRENT class — its declared
                                # type is authoritative.  Trust isListField (class-
                                # scoped) and do NOT fall through to the name-based
                                # fieldIsList, which false-positives when ANOTHER class
                                # has a same-named List field (e.g. one class's
                                # `source: str` vs another's `source: List(PNode)` →
                                # `self.source.items.len` on a `[]const u8`).
                                is_list_obj = isListField(fn2)
                            else
                                is_list_obj = isListField(fn2) or localIsList(fn2) or isKnownListField(fn2) or fieldIsList(.module_types, .dep_types, fn2)
                        is_hm_obj = fieldAwareIsHashMap(fn2)
                    if is_list_obj
                        w.emit("@as(i64, @intCast(")
                        genExpr(m.object)
                        w.emit(".items.len))")
                        return
                    if is_hm_obj
                        w.emit("@as(i64, @intCast(")
                        genExpr(m.object)
                        w.emit(".count()))")
                        return
                    # str.len or any other .len — always usize in Zig, cast to i64
                    if m.member == "len"
                        w.emit("@as(i64, @intCast(")
                        genExpr(m.object)
                        w.emit(".len))")
                        return
                # Math constants: Math.PI, Math.E, Math.TAU, Math.PHI, etc.
                if m.object is Expr.ident as math_id
                    if math_id.name == "Math"
                        if m.member == "PI"
                            w.emit("std.math.pi")
                            return
                        if m.member == "E"
                            w.emit("std.math.e")
                            return
                        if m.member == "TAU"
                            w.emit("std.math.tau")
                            return
                        if m.member == "INF"
                            w.emit("std.math.inf(f64)")
                            return
                        if m.member == "NAN"
                            w.emit("std.math.nan(f64)")
                            return
                        if m.member == "PHI"
                            w.emit("std.math.phi")
                            return
                        if m.member == "SQRT2"
                            w.emit("std.math.sqrt2")
                            return
                        if m.member == "LN2"
                            w.emit("std.math.ln2")
                            return
                        if m.member == "LN10"
                            w.emit("std.math.ln10")
                            return
                # DateTime field access: obj.year → _dt_to_gregorian(obj.epoch_ms).year
                # obj.weekday → _dt_weekday(obj)
                var is_dt_field = m.member == "year" or m.member == "month" or m.member == "day"
                var is_dt_field2 = m.member == "hour" or m.member == "minute" or m.member == "second"
                if is_dt_field or is_dt_field2
                    if isDateTimeExpr(m.object)
                        w.emit("_dt_to_gregorian(")
                        genExpr(m.object)
                        w.emit(".epoch_ms).")
                        w.emit(m.member)
                        return
                if m.member == "weekday"
                    if isDateTimeExpr(m.object)
                        w.emit("_dt_weekday(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                # Tuple index access: p.0 → p.@"0"
                if m.member.len > 0 and m.member.isNumeric()
                    genExpr(m.object)
                    w.emit(".@\"")
                    w.emit(m.member)
                    w.emit("\"")
                    return
                genExpr(m.object)
                w.emit(".")
                w.emit(m.member)
                # Auto-deref ^T fields: if binding.field is a *T, emit .*
                var obj_name = getIdentName(m.object)
                if obj_name != nil
                    var bfkey = makeDottedKey(obj_name to!, m.member)
                    # For-loop variable deref takes priority over branch-binding deref
                    if for_loop_vars.contains_(obj_name to!)
                        # Variable is a for-loop var: only deref if in for_loop_deref
                        if for_loop_deref.contains_(bfkey)
                            w.emit(".*")
                    else if ptr_field_bindings.contains_(bfkey)
                        w.emit(".*")
            on Expr.call as c
                genCall(c)
            on Expr.index as ix
                var idx_obj_nm = getMemberFieldName(ix.object)
                var is_hm_idx = false
                var is_list_idx = false
                if idx_obj_nm != nil
                    var idx_nm = idx_obj_nm to!
                    is_hm_idx = fieldAwareIsHashMap(idx_nm)
                    if not is_hm_idx
                        is_list_idx = fieldAwareIsList(idx_nm)
                if is_hm_idx
                    genExpr(ix.object)
                    w.emit(".get(")
                    genExpr(ix.index)
                    w.emit(").?")
                else
                    genExpr(ix.object)
                    if is_list_idx
                        # BUG-141: List receiver is a std.ArrayList — index its backing slice.
                        w.emit(".items")
                    w.emit("[@as(usize, @intCast(")
                    genExpr(ix.index)
                    w.emit("))]")
            on Expr.slice as sl2
                genExpr(sl2.object)
                w.emit("[")
                if sl2.start != nil
                    w.emit("@as(usize, @intCast(")
                    genExpr(sl2.start to!)
                    w.emit("))")
                w.emit("..")
                if sl2.stop_ != nil
                    w.emit("@as(usize, @intCast(")
                    genExpr(sl2.stop_ to!)
                    w.emit("))")
                w.emit("]")
            on Expr.binary as b
                genBinary(b)
            on Expr.unary as u
                genUnary(u)
            on Expr.cast as ca
                w.emit("@as(")
                genType(ca.target)
                w.emit(", ")
                genExpr(ca.expr)
                w.emit(")")
            on Expr.to_nilable as tn
                # Just emit the inner expression (optional wrapping is implicit)
                genExpr(tn.expr)
            on Expr.to_non_nil as tnn
                genExpr(tnn.expr)
                w.emit(".?")
                # If inner expr is a member access to a ^T? field, deref after unwrap
                if tnn.expr is Expr.member as tnn_m
                    var tnn_obj = getIdentName(tnn_m.object)
                    if tnn_obj != nil
                        var tnn_key = makeDottedKey(tnn_obj to!, tnn_m.member)
                        if opt_ptr_field_bindings.contains_(tnn_key)
                            w.emit(".*")
            on Expr.is_nil as isn
                w.emit("(")
                genExpr(isn.expr)
                w.emit(" == null)")
            on Expr.orelse_ as or_
                genExpr(or_.expr)
                w.emit(" orelse ")
                genExpr(or_.fallback)
            on Expr.catch_ as ca2
                genExpr(ca2.expr)
                w.emit(" catch ")
                if ca2.err_var != nil
                    w.emit("|")
                    w.emit(ca2.err_var to!)
                    w.emit("| ")
                genExpr(ca2.fallback)
            on Expr.if_expr as ie
                w.emit("if (")
                genExpr(ie.cond)
                w.emit(") ")
                genExpr(ie.then_expr)
                w.emit(" else ")
                genExpr(ie.else_expr)
            on Expr.lambda as lam
                genLambda(lam)
            on Expr.list_lit as ll
                # `[a, b, c]` lowers to a labeled-block that builds a
                # std.ArrayList(T).  Element type comes from:
                #   1. the explicit `elem_type` field (currently always nil
                #      from the parse path — reserved for a future syntax),
                #   2. inferExpr on the first element,
                #   3. fallback to `[]const u8` (which is wrong for non-str,
                #      but at least the resulting Zig error points here).
                # An empty `[]` from `var x: List(T) = []` is handled in
                # genLocalVar before this branch fires; a bare `[]` in
                # expression position uses the fallback.
                var ll_uid = w.nextUid()
                var ll_label: str = "blk_ll_" + ll_uid.toString()
                var ll_var:   str = "_ll_" + ll_uid.toString()
                w.emit("(" + ll_label + ": { var " + ll_var + ": std.ArrayList(")
                var elem_zig: str = "[]const u8"
                if ll.elem_type != nil
                    # honoured for future explicit-typed list literal
                    genType(ll.elem_type to!)
                    w.emit(") = std.ArrayList(")
                    genType(ll.elem_type to!)
                    w.emit(").empty; ")
                else if ll.elems.count() > 0 and .infer_ctx != nil
                    var et: Type_ = inferExpr(ll.elems.at(0), .infer_ctx to!)
                    # §27a: user class/struct elements render *Class (classes) /
                    # value (structs); cross-module user types are reference (*T).
                    # zigTypeForListElem (free fn) lacks the class registry, so
                    # resolve element type here.  Nested `else { if ... as ... }`
                    # (not `else if ... as ...`) avoids a bootstrap genIf crash on
                    # an else-if whose condition is `<call> as <bind>`.
                    if et is Type_.cross_module as et_cm
                        # Module-qualified (`*tween.TweenGoal`): the element type
                        # may not be `exposing`-imported, but the dep module is
                        # always `@import`ed under its alias.
                        elem_zig = "*" + et_cm.module + "." + et_cm.type_name
                    else
                        if structNameFromType(et) as et_snm
                            if class_names.contains_(et_snm)
                                elem_zig = "*" + et_snm
                            else
                                elem_zig = et_snm
                        else
                            elem_zig = zigTypeForListElem(et)
                    w.emit(elem_zig + ") = std.ArrayList(" + elem_zig + ").empty; ")
                else
                    w.emit(elem_zig + ") = std.ArrayList(" + elem_zig + ").empty; ")
                var li = 0
                while li < ll.elems.count()
                    w.emit(ll_var + ".append(_allocator, ")
                    genExpr(ll.elems.at(li))
                    w.emit(") catch @panic(\"OOM\"); ")
                    li += 1
                w.emit("break :" + ll_label + " " + ll_var + "; })")
            on Expr.dict_lit as dl
                w.emit("blk: { var _dl = std.StringHashMap(anytype).init(_allocator); ")
                for en in dl.entries
                    w.emit("_dl.put(")
                    genExpr(en.key)
                    w.emit(", ")
                    genExpr(en.value)
                    w.emit(") catch @panic(\"OOM\"); ")
                w.emit("break :blk _dl; }")
            on Expr.array_lit as al
                w.emit(".{")
                var ali = 0
                while ali < al.elems.count()
                    if ali > 0
                        w.emit(", ")
                    genExpr(al.elems.at(ali))
                    ali += 1
                w.emit("}")
            on Expr.zig_lit as zl
                # astbuilder already stripped the zig"..." wrapper via stripZigQuotes.
                w.emit(zl.text)
            on Expr.try_ as tr
                if try_block_label != nil
                    # Inside try block: use catch-break pattern instead of try keyword
                    in_try_expr = true
                    genExpr(tr.expr)
                    in_try_expr = false
                    emitTryBlockCatch()
                else
                    w.emit("try ")
                    in_try_expr = true
                    genExpr(tr.expr)
                    in_try_expr = false
            on Expr.tuple_lit as tu
                w.emit(".{")
                var ti = 0
                while ti < tu.elems.count()
                    if ti > 0
                        w.emit(", ")
                    genExpr(tu.elems.at(ti))
                    ti += 1
                w.emit("}")
            on Expr.type_check as tc2
                if tc2.variant_name != nil
                    # Union variant check: expr == .variant
                    w.emit("(")
                    genExpr(tc2.expr)
                    w.emit(" == .")
                    w.emit(tc2.variant_name to!)
                    w.emit(")")
                else
                    # Class type-tag check: expr._type_tag == _ttag_TypeName
                    w.emit("(")
                    genExpr(tc2.expr)
                    w.emit("._type_tag == _ttag_")
                    w.emit(tc2.type_name)
                    w.emit(")")
            on Expr.old_ as o
                # ensure contract: emit _old_N reference (uid set at AST build time)
                if in_ensure_emit
                    w.emit("_old_")
                    w.emit(o.uid.toString())
                else
                    genExpr(o.operand)
            on Expr.chained_cmp as cc
                # a < b < c → (_cchain_N: { const _cm0_N = b; break :_cchain_N (_zebra_lt(a, _cm0_N) and _zebra_lt(_cm0_N, c)); })
                var cc_uid = w.nextUid()
                var cc_n = cc.ops.count()
                w.emit("(_cchain_${cc_uid.toString()}: {")
                # Emit temps for middle operands (indices 1..n-1)
                var cc_ti = 0
                while cc_ti < cc_n - 1
                    w.emit("const _cm" + cc_ti.toString() + "_" + cc_uid.toString() + " = ")
                    genExpr(cc.operands.at(cc_ti + 1))
                    w.emit("; ")
                    cc_ti = cc_ti + 1
                w.emit("break :_cchain_" + cc_uid.toString() + " (")
                var cc_ci = 0
                while cc_ci < cc_n
                    if cc_ci > 0
                        w.emit(" and ")
                    var cc_op = cc.ops.at(cc_ci)
                    if cc_op == "=="
                        w.emit("_zebra_eq(")
                    else if cc_op == "!="
                        w.emit("_zebra_ne(")
                    else if cc_op == "<"
                        w.emit("_zebra_lt(")
                    else if cc_op == "<="
                        w.emit("_zebra_le(")
                    else if cc_op == ">"
                        w.emit("_zebra_gt(")
                    else
                        w.emit("_zebra_ge(")
                    # Left operand: first operand or previous temp
                    if cc_ci == 0
                        genExpr(cc.operands.at(0))
                    else
                        w.emit("_cm" + (cc_ci - 1).toString() + "_" + cc_uid.toString())
                    w.emit(", ")
                    # Right operand: current temp or last operand
                    if cc_ci < cc_n - 1
                        w.emit("_cm" + cc_ci.toString() + "_" + cc_uid.toString())
                    else
                        genExpr(cc.operands.at(cc_n))
                    w.emit(")")
                    cc_ci = cc_ci + 1
                w.emit("); })")

            on Expr.except_ as ex
                # struct update: blk: { var _tmp = base; _tmp.f = v; break :blk _tmp; }
                w.emit("blk: { var _except_tmp = ")
                genExpr(ex.base)
                # BUG-031: emit `.*` only when the base is `this`.  In method
                # bodies `this` lowers to `self: *Owner` (for both class and
                # struct owners — genMethod always writes `self: *T`), so a
                # deref is needed to produce a value copy.  Value-typed
                # locals (`local except {...}`) must not be deref'd.
                var base_is_this = false
                branch ex.base
                    on Expr.this_
                        base_is_this = true
                    else
                        pass
                if base_is_this and in_method
                    w.emit(".*")
                w.emit("; ")
                for ef in ex.fields
                    w.emit("_except_tmp.")
                    w.emit(ef.name)
                    w.emit(" = ")
                    var ef_ftype = lookupFieldType(ef.name)
                    if ef_ftype != nil
                        genCallWithTypeHint(ef.value, ef_ftype to!)
                    else
                        genExpr(ef.value)
                    w.emit("; ")
                w.emit("break :blk _except_tmp; }")

            on Expr.opt_chain as oc
                # Member: (if (base) |_oc_N| _oc_N.member else null)
                # Method: (if (base) |_oc_val_N| _oc_blk_N: { var _oc_N = _oc_val_N; break :_oc_blk_N _oc_N.method(args); } else null)
                var oc_uid = w.nextUid()
                var oc_u = oc_uid.toString()
                w.emit("(if (")
                genExpr(oc.base)
                if oc.has_args
                    w.emit(") |_oc_val_" + oc_u + "| _oc_blk_" + oc_u + ": { var _oc_" + oc_u + " = _oc_val_" + oc_u + "; break :_oc_blk_" + oc_u + " _oc_" + oc_u + ".")
                    w.emit(oc.member)
                    w.emit("(")
                    var ai = 0
                    while ai < oc.args.count()
                        if ai > 0
                            w.emit(", ")
                        var a = oc.args.at(ai)
                        if a.name != nil
                            w.emit(a.name to!)
                            w.emit(" = ")
                        genExpr(a.value)
                        ai = ai + 1
                    w.emit("); } else null)")
                else
                    w.emit(") |_oc_" + oc_u + "| _oc_" + oc_u + ".")
                    w.emit(oc.member)
                    w.emit(" else null)")

    # ── genIdent ──────────────────────────────────────────────────────────────

    def genIdent(id: ExprIdent)
        if capture_fields.contains_(id.name)
            w.emit("self.")
            w.emit(id.name)
            return
        if in_method and isFieldName(id.name)
            if isSharedField(id.name)
                w.emit(owner)
            else
                w.emit(self_name)
            w.emit(".")
            w.emit(id.name)
            return
        # BUG-137: a reference to a module-level var → its prefixed file-scope
        # name (matches genFieldDecl), UNLESS a local/param of the same name
        # shadows it — in which case the bare name refers to the local. A class
        # field of the same name already won returned above (fields shadow
        # module vars inside methods).
        if isModuleVarName(id.name) and not isLocalOrParamName(id.name)
            w.emit("_zbr_mv_")
            w.emit(id.name)
            return
        w.emit(id.name)

    # True if `name` is a module-level var/const (registered under the ""
    # sentinel class by populateModuleTypes). Module vars emit as a prefixed
    # file-scope `pub var`/`pub const`; see genFieldDecl + genIdent (BUG-137).
    def isModuleVarName(name: str): bool
        return .module_types.fieldType("", name) != nil

    # True if `name` is bound as a local or parameter in the current method, so
    # it shadows any same-named module var and must keep its bare Zig name.
    def isLocalOrParamName(name: str): bool
        if param_names != nil
            if param_names to!.contains_(name)
                return true
        if .infer_ctx as ic
            if ic.hasLocal(name)
                return true
        return false

    # BUG-137: register a binding name (for-loop variable, `if/branch … as`
    # capture, …) as a local in infer_ctx so the genIdent module-var shadow
    # guard treats it as a local rather than prefixing it as a module var.
    # genLocalVar handles plain `var`/`const`; this covers the other binding
    # forms. Binds as unknown only if not already bound, to avoid clobbering a
    # known type seeded for inference.
    def noteShadowLocal(name: str)
        if .infer_ctx as ic
            if not ic.hasLocal(name)
                ic.bind(name, Type_.unknown_)

    def isSharedField(name: str): bool
        for d in owner_members
            if d is Decl.var_ as fld
                if fld.name == name
                    return fld.mods.is_static
        return false

    def isFieldName(name: str): bool
        # Not a field if it's a parameter name (params shadow fields)
        if param_names != nil
            if param_names to!.contains_(name)
                return false
        for d in owner_members
            if d is Decl.var_ as fld
                if fld.name == name
                    return true
        return false

    # ── genBinary ─────────────────────────────────────────────────────────────

    def genBinary(b: ExprBinary)
        if b.op == BinaryOp.add
            # Check if string concatenation — use _str_concat which is always safe (no try needed)
            if .isStringBoth(b.left, "bin_add_l") or .isStringBoth(b.right, "bin_add_r")
                w.emit("_str_concat(")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(", _allocator)")
                return
        if b.op == BinaryOp.mod
            w.emit("@mod(")
            genExpr(b.left)
            w.emit(", ")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.int_div or b.op == BinaryOp.div
            # `//` is always integer-division; bare `/` becomes Zig `/` for
            # floats and `@divTrunc` for ints.  Without this discrimination,
            # `2.5 / 4.0` would compile to `@divTrunc(2.5, 4.0)` which Zig
            # rejects (or worse, with `int_div` semantics, silently rounds).
            var is_float_div = false
            if b.op == BinaryOp.div and .infer_ctx != nil
                var lt: Type_ = inferExpr(b.left, .infer_ctx to!)
                branch lt
                    on Type_.float_
                        is_float_div = true
                    on Type_.float_n as _
                        is_float_div = true
                    else
                        pass
            if is_float_div
                w.emit("(")
                genExpr(b.left)
                w.emit(" / ")
                genExpr(b.right)
                w.emit(")")
            else
                w.emit("@divTrunc(")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(")")
            return
        if b.op == BinaryOp.pow
            w.emit("std.math.pow(i64, ")
            genExpr(b.left)
            w.emit(", ")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.in_
            # `_zebra_in` handles ArrayList, HashMap, and tuple literals
            # uniformly via comptime dispatch in the runtime preamble.
            # Use it whenever the right operand is plausibly a container:
            #   - `@[…]` array literal
            #   - a List(T) or HashMap(K,V) — recognised via TC's inferred type.
            # Strings stay on the substring fast path (std.mem.indexOf).
            var in_use_zebra_in = false
            branch b.right
                on Expr.array_lit
                    in_use_zebra_in = true
                on Expr.list_lit
                    in_use_zebra_in = true
                on Expr.ident as in_id
                    if localIsList(in_id.name) or localIsHashMap(in_id.name)
                        in_use_zebra_in = true
                    else if .infer_ctx != nil
                        var rt: Type_ = inferExpr(b.right, .infer_ctx to!)
                        # The TC may not yet know the variable's declared
                        # generic type, but the local tracking sets above
                        # cover the common cases.  When TC does know,
                        # `.named` over List/HashMap also routes here.
                        if rt is Type_.named as nm
                            if nm == "List" or nm == "HashMap"
                                in_use_zebra_in = true
                else
                    pass
            if in_use_zebra_in
                w.emit("_zebra_in(")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(")")
                return
            # Default: string substring check via std.mem.indexOf.
            w.emit("(std.mem.indexOf(u8, ")
            genExpr(b.right)
            w.emit(", ")
            genExpr(b.left)
            w.emit(") != null)")
            return
        if b.op == BinaryOp.dotdot
            w.emit("(")
            genExpr(b.left)
            w.emit("..")
            genExpr(b.right)
            w.emit(")")
            return
        if b.op == BinaryOp.eq or b.op == BinaryOp.ne
            # String ==/!= must use std.mem.eql in Zig (slices can't use ==).
            # Skip when either side is nil (null comparison on optionals).
            var either_nil: bool = false
            branch b.left
                on Expr.nil_
                    either_nil = true
                else
                    pass
            if not either_nil
                branch b.right
                    on Expr.nil_
                        either_nil = true
                    else
                        pass
            if not either_nil and (.isStringBoth(b.left, "bin_eq_l") or .isStringBoth(b.right, "bin_eq_r"))
                if b.op == BinaryOp.ne
                    w.emit("!")
                w.emit("std.mem.eql(u8, ")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(")")
                return
            # Union variant comparison: X == UnionType.variant() → std.meta.eql
            if not either_nil and (isUnionCtorExpr(b.left) or isUnionCtorExpr(b.right))
                if b.op == BinaryOp.ne
                    w.emit("!")
                w.emit("std.meta.eql(")
                genExpr(b.left)
                w.emit(", ")
                genExpr(b.right)
                w.emit(")")
                return
            # @derive(Eq) struct: route == / != through the generated eql() method.
            if not either_nil
                var left_eq_struct = .isDeriveEqExpr(b.left)
                if left_eq_struct
                    if b.op == BinaryOp.ne
                        w.emit("!")
                    genExpr(b.left)
                    w.emit(".eql(&")
                    genExpr(b.right)
                    w.emit(")")
                    return
        # Ordered comparisons use _zebra_gt/lt/ge/le helpers which handle strings via comptime.
        # This is critical for anytype lambda params where Zig's > is invalid on []const u8.
        if b.op == BinaryOp.gt or b.op == BinaryOp.lt or b.op == BinaryOp.ge or b.op == BinaryOp.le
            var cmp_fn = "_zebra_gt"
            if b.op == BinaryOp.lt
                cmp_fn = "_zebra_lt"
            if b.op == BinaryOp.ge
                cmp_fn = "_zebra_ge"
            if b.op == BinaryOp.le
                cmp_fn = "_zebra_le"
            w.emit(cmp_fn)
            w.emit("(")
            genExpr(b.left)
            w.emit(", ")
            genExpr(b.right)
            w.emit(")")
            return
        w.emit("(")
        genExpr(b.left)
        w.emit(" ")
        w.emit(binaryOpStr(b.op))
        w.emit(" ")
        genExpr(b.right)
        w.emit(")")

    def isStringExpr(e: Expr): bool
        branch e
            on Expr.string_lit
                return true
            on Expr.string_interp
                return true
            on Expr.ident as id
                # Parameter or local typed: str
                if str_params.contains_(id.name)
                    return true
                # Owner field typed: str (bare ident = implicit self.field)
                var ftype = lookupFieldType(id.name)
                if ftype != nil
                    if ftype to! is TypeRef.named as nt
                        if nt.name == "str" or nt.name == "String"
                            return true
            on Expr.member as m
                # Common string field names
                if m.member == "text" or m.member == "name" or m.member == "message" or m.member == "path" or m.member == "stdout" or m.member == "stderr" or m.member == "src" or m.member == "member"
                    return true
                # Check field type from owner declarations
                if isStringField(e)
                    return true
            on Expr.call as c
                # .toString() / .concat() / other string-returning calls
                if c.callee is Expr.member as cm
                    if cm.member == "toString" or cm.member == "concat" or cm.member == "format" or cm.member == "join" or cm.member == "trim" or cm.member == "upper" or cm.member == "lower" or cm.member == "substring" or cm.member == "replace" or cm.member == "replaceAll"
                        return true
                    # .at(i) on a List(str) local returns a string
                    if cm.member == "at"
                        if cm.object is Expr.ident as lid
                            if localIsListStr(lid.name)
                                return true
            on Expr.to_non_nil as tnn
                # x to! where x is a string? → still a string
                return isStringExpr(tnn.expr)
            on Expr.binary as bin
                # s + "x" or s + typeRefStr(...) — concat is a string if either side is
                if bin.op == BinaryOp.add
                    if isStringExpr(bin.left) or isStringExpr(bin.right)
                        return true
            else
                pass
        return false

    def isUnionCtorExpr(e: Expr): bool
        # Detect union variant constructor: UnionName.variant() where UnionName in union_names
        if e is Expr.call as c
            if c.callee is Expr.member as m
                var obj_name = getIdentName(m.object)
                if obj_name != nil
                    if union_names.contains_(obj_name to!)
                        return true
        return false

    def isDeriveEqExpr(e: Expr): bool
        # Detect @derive(Eq) struct variable: ident whose type name is in derive_eq_structs.
        if .infer_ctx == nil
            return false
        var t: Type_ = inferExpr(e, .infer_ctx to!)
        if t is Type_.named as tn
            return derive_eq_structs.contains_(tn)
        return false

    # ── genUnary ──────────────────────────────────────────────────────────────

    def genUnary(u: ExprUnary)
        if u.op == UnaryOp.neg
            w.emit("(-")
            genExpr(u.operand)
            w.emit(")")
            return
        if u.op == UnaryOp.not_
            w.emit("(!")
            genExpr(u.operand)
            w.emit(")")
            return
        if u.op == UnaryOp.bit_not
            w.emit("(~")
            genExpr(u.operand)
            w.emit(")")
            return
        genExpr(u.operand)

    # ── genStringLit ──────────────────────────────────────────────────────────

    def genStringLit(sl: ExprStringLit)
        if sl.kind == StringKind.zig_
            w.emit(sl.text)
            return
        if sl.kind == StringKind.raw
            w.emit("\"")
            w.emit(sl.text)
            w.emit("\"")
            return
        # Triple-quoted doc string: sl.text starts with """
        var sl_text: str = sl.text
        if sl_text.startsWith("\"\"\"")
            .genDocStringLit(sl_text)
            return
        # plain / nosub: emit: Zig string literal
        w.emit("\"")
        w.emit(sl.text)
        w.emit("\"")

    def genDocStringLit(text: str)
        # Strip """ delimiters, leading newline; escape " and actual newlines for Zig output.
        var dq_parts = List(str)()
        for dqp in text.split("\"\"\"")
            dq_parts.add(dqp)
        var content: str = ""
        if dq_parts.count() >= 2
            content = dq_parts.at(1)
        # Strip leading newline (right after opening """)
        if content.startsWith("\n")
            var nl_split = List(str)()
            for nsp in content.split("\n")
                nl_split.add(nsp)
            content = ""
            var nsi = 1
            while nsi < nl_split.count()
                if nsi > 1
                    content = content + "\n"
                content = content + nl_split.at(nsi)
                nsi = nsi + 1
        # Escape " → \" (so it can be embedded in a Zig double-quoted string)
        var qparts = List(str)()
        for qp in content.split("\"")
            qparts.add(qp)
        var escaped: str = qparts.at(0)
        var qi = 1
        while qi < qparts.count()
            escaped = escaped + "\\\""
            escaped = escaped + qparts.at(qi)
            qi = qi + 1
        # Escape actual newline bytes → \n (the two-char Zig escape sequence)
        var nparts = List(str)()
        for np in escaped.split("\n")
            nparts.add(np)
        var final_str: str = nparts.at(0)
        var ni = 1
        while ni < nparts.count()
            final_str = final_str + "\\n"
            final_str = final_str + nparts.at(ni)
            ni = ni + 1
        w.emit("\"")
        w.emit(final_str)
        w.emit("\"")

    # ── genStringInterp ───────────────────────────────────────────────────────

    # Escape literal parts of a string interpolation for use in a Zig allocPrint
    # format string: double { → {{ and } → }} so they are not mistaken for format
    # specifiers. Other escape sequences (\n, \\, \") are kept as-is — the
    # tokenizer stores them as raw two-char sequences, which Zig interprets
    # correctly when the format string is emitted between double-quotes.
    def escapeLitForFmt(lit: str): str
        return lit.replace("{", "{{").replace("}", "}}")

    def genStringInterp(si: ExprStringInterp)
        # First pass: build format string and collect cast types for each expr slot
        var fmt_str: str = ""
        var cast_types: List(str) = List(str)()
        var needs_tostring: List(bool) = List(bool)()
        var i: int = 0
        while i < si.parts.count()
            var part = si.parts.at(i)
            branch part
                on StringPart.literal as lit
                    fmt_str = fmt_str + escapeLitForFmt(lit)
                on StringPart.expr_ as e
                    var has_fmt: bool = false
                    var fmt_spec: str = ""
                    if i + 1 < si.parts.count()
                        var np = si.parts.at(i + 1)
                        if np is StringPart.format as fs
                            has_fmt = true
                            fmt_spec = fs
                            i = i + 1
                    if has_fmt
                        var ex_type: Type_ = Type_.unknown_
                        if .infer_ctx != nil
                            ex_type = inferExpr(e, .infer_ctx to!)
                        var zig_spec: str = zigFmtSpec(fmt_spec, ex_type)
                        fmt_str = fmt_str + "{" + zig_spec + "}"
                        cast_types.add(bitCastType(fmt_spec, ex_type))
                        needs_tostring.add(false)
                    else
                        # Implicit toString: named type with toString() method → {s}.
                        var ts: bool = false
                        if .infer_ctx != nil
                            var et: Type_ = inferExpr(e, .infer_ctx to!)
                            if et is Type_.named as tn
                                if toString_types.contains_(tn)
                                    ts = true
                        if ts
                            fmt_str = fmt_str + "{s}"
                        else if .isStringBoth(e, "interp_fmt")
                            fmt_str = fmt_str + "{s}"
                        else
                            fmt_str = fmt_str + "{}"
                        cast_types.add("")
                        needs_tostring.add(ts)
                on StringPart.format as _
                    pass
            i = i + 1
        # Second pass: emit the allocPrint call
        w.emit("(std.fmt.allocPrint(_allocator, \"")
        w.emit(fmt_str)
        w.emit("\", .{")
        var first: bool = true
        var arg_idx: int = 0
        for part in si.parts
            if part is StringPart.expr_ as e
                if not first
                    w.emit(", ")
                first = false
                var cast: str = cast_types.at(arg_idx)
                var ts: bool = needs_tostring.at(arg_idx)
                if cast != ""
                    w.emit("@as(")
                    w.emit(cast)
                    w.emit(", @bitCast(")
                    genExpr(e)
                    w.emit("))")
                else if ts
                    genExpr(e)
                    w.emit(".toString()")
                else
                    genExpr(e)
                arg_idx = arg_idx + 1
        w.emit("}) catch @panic(\"OOM\"))")

    # Emit a type argument expression as a Zig type name.
    # Used for generic function call sites: identity(int)(42) → identity(i64, 42).
    def genTypeArg(e: Expr)
        if e is Expr.ident as id
            w.emit(zigPrimitive(id.name))
        else
            genExpr(e)

    # ── Gap 1: emit a call whose args include capture-block lambdas ──────────

    # Resolve the capture-block lambda backing a sig-typed call arg, if any.
    # Returns the lambda for an inline `def(...) capture {...}` or for an
    # ident bound to such a lambda; nil otherwise.  Mirrors the bootstrap's
    # closureLambdaFor — used in BOTH passes of emitCallWithClosureThunks so
    # we avoid a parallel `List(ExprLambda?)` (the optional-in-generic-arg
    # type mis-round-trips through the selfhost parser — emits `try ExprLambda`).
    def resolveClosureLambda(av: Expr): ExprLambda?
        if av is Expr.lambda as lam0
            if lam0.captures.count() > 0
                return lam0
        else if av is Expr.ident as id0
            if closure_vars.contains_(id0.name)
                if closure_lambdas.get(id0.name) as lam_id
                    return lam_id
        return nil

    # stdlib functions that take a closure *struct* via anytype dispatch and so
    # must never be handed a bare-fn-pointer thunk: sys.go(...) and
    # <pool: ThreadPool>.submit(...).  Mirrors bootstrap isStdlibClosureStructConsumer.
    def isStdlibClosureStructConsumer(callee: Expr): bool
        if callee is Expr.member as m
            if m.member == "go"
                if getIdentName(m.object) as on1
                    if on1 == "sys"
                        return true
            if m.member == "submit"
                if getIdentName(m.object) as on2
                    if thread_pool_locals.contains_(on2)
                        return true
        return false

    # Gap 1 gate: thunk every closure arg except those bound for a stdlib
    # struct-consumer (sys.go / ThreadPool.submit).  Mirrors bootstrap
    # callNeedsClosureThunks.  A closure value in Zebra user code can only be
    # typed through a sig param, so this negative gate never un-thunks the
    # cross-module sig case (Signal.connect) — Gap 1's reason for existing.
    def callNeedsClosureThunks(c: ExprCall): bool
        if .isStdlibClosureStructConsumer(c.callee)
            return false
        for a in c.args
            if a.value is Expr.lambda as lam_chk
                if lam_chk.captures.count() > 0
                    return true
            else if a.value is Expr.ident as id_chk
                if closure_vars.contains_(id_chk.name)
                    return true
        return false

    def emitCallWithClosureThunks(c: ExprCall)
        # Pre-assign thunk IDs per closure arg.  Parallel list keeps the same
        # order as c.args; entry is -1 for non-closure args.  The lambda nodes
        # are re-resolved in the emit loop via resolveClosureLambda rather than
        # stored in a parallel optional list.
        var thunk_ids = List(int)()
        for a in c.args
            var av = a.value
            var tid = -1
            if .resolveClosureLambda(av) as r
                tid = w.nextUid()
                pending_thunks.add(ClosureThunk(tid, r))
            thunk_ids.add(tid)
        # Wrap call in `({ setup; target(thunk) })` so it stays an expression
        # in the surrounding Stmt.expr context (Zig 0.16 rejects bare `};`).
        w.emit("({\n")
        var bg = indented()
        var i = 0
        for a in c.args
            var tid = thunk_ids.at(i)
            i = i + 1
            if tid < 0
                continue
            if .resolveClosureLambda(a.value) as lam
                var tid_s = "${tid}"
                # BUG-131: emit the closure value ONCE into _zbr_val_N, then
                # derive its type from that local so the create's @TypeOf and
                # the assignment use the same type.  Re-emitting the inline
                # (struct{...}{...}) literal twice yields two distinct anon
                # types and a "expected main__struct_N, found _M" mismatch.
                bg.writeIndent()
                bg.w.emit("const _zbr_val_" + tid_s + " = ")
                bg.genExpr(a.value)
                bg.w.emit(";")
                bg.w.emit("\n")
                bg.writeIndent()
                bg.w.emit("const _zbr_cls_" + tid_s + " = _allocator.create(@TypeOf(_zbr_val_" + tid_s + ")) catch @panic(\"OOM\");")
                bg.w.emit("\n")
                bg.writeIndent()
                bg.w.emit("_zbr_cls_" + tid_s + ".* = _zbr_val_" + tid_s + ";")
                bg.w.emit("\n")
                # Grab the next pool slot for this connection (BUG-126).
                bg.writeIndent()
                bg.w.emit("if (_zbr_next_" + tid_s + " >= 64) @panic(\"closure-via-sig pool exhausted (>64 live connections at one call site)\");")
                bg.w.emit("\n")
                bg.writeIndent()
                bg.w.emit("const _zbr_slot_" + tid_s + " = _zbr_next_" + tid_s + "; _zbr_next_" + tid_s + " += 1;")
                bg.w.emit("\n")
                bg.writeIndent()
                bg.w.emit("_zbr_state_" + tid_s + "[_zbr_slot_" + tid_s + "] = @ptrCast(_zbr_cls_" + tid_s + ");")
                bg.w.emit("\n")
                bg.writeIndent()
                bg.w.emit("_zbr_dispatch_" + tid_s + " = (struct {")
                bg.w.emit("\n")
                var dg = bg.indented()
                dg.writeIndent()
                dg.w.emit("fn dispatch(ctx: *anyopaque")
                for p in lam.params
                    dg.w.emit(", ")
                    dg.w.emit(p.name)
                    dg.w.emit(": ")
                    if p.type_ != nil
                        dg.genType(p.type_ to!)
                    else
                        dg.w.emit("anytype")
                dg.w.emit(") ")
                if lam.return_type != nil
                    dg.genType(lam.return_type to!)
                else
                    dg.w.emit("void")
                dg.w.emit(" {\n")
                var ig = dg.indented()
                ig.writeIndent()
                ig.w.emit("const cc: *@TypeOf(")
                ig.genExpr(a.value)
                ig.w.emit(") = @ptrCast(@alignCast(ctx));\n")
                ig.writeIndent()
                ig.w.emit("cc.call(")
                var pi = 0
                for p2 in lam.params
                    if pi > 0
                        ig.w.emit(", ")
                    ig.w.emit(p2.name)
                    pi = pi + 1
                ig.w.emit(");\n")
                dg.writeIndent()
                dg.w.emit("}\n")
                bg.writeIndent()
                bg.w.emit("}).dispatch;\n")
        # Emit actual call with thunk fn pointers in place of closure args.
        bg.writeIndent()
        bg.genExpr(c.callee)
        bg.w.emit("(")
        var j = 0
        for a2 in c.args
            if j > 0
                bg.w.emit(", ")
            var tid2 = thunk_ids.at(j)
            if tid2 >= 0
                var tid2_s = "${tid2}"
                bg.w.emit("_zbr_thunks_" + tid2_s + "[_zbr_slot_" + tid2_s + "]")
            else
                bg.genExpr(a2.value)
            j = j + 1
        bg.w.emit(");\n")
        writeIndent()
        w.emit("})")

    # BUG-126: per-call-site trampoline pool.  Each connection needs its own
    # (state slot, thunk fn) pair because a bare Zig fn-pointer carries no
    # context — so K distinct code addresses are required.  When one call site
    # is reached more than K times in a run (e.g. K+1 scene instances of the
    # same script connecting to the same signal), the call site panics rather
    # than silently overwriting earlier connections (the old single-slot
    # behaviour, which dropped all but the last).
    def flushPendingThunks()
        var i = 0
        while i < pending_thunks.count()
            var t = pending_thunks.at(i)
            var id_s = "${t.id}"
            # State pool + shared dispatcher + monotonic slot counter.
            w.emit("\n")
            w.emit("var _zbr_state_" + id_s + ": [64]?*anyopaque = .{null} ** 64;")
            w.emit("\n")
            w.emit("var _zbr_dispatch_" + id_s + ": ?*const fn(*anyopaque")
            for p in t.lambda.params
                w.emit(", ")
                w.emit(p.name)
                w.emit(": ")
                if p.type_ != nil
                    genType(p.type_ to!)
                else
                    w.emit("anytype")
            w.emit(") ")
            if t.lambda.return_type != nil
                genType(t.lambda.return_type to!)
            else
                w.emit("void")
            w.emit(" = null;")
            w.emit("\n")
            w.emit("var _zbr_next_" + id_s + ": usize = 0;")
            w.emit("\n")
            # K thunk functions, each bound to a fixed slot index.
            var slot = 0
            while slot < 64
                var slot_s = "${slot}"
                w.emit("fn _zbr_thunk_" + id_s + "_" + slot_s + "(")
                var pj = 0
                while pj < t.lambda.params.count()
                    if pj > 0
                        w.emit(", ")
                    var pp = t.lambda.params.at(pj)
                    w.emit(pp.name)
                    w.emit(": ")
                    if pp.type_ != nil
                        genType(pp.type_ to!)
                    else
                        w.emit("anytype")
                    pj = pj + 1
                w.emit(") ")
                if t.lambda.return_type != nil
                    genType(t.lambda.return_type to!)
                else
                    w.emit("void")
                w.emit(" {")
                w.emit("\n")
                w.emit("    if (_zbr_state_" + id_s + "[" + slot_s + "]) |s| _zbr_dispatch_" + id_s + ".?(s")
                for p2 in t.lambda.params
                    w.emit(", ")
                    w.emit(p2.name)
                w.emit(");")
                w.emit("\n")
                w.emit("}")
                w.emit("\n")
                slot = slot + 1
            # Lookup table of the K thunk fn pointers, indexed by slot.
            w.emit("const _zbr_thunks_" + id_s + " = [_]*const @TypeOf(_zbr_thunk_" + id_s + "_0){")
            var slot2 = 0
            while slot2 < 64
                if slot2 > 0
                    w.emit(", ")
                w.emit("&_zbr_thunk_" + id_s + "_" + "${slot2}")
                slot2 = slot2 + 1
            w.emit("};")
            w.emit("\n")
            i = i + 1

    # ── genCall ───────────────────────────────────────────────────────────────

    def genCall(c: ExprCall)
        # ── Gap 1: closure-via-sig thunking ───────────────────────────────────
        # Thunk every closure arg (inline capture-block lambda OR ident bound to
        # one) EXCEPT those passed to a stdlib closure-struct consumer (sys.go /
        # ThreadPool.submit), which take the struct directly.  See bootstrap
        # src/CodeGen.zig callNeedsClosureThunks.
        if .callNeedsClosureThunks(c)
            emitCallWithClosureThunks(c)
            return

        # Generic function call: identity(int)(42) → identity(i64, 42).
        # Detected as outer call where callee is a call of a known generic fn name.
        if c.callee is Expr.call as gf_inner
            if gf_inner.callee is Expr.ident as gf_id
                if .module_types.hasGenericFn(gf_id.name) or .dep_types.hasGenericFn(gf_id.name)
                    w.emit(gf_id.name)
                    w.emit("(")
                    var gf_first = true
                    for ta in gf_inner.args
                        if not gf_first
                            w.emit(", ")
                        gf_first = false
                        genTypeArg(ta.value)
                    for va in c.args
                        if not gf_first
                            w.emit(", ")
                        gf_first = false
                        genExpr(va.value)
                    w.emit(")")
                    return
        # Closure vars: capture-lambda struct instances use .call()
        if c.callee is Expr.ident as cid
            if closure_vars.contains_(cid.name)
                w.emit(cid.name)
                w.emit(".call(")
                genArgList(c.args)
                w.emit(")")
                return
        # Cross-module constructor: Module.ClassName(args) → Module.ClassName.init(args)
        # Two detection paths:
        # 1. isCrossModuleCtorCall: obj_name == member_name (same-name unwrap)
        # 2. dep_types.hasClass(member): general cross-module class/struct ctor
        var cm_obj = getMemberObjectIdent(c.callee)
        var cm_mem = getMemberName(c.callee)
        if cm_obj != nil and cm_mem != nil
            var is_xm_ctor = isCrossModuleCtorCall(c.callee) or .dep_types.hasClass(cm_mem to!)
            if is_xm_ctor
                # If genUse unwrapped this module (class_names), emit ClassName.init()
                # Otherwise emit ModuleName.ClassName.init()
                if unwrapped_imports.contains_(cm_obj to!)
                    w.emit(cm_mem to!)
                else
                    w.emit(cm_obj to!)
                    w.emit(".")
                    w.emit(cm_mem to!)
                w.emit(".init(")
                var fc = true
                for a in c.args
                    if not fc
                        w.emit(", ")
                    fc = false
                    genExpr(a.value)
                w.emit(")")
                return
        # Union construction: UnionName.variant(value?) → UnionName{ .variant = value }
        # Enum construction: EnumName.variant() → .variant
        var callee_obj = getMemberObjectIdent(c.callee)
        var callee_mem = getMemberName(c.callee)
        if callee_obj != nil and callee_mem != nil
            var oname = callee_obj to!
            var mname2 = callee_mem to!
            if union_names.contains_(oname) or enum_names.contains_(oname)
                if enum_names.contains_(oname)
                    # Full form for enum: EnumName{ .variant = {} }
                    # Bare .variant fails with `var` in Zig
                    w.emit(oname)
                    w.emit("{ .")
                    w.emit(mname2)
                    w.emit(" = {} }")
                else
                    var variant_key = makeDottedKey(oname, mname2)
                    # Check if this variant has a ^T (pointer) payload
                    # For same-module unions: check boxed_variants set
                    # For cross-module unions: assume all payload variants are boxed
                    # (most AST unions use ^T for their payloads)
                    var is_boxed = boxed_variants.contains_(variant_key)
                    if not is_boxed and c.args.count() > 0
                        # Cross-module or unknown: assume boxed if it has a payload arg
                        if not union_names.contains_(oname)
                            is_boxed = true
                    w.emit(oname)
                    w.emit("{ .")
                    w.emit(mname2)
                    w.emit(" = ")
                    if c.args.count() > 0
                        if is_boxed
                            # Heap-allocate the value for ^T payloads.
                            # Type _bv to the variant's payload child type so
                            # payload-less-tag args (e.g. Type_.string_) coerce
                            # from tag to union at the _bv binding rather than
                            # at @TypeOf(_bv), which would return the tag type.
                            var box_uid: int = w.nextUid()
                            var box_lbl: str = "blk_box_" + box_uid.toString()
                            w.emit(box_lbl)
                            w.emit(": { const _bv: std.meta.Child(@FieldType(")
                            w.emit(oname)
                            w.emit(", \"")
                            w.emit(mname2)
                            w.emit("\")) = ")
                            genExpr(c.args.at(0).value)
                            w.emit("; const _bp = _allocator.create(@TypeOf(_bv)) catch @panic(\"OOM\"); _bp.* = _bv; break :")
                            w.emit(box_lbl)
                            w.emit(" _bp; }")
                        else
                            genExpr(c.args.at(0).value)
                    else
                        w.emit("{}")
                    w.emit(" }")
                return
        # Cross-module union construction: Mod.Union.variant(args) → Mod.Union{ .variant = value }
        # Callee shape: member(member(ident(mod), union_name), variant_name)
        var xmu_parts = getXmUnionParts(c.callee)
        if xmu_parts != nil
            var xmu_list = xmu_parts to!
            var xmu_mod = xmu_list.at(0)
            var xmu_union = xmu_list.at(1)
            var xmu_variant = xmu_list.at(2)
            if .dep_types.hasUnion(xmu_union)
                var xmu_key = makeDottedKey(xmu_union, xmu_variant)
                var xmu_boxed = boxed_variants.contains_(xmu_key)
                w.emit(xmu_mod)
                w.emit(".")
                w.emit(xmu_union)
                w.emit("{ .")
                w.emit(xmu_variant)
                w.emit(" = ")
                if c.args.count() > 0
                    if xmu_boxed
                        var xmu_box_uid: int = w.nextUid()
                        var xmu_box_lbl: str = "blk_box_" + xmu_box_uid.toString()
                        w.emit(xmu_box_lbl)
                        w.emit(": { const _bv: std.meta.Child(@FieldType(")
                        w.emit(xmu_mod)
                        w.emit(".")
                        w.emit(xmu_union)
                        w.emit(", \"")
                        w.emit(xmu_variant)
                        w.emit("\")) = ")
                        genExpr(c.args.at(0).value)
                        w.emit("; const _bp = _allocator.create(@TypeOf(_bv)) catch @panic(\"OOM\"); _bp.* = _bv; break :")
                        w.emit(xmu_box_lbl)
                        w.emit(" _bp; }")
                    else
                        genExpr(c.args.at(0).value)
                else
                    w.emit("{}")
                w.emit(" }")
                return
        # Member call dispatch
        if c.callee is Expr.member as m
            genMemberCall(m, c.args)
            return
        # Generic stdlib ctor: List(T)(), HashMap(K,V)()
        # Generic class ctor: ClassName(TypeArg)(initArgs) → ClassName(*TypeArg).init(initArgs)
        if c.callee is Expr.call as inner
            if inner.callee is Expr.ident as id
                if id.name == "List" or id.name == "HashMap" or id.name == "Chan" or id.name == "Atomic" or id.name == "ThreadPool"
                    genGenericCtorCall(id.name, inner.args, c.args)
                    return
                if class_names.contains_(id.name)
                    w.emit(id.name)
                    w.emit("(")
                    var gci = 0
                    while gci < inner.args.count()
                        if gci > 0
                            w.emit(", ")
                        var gca = inner.args.at(gci).value
                        if gca is Expr.ident as gcid
                            var gca_nm: str = gcid.name
                            if class_names.contains_(gca_nm)
                                w.emit("*")
                            w.emit(zigPrimitive(gca_nm))
                        else
                            genExpr(gca)
                        gci += 1
                    w.emit(").init(")
                    var gci2 = 0
                    while gci2 < c.args.count()
                        if gci2 > 0
                            w.emit(", ")
                        genExpr(c.args.at(gci2).value)
                        gci2 += 1
                    w.emit(")")
                    return
        # Bare stdlib ctor: HashMap() or StrSet() without type params
        if c.callee is Expr.ident as id
            if id.name == "HashMap" and c.args.count() == 0
                # No LHS type context — emit anytype so the Zig error points at the
                # missing annotation rather than producing a misleading type mismatch.
                w.emit("std.StringHashMap(anytype).init(_allocator)")
                return
            if id.name == "StrSet" and c.args.count() == 0
                w.emit("StrSet.init()")
                return
            if id.name == "StringBuilder" and c.args.count() == 0
                w.emit("std.ArrayList(u8).empty")
                return
            if id.name == "ThreadPool"
                w.emit("_thread_pool_create(")
                if c.args.count() > 0
                    genExpr(c.args.at(0).value)
                else
                    w.emit("4")
                w.emit(")")
                return
        # SIMD vector constructor: f32x8(1.0, ...) → @as(@Vector(8, f32), .{1.0, ...})
        if c.callee is Expr.ident as simd_id
            if isSimdTypeName(simd_id.name)
                genSimdCtor(simd_id.name, c.args)
                return
        # BUG-118: class constructor → .init(args); struct without cue init → struct literal
        if c.callee is Expr.ident as id
            if class_names.contains_(id.name) or struct_with_init.contains_(id.name)
                w.emit(id.name)
                w.emit(".init(")
                # Named-arg / default-fill path: any arg has a name, or caller passed
                # fewer args than params (some need their declared defaults filled in).
                # Delegates to genArgListFull which does name→param matching + default emit.
                # Limitation: genArgListNamed does not do the ^T/union-boxing dance that
                # the positional path below does. Named calls with ^Expr-typed params +
                # union-valued args would miss the _bx0 boxing — but such calls don't
                # occur in practice (all user-facing cue init params are value types).
                var ctor_ps: List(Param)? = lookupFnParams(id.name + ".init")
                var ctor_has_named = false
                for ck_a in c.args
                    if ck_a.name != nil
                        ctor_has_named = true
                        break
                var ctor_needs_fill: bool = ctor_has_named
                if not ctor_needs_fill and ctor_ps != nil
                    ctor_needs_fill = c.args.count() < ctor_ps to!.count()
                if ctor_needs_fill
                    var ctor_body: List(Stmt)? = lookupFnBody(id.name + ".init")
                    genArgListFull(c.args, ctor_ps, ctor_body)
                else
                    var first2 = true
                    var box_labels: List(str) = List(str)()
                    box_labels.add("_bx0")
                    box_labels.add("_bx1")
                    box_labels.add("_bx2")
                    box_labels.add("_bx3")
                    box_labels.add("_bx4")
                    box_labels.add("_bx5")
                    var box_idx: int = 0
                    var arg_idx: int = 0
                    for a in c.args
                        if not first2
                            w.emit(", ")
                        first2 = false
                        # Phase 17c: box when the ctor param is ^T (per ModuleTypes)
                        # and inferExpr says the arg produces a union-typed value.
                        # This replaced `shouldBoxCtorArg`, a name-pattern
                        # heuristic (idents ending in _expr, _stmt, etc., plus a
                        # short allow-list of known variable names). Walker is
                        # strictly more conservative: on a 175-.zbr corpus it
                        # boxed 16 additional sites the heuristic missed — all
                        # of them legitimately require `&local` / boxing since
                        # the receiving ctor param is `^Expr` and Zig does not
                        # implicitly take addresses of values.
                        var is_ref_param: bool = ctorParamAtIsRefTo(.module_types, .dep_types, id.name, arg_idx)
                        var should_box: bool = false
                        if is_ref_param and .infer_ctx != nil
                            var wt17c: Type_ = inferExpr(a.value, .infer_ctx to!)
                            should_box = .isUnionType(wt17c)
                        if is_ref_param and should_box
                            # Box: heap-allocate for ^T parameter
                            var lbl = box_labels.at(box_idx)
                            w.emit(lbl)
                            w.emit(": { const _bv = ")
                            genExpr(a.value)
                            w.emit("; const _bp = _allocator.create(@TypeOf(_bv)) catch @panic(\"OOM\"); _bp.* = _bv; break :")
                            w.emit(lbl)
                            w.emit(" _bp; }")
                            box_idx = box_idx + 1
                        else
                            # Use param type hint for zero-arg generic ctors (HashMap(), List(), etc.)
                            var ctor_pt = lookupCtorParamType(id.name, a.name, arg_idx)
                            if ctor_pt != nil
                                genCallWithTypeHint(a.value, ctor_pt to!)
                            else
                                genExpr(a.value)
                        arg_idx = arg_idx + 1
                w.emit(")")
                return
            # BUG-118: plain struct (no cue init) → struct literal StructName{ .field = val }
            if struct_names.contains_(id.name)
                w.emit(id.name)
                w.emit("{")
                var first_sf = true
                for a in c.args
                    if first_sf
                        w.emit(" ")
                    else
                        w.emit(", ")
                    first_sf = false
                    if a.name != nil
                        w.emit(".")
                        var sf_name = a.name to!
                        w.emit(sf_name)
                        w.emit(" = ")
                        var sf_type = lookupStructFieldType(id.name, sf_name)
                        if sf_type != nil
                            genCallWithTypeHint(a.value, sf_type to!)
                        else
                            genExpr(a.value)
                    else
                        genExpr(a.value)
                if not first_sf
                    w.emit(" ")
                w.emit("}")
                return
        # Bare method call: method(args) → self.method(args) or Owner.method(args)
        if c.callee is Expr.ident as id
            if in_method and owner != "" and isOwnerMethod(id.name)
                var callee_throws = isOwnerMethodThrows(id.name)
                if callee_throws and current_method_throws and try_block_label == nil and not in_try_expr
                    w.emit("try ")
                if isOwnerSharedMethod(id.name)
                    w.emit(owner)
                    w.emit(".")
                else
                    w.emit("self.")
                w.emit(id.name)
                w.emit("(")
                var first3 = true
                for a in c.args
                    if not first3
                        w.emit(", ")
                    first3 = false
                    genExpr(a.value)
                w.emit(")")
                if callee_throws and try_block_label != nil and not in_try_expr
                    emitTryBlockCatch()
                return
        # Regular call: callee(args)
        genExpr(c.callee)
        w.emit("(")
        var reg_params: List(Param)? = nil
        var reg_body: List(Stmt)? = nil
        if c.callee is Expr.ident as reg_id
            reg_params = lookupFnParams(reg_id.name)
            reg_body = lookupFnBody(reg_id.name)
        genArgListFull(c.args, reg_params, reg_body)
        w.emit(")")

    # Returns true if `e` is `catch_var.details` — used to detect e.details.toString() pattern.
    def isDetailsMemberOnCatchVar(e: Expr, cv: str): bool
        if e is Expr.member as inner
            if inner.member == "details"
                var obj_name = getIdentName(inner.object)
                if obj_name != nil and obj_name to! == cv
                    return true
        return false

    def genMemberCall(m: ExprMember, args: List(Arg))
        var mname = m.member
        # e.details.toString() inside a catch block → (if (_error_ctx.details) |_det| _det.toString() else "")
        if mname == "toString" and catch_var != ""
            if isDetailsMemberOnCatchVar(m.object, catch_var)
                w.emit("(if (_error_ctx.details) |_det| _det.toString() else \"\")")
                return
        # DateTime.inZone — unique enough name; dispatch without type inference
        if mname == "inZone"
            w.emit("_dt_in_zone(")
            genExpr(m.object)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"UTC\"")
            w.emit(")")
            return
        # Regex instance methods: re.match/find/findAll/replace/groups
        if .infer_ctx != nil
            var recv_t: Type_ = inferExpr(m.object, .infer_ctx to!)
            branch recv_t
                on Type_.regex
                    if mname == "match"
                        w.emit("_regex_match(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "find"
                        w.emit("_regex_find(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "findAll"
                        w.emit("_regex_find_all(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "replace"
                        w.emit("_regex_replace(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(", ")
                        if args.count() >= 2
                            genExpr(args.at(1).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "groups"
                        w.emit("_regex_groups(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                on Type_.sys_process
                    if mname == "kill"
                        w.emit("_sys_process_kill(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                    if mname == "isRunning"
                        w.emit("_sys_process_is_running(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                on Type_.build_ctx
                    genBuildInstanceCall(m.object, mname, args)
                    return
                on Type_.build_target
                    genBuildTargetInstanceCall(m.object, mname, args)
                    return
                on Type_.ws_conn
                    if mname == "send"
                        w.emit("_ws_send(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "recv"
                        w.emit("_ws_recv(")
                        genExpr(m.object)
                        w.emit(", _allocator)")
                        return
                    if mname == "close"
                        w.emit("_ws_close(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                on Type_.tcp_conn
                    if mname == "write"
                        w.emit("_tcp_write(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "read"
                        w.emit("_tcp_read(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                    if mname == "readLine"
                        w.emit("_tcp_read_line(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                    if mname == "readBytes"
                        w.emit("_tcp_read_bytes(")
                        genExpr(m.object)
                        w.emit(", ")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("1024")
                        w.emit(")")
                        return
                    if mname == "close"
                        w.emit("_tcp_close(")
                        genExpr(m.object)
                        w.emit(")")
                        return
                on Type_.udp_socket
                    if mname == "send"
                        genExpr(m.object)
                        w.emit(".send_(")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("\"\"")
                        w.emit(", ")
                        if args.count() >= 2
                            genExpr(args.at(1).value)
                        else
                            w.emit("0")
                        w.emit(", ")
                        if args.count() >= 3
                            genExpr(args.at(2).value)
                        else
                            w.emit("\"\"")
                        w.emit(")")
                        return
                    if mname == "recv"
                        genExpr(m.object)
                        w.emit(".recv_(")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
                            w.emit("65536")
                        w.emit(")")
                        return
                    if mname == "close"
                        genExpr(m.object)
                        w.emit(".close_()")
                        return
                on Type_.sqlite_db
                    if mname == "exec"
                        if args.count() >= 2
                            genExpr(m.object)
                            w.emit(".exec_p_(")
                            genExpr(args.at(0).value)
                            w.emit(", ")
                            genSqliteParams(args.at(1).value)
                            w.emit(")")
                        else
                            genExpr(m.object)
                            w.emit(".exec_(")
                            if args.count() > 0
                                genExpr(args.at(0).value)
                            else
                                w.emit("\"\"")
                            w.emit(")")
                        return
                    if mname == "query"
                        if args.count() >= 2
                            genExpr(m.object)
                            w.emit(".query_p_(")
                            genExpr(args.at(0).value)
                            w.emit(", ")
                            genSqliteParams(args.at(1).value)
                            w.emit(")")
                        else
                            genExpr(m.object)
                            w.emit(".query_(")
                            if args.count() > 0
                                genExpr(args.at(0).value)
                            else
                                w.emit("\"\"")
                            w.emit(")")
                        return
                    if mname == "begin"
                        genExpr(m.object)
                        w.emit(".begin_()")
                        return
                    if mname == "commit"
                        genExpr(m.object)
                        w.emit(".commit_()")
                        return
                    if mname == "rollback"
                        genExpr(m.object)
                        w.emit(".rollback_()")
                        return
                    if mname == "close"
                        genExpr(m.object)
                        w.emit(".close_()")
                        return
                on Type_.sqlite_row
                    if mname == "asInt" or mname == "asBool"
                        genExpr(m.object)
                        w.emit(".int_(")
                        if args.count() > 0
                            genExpr(args.at(0).value)
                        else
