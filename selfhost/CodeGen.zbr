        # Stdlib primitives (List, StringBuilder, HashMap, …) are NOT in ModuleTypes, so
        # methodReturnAny returns nil for them and they fall through to the heuristics.
        if .infer_ctx != nil
            var um_recv_t: Type_ = inferExpr(m.object, .infer_ctx to!)
            if um_recv_t is Type_.named as um_cname
                if .infer_ctx to!.methodReturnAny(um_cname, mname) != nil
                    if isClassMethodThrows(um_cname, mname) and current_method_throws and try_block_label == nil and not in_try_expr
                        w.emit("try ")
                    genExpr(m.object)
                    w.emit("." + mname + "(")
                    var um_ai: int = 0
                    while um_ai < args.count()
