                first = false
                # BUG-091/097: three-case addr-of/pass/deref for container params.
                var already_emitted = false
                if mc_params != nil
                    var msp = mc_params to!
                    if ai_p < msp.count()
                        var mp = msp.at(ai_p)
                        if paramNeedsAddrOf(mp, mc_body)
                            if argIdentInCpp(a.value)
                                genExpr(a.value)        # Case 1: ptr→ptr, no &
                                already_emitted = true
                            else
                                w.emit("&")
                        else
                            if mp.type_ != nil and isContainerTypeRef(mp.type_ to!) and argIdentInCpp(a.value)
                                genExpr(a.value)
                                w.emit(".*")            # Case 2: ptr→value, deref
                                already_emitted = true
                if not already_emitted
                    genExpr(a.value)
                ai_p += 1
        w.emit(")")
        if callee_throws2 and try_block_label != nil and not in_try_expr
            emitTryBlockCatch()

    # ── SIMD helpers ─────────────────────────────────────────────────────────

    def isSimdTypeName(name: str): bool
        if not name.contains("x")
            return false
        var parts: List(str) = name.split("x")
        if parts.count() != 2
            return false
        if parts.at(1) == ""
            return false
        var prefix = parts.at(0)
        if prefix == "f16" or prefix == "f32" or prefix == "f64"
            return true
        if prefix == "i8" or prefix == "i16" or prefix == "i32" or prefix == "i64"
            return true
        if prefix == "u8" or prefix == "u16" or prefix == "u32" or prefix == "u64"
            return true
        return false

    def simdElemZig(prefix: str): str
        if prefix == "f16"
            return "f16"
        if prefix == "f32"
            return "f32"
        if prefix == "f64"
            return "f64"
        if prefix == "i8"
            return "i8"
        if prefix == "i16"
            return "i16"
        if prefix == "i32"
            return "i32"
        if prefix == "i64"
            return "i64"
        if prefix == "u8"
            return "u8"
        if prefix == "u16"
            return "u16"
        if prefix == "u32"
            return "u32"
        if prefix == "u64"
            return "u64"
        return "i64"

    def genSimdCtor(name: str, args: List(Arg))
        # f32x8(1.0, ...) → @as(@Vector(8, f32), .{1.0, ...})
        var parts: List(str) = name.split("x")
        var elem_zig = simdElemZig(parts.at(0))
        var lanes = parts.at(1)
        w.emit("@as(@Vector(")
        w.emit(lanes)
        w.emit(", ")
        w.emit(elem_zig)
        w.emit("), .{")
        var first_sa = true
        for a in args
            if not first_sa
                w.emit(", ")
            first_sa = false
            genExpr(a.value)
        w.emit("})")

    def genSimdStaticCall(type_name: str, mname: str, args: List(Arg))
        var parts: List(str) = type_name.split("x")
        var elem_zig = simdElemZig(parts.at(0))
        var lanes = parts.at(1)
        if mname == "splat"
            # f32x8.splat(v) → @as(@Vector(8, f32), @splat(@as(f32, v)))
            w.emit("@as(@Vector(")
            w.emit(lanes)
            w.emit(", ")
            w.emit(elem_zig)
            w.emit("), @splat(@as(")
            w.emit(elem_zig)
            w.emit(", ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")))")
            return
        if mname == "load"
            # f32x8.load(slice) → @as(@Vector(8, f32), slice[0..8].*)
            w.emit("@as(@Vector(")
            w.emit(lanes)
            w.emit(", ")
            w.emit(elem_zig)
            w.emit("), ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("undefined")
            w.emit("[0..")
            w.emit(lanes)
            w.emit("].*)")
            return

    def genSimdInstanceCall(obj: Expr, mname: str, args: List(Arg))
        if mname == "sum"
            w.emit("@reduce(.Add, ")
            genExpr(obj)
            w.emit(")")
            return
        if mname == "dot"
            w.emit("@reduce(.Add, ")
            genExpr(obj)
            w.emit(" * ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "max_element"
            w.emit("@reduce(.Max, ")
            genExpr(obj)
            w.emit(")")
            return
        if mname == "min_element"
            w.emit("@reduce(.Min, ")
            genExpr(obj)
            w.emit(")")
            return

    def genMathCall(mname: str, args: List(Arg))
        if mname == "sqrt"
            w.emit("std.math.sqrt(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "abs"
            w.emit("@abs(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "floor"
            w.emit("@floor(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "ceil"
            w.emit("@ceil(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "max"
            w.emit("@max(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "min"
            w.emit("@min(")
            genArgList(args)
            w.emit(")")
            return
        if mname == "pow"
            w.emit("std.math.pow(f64, ")
            genArgList(args)
            w.emit(")")
            return
        if mname == "PI"
            w.emit("std.math.pi")
            return
        if mname == "E"
            w.emit("std.math.e")
            return
        # Hyperbolic trig — std.math.* doesn't accept comptime_float; cast to f64
        if mname == "sinh" or mname == "cosh" or mname == "tanh" or mname == "asinh" or mname == "acosh" or mname == "atanh"
            w.emit("std.math.")
            w.emit(mname)
            w.emit("(@as(f64, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("))")
            return
        # Cube root, numerically stable variants
        if mname == "cbrt" or mname == "log1p" or mname == "expm1"
            w.emit("std.math.")
            w.emit(mname)
            w.emit("(@as(f64, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("))")
            return
        # Euclidean distance: hypot(a, b)
        if mname == "hypot"
            w.emit("std.math.hypot(@as(f64, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("), @as(f64, ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit("))")
            return
        # Linear interpolation: lerp(a, b, t)
        if mname == "lerp"
            w.emit("std.math.lerp(@as(f64, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("), @as(f64, ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit("), @as(f64, ")
            if args.count() >= 3
                genExpr(args.at(2).value)
            else
                w.emit("0")
            w.emit("))")
            return
        # Number theory: gcd/lcm — Euclidean algorithm, returns i64
        if mname == "gcd"
            w.emit("(blk_gcd: { var _ga = @as(i64, @intCast(@abs(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("))); var _gb = @as(i64, @intCast(@abs(")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit("))); while (_gb != 0) { const _gt = _gb; _gb = @mod(_ga, _gb); _ga = _gt; } break :blk_gcd _ga; })")
            return
        if mname == "lcm"
            w.emit("(blk_lcm: { const _la = @as(i64, @intCast(@abs(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("))); const _lb = @as(i64, @intCast(@abs(")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit("))); var _lg = _la; var _lh = _lb; while (_lh != 0) { const _lt = _lh; _lh = @mod(_lg, _lh); _lg = _lt; } break :blk_lcm if (_lg == 0) @as(i64, 0) else @divExact(_la, _lg) * _lb; })")
            return
        # Angle conversion
        if mname == "toRadians"
            w.emit("(@as(f64, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(") * std.math.pi / 180.0)")
            return
        if mname == "toDegrees"
            w.emit("(@as(f64, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(") * 180.0 / std.math.pi)")
            return
        # Integer predicates
        if mname == "isPowerOfTwo"
            w.emit("(blk_po2: { const _po2 = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit("; break :blk_po2 _po2 > 0 and (_po2 & (_po2 - 1)) == 0; })")
            return
        # wrap(x, r) — Python-style always-non-negative modulo
        if mname == "wrap"
            w.emit("@mod(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("1")
            w.emit(")")
            return
        # Bit operations
        if mname == "popcount"
            w.emit("@as(i64, @intCast(@popCount(@as(u64, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")))))")
            return
        if mname == "clz"
            w.emit("@as(i64, @intCast(@clz(@as(u64, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")))))")
            return
        if mname == "ctz"
            w.emit("@as(i64, @intCast(@ctz(@as(u64, @intCast(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("0")
            w.emit(")))))")
            return
        # Default: std.math.name(args)
        w.emit("std.math.")
        w.emit(mname)
        w.emit("(")
        genArgList(args)
        w.emit(")")

    def genArgList(args: List(Arg))
        var first = true
        for a in args
            if not first
                w.emit(", ")
            first = false
            genExpr(a.value)

    def lookupFnParams(key: str): List(Param)?
        for decl in module_decls
            if decl is Decl.method as m
                var mname: str = m.name
                if mname == key
                    return m.params
            if decl is Decl.class_ as c
                var cname: str = c.name
                for mem in c.members
                    if mem is Decl.method as dm
                        var full_key: str = cname + "." + dm.name
                        if full_key == key
                            return dm.params
                    if mem is Decl.init as di
                        var init_key: str = cname + ".init"
                        if init_key == key
                            return di.params
                    if mem is Decl.namespace_ as ns
                        for ndecl in ns.decls
                            if ndecl is Decl.method as ndm
                                var ns_key: str = cname + "." + ndm.name
                                if ns_key == key
                                    return ndm.params
            if decl is Decl.struct_ as s
                var sname: str = s.name
                for mem in s.members
                    if mem is Decl.method as dm
                        var full_key2: str = sname + "." + dm.name
                        if full_key2 == key
                            return dm.params
                    if mem is Decl.init as di2
                        var init_key2: str = sname + ".init"
                        if init_key2 == key
                            return di2.params
        # Cross-module fallback (§27b): dep ctor/fn Param lists (with default
        # exprs), so genArgListFull can fill defaulted args for cross-module
        # calls. Key is "Class.method"/"Class.init"; a bare key → free fn ("").
        var cm_parts: List(str) = key.split(".")
        var cm_class: str = ""
        var cm_method: str = key
        if cm_parts.count() >= 2
            cm_class = cm_parts.at(0)
            cm_method = cm_parts.at(1)
        # classOf/fnParamList are cross-module methods returning optionals; the
        # bootstrap now preserves the `?T` on cross-module returns (BUG-133), so
        # bind the unwrapped values directly with `if … as …`.
        if .dep_types.classOf(cm_class) as cm_ct
            if cm_ct.fnParamList(cm_method) as cm_ps
                return cm_ps
        return nil

    # Given a ctor name and an arg (possibly named), return the matching param's TypeRef.
    # Delegates to lookupParamType which takes List(Param) as a proper parameter
    # so that the for-loop rewrite to .items works correctly in the bootstrap.
    def lookupCtorParamType(ctor_name: str, arg_name: str?, arg_idx: int): TypeRef?
        var ps_raw = lookupFnParams(ctor_name + ".init")
        if ps_raw == nil
            return nil
        return lookupParamType(ps_raw to!, arg_name, arg_idx)

    # Worker for lookupCtorParamType — `ps` must be a proper List(Param) parameter
    # so that `for p in ps` rewrites to `for (ps.items) |p|` in the bootstrap compiler.
    def lookupParamType(ps: List(Param), arg_name: str?, arg_idx: int): TypeRef?
        if arg_name != nil
            for p in ps
                var pn: str = p.name
                if pn == arg_name to!
                    return p.type_
            return nil
        if arg_idx < ps.count()
            return ps.at(arg_idx).type_
        return nil

    # BUG-091: parallel to lookupFnParams — return the body so call-site emit
    # can run paramNeedsAddrOf and decide whether to take `&` for each arg.
    def lookupFnBody(key: str): List(Stmt)?
        for decl in module_decls
            if decl is Decl.method as m
                var mname: str = m.name
                if mname == key
                    return m.stmts
            if decl is Decl.class_ as c
                var cname: str = c.name
                for mem in c.members
                    if mem is Decl.method as dm
                        var full_key: str = cname + "." + dm.name
                        if full_key == key
                            return dm.stmts
                    if mem is Decl.init as di
                        var init_key: str = cname + ".init"
                        if init_key == key
                            return di.stmts
                    if mem is Decl.namespace_ as ns
                        for ndecl in ns.decls
                            if ndecl is Decl.method as ndm
                                var ns_key: str = cname + "." + ndm.name
                                if ns_key == key
                                    return ndm.stmts
            if decl is Decl.struct_ as s
                var sname: str = s.name
                for mem in s.members
                    if mem is Decl.method as dm
                        var full_key2: str = sname + "." + dm.name
                        if full_key2 == key
                            return dm.stmts
                    if mem is Decl.init as di2
                        var init_key2: str = sname + ".init"
                        if init_key2 == key
                            return di2.stmts
        return nil

    def genArgListFull(args: List(Arg), params: List(Param)?, body: List(Stmt)?)
        if params == nil
            genArgList(args)
            return
        # Delegate to a typed-parameter helper so .count()/.at() rewrite correctly
        # (the bootstrap compiler only rewrites list methods on function parameters).
        genArgListNamed(args, params to!, body)

    # Inner worker for genArgListFull — ps is a proper parameter so list rewrites apply.
    # Uses `for p in ps` (no .count()/.at() on ps) to avoid selfhost list-rewrite gaps.
    # Full algorithm: for each param, try named match, then positional, then default.
    # This produces byte-identical output to genArgList for purely positional calls.
    # body (when non-nil) drives BUG-091 addr-of detection.
    def genArgListNamed(args: List(Arg), ps: List(Param), body: List(Stmt)?)
        var first = true
        var pos_idx: int = 0
        for p in ps
            if not first
                w.emit(", ")
            first = false
            var needs_addr = paramNeedsAddrOf(p, body)
            var is_container = p.type_ != nil and isContainerTypeRef(p.type_ to!)
            var p_name_str: str = p.name
            var found = false
            var ai: int = 0
            while ai < args.count()
                var a = args.at(ai)
                if a.name != nil
                    if (a.name to!) == p_name_str
                        if needs_addr
                            if argIdentInCpp(a.value)
                                genExpr(a.value)        # Case 1: ptr→ptr, no &
                            else
                                w.emit("&")
                                genExpr(a.value)
                        else
                            if is_container and argIdentInCpp(a.value)
                                genExpr(a.value)
                                w.emit(".*")            # Case 2: ptr→value, deref
                            else
                                if p.type_ != nil
                                    genCallWithTypeHint(a.value, p.type_ to!)
                                else
                                    genExpr(a.value)
                        found = true
                        break
                ai += 1
            if not found
                while pos_idx < args.count()
                    var pa = args.at(pos_idx)
                    pos_idx += 1
                    if pa.name == nil
                        if needs_addr
                            if argIdentInCpp(pa.value)
                                genExpr(pa.value)       # Case 1: ptr→ptr, no &
                            else
                                w.emit("&")
                                genExpr(pa.value)
                        else
                            if is_container and argIdentInCpp(pa.value)
                                genExpr(pa.value)
                                w.emit(".*")            # Case 2: ptr→value, deref
                            else
                                if p.type_ != nil
                                    genCallWithTypeHint(pa.value, p.type_ to!)
                                else
                                    genExpr(pa.value)
                        found = true
                        break
            if not found
                genParamDefault(p)

    # Emit the default expression for an omitted argument to parameter p. With a
    # declared default, emit it. Otherwise emit a deterministic zero value
    # (std.mem.zeroes) rather than `undefined`: a too-few-arguments call — which
    # the type-checker already warns about (BUG-142) — must not read
    # uninitialized memory (undefined behavior). Falls back to `undefined` only
    # when the parameter has no type to zero.
    # p must be a named-type parameter so opt_ptr_field_bindings is seeded for p.default_.
    def genParamDefault(p: Param)
        if p.default_ != nil
            genExpr(p.default_ to!)
        else if p.type_ != nil
            w.emit("std.mem.zeroes(")
            genType(p.type_ to!)
            w.emit(")")
        else
            w.emit("undefined")

    # Helper: scan stmts for the first return-with-value and emit @TypeOf(expr).
    # Returns true if emitted. Using a typed parameter avoids resolver type loss
    # that occurs when the stmts come from a union-bound variable.
    def emitLambdaStmtsRetType(ss: List(Stmt)): bool
        for s in ss
            if s is Stmt.return_ as ret
                if ret.value != nil
                    w.emit("@TypeOf(")
                    genExpr(ret.value to!)
                    w.emit(")")
                    return true
        return false

    # ── genLambda ────────────────────────────────────────────────────────────
    # Emit anonymous struct with a call method.
    # Without capture:   struct { fn call(params) RetT { body } }.call
    def genLambda(lam: ExprLambda)
        var has_capture = lam.captures.count() > 0
        if has_capture
            w.emit("(")
        w.emit("struct {")
        # Emit capture fields
        if has_capture
            w.emit("\n")
            var fg = indented()
            for cv in lam.captures
                fg.writeIndent()
                fg.w.emit(cv.name)
                fg.w.emit(": ")
                if cv.type_ != nil
                    fg.genType(cv.type_ to!)
                else if cv.init_expr != nil
                    # BUG-FIX: previously emitted @TypeOf(cv.name) here, but cv.name
                    # is the field name — not in scope at struct definition time.
                    # Use @TypeOf(<init expression>) instead so Zig can infer.
                    fg.w.emit("@TypeOf(")
                    fg.genExpr(cv.init_expr to!)
                    fg.w.emit(")")
                else
                    fg.w.emit("anytype")
                fg.w.emit(",\n")
            writeIndent()
        # call method
        w.emit(" fn call(")
        var first = true
        if has_capture
            w.emit("self: @This()")
            first = false
        for p in lam.params
            if not first
                w.emit(", ")
            first = false
            w.emit(p.name)
            w.emit(": ")
            if p.type_ != nil
                genType(p.type_ to!)
            else
                w.emit("anytype")
        w.emit(") ")
        # Return type
        if lam.return_type != nil
            genType(lam.return_type to!)
        else
            branch lam.body_
                on LambdaBody.expr_ as ex
                    w.emit("@TypeOf(")
                    genExpr(ex)
                    w.emit(")")
                on LambdaBody.stmts as ss
                    if not emitLambdaStmtsRetType(ss)
                        w.emit("void")
        w.emit(" {")
        # Build capture context for body
        var cf = StrSet()
        for cv in lam.captures
            cf.add(cv.name)
        var mg = asMethod()
        var lg = mg.withCaptureFields(cf)
        branch lam.body_
            on LambdaBody.expr_ as ex
                w.emit(" return ")
                lg.genExpr(ex)
                w.emit(";")
            on LambdaBody.stmts as ss
                w.emit("\n")
                # Clear the outer-fn ensure context so `return` inside the lambda
                # body is NOT rewritten to outer-fn `_result` capture.
                var ig = lg.withInLambda().indented()
                ig.genStmts(ss)
                lg.writeIndent()
        w.emit(" } }")
        # Capture initializer or .call suffix
        if has_capture
            w.emit("{ ")
            for cv in lam.captures
                w.emit(".")
                w.emit(cv.name)
                w.emit(" = ")
                if cv.init_expr != nil
                    # BUG-FIX: previously emitted cv.name here, which only worked
                    # when the capture decl's name happened to match an outer-scope
                    # var of the same name.  Emit the actual init expression instead
                    # (matches the bootstrap codegen at src/CodeGen.zig:9205).
                    genExpr(cv.init_expr to!)
                else
                    w.emit("undefined")
                w.emit(", ")
            w.emit("})")
        else
            w.emit(".call")

    # ── genFileCall ───────────────────────────────────────────────────────────
    # Emit File.* static calls: inline Zig expressions (no allocation needed).

    def genFileCall(mname: str, args: List(Arg))
        if mname == "read"
            w.emit("(std.Io.Dir.cwd().readFileAlloc(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", _allocator, .unlimited) catch @panic(\"File.read error\"))")
            return
        if mname == "write"
            w.emit("(blk_fw: {\n")
            writeIndent()
            w.emit("    const _fw_path = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(";\n")
            writeIndent()
            w.emit("    const _fw_f = std.Io.Dir.cwd().createFile(_io, _zbr_norm_path(_fw_path), .{}) catch @panic(\"File.write error\");\n")
            writeIndent()
            w.emit("    defer _fw_f.close(_io);\n")
            writeIndent()
            w.emit("    _fw_f.writeStreamingAll(_io, ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"File.write error\");\n")
            writeIndent()
            w.emit("    break :blk_fw {};\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "exists"
            w.emit("(blk_fex: { std.Io.Dir.cwd().access(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_fex false; break :blk_fex true; })")
            return
        if mname == "readLines"
            w.emit("(blk_frl: {\n")
            writeIndent()
            w.emit("    const _fl_content = std.Io.Dir.cwd().readFileAlloc(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", _allocator, .unlimited) catch @panic(\"File.readLines error\");\n")
            writeIndent()
            w.emit("    var _fl_list = std.ArrayList([]const u8).empty;\n")
            writeIndent()
            w.emit("    var _fl_it = std.mem.splitScalar(u8, _fl_content, '\\n');\n")
            writeIndent()
            w.emit("    while (_fl_it.next()) |_fl_line| { _fl_list.append(_allocator, _fl_line) catch unreachable; }\n")
            writeIndent()
            w.emit("    break :blk_frl _fl_list;\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "append"
            w.emit("(blk_fa: {\n")
            writeIndent()
            w.emit("    const _fa_path = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(";\n")
            writeIndent()
            w.emit("    const _fa_file = std.Io.Dir.cwd().openFile(_io, _zbr_norm_path(_fa_path), .{ .mode = .read_write })")
            w.emit(" catch std.Io.Dir.cwd().createFile(_io, _zbr_norm_path(_fa_path), .{}) catch @panic(\"File.append error\");\n")
            writeIndent()
            w.emit("    defer _fa_file.close(_io);\n")
            writeIndent()
            w.emit("    _ = _fa_file.seekFromEnd(_io, 0) catch @panic(\"File.append seek error\");\n")
            writeIndent()
            w.emit("    _fa_file.writeStreamingAll(_io, ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"File.append write error\");\n")
            writeIndent()
            w.emit("    break :blk_fa {};\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "delete"
            w.emit("(std.Io.Dir.cwd().deleteFile(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"File.delete error\"))")
            return
        if mname == "size"
            w.emit("(blk_fsz: { const _sz_stat = std.Io.Dir.cwd().statFile(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_fsz @as(i64, -1); break :blk_fsz @as(i64, @intCast(_sz_stat.size)); })")
            return
        if mname == "isFile"
            w.emit("(blk_fif: { const _if_stat = std.Io.Dir.cwd().statFile(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_fif false; break :blk_fif _if_stat.kind == .file; })")
            return
        if mname == "isDir"
            w.emit("(blk_fid: { var _fd_dir = std.Io.Dir.cwd().openDir(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_fid false; _fd_dir.close(_io); break :blk_fid true; })")
            return
        if mname == "writeLines"
            w.emit("_file_write_lines(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", ")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("undefined")
            w.emit(")")
            return
        if mname == "modtime"
            w.emit("(blk_mt: {\n")
            writeIndent()
            w.emit("    const _mt_stat = std.Io.Dir.cwd().statFile(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_mt @as(?i64, null);\n")
            writeIndent()
            w.emit("    break :blk_mt @as(?i64, _mt_stat.mtime.toMilliseconds());\n")
            writeIndent()
            w.emit("})")
            return
        # Fallback: unknown File method
        w.emit("@compileError(\"selfhost: unknown File.")
        w.emit(mname)
        w.emit("\")")

