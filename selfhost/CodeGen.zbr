                w.emit("\"\"")
            w.emit(")")
            return
        w.emit("@compileError(\"selfhost: unknown Sqlite.")
        w.emit(mname)
        w.emit("\")")

    # Emit a &[_]_SqliteParam{...} slice from a Zebra list literal.
    # Falls back to &.{} (empty) for non-literal expressions.
    # Determines param type from the TC when available, otherwise from expr shape.
    def genSqliteParams(params_expr: Expr)
        if params_expr is Expr.list_lit as lit
            w.emit("&[_]_SqliteParam{")
            var first: bool = true
            for elem in lit.elems
                if not first
                    w.emit(", ")
                first = false
                var et: Type_ = Type_.unknown_
                if .infer_ctx != nil
                    et = inferExpr(elem, .infer_ctx to!)
                if et is Type_.int_ or elem is Expr.int_lit
                    w.emit(".{ .int = @as(i64, @intCast(")
                    genExpr(elem)
                    w.emit(")) }")
                else if et is Type_.float_ or elem is Expr.float_lit
                    w.emit(".{ .float = @as(f64, ")
                    genExpr(elem)
                    w.emit(") }")
                else
                    w.emit(".{ .text = ")
                    genExpr(elem)
                    w.emit(" }")
            w.emit("}")
        else
            w.emit("&.{}")

