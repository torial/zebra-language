    # ── genGuiCall ───────────────────────────────────────────────────────────
    def genGuiCall(mname: str, args: List(Arg))
        if mname == "run"
            if args.count() >= 6
                w.emit("_gui_mvu_run(")
                genExpr(args.at(0).value)
                w.emit(", ")
                genExpr(args.at(1).value)
                w.emit(", ")
                genExpr(args.at(2).value)
                w.emit(", ")
                genExpr(args.at(3).value)
                w.emit(", ")
                genExpr(args.at(4).value)
                w.emit(", ")
                genExpr(args.at(5).value)
                w.emit(")")
            else
                w.emit("_gui_run(")
                if args.count() > 0
                    genExpr(args.at(0).value)
                else
                    w.emit("\"App\"")
                w.emit(", ")
                if args.count() >= 2
                    genExpr(args.at(1).value)
                else
                    w.emit("800")
                w.emit(", ")
                if args.count() >= 3
                    genExpr(args.at(2).value)
                else
                    w.emit("600")
                w.emit(", ")
                if args.count() >= 4
                    genExpr(args.at(3).value)
                else
                    w.emit("undefined")
                w.emit(")")
            return
        if mname == "setColor"
            w.emit("_gui_active_backend.setColorFn(")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", @as(f32, @floatCast(")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit(")), @as(f32, @floatCast(")
            if args.count() >= 3
                genExpr(args.at(2).value)
            else
                w.emit("0")
            w.emit(")), @as(f32, @floatCast(")
            if args.count() >= 4
                genExpr(args.at(3).value)
            else
                w.emit("0")
            w.emit(")), @as(f32, @floatCast(")
            if args.count() >= 5
                genExpr(args.at(4).value)
            else
                w.emit("1")
            w.emit(")))")
            return
        if mname == "setColorsDark"
            w.emit("_gui_active_backend.setColorsDarkFn()")
            return
        if mname == "setStyleFloat"
            w.emit("_gui_active_backend.setStyleFloatFn(")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", @as(f32, @floatCast(")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit(")))")
            return
        if mname == "setVec2"
            w.emit("_gui_active_backend.setVec2Fn(")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", @as(f32, @floatCast(")
            if args.count() >= 2
                genExpr(args.at(1).value)
            else
                w.emit("0")
            w.emit(")), @as(f32, @floatCast(")
            if args.count() >= 3
                genExpr(args.at(2).value)
            else
                w.emit("0")
            w.emit(")))")
            return
        if mname == "scaleAllSizes"
            w.emit("_gui_active_backend.scaleAllSizesFn(@as(f32, @floatCast(")
            if args.count() >= 1
                genExpr(args.at(0).value)
            else
                w.emit("1")
            w.emit(")))")
            return
        if mname == "getDpi"
            w.emit("@as(f64, @floatCast(_gui_active_backend.getDpiFn()))")
            return
        w.emit("@compileError(\"selfhost: unknown Gui.")
        w.emit(mname)
        w.emit("\")")

    # ── genShellCall ─────────────────────────────────────────────────────────
    def genShellCall(mname: str, args: List(Arg))
        if mname == "run"
            w.emit("(blk_sh: {\n")
            writeIndent()
            w.emit("    const _sh_cmd = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(";\n")
            writeIndent()
            w.emit("    const _sh_argv = if (comptime builtin.os.tag == .windows)\n")
            writeIndent()
            w.emit("        @as([]const []const u8, &[_][]const u8{ \"cmd\", \"/c\", _sh_cmd })\n")
            writeIndent()
            w.emit("    else\n")
            writeIndent()
            w.emit("        @as([]const []const u8, &[_][]const u8{ \"sh\", \"-c\", _sh_cmd });\n")
            writeIndent()
            w.emit("    const _sh_res = std.process.Child.run(.{\n")
            writeIndent()
            w.emit("        .allocator = _allocator,\n")
            writeIndent()
            w.emit("        .argv = _sh_argv,\n")
            writeIndent()
            w.emit("        .max_output_bytes = 1024 * 1024,\n")
            writeIndent()
            w.emit("    }) catch @panic(\"Shell.run error\");\n")
            writeIndent()
            w.emit("    break :blk_sh std.mem.concat(_allocator, u8, &[_][]const u8{ _sh_res.stdout, _sh_res.stderr }) catch @panic(\"OOM\");\n")
            writeIndent()
            w.emit("})")
            return
        w.emit("@compileError(\"selfhost: unknown Shell.")
        w.emit(mname)
        w.emit("\")")

    # ── genDirCall ───────────────────────────────────────────────────────────
    def genDirCall(mname: str, args: List(Arg))
        if mname == "create"
            w.emit("(std.Io.Dir.cwd().createDirPath(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"Dir.create error\"))")
            return
        if mname == "createAll"
            w.emit("(std.Io.Dir.cwd().createDirPath(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"Dir.createAll error\"))")
            return
        if mname == "delete"
            w.emit("(std.Io.Dir.cwd().deleteDir(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch |_dd_err| { if (_dd_err != error.FileNotFound) @panic(\"Dir.delete error\"); })")
            return
        if mname == "deleteAll"
            w.emit("(std.Io.Dir.cwd().deleteTree(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") catch @panic(\"Dir.deleteAll error\"))")
            return
        if mname == "exists"
            w.emit("(blk_de: { var _de_d = std.Io.Dir.cwd().openDir(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(", .{}) catch break :blk_de false; _de_d.close(_io); break :blk_de true; })")
            return
        if mname == "list"
            w.emit("(blk_dl: {\n")
            writeIndent()
            w.emit("    var _dl_dir = std.Io.Dir.cwd().openDir(_io, ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\".\"")
            w.emit(", .{ .iterate = true }) catch @panic(\"Dir.list error\");\n")
            writeIndent()
            w.emit("    defer _dl_dir.close(_io);\n")
            writeIndent()
            w.emit("    var _dl_list = std.ArrayList([]const u8).empty;\n")
            writeIndent()
            w.emit("    var _dl_iter = _dl_dir.iterate();\n")
            writeIndent()
            w.emit("    while (_dl_iter.next(_io) catch null) |_dl_entry| {\n")
            writeIndent()
            w.emit("        _dl_list.append(_allocator, _allocator.dupe(u8, _dl_entry.name) catch @panic(\"OOM\")) catch @panic(\"OOM\");\n")
            writeIndent()
            w.emit("    }\n")
            writeIndent()
            w.emit("    break :blk_dl _dl_list;\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "walk"
            w.emit("(blk_dw: {\n")
            writeIndent()
            w.emit("    const _dw_root = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\".\"")
            w.emit(";\n")
            writeIndent()
            w.emit("    var _dw_dir = std.Io.Dir.cwd().openDir(_io, _dw_root, .{ .iterate = true }) catch @panic(\"Dir.walk error\");\n")
            writeIndent()
            w.emit("    defer _dw_dir.close(_io);\n")
            writeIndent()
            w.emit("    var _dw_walker = _dw_dir.walk(_allocator) catch @panic(\"Dir.walk alloc error\");\n")
            writeIndent()
            w.emit("    defer _dw_walker.deinit();\n")
            writeIndent()
            w.emit("    var _dw_list = std.ArrayList([]const u8).empty;\n")
            writeIndent()
            w.emit("    while (_dw_walker.next(_io) catch null) |_dw_entry| {\n")
            writeIndent()
            w.emit("        if (_dw_entry.kind != .file) continue;\n")
            writeIndent()
            w.emit("        const _dw_raw = std.fmt.allocPrint(_allocator, \"{s}/{s}\", .{ _dw_root, _dw_entry.path }) catch @panic(\"OOM\");\n")
            writeIndent()
            w.emit("        for (_dw_raw) |*_dw_c| if (_dw_c.* == '\\\\') { _dw_c.* = '/'; };\n")
            writeIndent()
            w.emit("        _dw_list.append(_allocator, _dw_raw) catch @panic(\"OOM\");\n")
            writeIndent()
            w.emit("    }\n")
            writeIndent()
            w.emit("    break :blk_dw _dw_list;\n")
            writeIndent()
            w.emit("})")
            return
        w.emit("@compileError(\"selfhost: unknown Dir.")
        w.emit(mname)
        w.emit("\")")

    # ── genPathCall ──────────────────────────────────────────────────────────
    def genPathCall(mname: str, args: List(Arg))
        if mname == "join"
            w.emit("(std.fs.path.join(_allocator, &.{")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            if args.count() >= 2
                w.emit(", ")
                genExpr(args.at(1).value)
            if args.count() >= 3
                w.emit(", ")
                genExpr(args.at(2).value)
            w.emit("}) catch @panic(\"Path.join error\"))")
            return
        if mname == "basename"
            w.emit("(std.fs.path.basename(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("))")
            return
        if mname == "dirname"
            w.emit("(std.fs.path.dirname(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(") orelse \"\")")
            return
        if mname == "ext" or mname == "extension"
            w.emit("(std.fs.path.extension(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("))")
            return
        if mname == "stem"
            w.emit("(blk_ps: {\n")
            writeIndent()
            w.emit("    const _ps_base = std.fs.path.basename(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit(");\n")
            writeIndent()
            w.emit("    const _ps_ext = std.fs.path.extension(_ps_base);\n")
            writeIndent()
            w.emit("    break :blk_ps _ps_base[0 .. _ps_base.len - _ps_ext.len];\n")
            writeIndent()
            w.emit("})")
            return
        if mname == "isAbsolute"
            w.emit("(std.fs.path.isAbsolute(")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("))")
            return
        if mname == "absolute"
            w.emit("(blk_pa: { const _pp = ")
            if args.count() > 0
                genExpr(args.at(0).value)
            else
                w.emit("\"\"")
            w.emit("; break :blk_pa std.fs.path.resolve(_allocator, &[_][]const u8{_pp}) catch _pp; })")
            return
        w.emit("@compileError(\"selfhost: unknown Path.")
        w.emit(mname)
        w.emit("\")")

    # ── genReflectCall ───────────────────────────────────────────────────────
    def genReflectCall(mname: str, args: List(Arg))
        if args.count() < 1
            w.emit("@compileError(\"Reflect requires 1 argument\")")
            return
        # Reflect.hostKind(x): language-neutral substrate category of x's
        # compile-time type, resolved by Zig at comptime.  @TypeOf does not
        # evaluate its operand, so call-args are side-effect-safe.  Per-language
        # name mapping lives in the consumer (see docs/dynamic_interop.md).
        if mname == "hostKind"
            w.emit("switch (@typeInfo(@TypeOf(")
            genExpr(args.at(0).value)
            w.emit("))) { .bool => \"bool\", .int, .comptime_int => \"int\", .float, .comptime_float => \"float\", .pointer => |_p| _sw: { const _ci = @typeInfo(_p.child); break :_sw if (_p.child == u8 or (_ci == .array and _ci.array.child == u8)) \"string\" else \"ref\"; }, .@\"fn\" => \"function\", .optional, .null => \"nil\", else => \"ref\" }")
            return
        if mname == "className"
            w.emit("_reflect_lookup_name(")
            genExpr(args.at(0).value)
            w.emit("._type_tag)")
            return
        if mname == "fieldNames"
            w.emit("_reflect_lookup_fields(")
            genExpr(args.at(0).value)
            w.emit("._type_tag)")
            return
        if mname == "fieldTypes"
            w.emit("_reflect_lookup_field_types(")
            genExpr(args.at(0).value)
            w.emit("._type_tag)")
            return
        w.emit("@compileError(\"selfhost: unknown Reflect.")
        w.emit(mname)
        w.emit("\")")

    def genGenericCtorCall(name: str, type_args: List(Arg), val_args: List(Arg))
        if name == "Chan"
            w.emit("_chan_create(")
            if type_args.count() > 0
                genTypeFromExpr(type_args.at(0).value)
            else
                w.emit("anytype")
            w.emit(", ")
            if val_args.count() > 0
                genExpr(val_args.at(0).value)
            else
                w.emit("0")
            w.emit(")")
            return
        if name == "Atomic"
            w.emit("_atomic_create(")
            if type_args.count() > 0
                genTypeFromExpr(type_args.at(0).value)
            else
                w.emit("anytype")
            w.emit(", ")
            if val_args.count() > 0
                genExpr(val_args.at(0).value)
            else
                w.emit("0")
            w.emit(")")
            return
        if name == "ThreadPool"
            w.emit("_thread_pool_create(")
            if val_args.count() > 0
                genExpr(val_args.at(0).value)
            else if type_args.count() > 0
                genExpr(type_args.at(0).value)
            else
                w.emit("4")
            w.emit(")")
            return
        if name == "List"
            w.emit("std.ArrayList(")
            if type_args.count() > 0
                genTypeFromExpr(type_args.at(0).value)
            else
                w.emit("anytype")
            w.emit(").empty")
            return
        if name == "HashMap"
            var key_is_str = type_args.count() > 0 and isStringArgExpr(type_args.at(0).value)
            if key_is_str
                w.emit("std.StringHashMap(")
                if type_args.count() >= 2
                    genTypeFromExpr(type_args.at(1).value)
                else
                    w.emit("anytype")
            else
                w.emit("std.AutoHashMap(")
                var fi = true
                for ta in type_args
                    if not fi
                        w.emit(", ")
                    fi = false
                    genTypeFromExpr(ta.value)
            w.emit(").init(_allocator)")
            return
        # Generic user type
        w.emit(name)
        w.emit("(")
        var fi2 = true
        for ta in type_args
            if not fi2
                w.emit(", ")
            fi2 = false
            genTypeFromExpr(ta.value)
        w.emit(").init(")
        var fi3 = true
        for va in val_args
            if not fi3
                w.emit(", ")
            fi3 = false
            genExpr(va.value)
        w.emit(")")
