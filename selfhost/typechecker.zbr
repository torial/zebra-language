# typechecker.zbr -- Phases 16a–b: TypeChecker for self-hosted compiler.
#
# Mirrors src/TypeChecker.zig. Phase 16a shipped the data model: `Type_`,
# `ClassTypes`, `ModuleTypes`. Phase 16b adds:
#   - typeFromRef(TypeRef) → Type_
#   - buildModuleTypes(Module) → ModuleTypes        (walks AST, populates)
#   - InferCtx / inferExpr(Expr, InferCtx) → Type_   (expr-level inference)
#
# These are advisory only: codegen.zbr still uses its heuristics. Phase 16c
# wires codegen to prefer ModuleTypes over the heuristics, one at a time.
#
# Roadmap: see selfhost/TYPECHECKER_ROADMAP.md.

use ast exposing Module, Decl, DeclClass, DeclStruct, DeclVar, DeclMethod, DeclInit, DeclUnion, UnionVariant, Param, TypeRef, NamedTypeRef, GenericTypeRef, Expr, ExprIdent, ExprMember, ExprCall, ExprBinary, ExprTry, ExprToNonNil, ExprToNilable, ExprOrelse, ExprCatch, ExprExcept, ExprIf, ExprCast, Arg, BinaryOp, Stmt, StmtIf, StmtWhile, StmtForIn, StmtForNum, StmtBranch, StmtReturn, StmtAssert, StmtAssign, StmtDefer, StmtWith, StmtRaise, StmtTryCatch, StmtGuard, StmtDestruct, StmtArenaScope, StmtPrint, BranchOn, ElseIf, CatchClause

# ── internString — storage-boundary copy ─────────────────────────────────────
# Every string stored in Type_ / ClassTypes / ModuleTypes / CrossModuleType
# must pass through internString. These types live in `dep_types` (long-lived,
# shared across dep compilations) while many of their string inputs originate
#: slices into per-compilation state: the `src` local of compileDep, token
# slices into src, PNode slices into tokens. Without a storage-boundary copy,
# a `Type_.named` constructed in dep A and read by dep B (or by the root) can
# dangle once dep A's compileDep frame exits.
#
# Phase 17d fixed one instance of this at typeFromRef (the `""+ n.name` line
# that turned garbage `named(������)` reads into valid strings). internString
# generalizes that fix: the copy is performed *inside* the storage sink, so
# callers cannot forget. Implementation is a simple `""+ s` concat; dedup /
# invariant checks can be layered on later if profiling motivates them.
def internString(s: str): str
    return "" + s

# ── Cross-module type reference ──────────────────────────────────────────────
# An instance of a user-defined type from an imported module, stored as
# (module_alias, type_name) — no Symbol pointers, safe across compilation
# boundaries. Phase 18 will add symmetric equality with `named`.

struct CrossModuleType
    var module: str
    var type_name: str

    cue init(module: str, type_name: str)
        this.module = internString(module)
        this.type_name = internString(type_name)

# ── Type representation ──────────────────────────────────────────────────────
# Skeleton variant set for Phase 16a. Phases 17–19 add:
#   generic_named, tuple, fn_ref, fn_sig, http_request, http_response,
#   tcp_conn, udp_socket, gui_context, shell, file, sys_run_result,
#   json_value, json_array, date_time, calendar_view, csv_*, arg_result,
#   uri_result, timer_handle.
#
# Keyword-collision rule: Zebra keywords get `_` suffix on variants.
# int/uint/float/bool/char are keywords; string/regex/named/optional are not,
# but `void_` matches the existing convention in ast.zbr::TypeRef.

union Type_
    # Primitives
    int_
    uint_
    float_
    bool_
    char_
    string_
    void_

    # Explicit-width numerics (payload = bit width)
    int_n: int
    uint_n: int
    float_n: int

    # User-defined class/struct/enum/union, referenced by name
    named: str

    # Optional wrapper: ?T. Phase 17 may extend to nested optionals.
    optional: ^Type_

    # Heap-indirection pointer: ^T (matches ast.TypeRef.ref_to).
    # src/TypeChecker.zig lacks this variant — it tracks ref_to-ness via a
    # side table (struct_init_ref_params). The selfhost port carries it in
    # Type_ directly; Phase 18 may refactor to match the Zig compiler.
    ref_to: ^Type_

    # Cross-module instance — fully qualified
    cross_module: CrossModuleType

    # Stdlib (partial — rest in Phase 19)
    str_slice
    string_builder
    regex
    str_set

    # Unrecoverable: upstream error or unsupported construct.
    # Suppresses further cascading errors (matches src/TypeChecker.zig).
    unknown_

# ── Per-class type info ──────────────────────────────────────────────────────
# Holds the subset of a class declaration's typing surface that
# codegen.zbr's heuristics currently approximate:
#   - field types   (replaces isKnownStrSetField name list)
#   - method return types (future: method-chain inference)
#   - positional ctor param types (replaces shouldBoxCtorArg / isUnboxedCtorArg)

class ClassTypes
    var name: str
    var field_types: HashMap(str, Type_)
    var method_returns: HashMap(str, Type_)
    var method_params: HashMap(str, str)
    var ctor_params: List(Type_)

    cue init(name: str)
        this.name = internString(name)
        field_types = HashMap()
        method_returns = HashMap()
        method_params = HashMap()
        ctor_params = List(Type_)()

    def setField(field_name: str, t: Type_)
        this.field_types.put(internString(field_name), t)

    def setMethodReturn(method_name: str, t: Type_)
        this.method_returns.put(internString(method_name), t)

    def setMethodParams(method_name: str, params_csv: str)
        this.method_params.put(internString(method_name), internString(params_csv))

    def addCtorParam(t: Type_)
        this.ctor_params.add(t)

    def fieldType(field_name: str): Type_?
        if this.field_types.contains(field_name)
            return this.field_types.fetch(field_name)
        return nil

    def methodReturn(method_name: str): Type_?
        if this.method_returns.contains(method_name)
            return this.method_returns.fetch(method_name)
        return nil

    def methodParamsCsv(method_name: str): str?
        if this.method_params.contains(method_name)
            return this.method_params.fetch(method_name)
        return nil

    def ctorParamAt(idx: int): Type_?
        if idx < 0
            return nil
        if idx >= this.ctor_params.len
            return nil
        return this.ctor_params.at(idx)

    def ctorParamCount(): int
        return this.ctor_params.len

# ── Module-level type table ──────────────────────────────────────────────────
# Aggregates ClassTypes for every user-defined class/struct in a module.
# Phase 16b adds a builder that walks an ast.Module to populate this.

class ModuleTypes
    var classes: HashMap(str, ClassTypes)
    # Reverse index: field names (across all classes in this module)
    # whose declared type is Type_.str_set. Used by codegen to decide
    # whether `obj.name.add(s)` is set-add or list-append without doing
    # full receiver-type inference. Populated by addClassMembers.
    var strset_field_names: HashMap(str, bool)
    # Reverse index: field names whose declared type is HashMap(K,V).
    # Parallel to strset_field_names; used by codegen to discriminate
    # HashMap vs List receivers at .remove / .contains dispatch sites
    # (BUG-032 et al). Populated by addClassMembers.
    var hashmap_field_names: HashMap(str, bool)
    # Union variant payload index — key "UnionName.variantName", value is
    # the payload's Type_ (or Type_.unknown_ for payload-less variants).
    # Drives Phase 17b branch-on narrowing: `branch x on Foo.bar: n`
    # binds n to variant_payloads["Foo.bar"]. Populated by
    # populateModuleTypes on Decl.union_ arms.
    var variant_payloads: HashMap(str, Type_)
    # Parallel to variant_payloads: keys where the payload type is Type_.ref_to.
    # Iterable without HashMap key enumeration; used by codegen to seed boxed_variants.
    var boxed_variant_keys: List(str)
    # "ClassName.fieldName" entries for ^T (non-optional ref) fields across all
    # classes/structs; populated by addClassMembers. Used by codegen to replace
    # the hardcoded addCrossModuleRefFields table.
    var ref_field_keys: List(str)
    # Same as ref_field_keys but for ^T? (optional ref) fields.
    var opt_ref_field_keys: List(str)
    # Separate set of known union type names — so a caller can ask
    # "is 'Foo' declared: a union in this module?" without enumerating
    # variant_payloads. Populated alongside variant_payloads.
    var union_names: HashMap(str, bool)
    cue init()
        classes = HashMap()
        strset_field_names = HashMap()
        hashmap_field_names = HashMap()
        variant_payloads = HashMap()
        boxed_variant_keys = List()
        ref_field_keys = List()
        opt_ref_field_keys = List()
        union_names = HashMap()

    def addClass(c: ClassTypes)
        this.classes.put(c.name, c)

    def addStrSetField(field_name: str)
        this.strset_field_names.put(internString(field_name), true)

    def hasStrSetField(field_name: str): bool
        return this.strset_field_names.contains(field_name)

    def addHashMapField(field_name: str)
        this.hashmap_field_names.put(internString(field_name), true)

    def hasHashMapField(field_name: str): bool
        return this.hashmap_field_names.contains(field_name)

    def addUnion(name: str)
        this.union_names.put(internString(name), true)

    def hasUnion(name: str): bool
        return this.union_names.contains(name)

    def addVariantPayload(union_name: str, variant_name: str, t: Type_)
        # Concatenation already produces a fresh owned str, so no additional
        # internString is needed on the composed key.
        var key: str = union_name + "." + variant_name
        this.variant_payloads.put(key, t)
        branch t
            on Type_.ref_to
                this.boxed_variant_keys.add(key)
            else
                pass

    def variantPayload(union_name: str, variant_name: str): Type_?
        var key: str = union_name + "." + variant_name
        if this.variant_payloads.contains(key)
            return this.variant_payloads.fetch(key)
        return nil

    def hasClass(class_name: str): bool
        return this.classes.contains(class_name)

    def classOf(class_name: str): ClassTypes?
        if this.classes.contains(class_name)
            return this.classes.fetch(class_name)
        return nil

    def fieldType(class_name: str, field_name: str): Type_?
        if not this.classes.contains(class_name)
            return nil
        var c: ClassTypes = this.classes.fetch(class_name)
        return c.fieldType(field_name)

    def methodReturn(class_name: str, method_name: str): Type_?
        if not this.classes.contains(class_name)
            return nil
        var c: ClassTypes = this.classes.fetch(class_name)
        return c.methodReturn(method_name)

    def methodParamsCsv(class_name: str, method_name: str): str?
        if not this.classes.contains(class_name)
            return nil
        var c: ClassTypes = this.classes.fetch(class_name)
        return c.methodParamsCsv(method_name)

    def ctorParamAt(class_name: str, idx: int): Type_?
        if not this.classes.contains(class_name)
            return nil
        var c: ClassTypes = this.classes.fetch(class_name)
        return c.ctorParamAt(idx)

# ── Built-in name → Type_ mapping ────────────────────────────────────────────
# Maps the plain type-name strings used in AST TypeRef.named nodes to Type_.
# Unknown names fall through to Type_.named(intern(n)) — callers can then
# check ModuleTypes.hasClass to confirm it is a user-defined type in this
# module. The intern at the fallback is the storage-boundary copy for every
# `Type_.named(...)` that passes through typeFromName; direct constructions
# elsewhere must intern at their own call site.

def typeFromName(n: str): Type_
    if n == "int"
        return Type_.int_
    if n == "uint"
        return Type_.uint_
    if n == "float"
        return Type_.float_
    if n == "bool"
        return Type_.bool_
    if n == "char"
        return Type_.char_
    if n == "str"
        return Type_.string_
    if n == "String"
        return Type_.string_
    if n == "StringBuilder"
        return Type_.string_builder
    if n == "Regex"
        return Type_.regex
    if n == "StrSet"
        return Type_.str_set
    return Type_.named(internString(n))

# ── TypeRef → Type_ mapping ──────────────────────────────────────────────────
# Maps a parsed ast.TypeRef into the Type_ domain. Phase 16b handles
# primitive named, nilable, ref_to, void; 17+ extend to generics and tuples.

def typeFromRef(tr: TypeRef): Type_
    branch tr
        on TypeRef.named as n
            # Storage-boundary copy. typeFromName interns its Type_.named
            # fallback (see internString at the top of this file). We keep
            # the `"" + n.name` here: defense-in-depth: it guarantees the
            # string handed to typeFromName is owned even if a future edit
            # short-circuits the intern inside typeFromName for a built-in
            # name. n.name itself is a slice whose backing traces to the
            # dep's `src` local (File.read result) in compileDep and must
            # not be stored directly in long-lived dep_types.
            return typeFromName("" + n.name)
        on TypeRef.nilable as inner
            return Type_.optional(typeFromRef(inner))
        on TypeRef.ref_to as inner
            return Type_.ref_to(typeFromRef(inner))
        on TypeRef.void_
            return Type_.void_
        on TypeRef.generic as g
            # Recognise List(str) / List(String) as str_slice for inference.
            var gname: str = "" + g.name
            if gname == "List" and g.args.count() == 1
                var arg_t: Type_ = typeFromRef(g.args.at(0))
                if arg_t is Type_.string_
                    return Type_.str_slice
            # HashMap(K, str) — value type is string; reuse str_slice as sentinel.
            if gname == "HashMap" and g.args.count() == 2
                var val_t: Type_ = typeFromRef(g.args.at(1))
                if val_t is Type_.string_
                    return Type_.str_slice
            return Type_.unknown_
        else
            # error_union, stream, same_, tuple — Phase 17 handles these.
            return Type_.unknown_

# ── ModuleTypes builder ──────────────────────────────────────────────────────
# Walks an ast.Module and populates ModuleTypes. Phase 16b covers class and
# struct declarations. Unions and enums are added in Phase 17 when inferExpr
# needs to infer union-variant / enum-member types.

# Helper: true if t is Type_.str_set, or an optional/ref_to wrapping str_set.
# (Mirrors the intent of isKnownStrSetField, which ignored `StrSet?` vs `StrSet`.)
def isStrSetOrWrapped(t: Type_): bool
    branch t
        on Type_.str_set
            return true
        on Type_.optional as inner
            return isStrSetOrWrapped(inner)
        on Type_.ref_to as inner
            return isStrSetOrWrapped(inner)
        else
            return false

# Helper: true if tr is HashMap(K,V), or a nilable/ref_to wrapping one.
# typeFromRef maps TypeRef.generic to Type_.unknown_, so HashMap-ness is
# detected from the raw TypeRef before it loses generic-arg fidelity.
def isHashMapTypeRef(tr: TypeRef): bool
    branch tr
        on TypeRef.generic as gtr
            return gtr.name == "HashMap"
        on TypeRef.nilable as inner
            return isHashMapTypeRef(inner)
        on TypeRef.ref_to as inner
            return isHashMapTypeRef(inner)
        else
            return false

def addClassMembers(mt: ModuleTypes, ct: ClassTypes, members: List(Decl))
    for member in members
        branch member
            on Decl.var_ as v
                if v.type_ != nil
                    var ft: Type_ = typeFromRef(v.type_ to!)
                    ct.setField("" + v.name, ft)
                    if isStrSetOrWrapped(ft)
                        mt.addStrSetField("" + v.name)
                    if isHashMapTypeRef(v.type_ to!)
                        mt.addHashMapField("" + v.name)
                    # Populate ref_field_keys / opt_ref_field_keys for ^T and ^T? fields.
                    # ^T? parses as ref_to(nilable(inner)); ^T as ref_to(non-nilable inner).
                    if v.type_ to! is TypeRef.ref_to as refInner
                        var key: str = ct.name + "." + ("" + v.name)
                        if refInner is TypeRef.nilable
                            mt.opt_ref_field_keys.add(key)
                        else
                            mt.ref_field_keys.add(key)
                else
                    ct.setField("" + v.name, Type_.unknown_)
            on Decl.method as m
                if m.return_type != nil
                    ct.setMethodReturn("" + m.name, typeFromRef(m.return_type to!))
                else
                    ct.setMethodReturn("" + m.name, Type_.void_)
                # Collect param names as CSV for named-arg reordering in codegen.
                var pcsv: str = ""
                var pi: int = 0
                while pi < m.params.count()
                    var p = m.params.at(pi)
                    if pi > 0
                        pcsv = pcsv + ","
                    pcsv = pcsv + ("" + p.name)
                    pi += 1
                if pcsv != ""
                    ct.setMethodParams("" + m.name, pcsv)
            on Decl.init as ini
                # Ctor params — first init wins (Zebra supports only one cue init per class).
                if ct.ctorParamCount() == 0
                    for p in ini.params
                        if p.type_ != nil
                            ct.addCtorParam(typeFromRef(p.type_ to!))
                        else
                            ct.addCtorParam(Type_.unknown_)
            else
                pass

def populateModuleTypes(mt: ModuleTypes, m: Module)
    # "" sentinel collects module-level def return types for sibling lookup.
    var module_fns = ClassTypes("")
    for decl in m.decls
        branch decl
            on Decl.class_ as c
                var ct = ClassTypes("" + c.name)
                addClassMembers(mt, ct, c.members)
                mt.addClass(ct)
            on Decl.struct_ as s
                var ct2 = ClassTypes("" + s.name)
                addClassMembers(mt, ct2, s.members)
                mt.addClass(ct2)
            on Decl.union_ as u
                # Index variant → payload Type_ for branch-on narrowing (17b).
                var uname: str = "" + u.name
                mt.addUnion(uname)
                for variant in u.variants
                    if variant.payload != nil
                        mt.addVariantPayload(uname, "" + variant.name, typeFromRef(variant.payload to!))
                    else
                        mt.addVariantPayload(uname, "" + variant.name, Type_.unknown_)
            on Decl.method as topfn
                # Top-level def: register under "" sentinel so bare calls inside
                # class methods can resolve the return type via methodReturnAny.
                if topfn.return_type != nil
                    module_fns.setMethodReturn("" + topfn.name, typeFromRef(topfn.return_type to!))
                else
                    module_fns.setMethodReturn("" + topfn.name, Type_.void_)
            else
                pass
    mt.addClass(module_fns)

def buildModuleTypes(m: Module): ModuleTypes
    var mt = ModuleTypes()
    populateModuleTypes(mt, m)
    return mt

# ── Expression-level inference ───────────────────────────────────────────────
# InferCtx holds the module's type table and the current class (for `this.x`).
# A scope map is intentionally absent in Phase 16b — local variable tracking
# lands in Phase 17. Callers may still seed the scope HashMap when useful.

class InferCtx
    var module_types: ModuleTypes
    var dep_types: ModuleTypes
    var current_class: str
    var scope: HashMap(str, Type_)

    cue init(module_types: ModuleTypes, current_class: str)
        this.module_types = module_types
        this.dep_types = ModuleTypes()
        this.current_class = current_class
        scope = HashMap()

    # Phase 17c — attach merged dependency ModuleTypes (from codegen's
    # buildModuleTypes over transitive deps) so inferExpr can see unions /
    # classes defined in imported modules. Defaults to empty ModuleTypes so
    # standalone callers (tests) don't need to build a dep table.
    def withDepTypes(dt: ModuleTypes)
        this.dep_types = dt

    # True if a named union is known in this module OR in any dep.
    def hasUnion(name: str): bool
        if this.module_types.hasUnion(name)
            return true
        return this.dep_types.hasUnion(name)

    def bind(name: str, t: Type_)
        scope.put(name, t)

    def unbind(name: str)
        # Workaround: selfhost mis-emits HashMap.remove: orderedRemove. Until
        # that bug is fixed, "unbind" by rebinding to Type_.unknown_. Effect:
        # hasLocal returns true with an unknown type, which is safe (callers
        # treat unknown: no information).
        if scope.contains(name)
            scope.put(name, Type_.unknown_)

    def hasLocal(name: str): bool
        return scope.contains(name)

    def localType(name: str): Type_
        return scope.fetch(name)

    # Phase 17d — cross-module field/method lookups. The walker previously
    # consulted only module_types for Expr.member/Expr.call; that missed
    # parameters and locals of types defined in deps (the common case when
    # compiling parser/resolver/codegen, all of which take AST struct params
    # from ast.zbr). These two helpers mirror hasUnion's module+dep fallback.
    def fieldTypeAny(class_name: str, field_name: str): Type_?
        var ft: Type_? = this.module_types.fieldType(class_name, field_name)
        if ft != nil
            return ft
        ft = this.dep_types.fieldType(class_name, field_name)
        if ft != nil
            return ft
        # Cross-module qualified name fallback — parsed types keep the
        # module prefix ("Token.Token", "Parser.PNode"). Strip to the last
        # segment and retry, so dep_types (keyed by bare class name)
        # resolves cross-module field access.
        var bare: str = stripModulePrefix(class_name)
        if bare != class_name
            ft = this.module_types.fieldType(bare, field_name)
            if ft != nil
                return ft
            return this.dep_types.fieldType(bare, field_name)
        return nil

    def methodReturnAny(class_name: str, method_name: str): Type_?
        var mr: Type_? = this.module_types.methodReturn(class_name, method_name)
        if mr != nil
            return mr
        mr = this.dep_types.methodReturn(class_name, method_name)
        if mr != nil
            return mr
        var bare: str = stripModulePrefix(class_name)
        if bare != class_name
            mr = this.module_types.methodReturn(bare, method_name)
            if mr != nil
                return mr
            return this.dep_types.methodReturn(bare, method_name)
        return nil

    def hasClassAny(class_name: str): bool
        if this.module_types.hasClass(class_name)
            return true
        if this.dep_types.hasClass(class_name)
            return true
        var bare: str = stripModulePrefix(class_name)
        if bare != class_name
            if this.module_types.hasClass(bare)
                return true
            return this.dep_types.hasClass(bare)
        return false

# Strip the leading "Module." from a qualified type name, leaving the
# bare class name. "Token.Token" → "Token", "Parser.PNode" → "PNode",
# "Foo" → "Foo" (no dot → unchanged).
def stripModulePrefix(name: str): str
    if not name.contains(".")
        return name
    var last: str = name
    for p in name.split(".")
        last = p
    return last

# Helper: true iff t is Type_.string_.
def isString(t: Type_): bool
    branch t
        on Type_.string_
            return true
        on Type_.cross_module as cm
            # BUG-075: String class imported cross-module yields cross_module, not string_.
            return cm.type_name == "String"
        else
            return false

# BUG-071: return type of a method call whose receiver is `str`. Grounded in
# src/CodeGen.zig::genStringMethod (6373-6600). nil → method is not a known
# string stdlib method; caller falls through to Type_.unknown_.
# chars/split/lines return generics (List(char)/List(str)); Phase 18 generics
# will infer them properly — returning unknown_ here is intentional.
def stringMethodReturn(name: str): Type_?
    if name == "trim" or name == "trimLeft" or name == "trimRight"
        return Type_.string_
    if name == "replace" or name == "replaceAll" or name == "reverse" or name == "repeat"
        return Type_.string_
    if name == "concat" or name == "format" or name == "upper" or name == "lower"
        return Type_.string_
    if name == "toHex" or name == "padLeft" or name == "padRight" or name == "center"
        return Type_.string_
    if name == "substring" or name == "charAt"
        return Type_.string_
    if name == "join" or name == "toString"
        return Type_.string_
    if name == "count"
        return Type_.int_
    if name == "indexOf" or name == "lastIndexOf"
        return Type_.optional(Type_.int_)
    if name == "codePointCount" or name == "toInt"
        return Type_.int_
    if name == "toFloat"
        return Type_.float_
    if name == "contains" or name == "startsWith" or name == "endsWith"
        return Type_.bool_
    if name == "isEmpty" or name == "isAlpha" or name == "isNumeric" or name == "isValidUtf8"
        return Type_.bool_
    if name == "fromHex"
        return Type_.optional(Type_.string_)
    return nil

# Phase 17d diagnostic: short tag name for a Type_ variant. Caller may strip.
def typeTag(t: Type_): str
    branch t
        on Type_.int_
            return "int"
        on Type_.uint_
            return "uint"
        on Type_.float_
            return "flt"
        on Type_.bool_
            return "bool"
        on Type_.char_
            return "char"
        on Type_.string_
            return "str"
        on Type_.void_
            return "void"
        on Type_.named as n
            return "named(" + n + ")"
        on Type_.optional
            return "opt"
        on Type_.ref_to
            return "ref"
        on Type_.cross_module
            return "crossmod"
        on Type_.str_slice
            return "slice"
        on Type_.string_builder
            return "sbld"
        on Type_.regex
            return "rgx"
        on Type_.str_set
            return "sset"
        on Type_.unknown_
            return "unk"
        else
            return "?"

# Helper: true iff t is a numeric type (int/uint/float or their sized forms).
def isNumeric(t: Type_): bool
    branch t
        on Type_.int_
            return true
        on Type_.uint_
            return true
        on Type_.float_
            return true
        on Type_.int_n as _
            return true
        on Type_.uint_n as _
            return true
        on Type_.float_n as _
            return true
        else
            return false

def inferExpr(e: Expr, ctx: InferCtx): Type_
    branch e
        on Expr.int_lit as _
            return Type_.int_
        on Expr.float_lit as _
            return Type_.float_
        on Expr.bool_lit as _
            return Type_.bool_
        on Expr.char_lit as _
            return Type_.char_
        on Expr.string_lit as _
            return Type_.string_
        on Expr.string_interp
            return Type_.string_
        on Expr.nil_ as _
            # Represents untyped nil — wraps unknown_ for optional compatibility.
            # Workaround: bind to local first so selfhost's box emit has a named
            # Type_ value (not a bare tag ref) for @TypeOf inspection.
            var inner_unk: Type_ = Type_.unknown_
            return Type_.optional(inner_unk)
        on Expr.this_ as _
            if ctx.current_class == ""
                return Type_.unknown_
            return Type_.named(ctx.current_class)
        on Expr.ident as id
            var nm: str = "" + id.name
            if ctx.hasLocal(nm)
                return ctx.localType(nm)
            # Ident referencing a class name — treat: the class type so a
            # bare `Foo` in `Foo(...)` can be resolved by the caller of
            # inferExpr for the outer call.
            if ctx.module_types.hasClass(nm)
                return Type_.named(nm)
            # Implicit self-field: a bare ident inside a method that doesn't
            # resolve to a local can mean `self.field`. Look up field type
            # on the current class.
            if ctx.current_class != ""
                var fft: Type_? = ctx.module_types.fieldType(ctx.current_class, nm)
                if fft != nil
                    return fft to!
            return Type_.unknown_
        on Expr.member as m
            # Phase 17d — infer the object's type recursively, then look up
            # the field through module_types + dep_types. Unwraps `^T` and
            # `T?` because field access through a pointer or nilable has the
            # same field set: the underlying. This path subsumes the older
            # dedicated Expr.this_/Expr.ident branches.
            var obj_t: Type_ = inferExpr(m.object, ctx)
            branch obj_t
                on Type_.ref_to as rt
                    obj_t = rt
                on Type_.optional as ot
                    obj_t = ot
                else
                    pass
            if obj_t is Type_.named as tn
                var ft: Type_? = ctx.fieldTypeAny(tn, "" + m.member)
                if ft != nil
                    return ft to!
            # Stdlib Shell.Result — its `stdout`/`stderr` fields are strings,
            # registered nowhere in user code but widely used as `r.stdout`
            # etc. Recognise by field name when the object type is unknown,
            # so equality emits std.mem.eql instead of a broken slice ==.
            var mm: str = "" + m.member
            if mm == "stdout" or mm == "stderr"
                return Type_.string_
            return Type_.unknown_
        on Expr.call as c
            # Constructor or class name used: callee: `Foo(args)` → named("Foo").
            branch c.callee
                on Expr.ident as id
                    var cname: str = "" + id.name
                    if ctx.hasClassAny(cname)
                        return Type_.named(cname)
                    # Primitive-name ctors like `int(x)` cast to that primitive.
                    var as_name: Type_ = typeFromName(cname)
                    branch as_name
                        on Type_.named as _
                            pass
                        else
                            return as_name
                    # Bare call: check current class first, then module-level
                    # functions registered under the "" sentinel in ModuleTypes.
                    if ctx.current_class != ""
                        var mr: Type_? = ctx.methodReturnAny(ctx.current_class, cname)
                        if mr != nil
                            return mr to!
                    var mf: Type_? = ctx.methodReturnAny("", cname)
                    if mf != nil
                        return mf to!
                    return Type_.unknown_
                on Expr.member as mem
                    # Universal primitive conversion: `x.toString()` yields str
                    # regardless of x's static type (int/float/char/bool all
                    # have toString). Short-circuit before methodReturn lookup
                    # since primitive toString() isn't registered anywhere.
                    if mem.member == "toString"
                        return Type_.string_
                    # Method call: infer receiver type, look up method return.
                    # Builtin type constructors: Regex.compile → regex, etc.
                    if mem.object is Expr.ident as bid
                        var bname: str = "" + bid.name
                        if bname == "Regex" and mem.member == "compile"
                            return Type_.regex
                    # Special case first: `UnionName.variant(args)` — when the
                    # receiver ident names a known union, the call yields a
                    # value of the union's named type.
                    if mem.object is Expr.ident as uid
                        var uname2: str = "" + uid.name
                        if ctx.hasUnion(uname2)
                            return Type_.named(uname2)
                    # BUG-071: recursive receiver inference (not just this_/ident)
                    # so chained calls like `s.trim().upper()` resolve: inferExpr
                    # of mem.object returns string_ from the inner trim call via
                    # stringMethodReturn, and the outer upper call dispatches on
                    # string_ again.
                    var recv: Type_ = inferExpr(mem.object, ctx)
                    branch recv
                        on Type_.ref_to as rrt
                            recv = rrt
                        on Type_.optional as rro
                            recv = rro
                        else
                            pass
                    branch recv
                        on Type_.named as tn
                            var rt: Type_? = ctx.methodReturnAny(tn, "" + mem.member)
                            if rt != nil
                                return rt to!
                        on Type_.string_
                            var srt: Type_? = stringMethodReturn("" + mem.member)
                            if srt != nil
                                return srt to!
                        on Type_.regex
                            var mname: str = "" + mem.member
                            if mname == "find"
                                return Type_.string_
                            if mname == "test" or mname == "match"
                                return Type_.bool_
                        on Type_.string_builder
                            var sbmname: str = "" + mem.member
                            if sbmname == "build" or sbmname == "toString"
                                return Type_.string_
                            if sbmname == "len"
                                return Type_.int_
                        on Type_.str_slice
                            var slmname: str = "" + mem.member
                            if slmname == "at" or slmname == "join" or slmname == "fetch"
                                return Type_.string_
                            if slmname == "count" or slmname == "len"
                                return Type_.int_
                        else
                            pass
                    return Type_.unknown_
                else
                    return Type_.unknown_
        on Expr.try_ as et
            # `expr?` — propagate the inner type; the `?` suffix only affects
            # control flow (error propagation).
            return inferExpr(et.expr, ctx)
        on Expr.to_non_nil as etn
            # `expr to!` — strip an outer optional wrapper if present.
            var inner: Type_ = inferExpr(etn.expr, ctx)
            branch inner
                on Type_.optional as opt
                    return opt
                else
                    return inner
        on Expr.to_nilable as etl
            # `expr to?` — wrap in optional.
            var inner_t: Type_ = inferExpr(etl.expr, ctx)
            return Type_.optional(inner_t)
        on Expr.orelse_ as eo
            # `expr orelse fallback` — result takes the non-optional inner type
            # when it exists; otherwise the expression's type.
            var lt_o: Type_ = inferExpr(eo.expr, ctx)
            branch lt_o
                on Type_.optional as opt_o
                    return opt_o
                else
                    return lt_o
        on Expr.catch_ as ec
            # `expr catch fallback` — result is the expression's type.
            return inferExpr(ec.expr, ctx)
        on Expr.except_ as ee
            # `base except f = v ...` — struct-update yields the base's type.
            return inferExpr(ee.base, ctx)
        on Expr.if_expr as eif
            # ternary `if cond then a else b` — result is then-branch type.
            return inferExpr(eif.then_expr, ctx)
        on Expr.cast as ect
            # `expr: TypeRef` / `cast(Expr, T)` — result is the target type.
            return typeFromRef(ect.target)
        on Expr.binary as b
            var lt: Type_ = inferExpr(b.left, ctx)
            var rt: Type_ = inferExpr(b.right, ctx)
            branch b.op
                on BinaryOp.add
                    # String concatenation: if either side is a string, result is string.
                    if isString(lt)
                        return Type_.string_
                    if isString(rt)
                        return Type_.string_
                    if isNumeric(lt)
                        return lt
                    if isNumeric(rt)
                        return rt
                    return Type_.unknown_
                on BinaryOp.sub
                    if isNumeric(lt)
                        return lt
                    return rt
                on BinaryOp.mul
                    if isNumeric(lt)
                        return lt
                    return rt
                on BinaryOp.div
                    if isNumeric(lt)
                        return lt
                    return rt
                on BinaryOp.eq
                    return Type_.bool_
                on BinaryOp.ne
                    return Type_.bool_
                on BinaryOp.lt
                    return Type_.bool_
                on BinaryOp.le
                    return Type_.bool_
                on BinaryOp.gt
                    return Type_.bool_
                on BinaryOp.ge
                    return Type_.bool_
                on BinaryOp.and_
                    return Type_.bool_
                on BinaryOp.or_
                    return Type_.bool_
                on BinaryOp.in_
                    return Type_.bool_
                else
                    return Type_.unknown_
        on Expr.index as ei
            # s[i] — element type depends on receiver type.
            var idx_recv: Type_ = inferExpr(ei.object, ctx)
            branch idx_recv
                on Type_.string_
                    return Type_.char_
                on Type_.str_slice
                    return Type_.string_
                else
                    return Type_.unknown_
        on Expr.slice as esl
            # s[a..b] — slice type depends on receiver type.
            var sl_recv: Type_ = inferExpr(esl.object, ctx)
            branch sl_recv
                on Type_.string_
                    return Type_.string_
                on Type_.str_slice
                    return Type_.str_slice
                else
                    return Type_.unknown_
        else
            return Type_.unknown_

# ── Branch-on narrowing helper ───────────────────────────────────────────────
# Given an on-case value like `Foo.bar` (parsed: Expr.member with object =
# Expr.ident("Foo"), member = "bar"), look up the variant's payload type in
# mt. Returns nil when the expression shape doesn't match, the union isn't
# known, or the variant is payload-less (Type_.unknown_ in the index is the
# sentinel for "no payload" vs. "missing").

def narrowPayloadFromOnValue(mt: ModuleTypes, v: Expr): Type_?
    return narrowPayloadFromOnValueDeps(mt, ModuleTypes(), v)

# Phase 17d — variant payload lookup that also consults dep_types, so
# branch-on patterns against unions defined in imported modules (Expr /
# Stmt / Decl live in ast.zbr; every other selfhost module branches on
# them) get their payload types narrowed correctly.
def narrowPayloadFromOnValueDeps(mt: ModuleTypes, dt: ModuleTypes, v: Expr): Type_?
    if v is Expr.member as em
        if em.object is Expr.ident as oid
            var unam: str = "" + oid.name
            var vnam: str = "" + em.member
            var pt: Type_? = mt.variantPayload(unam, vnam)
            if pt == nil
                pt = dt.variantPayload(unam, vnam)
            if pt != nil
                var pt_val: Type_ = pt to!
                branch pt_val
                    on Type_.unknown_
                        return nil
                    else
                        return pt_val
    return nil

# ── Statement walker ─────────────────────────────────────────────────────────
# Phase 17a: structural walker over all 22 ast.Stmt variants. Populates
# InferCtx scope bindings on var/const decls and (basic) for-in loop vars
# so that later expr-level inference sees real types for local names.
# Sub-expression inference is advisory — results are not yet persisted to a
# side table. Phase 17b adds branch-on variant-payload narrowing; Phase 17c
# wires this walker into codegen so heuristics can be retired.

# Wraps inferExpr to discard the returned Type_ — walkStmt sites only care
# about side effects (scope bindings populated by sub-expression inference).
# Zig 0.15 rejects throwing away non-void values, so this helper is required.
def walkExpr(e: Expr, ctx: InferCtx)
    var t_ign: Type_ = inferExpr(e, ctx)
    # Force a use of t_ign so neither Zig nor Zebra warns; isString is pure.
    var used: bool = isString(t_ign)
    if used
        pass

# Returns true when e is a bare `.chars()` call (no args). Used by the
# for_in walker to bind the loop variable: char_ so that c.toString()
# inside the body routes to utf8Encode rather than allocPrint.
def isCharsCallExpr(e: Expr): bool
    if e is Expr.call as cal
        if cal.callee is Expr.member as mem
            if mem.member == "chars"
                return true
    return false

# Detects iterators whose elements are known to be strings:
# .split()/.lines() return string slices; .keys()/.items()/.values() on str containers;
# .groups()/.findAll() on Regex return string slices.
def isStrListCallExpr(e: Expr): bool
    if e is Expr.call as cal
        if cal.callee is Expr.member as mem
            if mem.member == "split" or mem.member == "lines"
                return true
            if mem.member == "keys" or mem.member == "items" or mem.member == "values"
                return true
            if mem.member == "groups" or mem.member == "findAll"
                return true
    return false

def walkStmts(stmts: List(Stmt), ctx: InferCtx)
    for s in stmts
        walkStmt(s, ctx)

def walkStmt(s: Stmt, ctx: InferCtx)
    branch s
        on Stmt.if_ as si
            walkExpr(si.cond, ctx)
            if si.is_capture != nil
                var cap_t: Type_ = Type_.unknown_
                if si.cond is Expr.type_check as tce
                    if tce.variant_name != nil
                        var type_nm: str = "" + tce.type_name
                        var var_nm: str = "" + tce.variant_name to!
                        var pt: Type_? = ctx.module_types.variantPayload(type_nm, var_nm)
                        if pt == nil
                            pt = ctx.dep_types.variantPayload(type_nm, var_nm)
                        if pt != nil
                            cap_t = pt to!
                ctx.bind(si.is_capture to!, cap_t)
            walkStmts(si.then_stmts, ctx)
            for ei in si.else_ifs
                walkExpr(ei.cond, ctx)
                if ei.is_capture != nil
                    var ei_cap_t: Type_ = Type_.unknown_
                    if ei.cond is Expr.type_check as eice
                        if eice.variant_name != nil
                            var e_type_nm: str = "" + eice.type_name
                            var e_var_nm: str = "" + eice.variant_name to!
                            var e_pt: Type_? = ctx.module_types.variantPayload(e_type_nm, e_var_nm)
                            if e_pt == nil
                                e_pt = ctx.dep_types.variantPayload(e_type_nm, e_var_nm)
                            if e_pt != nil
                                ei_cap_t = e_pt to!
                    ctx.bind(ei.is_capture to!, ei_cap_t)
                walkStmts(ei.stmts, ctx)
            if si.else_stmts != nil
                walkStmts(si.else_stmts to!, ctx)
        on Stmt.while_ as sw
            walkExpr(sw.cond, ctx)
            walkStmts(sw.stmts, ctx)
        on Stmt.for_in as fi
            walkExpr(fi.iter, ctx)
            # 17a: element-type inference for loop vars is deferred to 17c
            # (needs generic-arg awareness for List(T) / HashMap(K,V)). Bind
            # each loop var: unknown_ so `hasLocal` returns true — any later
            # inferExpr on the loop var yields unknown_, which is safe.
            # Exception: `for c in s.chars()` (single var) → c is char_,
            # so c.toString() in the body routes to utf8Encode, not allocPrint.
            var loop_var_t: Type_ = Type_.unknown_
            if fi.vars.count() == 1 and isCharsCallExpr(fi.iter)
                loop_var_t = Type_.char_
            else if fi.vars.count() == 1 and isStrListCallExpr(fi.iter)
                loop_var_t = Type_.string_
            for v in fi.vars
                ctx.bind("" + v, loop_var_t)
            walkStmts(fi.stmts, ctx)
            # Keep the loop var binding at its typed value (not reset to unknown_)
            # so the single-pass ctx persists the correct type for code generation.
            for v2 in fi.vars
                ctx.bind("" + v2, loop_var_t)
        on Stmt.for_num as fnum
            walkExpr(fnum.start, ctx)
            walkExpr(fnum.stop_, ctx)
            if fnum.step != nil
                walkExpr(fnum.step to!, ctx)
            ctx.bind("" + fnum.var_, Type_.int_)
            walkStmts(fnum.stmts, ctx)
        on Stmt.branch_ as sb
            walkExpr(sb.expr, ctx)
            # 17b: narrow `as name` bindings to the variant's payload type
            # when the on-case is `on UnionName.variant: name` and
            # UnionName is a known union in this module. Cross-module
            # unions and Result(T,E) are handled in Phase 18 (needs
            # generic_named + dep_types threading into InferCtx).
            # Phase 17d — do NOT restore the prior binding after the case
            # body. The walker runs in a single pre-pass before emission,
            # so any restore would leave the scope empty by the time
            # genExpr runs inside the same branch arm. Last-writer-wins is
            # good enough for string-literal detection: selfhost code does
            # not rebind the same pattern name across sibling arms to
            # incompatible types.
            for c in sb.cases
                for v in c.values
                    walkExpr(v, ctx)
                if c.binding != nil and c.values.count() == 1
                    var val: Expr = c.values.at(0)
                    var payload: Type_? = narrowPayloadFromOnValueDeps(ctx.module_types, ctx.dep_types, val)
                    if payload != nil
                        ctx.bind("" + c.binding to!, payload to!)
                walkStmts(c.stmts, ctx)
            if sb.else_ != nil
                walkStmts(sb.else_ to!, ctx)
        on Stmt.return_ as sr
            if sr.value != nil
                walkExpr(sr.value to!, ctx)
        on Stmt.assert_ as sa
            walkExpr(sa.cond, ctx)
            if sa.message != nil
                walkExpr(sa.message to!, ctx)
        on Stmt.pass_
            pass
        on Stmt.break_
            pass
        on Stmt.continue_
            pass
        on Stmt.assign as sasn
            walkExpr(sasn.target, ctx)
            walkExpr(sasn.value, ctx)
        on Stmt.var_ as dv
            # Bind local name to declared type, or to init_expr's inferred type
            # when the declaration omits the type annotation.
            var t: Type_ = Type_.unknown_
            if dv.type_ != nil
                t = typeFromRef(dv.type_ to!)
            else
                if dv.init_expr != nil
                    t = inferExpr(dv.init_expr to!, ctx)
            ctx.bind("" + dv.name, t)
        on Stmt.expr as e
            walkExpr(e, ctx)
        on Stmt.defer_ as sd
            walkStmt(sd.stmt, ctx)
        on Stmt.with_ as sw2
            walkExpr(sw2.target, ctx)
            walkStmts(sw2.stmts, ctx)
        on Stmt.raise_ as sra
            if sra.message != nil
                walkExpr(sra.message to!, ctx)
            if sra.details != nil
                walkExpr(sra.details to!, ctx)
        on Stmt.try_catch as stc
            walkStmts(stc.stmts, ctx)
            for cc in stc.clauses
                walkStmts(cc.stmts, ctx)
        on Stmt.guard_ as sg
            walkExpr(sg.cond, ctx)
            walkStmts(sg.else_stmts, ctx)
        on Stmt.destruct as sds
            walkExpr(sds.init_expr, ctx)
            var destruct_recv_t: Type_ = inferExpr(sds.init_expr, ctx)
            if destruct_recv_t is Type_.ref_to as dr
                destruct_recv_t = dr
            var destruct_class: str = ""
            if destruct_recv_t is Type_.named as dtn
                destruct_class = "" + dtn
            for nm in sds.names
                var nm_s: str = "" + nm
                var ftype: Type_ = Type_.unknown_
                if destruct_class != ""
                    var ft: Type_? = ctx.fieldTypeAny(destruct_class, nm_s)
                    if ft != nil
                        ftype = ft to!
                ctx.bind(nm_s, ftype)
        on Stmt.arena_scope as sas
            walkStmts(sas.stmts, ctx)
        on Stmt.print_ as sp
            for a in sp.args
                walkExpr(a, ctx)

class Main
    shared def main()
        # Smoke-test entry point so this file compiles/runs standalone.
        # Real tests live in typechecker_test.zbr.
        var mt: ModuleTypes = ModuleTypes()
        var ct: ClassTypes = ClassTypes("Foo")
        ct.setField("name", Type_.string_)
        mt.addClass(ct)
        if mt.hasClass("Foo")
            print "ok"
        else
            print "fail"
