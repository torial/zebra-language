# Token kinds and source-annotated token structs for the Zebra self-hosted lexer.

union TokenKind
    indent
    dedent
    eol
    eof
    id
    at_id
    integer_lit
    integer_lit_explicit
    hex_lit
    hex_lit_unsign
    hex_lit_explicit
    float_lit
    decimal_lit
    number_lit
    int_size
    uint_size
    float_size
    char_lit_single
    char_lit_double
    string_single
    string_double
    string_nosub_single
    string_nosub_double
    string_raw_single
    string_raw_double
    string_start_single
    string_part_single
    string_stop_single
    string_start_double
    string_part_double
    string_stop_double
    string_part_format
    rcurly_special
    zig_single
    zig_double
    doc_string_start
    doc_string_line
    dot
    dotdot
    colon
    semi
    comma
    lparen
    rparen
    lbracket
    rbracket
    lcurly
    rcurly
    at_lbracket
    plus
    plusplus
    minus
    minusminus
    arrow
    star
    starstar
    slash
    slashslash
    percent
    percentpercent
    ampersand
    vertical_bar
    caret
    tilde
    question
    bang
    double_lt
    double_gt
    assign
    eq
    ne
    lt
    gt
    le
    ge
    plus_equals
    minus_equals
    star_equals
    slash_equals
    slashslash_equals
    percent_equals
    starstar_equals
    ampersand_equals
    vertical_bar_equals
    caret_equals
    double_lt_equals
    double_gt_equals
    question_equals
    bang_equals
    toq
    open_call
    kw_use
    kw_exposing
    kw_namespace
    kw_class
    kw_interface
    kw_mixin
    kw_struct
    kw_enum
    kw_extend
    kw_def
    kw_sig
    kw_var
    kw_const
    kw_cue
