# Phase 3: Recursive-descent parser - parser.zbr
# Self-hosting demo: token stream - PNode parse tree.
#
# Design note: all recursive child references go through List(PNode) or union
# ^T variant auto-boxing - struct fields are only String/bool/int/List(T).
# This sidesteps the struct-field ^T auto-boxing gap (no compiler change needed).
# The gap is documented in SELFHOST_JOURNAL.md Phase 3 "Where Zebra felt worse".
#
# Language features exercised:
#   - throws auto-propagation through mutually-recursive parse methods
#   - Union variant ^T auto-boxing (PNode.stmt_if(PIf(...)))
#   - List(PNode) accumulation in parse loops
#   - branch dispatch on TokenKind union variants
#   - String comparison for keyword/operator detection
#   - Recursive method calls (parseExpr - parseAddSub - parseUnary - parsePostfix - parseAtom)

use Token exposing TokenKind
use Lexer

# -- Parse tree node types -----------------------------------------------------

union PNode
    # Top level
    module_ as ^PModule
    use_ as ^PUse
    class_ as ^PClass
    struct_ as ^PClass
    interface_ as ^PClass
    extend_ as ^PExtend
    enum_ as ^PEnum
    union_decl as ^PUnionDecl
    sig_ as ^PSig
    namespace_decl as ^PNamespace

    # Members / declarations
    field_ as ^PField
    method_ as ^PMethod
    init_ as ^PInit

    # Statements
    stmt_pass
    stmt_break
    stmt_continue
    stmt_return as ^PReturn
    stmt_if as ^PIf
    stmt_while as ^PWhile
    stmt_for_in as ^PForIn
    stmt_var as ^PVar
    stmt_assign as ^PAssign
    stmt_assert as ^PAssert
    stmt_raise as ^PRaise
    stmt_try_catch as ^PTryCatch
    stmt_expr as ^PNode
    stmt_print as ^PNode
    stmt_arena_scope as ^PArenaScope
    stmt_with as ^PWith
    stmt_guard as ^PGuard
    expr_orelse as ^POrelse
    expr_pipeline as ^PPipeline

    # Expressions (inline - no heap indirection)
    expr_int as str
    expr_float as str
    expr_bool as bool
    expr_nil
    expr_this
    expr_str as str
    expr_char as str
    expr_zig_lit as str
    expr_raw_str as str
    expr_id as str

    # Expressions (heap-boxed - recursive)
    expr_member as ^PMember
    expr_call as ^PCall
    expr_index as ^PIndex
    expr_slice as ^PSlice
    expr_binary as ^PBinary
    expr_unary as ^PUnary
    expr_try as ^PNode
    expr_to_bang as ^PNode
    expr_except as ^PExcept
    expr_string_interp as ^PStringInterp
    expr_lambda as PLambda

    # Branch statement
    stmt_branch as ^PBranch

struct PUnionDecl
    var name as str
    var variants as List(PUnionVariant)
    cue init(name as str, variants as List(PUnionVariant))
        this.name = name
        this.variants = variants

struct PUnionVariant
    var name as str
    var type_name as str
    cue init(name as str, type_name as str)
        this.name = name
        this.type_name = type_name

struct PSig
    var name as str
    var params as List(PParam)
    var return_type as str
    cue init(name as str, params as List(PParam), return_type as str)
        this.name = name
        this.params = params
        this.return_type = return_type

struct PBranch
    var subject as List(PNode)
    var arms as List(PBranchOn)
    var else_stmts as List(PNode)
    cue init(subject as List(PNode), arms as List(PBranchOn), else_stmts as List(PNode))
        this.subject = subject
        this.arms = arms
        this.else_stmts = else_stmts

struct PBranchOn
    var patterns as List(str)
    var binding as str
    var stmts as List(PNode)
    cue init(patterns as List(str), binding as str, stmts as List(PNode))
        this.patterns = patterns
        this.binding = binding
        this.stmts = stmts

struct PExcept
    var base as List(PNode)
    var fields as List(PExceptField)
    cue init(base as List(PNode), fields as List(PExceptField))
        this.base = base
        this.fields = fields

struct PExceptField
    var name as str
    var value as List(PNode)
    cue init(name as str, value as List(PNode))
        this.name = name
        this.value = value

struct PStringInterp
    var parts as List(PNode)
    cue init(parts as List(PNode))
        this.parts = parts

struct PLambda
    var params as List(PParam)
    var return_type as str
    var captures as List(PCaptureVar)
    var body_expr as List(PNode)
    var body_stmts as List(PNode)
    cue init(params as List(PParam), return_type as str, captures as List(PCaptureVar), body_expr as List(PNode), body_stmts as List(PNode))
        this.params = params
        this.return_type = return_type
        this.captures = captures
        this.body_expr = body_expr
        this.body_stmts = body_stmts

struct PCaptureVar
    var name as str
    var type_name as str
    var init_name as str
    var is_const as bool
    cue init(name as str, type_name as str, init_name as str, is_const as bool)
        this.name = name
        this.type_name = type_name
        this.init_name = init_name
        this.is_const = is_const

struct PUse
    var path as str
    var exposed as List(str)
    cue init(path as str, exposed as List(str))
        this.path = path
        this.exposed = exposed

struct PModule
    var decls as List(PNode)
    cue init(decls as List(PNode))
        this.decls = decls

struct PNamespace
    var name as str
    var decls as List(PNode)
    cue init(name as str, decls as List(PNode))
        this.name = name
        this.decls = decls

struct PParam
    var name as str
    var type_name as str
    cue init(name as str, type_name as str)
        this.name = name
        this.type_name = type_name

struct PClass
    var name as str
    var type_params as List(str)
    var ifaces as List(str)
    var members as List(PNode)
    cue init(name as str, type_params as List(str), ifaces as List(str), members as List(PNode))
        this.name = name
        this.type_params = type_params
        this.ifaces = ifaces
        this.members = members

struct PExtend
    var target_name as str
    var members as List(PNode)
    cue init(target_name as str, members as List(PNode))
        this.target_name = target_name
        this.members = members

struct PEnum
    var name as str
    var variants as List(str)
    cue init(name as str, variants as List(str))
        this.name = name
        this.variants = variants

struct PField
    var name as str
    var type_name as str
    var is_const as bool
    var init_expr as List(PNode)
    cue init(name as str, type_name as str, is_const as bool, init_expr as List(PNode))
        this.name = name
        this.type_name = type_name
        this.is_const = is_const
        this.init_expr = init_expr

struct PMethod
    var name as str
    var is_shared as bool
    var throws_ as bool
    var params as List(PParam)
    var return_type as str
    var stmts as List(PNode)
    cue init(name as str, is_shared as bool, throws_ as bool, params as List(PParam), return_type as str, stmts as List(PNode))
        this.name = name
        this.is_shared = is_shared
        this.throws_ = throws_
        this.params = params
        this.return_type = return_type
        this.stmts = stmts

struct PInit
    var params as List(PParam)
    var stmts as List(PNode)
    cue init(params as List(PParam), stmts as List(PNode))
        this.params = params
        this.stmts = stmts

struct PReturn
    var value as List(PNode)
    cue init(value as List(PNode))
        this.value = value

struct PIf
    var cond as List(PNode)
    var then_stmts as List(PNode)
    var else_stmts as List(PNode)
    cue init(cond as List(PNode), then_stmts as List(PNode), else_stmts as List(PNode))
        this.cond = cond
        this.then_stmts = then_stmts
        this.else_stmts = else_stmts

struct PWhile
    var cond as List(PNode)
    var stmts as List(PNode)
    cue init(cond as List(PNode), stmts as List(PNode))
        this.cond = cond
        this.stmts = stmts

struct PArenaScope
    var stmts as List(PNode)
    cue init(stmts as List(PNode))
        this.stmts = stmts

struct PWith
    var target as List(PNode)
    var stmts as List(PNode)
    cue init(target as List(PNode), stmts as List(PNode))
        this.target = target
        this.stmts = stmts

struct PGuard
    var cond as List(PNode)
    var else_stmts as List(PNode)
    cue init(cond as List(PNode), else_stmts as List(PNode))
        this.cond = cond
        this.else_stmts = else_stmts

struct POrelse
    var expr as List(PNode)
    var fallback as List(PNode)
    cue init(expr as List(PNode), fallback as List(PNode))
        this.expr = expr
        this.fallback = fallback

struct PPipeline
    var lhs as List(PNode)
    var rhs as List(PNode)
    cue init(lhs as List(PNode), rhs as List(PNode))
        this.lhs = lhs
        this.rhs = rhs

struct PForIn
    var var_names as List(str)
    var iter as List(PNode)
    var stmts as List(PNode)
    cue init(var_names as List(str), iter as List(PNode), stmts as List(PNode))
        this.var_names = var_names
        this.iter = iter
        this.stmts = stmts

struct PVar
    var name as str
    var is_const as bool
    var type_name as str
    var init_expr as List(PNode)
    cue init(name as str, is_const as bool, type_name as str, init_expr as List(PNode))
        this.name = name
        this.is_const = is_const
        this.type_name = type_name
        this.init_expr = init_expr

struct PAssign
    var op as str
    var target as List(PNode)
    var value as List(PNode)
    cue init(op as str, target as List(PNode), value as List(PNode))
        this.op = op
        this.target = target
        this.value = value

struct PAssert
    var cond as List(PNode)
    var message as List(PNode)
    cue init(cond as List(PNode), message as List(PNode))
        this.cond = cond
        this.message = message

struct PRaise
    var message as List(PNode)
    cue init(message as List(PNode))
        this.message = message

struct PTryCatch
    var body_stmts as List(PNode)
    var catch_binding as str
    var catch_stmts as List(PNode)
    cue init(body_stmts as List(PNode), catch_binding as str, catch_stmts as List(PNode))
        this.body_stmts = body_stmts
        this.catch_binding = catch_binding
        this.catch_stmts = catch_stmts

struct PMember
    var base as List(PNode)
    var member as str
    cue init(base as List(PNode), member as str)
        this.base = base
        this.member = member

struct PCall
    var callee as List(PNode)
    var args as List(PNode)
    cue init(callee as List(PNode), args as List(PNode))
        this.callee = callee
        this.args = args

struct PIndex
    var object as List(PNode)
    var index as List(PNode)
    cue init(object as List(PNode), index as List(PNode))
        this.object = object
        this.index = index

struct PSlice
    var object as List(PNode)
    var start as List(PNode)
    var stop_ as List(PNode)
    cue init(object as List(PNode), start as List(PNode), stop_ as List(PNode))
        this.object = object
        this.start = start
        this.stop_ = stop_

struct PBinary
    var op as str
    var left as List(PNode)
    var right as List(PNode)
    cue init(op as str, left as List(PNode), right as List(PNode))
        this.op = op
        this.left = left
        this.right = right

struct PUnary
    var op as str
    var operand as List(PNode)
    cue init(op as str, operand as List(PNode))
        this.op = op
        this.operand = operand

# -- Parser class --------------------------------------------------------------

class Parser
    var tokens as List(Token.Token)
    var pos as int

    cue init(tokens as List(Token.Token))
        this.tokens = tokens
        this.pos = 0

    # -- Cursor ----------------------------------------------------------------

    def peek() as Token.Token
        if this.pos < this.tokens.len
            return this.tokens.at(this.pos)
        return this.tokens.at(this.tokens.len - 1)

    def peekAt(offset as int) as Token.Token
        var idx = this.pos + offset
        if idx < this.tokens.len
            return this.tokens.at(idx)
        return this.tokens.at(this.tokens.len - 1)

    def advance()
        if this.pos < this.tokens.len
            this.pos = this.pos + 1

    def textIs(s as str) as bool
        return this.peek().text == s

    def expectText(s as str) throws
        if not this.textIs(s)
            raise "expected '" + s + "', got '" + this.peek().text + "' at line " + this.peek().line.toString()
        this.advance()

    def isEol() as bool
        branch this.peek().kind
            on TokenKind.eol
                return true
            else
                return false

    def isIndent() as bool
        branch this.peek().kind
            on TokenKind.indent
                return true
            else
                return false

    def isDedent() as bool
        branch this.peek().kind
            on TokenKind.dedent
                return true
            else
                return false

    def isEof() as bool
        branch this.peek().kind
            on TokenKind.eof
                return true
            else
                return false

    def isId() as bool
        branch this.peek().kind
            on TokenKind.id
                return true
            else
                return false

    # Type keywords used as expressions (e.g., List(int), HashMap(str, bool))
    def isTypeKeyword() as bool
        branch this.peek().kind
            on TokenKind.kw_int
                return true
            on TokenKind.kw_uint
                return true
            on TokenKind.kw_float
                return true
            on TokenKind.kw_bool
                return true
            on TokenKind.kw_char
                return true
            else
                return false

    def isOpenCall() as bool
        branch this.peek().kind
            on TokenKind.open_call
                return true
            else
                return false

    def isIntLit() as bool
        branch this.peek().kind
            on TokenKind.integer_lit
                return true
            else
                return false

    def isFloatLit() as bool
        branch this.peek().kind
            on TokenKind.float_lit
                return true
            on TokenKind.fractional_lit
                return true
            on TokenKind.float_lit_exp
                return true
            else
                return false

    def isStringSingle() as bool
        branch this.peek().kind
            on TokenKind.string_single
                return true
            else
                return false

    def isStringDouble() as bool
        branch this.peek().kind
            on TokenKind.string_double
                return true
            else
                return false

    def isCharLit() as bool
        branch this.peek().kind
            on TokenKind.char_lit_single
                return true
            on TokenKind.char_lit_double
                return true
            else
                return false

    def isZigLit() as bool
        branch this.peek().kind
            on TokenKind.zig_single
                return true
            on TokenKind.zig_double
                return true
            else
                return false

    def isRawString() as bool
        branch this.peek().kind
            on TokenKind.string_raw_single
                return true
            on TokenKind.string_raw_double
                return true
            else
                return false

    def isStringStart() as bool
        branch this.peek().kind
            on TokenKind.string_start_single
                return true
            on TokenKind.string_start_double
                return true
            else
                return false

    def isStringPart() as bool
        branch this.peek().kind
            on TokenKind.string_part_single
                return true
            on TokenKind.string_part_double
                return true
            else
                return false

    def isStringStop() as bool
        branch this.peek().kind
            on TokenKind.string_stop_single
                return true
            on TokenKind.string_stop_double
                return true
            else
                return false

    def isRcurlySpecial() as bool
        branch this.peek().kind
            on TokenKind.rcurly_special
                return true
            else
                return false

    def skipEol()
        while this.isEol()
            this.advance()

    def eatId() as str throws
        if not this.isId()
            raise "expected identifier, got '" + this.peek().text + "' at line " + this.peek().line.toString()
        const text = this.peek().text
        this.advance()
        return text

    def eatName() as str throws
        if this.isId()
            const text = this.peek().text
            this.advance()
            return text
        else if this.isOpenCall()
            const text = this.peek().text
            this.advance()
            return text
        raise "expected name, got '" + this.peek().text + "' at line " + this.peek().line.toString()

    # Consume a type-name token - accepts identifiers AND built-in type keywords
    # (int, bool, str, float, char, void) which the lexer promotes to keywords.
    # Also handles generic types like List(str) and HashMap(str,int) by consuming
    # the open_call token and its argument list.
    def eatTypeName() as str throws
        # Handle ^Type (heap-pointer prefix)
        if this.textIs("^")
            this.advance()
            var inner as str = .eatTypeName()
            var sb as StringBuilder = StringBuilder()
            sb.append("^")
            sb.append(inner)
            return sb.build()
        const text = this.peek().text
        if .isOpenCall()
            # Generic type: "List(str)" — open_call token is "Name(" (text is just "Name")
            this.advance()  # consume "Name("
            var args as List(str) = List(str)()
            while not this.textIs(")")
                if this.textIs(",")
                    this.advance()
                else
                    args.add(.eatTypeName())
            .expectText(")")
            # Build "Name(arg1,arg2,...)" using StringBuilder to avoid cross-module str type issue
            var sb as StringBuilder = StringBuilder()
            sb.append(text)
            sb.append("(")
            var first = true
            for arg in args
                if not first
                    sb.append(",")
                sb.append(arg)
                first = false
            sb.append(")")
            return sb.build()
        if .isId()
            this.advance()
            # Handle dotted names: Token.Token, ast.Module, etc.
            if this.textIs(".")
                this.advance()
                var rest as str = .eatTypeName()
                var sb as StringBuilder = StringBuilder()
                sb.append(text)
                sb.append(".")
                sb.append(rest)
                return sb.build()
            return text
        # Accept built-in type keywords by text
        if text == "int" or text == "bool" or text == "str" or text == "float" or text == "char" or text == "void" or text == "any"
            this.advance()
            return text
        raise "expected type name, got '" + text + "' at line " + this.peek().line.toString()

    # -- Module ----------------------------------------------------------------

    def parseModule() as PNode throws
        var decls = List(PNode)()
        .skipEol()
        while not .isEof()
            decls.add(.parseTopDecl())
            .skipEol()
        return PNode.module_(PModule(decls))

    # -- Top-level declarations ------------------------------------------------

    def parseTopDecl() as PNode throws
        if this.textIs("use")
            return .parseUseDecl()
        else if this.textIs("namespace")
            return .parseNamespaceDecl()
        else if this.textIs("class")
            return .parseClassDecl()
        else if this.textIs("struct")
            return .parseStructDecl()
        else if this.textIs("interface")
            return .parseInterfaceDecl()
        else if this.textIs("extend")
            return .parseExtendDecl()
        else if this.textIs("union")
            return .parseUnionDecl()
        else if this.textIs("enum")
            return .parseEnumDecl()
        else if this.textIs("sig")
            return .parseSigDecl()
        else if this.textIs("shared")
            this.advance()
            return .parseMethodDecl(true)
        else if this.textIs("def")
            return .parseMethodDecl(false)
        raise "unexpected top-level token: '" + this.peek().text + "' at line " + this.peek().line.toString()

    def parseNamespaceDecl() as PNode throws
        .expectText("namespace")
        var name as str = .eatId()
        while this.textIs(".")
            this.advance()
            name = name + "."
            name = name + .eatId()
        .skipEol()
        var decls = List(PNode)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                decls.add(.parseTopDecl())
                .skipEol()
            if .isDedent()
                this.advance()
        return PNode.namespace_decl(PNamespace(name, decls))

    def parseUseDecl() as PNode throws
        .expectText("use")
        var path as str = .eatId()
        while this.textIs(".")
            this.advance()
            path = path + "."
            path = path + .eatId()
        var exposed = List(str)()
        if this.textIs("exposing")
            this.advance()
            exposed.add(.eatId())
            while this.textIs(",")
                this.advance()
                exposed.add(.eatId())
        .skipEol()
        return PNode.use_(PUse(path, exposed))

    def parseClassDecl() as PNode throws
        .expectText("class")
        var name as str = ""
        var type_params = List(str)()
        # Generic class: name is tokenized as open_call because `(` follows immediately.
        if .isOpenCall()
            name = this.peek().text
            this.advance()
            if not this.textIs(")")
                type_params.add(.eatId())
                while this.textIs(",")
                    this.advance()
                    type_params.add(.eatId())
            .expectText(")")
        else
            name = .eatId()
        var ifaces = List(str)()
        if this.textIs("implements")
            this.advance()
            ifaces.add(.eatId())
            while this.textIs(",")
                this.advance()
                ifaces.add(.eatId())
        .skipEol()
        var members = List(PNode)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                if this.textIs("shared")
                    this.advance()
                    .skipEol()
                    if .isIndent()
                        this.advance()
                        while not .isDedent() and not .isEof()
                            .skipEol()
                            if .isDedent()
                                break
                            members.add(.parseMemberDecl(true))
                        if .isDedent()
                            this.advance()
                    else
                        # Inline `shared def foo()` — no indented block
                        members.add(.parseMemberDecl(true))
                else
                    members.add(.parseMemberDecl(false))
            if .isDedent()
                this.advance()
        return PNode.class_(PClass(name, type_params, ifaces, members))

    def parseEnumDecl() as PNode throws
        .expectText("enum")
        const name = .eatId()
        .skipEol()
        var variants = List(str)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                variants.add(.eatId())
                .skipEol()
            if .isDedent()
                this.advance()
        return PNode.enum_(PEnum(name, variants))

    def parseStructDecl() as PNode throws
        .expectText("struct")
        const name = .eatId()
        .skipEol()
        var members = List(PNode)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                members.add(.parseMemberDecl(false))
            if .isDedent()
                this.advance()
        var ifaces = List(str)()
        var type_params = List(str)()
        return PNode.struct_(PClass(name, type_params, ifaces, members))

    def parseInterfaceDecl() as PNode throws
        .expectText("interface")
        const name = .eatId()
        var ifaces = List(str)()
        if this.textIs("implements")
            this.advance()
            ifaces.add(.eatId())
            while this.textIs(",")
                this.advance()
                ifaces.add(.eatId())
        .skipEol()
        var members = List(PNode)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                members.add(.parseMemberDecl(false))
            if .isDedent()
                this.advance()
        var type_params = List(str)()
        return PNode.interface_(PClass(name, type_params, ifaces, members))

    def parseExtendDecl() as PNode throws
        .expectText("extend")
        const target_name = .eatTypeName()
        .skipEol()
        var members = List(PNode)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                members.add(.parseMemberDecl(false))
            if .isDedent()
                this.advance()
        return PNode.extend_(PExtend(target_name, members))

    def parseUnionDecl() as PNode throws
        .expectText("union")
        const name = .eatId()
        .skipEol()
        var variants = List(PUnionVariant)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                const vname = .eatId()
                var vtype as str = ""
                if this.textIs("as")
                    this.advance()
                    # Handle ^Type prefix
                    if this.textIs("^")
                        this.advance()
                        vtype = "^" + .eatTypeName()
                    else
                        vtype = .eatTypeName()
                    if this.textIs("?")
                        this.advance()
                        vtype = vtype + "?"
                .skipEol()
                variants.add(PUnionVariant(vname, vtype))
            if .isDedent()
                this.advance()
        return PNode.union_decl(PUnionDecl(name, variants))

    def parseSigDecl() as PNode throws
        .expectText("sig")
        var name = ""
        var has_params = false
        if .isOpenCall()
            name = this.peek().text
            this.advance()
            has_params = true
        else
            name = .eatId()
        var params = List(PParam)()
        if has_params
            while not this.textIs(")")
                if this.textIs(",")
                    this.advance()
                else
                    const pname = .eatId()
                    var ptype = ""
                    if this.textIs("as")
                        this.advance()
                        ptype = .eatTypeName()
                    params.add(PParam(pname, ptype))
            .expectText(")")
        var return_type = ""
        if this.textIs("as")
            this.advance()
            return_type = .eatTypeName()
        .skipEol()
        return PNode.sig_(PSig(name, params, return_type))

    # -- Member declarations ---------------------------------------------------

    def parseMemberDecl(is_shared as bool) as PNode throws
        if this.textIs("def")
            return .parseMethodDecl(is_shared)
        else if this.textIs("var")
            return .parseDeclField(false)
        else if this.textIs("const")
            return .parseDeclField(true)
        else if this.textIs("cue")
            return .parseDeclInit()
        raise "unexpected member: '" + this.peek().text + "' at line " + this.peek().line.toString()

    def parseDeclField(is_const as bool) as PNode throws
        if is_const
            .expectText("const")
        else
            .expectText("var")
        const name = .eatId()
        var type_name as str = ""
        if this.textIs("as")
            this.advance()
            type_name = .eatTypeName()
            if this.textIs("?")
                this.advance()
                type_name = type_name + "?"
        var init_expr = List(PNode)()
        if this.textIs("=")
            this.advance()
            init_expr.add(.parseExpr())
        .skipEol()
        return PNode.field_(PField(name, type_name, is_const, init_expr))

    def parseDeclInit() as PNode throws
        .expectText("cue")
        if this.peek().text != "init"
            raise "expected 'init' after cue, got '" + this.peek().text + "'"
        var was_open_call = .isOpenCall()
        this.advance()
        if not was_open_call
            .expectText("(")
        var params = List(PParam)()
        while not this.textIs(")")
            if this.textIs(",")
                this.advance()
            else
                const pname = .eatId()
                var ptype = ""
                if this.textIs("as")
                    this.advance()
                    ptype = .eatTypeName()
                    if this.textIs("?")
                        this.advance()
                        ptype = ptype + "?"
                params.add(PParam(pname, ptype))
        .expectText(")")
        .skipEol()
        var stmts = List(PNode)()
        if .isIndent()
            stmts = .parseBlock()
        return PNode.init_(PInit(params, stmts))

    def parseMethodDecl(is_shared as bool) as PNode throws
        .expectText("def")
        var name = ""
        var has_params = false
        var params = List(PParam)()
        if .isOpenCall()
            name = this.peek().text
            this.advance()
            has_params = true
        else
            name = .eatId()
        if has_params
            while not this.textIs(")")
                if this.textIs(",")
                    this.advance()
                else
                    const pname = .eatId()
                    var ptype = ""
                    if this.textIs("as")
                        this.advance()
                        ptype = .eatTypeName()
                        if this.textIs("?")
                            this.advance()
                            ptype = ptype + "?"
                    params.add(PParam(pname, ptype))
            .expectText(")")
        var return_type = ""
        if this.textIs("as")
            this.advance()
            return_type = .eatTypeName()
            if this.textIs("?")
                this.advance()
                return_type = return_type + "?"
        var throws_ = false
        if this.textIs("throws")
            this.advance()
            throws_ = true
        .skipEol()
        var stmts = List(PNode)()
        if .isIndent()
            stmts = .parseBlock()
        return PNode.method_(PMethod(name, is_shared, throws_, params, return_type, stmts))

    # -- Block and statements --------------------------------------------------

    def parseBlock() as List(PNode) throws
        if not .isIndent()
            raise "expected indent, got '" + this.peek().text + "'"
        this.advance()
        var stmts = List(PNode)()
        while not .isDedent() and not .isEof()
            .skipEol()
            if .isDedent()
                break
            stmts.add(.parseStmt())
        if .isDedent()
            this.advance()
        return stmts

    def parseStmt() as PNode throws
        if this.textIs("pass")
            this.advance()
            .skipEol()
            return PNode.stmt_pass()
        else if this.textIs("break")
            this.advance()
            .skipEol()
            return PNode.stmt_break()
        else if this.textIs("continue")
            this.advance()
            .skipEol()
            return PNode.stmt_continue()
        else if this.textIs("return")
            return .parseReturnStmt()
        else if this.textIs("if")
            return .parseIfStmt()
        else if this.textIs("while")
            return .parseWhileStmt()
        else if this.textIs("for")
            return .parseForInStmt()
        else if this.textIs("var")
            return .parseVarStmt(false)
        else if this.textIs("const")
            return .parseVarStmt(true)
        else if this.textIs("assert")
            return .parseAssertStmt()
        else if this.textIs("raise")
            return .parseRaiseStmt()
        else if this.textIs("try")
            return .parseTryCatch()
        else if this.textIs("branch")
            return .parseBranchStmt()
        else if this.textIs("arena")
            return .parseArenaScopeStmt()
        else if this.textIs("with")
            return .parseWithStmt()
        else if this.textIs("guard")
            return .parseGuardStmt()
        else if this.textIs("print")
            this.advance()
            const expr = .parseExpr()
            .skipEol()
            return PNode.stmt_print(expr)
        else
            return .parseExprOrAssignStmt()

    def parseReturnStmt() as PNode throws
        .expectText("return")
        var value = List(PNode)()
        if not .isEol() and not .isEof() and not .isDedent()
            value.add(.parseExpr())
        .skipEol()
        return PNode.stmt_return(PReturn(value))

    def parseIfStmt() as PNode throws
        .expectText("if")
        const cond_expr = .parseExpr()
        .skipEol()
        const then_stmts = .parseBlock()
        var else_stmts = List(PNode)()
        if this.textIs("else")
            this.advance()
            if this.textIs("if")
                # else if → wrap as single-element else list
                else_stmts.add(.parseIfStmt())
            else
                .skipEol()
                else_stmts = .parseBlock()
        var cond_list = List(PNode)()
        cond_list.add(cond_expr)
        return PNode.stmt_if(PIf(cond_list, then_stmts, else_stmts))

    def parseWhileStmt() as PNode throws
        .expectText("while")
        # Bind-and-guard form: `while var id = InitExpr, CondExpr eol Block`.
        # Desugared here to `while true { var id = InitExpr; if not CondExpr: break; body }`
        # so the existing StmtWhile/StmtVar/StmtIf/StmtBreak codegen path carries it.
        if this.textIs("var")
            this.advance()
            const bind_name = .eatId()
            .expectText("=")
            const init_expr_pn = .parseExpr()
            .expectText(",")
            const guard_expr_pn = .parseExpr()
            .skipEol()
            var body_stmts as List(PNode) = .parseBlock()
            var init_list = List(PNode)()
            init_list.add(init_expr_pn)
            var guard_operand = List(PNode)()
            guard_operand.add(guard_expr_pn)
            var if_cond_list = List(PNode)()
            if_cond_list.add(PNode.expr_unary(PUnary("not", guard_operand)))
            var break_list = List(PNode)()
            break_list.add(PNode.stmt_break())
            var empty_else = List(PNode)()
            var wrapped = List(PNode)()
            wrapped.add(PNode.stmt_var(PVar(bind_name, false, "", init_list)))
            wrapped.add(PNode.stmt_if(PIf(if_cond_list, break_list, empty_else)))
            for bs in body_stmts
                wrapped.add(bs)
            var true_cond = List(PNode)()
            true_cond.add(PNode.expr_bool(true))
            return PNode.stmt_while(PWhile(true_cond, wrapped))
        const cond_expr = .parseExpr()
        .skipEol()
        const stmts = .parseBlock()
        var cond_list = List(PNode)()
        cond_list.add(cond_expr)
        return PNode.stmt_while(PWhile(cond_list, stmts))

    def parseArenaScopeStmt() as PNode throws
        .expectText("arena")
        .skipEol()
        const stmts = .parseBlock()
        return PNode.stmt_arena_scope(PArenaScope(stmts))

    def parseWithStmt() as PNode throws
        .expectText("with")
        const target_expr = .parseExpr()
        .skipEol()
        const stmts = .parseBlock()
        var target_list = List(PNode)()
        target_list.add(target_expr)
        return PNode.stmt_with(PWith(target_list, stmts))

    def parseGuardStmt() as PNode throws
        .expectText("guard")
        const cond_expr = .parseExpr()
        .expectText("else")
        var cond_list = List(PNode)()
        cond_list.add(cond_expr)
        var else_stmts = List(PNode)()
        if this.textIs(",")
            this.advance()
            # Inline form: `guard Expr else, Stmt`
            else_stmts.add(.parseStmt())
        else
            # Block form: `guard Expr else eol Block`
            .skipEol()
            else_stmts = .parseBlock()
        return PNode.stmt_guard(PGuard(cond_list, else_stmts))

    def parseForInStmt() as PNode throws
        .expectText("for")
        var var_names = List(str)()
        var_names.add(.eatId())
        while this.textIs(",")
            this.advance()
            var_names.add(.eatId())
        .expectText("in")
        const iter_expr = .parseExpr()
        .skipEol()
        const stmts = .parseBlock()
        var iter_list = List(PNode)()
        iter_list.add(iter_expr)
        return PNode.stmt_for_in(PForIn(var_names, iter_list, stmts))

    def parseVarStmt(is_const as bool) as PNode throws
        if is_const
            .expectText("const")
        else
            .expectText("var")
        const name = .eatId()
        var type_name as str = ""
        if this.textIs("as")
            this.advance()
            type_name = .eatTypeName()
            if this.textIs("?")
                this.advance()
                type_name = type_name + "?"
        var init_expr = List(PNode)()
        if this.textIs("=")
            this.advance()
            # Check for statement-body lambda: var x = def(params) eol indent [capture] stmts dedent
            if this.textIs("def") and .peekAt(1).text == "("
                # Could be expression-body (def(x) = expr) or statement-body (def(x) eol ...)
                # Parse the def(params) [as T] prefix, then decide
                var lam = .parseLambdaPrefix()
                if this.textIs("=")
                    # Expression-body: def(params) = expr
                    this.advance()
                    var body_expr = List(PNode)()
                    body_expr.add(.parseExpr())
                    .skipEol()
                    var lambda_node = PLambda(lam.params, lam.return_type, List(PCaptureVar)(), body_expr, List(PNode)())
                    init_expr.add(PNode.expr_lambda(lambda_node))
                    return PNode.stmt_var(PVar(name, is_const, type_name, init_expr))
                # Statement-body: def(params) eol indent [capture] stmts dedent
                .skipEol()
                if not .isIndent()
                    raise "expected indent after lambda header at line " + this.peek().line.toString()
                this.advance()
                var captures = List(PCaptureVar)()
                if this.textIs("capture")
                    captures = .parseCaptureBlock()
                var body_stmts = List(PNode)()
                while not .isDedent() and not .isEof()
                    .skipEol()
                    if .isDedent()
                        break
                    body_stmts.add(.parseStmt())
                if .isDedent()
                    this.advance()
                var lambda_node = PLambda(lam.params, lam.return_type, captures, List(PNode)(), body_stmts)
                init_expr.add(PNode.expr_lambda(lambda_node))
                return PNode.stmt_var(PVar(name, is_const, type_name, init_expr))
            init_expr.add(.parseExpr())
        .skipEol()
        return PNode.stmt_var(PVar(name, is_const, type_name, init_expr))

    def parseAssertStmt() as PNode throws
        .expectText("assert")
        const cond_expr = .parseExpr()
        var cond_list = List(PNode)()
        cond_list.add(cond_expr)
        var msg_list = List(PNode)()
        if this.textIs(",")
            this.advance()
            msg_list.add(.parseExpr())
        .skipEol()
        return PNode.stmt_assert(PAssert(cond_list, msg_list))

    def parseRaiseStmt() as PNode throws
        .expectText("raise")
        var msg_list = List(PNode)()
        if not .isEol() and not .isEof() and not .isDedent()
            msg_list.add(.parseExpr())
            if this.textIs(",")
                this.advance()
                msg_list.add(.parseExpr())
        .skipEol()
        return PNode.stmt_raise(PRaise(msg_list))

    def parseTryCatch() as PNode throws
        .expectText("try")
        .skipEol()
        const body_stmts = .parseBlock()
        .expectText("catch")
        var catch_binding as str = ""
        if this.textIs("|")
            this.advance()
            catch_binding = .eatId()
            .expectText("|")
        .skipEol()
        const catch_stmts = .parseBlock()
        return PNode.stmt_try_catch(PTryCatch(body_stmts, catch_binding, catch_stmts))

    def parseBranchStmt() as PNode throws
        .expectText("branch")
        const subject = .parseExpr()
        .skipEol()
        var arms = List(PBranchOn)()
        var else_stmts = List(PNode)()
        if .isIndent()
            this.advance()
            while not .isDedent() and not .isEof()
                .skipEol()
                if .isDedent()
                    break
                if this.textIs("on")
                    this.advance()
                    # Parse pattern list: one or more comma-separated patterns
                    var patterns = List(str)()
                    patterns.add(.eatBranchPattern())
                    while this.textIs(",")
                        this.advance()
                        patterns.add(.eatBranchPattern())
                    var binding = ""
                    if this.textIs("as")
                        this.advance()
                        binding = .eatId()
                    .skipEol()
                    var stmts = List(PNode)()
                    if .isIndent()
                        stmts = .parseBlock()
                    else if not .isEol() and not .isDedent() and not .isEof()
                        # Inline single-line arm: `on Pattern  return value`
                        stmts.add(.parseStmt())
                    arms.add(PBranchOn(patterns, binding, stmts))
                else if this.textIs("else")
                    this.advance()
                    if this.textIs(",")
                        # Inline else form: `else, stmt`
                        this.advance()
                        else_stmts.add(.parseStmt())
                    else
                        .skipEol()
                        if .isIndent()
                            else_stmts = .parseBlock()
                else
                    break
            if .isDedent()
                this.advance()
        var subj_list = List(PNode)()
        subj_list.add(subject)
        return PNode.stmt_branch(PBranch(subj_list, arms, else_stmts))

    def eatBranchPattern() as str throws
        # Collect pattern text: e.g., "TokenKind.eol", "PNode.class_", "c'0'..c'9'"
        var sb as StringBuilder = StringBuilder()
        # First token
        sb.append(this.peek().text)
        this.advance()
        # Continue with . member access and range operators
        var going as bool = true
        while going
            if this.textIs(".")
                sb.append(".")
                this.advance()
                sb.append(this.peek().text)
                this.advance()
            else if this.textIs("..")
                sb.append("..")
                this.advance()
                sb.append(this.peek().text)
                this.advance()
            else
                going = false
        return sb.build()

    def parseExprOrAssignStmt() as PNode throws
        const target_expr = .parseExpr()
        var op as str = ""
        if this.textIs("=")
            op = "="
        else if this.textIs("+=")
            op = "+="
        else if this.textIs("-=")
            op = "-="
        else if this.textIs("*=")
            op = "*="
        if op != ""
            this.advance()
            const value_expr = .parseExpr()
            .skipEol()
            var tgt = List(PNode)()
            tgt.add(target_expr)
            var val = List(PNode)()
            val.add(value_expr)
            return PNode.stmt_assign(PAssign(op, tgt, val))
        .skipEol()
        return PNode.stmt_expr(target_expr)

    # -- Expressions -----------------------------------------------------------
    # Precedence (lowest - highest):
    # or - and - not - comparison - add/sub - mul/div - unary - - postfix - atom

    def parseExpr() as PNode throws
        return .parsePipeline()

    def parsePipeline() as PNode throws
        var left = .parseOr()
        while this.textIs("->")
            this.advance()
            const rhs = .parseOr()
            var lhs_list = List(PNode)()
            lhs_list.add(left)
            var rhs_list = List(PNode)()
            rhs_list.add(rhs)
            left = PNode.expr_pipeline(PPipeline(lhs_list, rhs_list))
        return left

    def parseOr() as PNode throws
        var left = .parseAnd()
        while this.textIs("or") or this.textIs("orelse")
            const is_orelse = this.textIs("orelse")
            this.advance()
            const right = .parseAnd()
            var l = List(PNode)()
            l.add(left)
            var r = List(PNode)()
            r.add(right)
            if is_orelse
                left = PNode.expr_orelse(POrelse(l, r))
            else
                left = PNode.expr_binary(PBinary("or", l, r))
        return left

    def parseAnd() as PNode throws
        var left = .parseNot()
        while this.textIs("and")
            this.advance()
            const right = .parseNot()
            var l = List(PNode)()
            l.add(left)
            var r = List(PNode)()
            r.add(right)
            left = PNode.expr_binary(PBinary("and", l, r))
        return left

    def parseNot() as PNode throws
        if this.textIs("not")
            this.advance()
            const operand = .parseNot()
            var ops = List(PNode)()
            ops.add(operand)
            return PNode.expr_unary(PUnary("not", ops))
        return .parseComparison()

    def parseComparison() as PNode throws
        var left = .parseAddSub()
        var op as str = ""
        if this.textIs("==")
            op = "=="
        else if this.textIs("!=") or this.textIs("<>")
            op = "!="
        else if this.textIs("<=")
            op = "<="
        else if this.textIs(">=")
            op = ">="
        else if this.textIs("<")
            op = "<"
        else if this.textIs(">")
            op = ">"
        else if this.textIs("in")
            op = "in"
        if op != ""
            this.advance()
            const right = .parseAddSub()
            var l = List(PNode)()
            l.add(left)
            var r = List(PNode)()
            r.add(right)
            return PNode.expr_binary(PBinary(op, l, r))
        return left

    def parseAddSub() as PNode throws
        var left = .parseMulDiv()
        while this.textIs("+") or this.textIs("-")
            const op = this.peek().text
            this.advance()
            const right = .parseMulDiv()
            var l = List(PNode)()
            l.add(left)
            var r = List(PNode)()
            r.add(right)
            left = PNode.expr_binary(PBinary(op, l, r))
        return left

    def parseMulDiv() as PNode throws
        var left = .parseUnary()
        while this.textIs("*") or this.textIs("/") or this.textIs("%")
            const op = this.peek().text
            this.advance()
            const right = .parseUnary()
            var l = List(PNode)()
            l.add(left)
            var r = List(PNode)()
            r.add(right)
            left = PNode.expr_binary(PBinary(op, l, r))
        return left

    def parseUnary() as PNode throws
        if this.textIs("-")
            this.advance()
            const operand = .parseUnary()
            var ops = List(PNode)()
            ops.add(operand)
            return PNode.expr_unary(PUnary("-", ops))
        if this.textIs("try")
            # `try expr` prefix form — semantically identical to `expr?`
            # (both emit Expr.try_ / ExprTry). Zig backend treats them as
            # the same Expr8 production.
            this.advance()
            const operand = .parseUnary()
            return PNode.expr_try(operand)
        return .parsePostfix()

    def parsePostfix() as PNode throws
        var expr = .parseAtom()
        var going as bool = true
        while going
            if this.textIs(".")
                this.advance()
                if .isOpenCall()
                    # expr.method(args)
                    const mname = this.peek().text
                    this.advance()
                    const args = .parseCallArgs()
                    var base = List(PNode)()
                    base.add(expr)
                    var callee = List(PNode)()
                    callee.add(PNode.expr_member(PMember(base, mname)))
                    expr = PNode.expr_call(PCall(callee, args))
                else if (this.textIs("get") or this.textIs("post")) and this.peekAt(1).text == "("
                    # expr.get(args) / expr.post(args) — keyword used as method name.
                    # Zig backend: Expr9 → Expr9 dot (kw_get|kw_post) lparen ArgList rparen.
                    const mname = this.peek().text
                    this.advance()
                    this.advance()
                    const args = .parseCallArgs()
                    var base = List(PNode)()
                    base.add(expr)
                    var callee = List(PNode)()
                    callee.add(PNode.expr_member(PMember(base, mname)))
                    expr = PNode.expr_call(PCall(callee, args))
                else
                    # expr.field
                    const field = .eatId()
                    var base = List(PNode)()
                    base.add(expr)
                    expr = PNode.expr_member(PMember(base, field))
            else if this.textIs("?")
                this.advance()
                expr = PNode.expr_try(expr)
            else if this.textIs("to")
                # to! force-unwrap
                this.advance()
                .expectText("!")
                expr = PNode.expr_to_bang(expr)
            else if this.textIs("except")
                # struct update: expr except \n field = value \n ...
                this.advance()
                .skipEol()
                var fields = List(PExceptField)()
                if .isIndent()
                    this.advance()
                    while not .isDedent() and not .isEof()
                        .skipEol()
                        if .isDedent()
                            break
                        const fname = .eatId()
                        .expectText("=")
                        const fval = .parseExpr()
                        .skipEol()
                        var vlist = List(PNode)()
                        vlist.add(fval)
                        fields.add(PExceptField(fname, vlist))
                    if .isDedent()
                        this.advance()
                var base_list = List(PNode)()
                base_list.add(expr)
                expr = PNode.expr_except(PExcept(base_list, fields))
            else if this.textIs("[")
                # index or slice: expr[index] or expr[start..stop]
                this.advance()
                const first = .parseExpr()
                if this.textIs("..")
                    # slice: expr[start..stop]
                    this.advance()
                    const stop_expr = .parseExpr()
                    .expectText("]")
                    var obj = List(PNode)()
                    obj.add(expr)
                    var start_list = List(PNode)()
                    start_list.add(first)
                    var stop_list = List(PNode)()
                    stop_list.add(stop_expr)
                    expr = PNode.expr_slice(PSlice(obj, start_list, stop_list))
                else
                    .expectText("]")
                    var obj = List(PNode)()
                    obj.add(expr)
                    var idx_list = List(PNode)()
                    idx_list.add(first)
                    expr = PNode.expr_index(PIndex(obj, idx_list))
            else if this.textIs("(")
                # chained call: expr(args) — handles List(T)(), HashMap(K,V)(), etc.
                this.advance()  # consume the "("
                const args = .parseCallArgs()
                var callee = List(PNode)()
                callee.add(expr)
                expr = PNode.expr_call(PCall(callee, args))
            else
                going = false
        return expr

    def parseAtom() as PNode throws
        if this.textIs("true")
            this.advance()
            return PNode.expr_bool(true)
        else if this.textIs("false")
            this.advance()
            return PNode.expr_bool(false)
        else if this.textIs("nil")
            this.advance()
            return PNode.expr_nil()
        else if this.textIs("this")
            this.advance()
            return PNode.expr_this()
        else if .isIntLit()
            const text = this.peek().text
            this.advance()
            return PNode.expr_int(text)
        else if .isFloatLit()
            const text = this.peek().text
            this.advance()
            return PNode.expr_float(text)
        else if .isStringStart()
            return .parseStringInterp()
        else if .isStringSingle() or .isStringDouble()
            const text = this.peek().text
            this.advance()
            return PNode.expr_str(text)
        else if .isCharLit()
            const text = this.peek().text
            this.advance()
            return PNode.expr_char(text)
        else if .isZigLit()
            const text = this.peek().text
            this.advance()
            return PNode.expr_zig_lit(text)
        else if .isRawString()
            const text = this.peek().text
            this.advance()
            return PNode.expr_raw_str(text)
        else if this.textIs("(")
            this.advance()
            const inner = .parseExpr()
            .expectText(")")
            return inner
        else if .isOpenCall()
            # function/constructor call: name(args)
            const name = this.peek().text
            this.advance()
            const args = .parseCallArgs()
            var callee = List(PNode)()
            callee.add(PNode.expr_id(name))
            return PNode.expr_call(PCall(callee, args))
        else if this.textIs(".")
            # self-member access or self-call: .field or .method(args)
            this.advance()
            if .isOpenCall()
                const mname = this.peek().text
                this.advance()
                const args = .parseCallArgs()
                var base = List(PNode)()
                var callee = List(PNode)()
                callee.add(PNode.expr_member(PMember(base, mname)))
                return PNode.expr_call(PCall(callee, args))
            else
                const field = .eatId()
                var base = List(PNode)()
                return PNode.expr_member(PMember(base, field))
        else if .isId()
            const name = this.peek().text
            this.advance()
            return PNode.expr_id(name)
        else if .isTypeKeyword()
            # type keyword used as expression (e.g. in List(int), HashMap(str, bool))
            const name = this.peek().text
            this.advance()
            return PNode.expr_id(name)
        else if this.textIs("def") and .peekAt(1).text == "("
            return .parseLambdaExpr()
        raise "unexpected expression token: '" + this.peek().text + "' at line " + this.peek().line.toString()

    def parseLambdaExpr() as PNode throws
        # Expression-body lambda: def(params) [as T] = expr
        .expectText("def")
        .expectText("(")
        var params = List(PParam)()
        if not this.textIs(")")
            params.add(.parseLambdaParam())
            while this.textIs(",")
                this.advance()
                params.add(.parseLambdaParam())
        .expectText(")")
        var ret_type = ""
        if this.textIs("as")
            this.advance()
            ret_type = .eatTypeName()
        .expectText("=")
        var body_expr = List(PNode)()
        body_expr.add(.parseExpr())
        return PNode.expr_lambda(PLambda(params, ret_type, List(PCaptureVar)(), body_expr, List(PNode)()))

    def parseLambdaParam() as PParam throws
        const name = .eatId()
        var type_name = ""
        if this.textIs("as")
            this.advance()
            type_name = .eatTypeName()
        return PParam(name, type_name)

    def parseLambdaPrefix() as PLambda throws
        # Parse def(params) [as T] without consuming the body
        .expectText("def")
        .expectText("(")
        var params = List(PParam)()
        if not this.textIs(")")
            params.add(.parseLambdaParam())
            while this.textIs(",")
                this.advance()
                params.add(.parseLambdaParam())
        .expectText(")")
        var ret_type = ""
        if this.textIs("as")
            this.advance()
            ret_type = .eatTypeName()
        return PLambda(params, ret_type, List(PCaptureVar)(), List(PNode)(), List(PNode)())

    def parseCaptureBlock() as List(PCaptureVar) throws
        # capture eol indent var_decls dedent
        .expectText("capture")
        .skipEol()
        if not .isIndent()
            raise "expected indent after 'capture' at line " + this.peek().line.toString()
        this.advance()
        var caps = List(PCaptureVar)()
        while not .isDedent() and not .isEof()
            .skipEol()
            if .isDedent()
                break
            var is_const = false
            if this.textIs("const")
                is_const = true
                this.advance()
            else
                .expectText("var")
            const cap_name = .eatId()
            var cap_type = ""
            if this.textIs("as")
                this.advance()
                cap_type = .eatTypeName()
            var init_name = cap_name
            if this.textIs("=")
                this.advance()
                init_name = .eatId()
            .skipEol()
            caps.add(PCaptureVar(cap_name, cap_type, init_name, is_const))
        if .isDedent()
            this.advance()
        return caps

    def parseStringInterp() as PNode throws
        # string_start_X  {expr rcurly_special [string_part_X expr rcurly_special]*}  string_stop_X
        var parts = List(PNode)()
        # Leading literal from string_start token (includes text before first ${)
        parts.add(PNode.expr_str(this.peek().text))
        this.advance()
        # Parse interleaved expressions and literal parts
        while not .isStringStop() and not .isEof()
            # Parse the interpolated expression
            parts.add(.parseExpr())
            # Consume rcurly_special (the closing } of ${...})
            if .isRcurlySpecial()
                this.advance()
            # If followed by a string_part, consume it as literal
            if .isStringPart()
                parts.add(PNode.expr_str(this.peek().text))
                this.advance()
        # Trailing literal from string_stop token
        if .isStringStop()
            parts.add(PNode.expr_str(this.peek().text))
            this.advance()
        return PNode.expr_string_interp(PStringInterp(parts))

    def parseCallArgs() as List(PNode) throws
        var args = List(PNode)()
        while not this.textIs(")")
            # skip named arg label: name = expr
            if .isId() and false  # placeholder - named args not needed for demo
                pass
            args.add(.parseExpr())
            if this.textIs(",")
                this.advance()
        .expectText(")")
        return args

    # -- Public API ------------------------------------------------------------

    shared def parse(src as str) as PNode throws
        var toks = Lexer.tokenize(src)?
        var p = Parser(toks)
        return p.parseModule()
